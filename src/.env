# Server Configuration
PORT=3000
NODE_ENV=production

# AWS Lambda Configuration
USE_LAMBDA=true
LAMBDA_API_URL=https://49ov366dtf.execute-api.us-east-1.amazonaws.com/default/puppeteer-pdf-generator
LAMBDA_TIMEOUT_MS=60000

# Cache Configuration (still used for preprocessing)
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE_MB=500

# Image Processing (still used for headers/footers/watermarks)
IMAGE_QUALITY=95
IMAGE_MAX_WIDTH=2480
IMAGE_MAX_HEIGHT=3508

# CORS Configuration
ALLOWED_ORIGINS=*

# ============================================
# DEPRECATED - No longer needed with Lambda
# ============================================
# Puppeteer Configuration
# PUPPETEER_HEADLESS=true
# PUPPETEER_ARGS=--no-sandbox,--disable-setuid-sandbox,--disable-dev-shm-usage

# Browser Pool Configuration
# BROWSER_POOL_MIN=2
# BROWSER_POOL_MAX=5
# BROWSER_POOL_IDLE_TIMEOUT=30000

# PDF Generation Settings
# PDF_TIMEOUT_MS=45000
# PDF_MAX_RETRIES=2

# cPanel Deployment Settings
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser