# Server Configuration
PORT=3000
NODE_ENV=development

# Puppeteer Service — replace with actual EC2 IP
PUPPETEER_SERVICE_URL=http://YOUR_EC2_IP:3001

# Cache Configuration
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE_MB=500

# Image Processing
IMAGE_QUALITY=95
IMAGE_MAX_WIDTH=2480
IMAGE_MAX_HEIGHT=3508

# CORS Configuration
ALLOWED_ORIGINS=*
