# Server Configuration
PORT=3000
NODE_ENV=production

# Puppeteer Service (EC2) — used for local dev; in Docker this defaults to http://puppeteer-service:3001
PUPPETEER_SERVICE_URL=http://13.232.81.37:3001

# Cache Configuration (still used for preprocessing)
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE_MB=500

# Image Processing (still used for headers/footers/watermarks)
IMAGE_QUALITY=95
IMAGE_MAX_WIDTH=2480
IMAGE_MAX_HEIGHT=3508

# CORS Configuration
ALLOWED_ORIGINS=*
