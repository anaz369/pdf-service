<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Tax Invoice - {{basicdetails.[0].inv_no}}</title>

<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: #ffffff;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 10px;
    color: #222;
    line-height: 1.4;
    margin: 0 8mm;
  }

  .page { width: 100%; margin: 0 auto; padding-top: 4px; }

  /* ── Title ─────────────────────────────────── */
  .main-title {
    text-align: center;
    font-weight: bold;
    font-size: 14px;
    padding: 4px 0 4px;
  }
  .main-title .ar { direction: rtl; }

  .vat-line {
    text-align: center;
    padding: 2px 0 8px;
    font-size: 10px;
  }
  .vat-line .ar { direction: rtl; }

  /* ── Top info table ────────────────────────── */
  .info-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
    border: 1px solid #000;
  }
  .info-table td {
    border: 1px solid #bfbfbf;
    padding: 4px 8px;
    font-size: 10px;
    vertical-align: top;
  }
  .info-table .info-lbl { width: 30%; font-weight: bold; }
  .info-table .info-lbl .ar { direction: rtl; font-weight: normal; }
  .info-table .info-sep { width: 14px; padding: 4px 0; }
  .info-table .info-val { width: auto; }

  /* ── Items table ───────────────────────────── */
  .items-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
    border: 1px solid #000;
    border-top: none;
  }
  .items-table th,
  .items-table td {
    border: 1px solid #bfbfbf;
    padding: 4px 6px;
    font-size: 10px;
    vertical-align: middle;
  }
  .items-table thead th {
    text-align: center;
    font-weight: bold;
    background: #ffffff;
    padding: 4px 6px;
  }
  .items-table .head-en { display: block; font-weight: bold; }
  .items-table .head-ar { display: block; direction: rtl; font-size: 9px; color: #555; }
  .items-table .center { text-align: center; }
  .items-table .right  { text-align: right; }
  .items-table .left   { text-align: left; }

  /* Filler row */
  .item-spacer td {
    border-left: 1px solid #bfbfbf;
    border-right: 1px solid #bfbfbf;
    border-top: none;
    border-bottom: none;
    height: 240px;
    padding: 0;
  }
  .item-spacer td:first-child { border-left: 1px solid #000; }
  .item-spacer td:last-child  { border-right: 1px solid #000; }

  /* ── QR + Totals row ──────────────────────── */
  .qrtot-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
    border: 1px solid #000;
    border-top: none;
  }
  .qrtot-table > tbody > tr > td {
    border: 1px solid #bfbfbf;
    vertical-align: middle;
    padding: 0;
  }
  .qrtot-qr {
    width: 24%;
    background: #f0f0f0;
    text-align: center;
    padding: 8px;
  }
  .qrtot-qr img { max-width: 110px; max-height: 110px; display: inline-block; }

  .qrtot-list { width: 100%; border-collapse: collapse; }
  .qrtot-list td {
    border: 1px solid #bfbfbf;
    padding: 4px 8px;
    font-size: 10px;
    vertical-align: middle;
  }
  .qrtot-list .tt-en { width: 36%; }
  .qrtot-list .tt-ar { width: 46%; direction: rtl; text-align: right; color: #444; font-size: 9.5px; }
  .qrtot-list .tt-val { width: 18%; text-align: right; }

  /* ── Words row ────────────────────────────── */
  .words-row {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
    border: 1px solid #000;
    border-top: none;
  }
  .words-row td {
    border: 1px solid #bfbfbf;
    padding: 4px 10px;
    font-size: 10px;
  }
  .words-row .w-en { width: 50%; }
  .words-row .w-ar { width: 50%; direction: rtl; text-align: right; }

  /* ── Centered footer line ─────────────────── */
  .center-foot {
    text-align: center;
    border: 1px solid #000;
    border-top: none;
    padding: 4px 8px;
    font-size: 10px;
    direction: rtl;
  }
  .center-foot2 {
    text-align: center;
    border: 1px solid #000;
    border-top: none;
    padding: 4px 8px;
    font-size: 10px;
  }
  .center-foot2 .ar { direction: rtl; margin-left: 6px; }

  /* ── Bottom signature row ─────────────────── */
  .sign-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
    border: 1px solid #000;
    border-top: none;
  }
  .sign-table td {
    border: 1px solid #bfbfbf;
    padding: 6px 8px;
    font-size: 10px;
    vertical-align: top;
    text-align: center;
  }
  .sign-table .sg-lbl { text-align: left; }
  .sign-table .sg-lbl .ar { direction: rtl; color: #555; font-size: 9px; }
</style>
</head>
<body>

<div class="page">

  <!-- Title -->
  <div class="main-title">
    TAX INVOICE / <span class="ar">فاتورة ضريبية</span>
  </div>
  <div class="vat-line">
    VAT : {{#if branch.[0].vat}}{{branch.[0].vat}}{{else}}{{compprof.gstin}}{{/if}}
    || <span class="ar">الرقم الضريبي : {{#if branch.[0].vat}}{{branch.[0].vat}}{{else}}{{compprof.gstin}}{{/if}}</span>
  </div>

  <!-- Top Info Table -->
  <table class="info-table">
    <tr>
      <td class="info-lbl">Invoice Number / <span class="ar">رقم الفاتورة</span></td>
      <td class="info-sep">:</td>
      <td class="info-val">{{basicdetails.[0].inv_no}}</td>
    </tr>
    <tr>
      <td class="info-lbl">Invoice Date / <span class="ar">تاريخ إصدار الفاتورة</span></td>
      <td class="info-sep">:</td>
      <td class="info-val">{{basicdetails.[0].inv_date}}</td>
    </tr>
    <tr>
      <td class="info-lbl">PO No / <span class="ar">رقم طلب الشراء</span></td>
      <td class="info-sep">:</td>
      <td class="info-val">{{basicdetails.[0].order_no}}</td>
    </tr>
    <tr>
      <td class="info-lbl">Customer VAT No / <span class="ar">رقم ضريبة العميل</span></td>
      <td class="info-sep">:</td>
      <td class="info-val">{{billing_address.[0].vat}}</td>
    </tr>
    <tr>
      <td class="info-lbl">Customer Name / <span class="ar">اسم العميل</span></td>
      <td class="info-sep">:</td>
      <td class="info-val">{{billing_address.[0].name}}</td>
    </tr>
    <tr>
      <td class="info-lbl">Customer Address</td>
      <td class="info-sep">:</td>
      <td class="info-val">
        {{#if billing_address.[0].address_line1}}{{billing_address.[0].address_line1}}{{/if}}
        <div>{{#if billing_address.[0].address_line2}}{{billing_address.[0].address_line2}} {{/if}}{{#if billing_address.[0].address_line3}}{{billing_address.[0].address_line3}} {{/if}}{{#if billing_address.[0].address_line4}}{{billing_address.[0].address_line4}} {{/if}}{{billing_address.[0].address_code}}</div>
      </td>
    </tr>
  </table>

  <!-- Items Table -->
  <table class="items-table">
    <colgroup>
      <col style="width:9%">
      <col style="width:43%">
      <col style="width:10%">
      <col style="width:18%">
      <col style="width:20%">
    </colgroup>
    <thead>
      <tr>
        <th>
          <span class="head-en">Sl#</span>
          <span class="head-ar">رقم التسلسل</span>
        </th>
        <th>
          <span class="head-en">Descriptions</span>
          <span class="head-ar">الوصف</span>
        </th>
        <th>
          <span class="head-en">Qty</span>
          <span class="head-ar">كمية</span>
        </th>
        <th>
          <span class="head-en">Unit price / SR</span>
          <span class="head-ar">سعر الوحدة ريال سعودي</span>
        </th>
        <th>
          <span class="head-en">Total / SAR</span>
          <span class="head-ar">المجموع ريال سعودي</span>
        </th>
      </tr>
    </thead>
    <tbody>
      {{#each itemdetails}}
      <tr>
        <td class="center">{{addOne @index}}</td>
        <td class="left">
          {{#if item_name}}{{item_name}}{{else}}{{description}}{{/if}}
          {{#if name_lang2}}<div>{{name_lang2}}</div>{{/if}}
          {{#if description}}{{#if item_name}}<div>{{description}}</div>{{/if}}{{/if}}
        </td>
        <td class="center">{{formatAmount quantity 0}}</td>
        <td class="right">{{formatAmount price ../bcdp}}</td>
        <td class="right">{{formatAmount amount ../bcdp}}</td>
      </tr>
      {{/each}}
      <tr class="item-spacer">
        <td></td><td></td><td></td><td></td><td></td>
      </tr>
    </tbody>
  </table>

  <!-- QR + Totals -->
  <table class="qrtot-table">
    <tr>
      <td class="qrtot-qr" rowspan="5">
        {{{qrDataUri qrCodeBase64}}}
      </td>
      <td style="padding:0;" colspan="3">
        <table class="qrtot-list">
          <tr>
            <td class="tt-en">Total</td>
            <td class="tt-ar">الإجمالي</td>
            <td class="tt-val">{{formatAmount (add (divide basicdetails.[0].subtotal ccrate) (divide basicdetails.[0].vatamt ccrate)) bcdp}}</td>
          </tr>
          <tr>
            <td class="tt-en">Total Amount (Excluding VAT)</td>
            <td class="tt-ar">الإجمالي الخاضع للضريبة (غير شاملة ضريبة القيمة المضافة)</td>
            <td class="tt-val">{{formatAmount (divide basicdetails.[0].subtotal ccrate) bcdp}}</td>
          </tr>
          <tr>
            <td class="tt-en">Total VAT</td>
            <td class="tt-ar">مجموع ضريبة القيمة المضافة</td>
            <td class="tt-val">{{formatAmount (divide basicdetails.[0].vatamt ccrate) bcdp}}</td>
          </tr>
          <tr>
            <td class="tt-en">Total Amount (Incl. VAT)</td>
            <td class="tt-ar">إجمالي المبلغ المستحق بعد ضريبة ١٥</td>
            <td class="tt-val">{{formatAmount (divide basicdetails.[0].grand_total ccrate) bcdp}}</td>
          </tr>
          <tr>
            <td class="tt-en">Total Payable</td>
            <td class="tt-ar">إجمالي المبلغ المستحق</td>
            <td class="tt-val">{{formatAmount (divide basicdetails.[0].grand_total ccrate) bcdp}}</td>
          </tr>
        </table>
      </td>
    </tr>
  </table>

  <!-- Words row -->
  <table class="words-row">
    <tr>
      <td class="w-en">{{bcamountinwords}}</td>
      <td class="w-ar">{{bcamountinwordsar}}</td>
    </tr>
  </table>

  <!-- Centered footer lines -->
  <div class="center-foot">{{#if compprof.name}}{{compprof.name}}{{else}}{{branch.[0].name}}{{/if}}</div>
  <div class="center-foot2">
    <span class="ar">رقم السجل: {{#if branch.[0].cr_no}}{{branch.[0].cr_no}}{{else}}{{compprof.cr_no}}{{/if}}</span>
    Thanks for your business /
    <span class="ar">شكراً لكم</span>
  </div>

  <!-- Bottom signature row -->
  <table class="sign-table">
    <colgroup>
      <col style="width:18%">
      <col style="width:25%">
      <col style="width:19%">
      <col style="width:19%">
      <col style="width:19%">
    </colgroup>
    <tr>
      <td class="sg-lbl">
        <div>Account Name</div>
        <div class="ar">إسم الحساب</div>
      </td>
      <td>{{bankdetails.acc_name}}{{#unless bankdetails.acc_name}}{{bankdetails.name}}{{/unless}}</td>
      <td><strong>Prepared By</strong></td>
      <td><strong>Approved By</strong></td>
      <td><strong>Received By</strong></td>
    </tr>
  </table>

</div>

</body>
</html>
