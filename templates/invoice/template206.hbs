<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>INVOICE - {{basicdetails.[0].inv_no}}</title>
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        font-family: "IBM Plex Sans Arabic", sans-serif;
        font-size: 11px;
        line-height: 1.35;
        color: #000;
        margin: 0 4mm;
      }

      .top-header-bar {
        width: 100%;
        background: #2a2a2a;
        color: #fff;
        display: table;
        table-layout: fixed;
        padding: 6px 8px;
        font-size: 11.5px;
        font-weight: 600;
      }
      .top-header-bar .cell {
        display: table-cell;
        vertical-align: middle;
      }
      .top-header-bar .left {
        text-align: left;
        width: 50%;
      }
      .top-header-bar .right {
        text-align: right;
        width: 50%;
        direction: ltr;
      }
      .top-header-bar .ar {
        direction: rtl;
        margin: 0 6px;
      }

      .header-row {
        width: 100%;
        border-collapse: collapse;
        margin-top: 6px;
        table-layout: fixed;
      }
      .header-row > tbody > tr > td {
        vertical-align: top;
        padding: 0;
      }
      .cust-box,
      .pay-box {
          border: 1px solid #000;
          border-radius: 14px;
          overflow: hidden;
      }
      .cust-box {
        border: 1px solid #000;
        border-radius: 14px;
        overflow: hidden;
        vertical-align: top;
      }
      .cust-box .cust-head {
        font-weight: 700;
        padding: 6px 10px;
        border-bottom: 1px solid #000;
        font-size: 11.5px;
        letter-spacing: 0.3px;
      }
      .cust-box table {
        width: 100%;
        font-size: 11px;
      }
      .cust-box table td {
        padding: 5px 10px;
        vertical-align: top;
        border-bottom: 1px solid #000;
      }
      .cust-box table tr:last-child td {
        border-bottom: none;
      }
      .cust-box td.lbl {
        width: 36%;
        font-weight: bold;
        color: #000;
        border-right: 1px solid #000;
      }

      .center-box {
        text-align: center;
        vertical-align: middle !important;
        padding: 0 8px !important;
      }
      .center-box .inv-title-ar {
        font-size: 19px;
        font-weight: 800;
        direction: rtl;
        margin-bottom: 2px;
      }
      .center-box .inv-title {
        font-size: 19px;
        font-weight: 800;

        letter-spacing: 0.5px;
        margin-bottom: 6px;
      }
      .center-box .qr-wrap {
        display: inline-block;
        width: 110px;
        height: 110px;
      }
      .center-box .qr-wrap img {
        width: 100%;
        height: 100%;
        object-fit: contain;
      }

      .pay-box {
        
        border: 1px solid #000;
        border-radius: 14px;
        overflow: hidden;
        vertical-align: top;
      }
      .pay-box table {
        width: 100%;
        
        font-size: 11px;
      }
      .pay-box table td {
        padding: 5px 10px;
        border-bottom: 1px solid #000;
        vertical-align: middle;
      }
      .pay-box table tr:last-child td {
        border-bottom: none;
      }
      .pay-box td.lbl-en {
        width: 56%;
        border-right: 1px solid #000;
      }
      .pay-box td.val {
        width: 50%;
        text-align: center;
      }

      .items-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 8px;
        font-size: 11px;
      }
      .items-table th,
      .items-table td {
        border: 1px solid #000;
        padding: 4px 4px;
        vertical-align: middle;
      }
      .items-table thead th {
        font-weight: 700;
        text-align: center;
        line-height: 1.3;
      }
      .items-table thead th .ar {
        display: block;
        direction: rtl;
        font-size: 9.5px;
        font-weight: 700;
      }
      .items-table thead th .en {
        display: block;
        font-size: 10px;
        font-weight: 700;
      }
      .items-table td.num {
        text-align: center;
      }
      .items-table td.right {
        text-align: right;
      }
      .items-table td.desc {
        text-align: left;
      }
      .items-table td.desc .sub-ar {
        direction: rtl;
        font-size: 9.5px;
        color: #444;
      }
      .items-table td.desc .sub-en {
        font-size: 9.5px;
        color: #444;
      }

      .totals-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 6px;
        font-size: 11px;
        table-layout: fixed;
      }
      .totals-table td {
        padding: 5px 8px;
        vertical-align: middle;
      }
      .totals-table .qty-lbl {
        width: 25%;
        font-weight: 700;
        text-align: right;
      }
      .totals-table .qty-val {
        width: 13%;
        text-align: right;
        font-weight: 700;
      }
      .totals-table .lbl-en {
        width: 17%;
        font-weight: 700;
      }
      .totals-table .lbl-ar {
        width: 21%;
        text-align: right;
        direction: rtl;
        font-weight: 700;
      }
      .totals-table .val {
        width: 14%;
        text-align: right;
        font-weight: 700;
      }
      .totals-table .words-cell {
        vertical-align: middle;
        padding: 8px 10px;
        line-height: 1.6;
      }
      .totals-table .words-cell .ar {
        direction: rtl;
        text-align: right;
        display: block;
        margin-top: 6px;
      }

      .sign-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 11px;
        table-layout: fixed;
      }
      .sign-table td {
        width: 33.33%;
        padding: 14px 14px 16px;
        vertical-align: top;
        border: 1px solid #000;
        border-top: none;
      }
      .sign-table td .lbl-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-weight: 700;
        margin-bottom: 24px;
      }
      .sign-table td .lbl-row .en {
        letter-spacing: 1px;
      }
      .sign-table td .lbl-row .ar {
        direction: rtl;
      }
      .sign-table td .dots {
        text-align: center;
        letter-spacing: 2px;
        color: #000;
      }
      .ryl { font-family: Arial, sans-serif;font-size: 15px;}
    </style>
  </head>
  <body>

    <!-- TOP HEADER BAR -->


    <!-- HEADER ROW : CUSTOMER | TAX INVOICE + QR | PAYMENT -->
    <table class="header-row">
      <tbody>
        <tr>
          <!-- CUSTOMER BOX -->
          <td style="width: 42%;">
            <div class="cust-box">
              <table>
                <tr>
                  <td class="lbl">Name:</td>
                  <td>{{billing_address.[0].name}}</td>
                </tr>
                <tr>
                  <td class="lbl">الاسم:</td>
                  <td>{{billing_address_lang2.[0].name}}</td>
                </tr>
                <tr>
                  <td class="lbl">Address:</td>
                  <td>{{billing_address.[0].address_line1}}  {{billing_address.[0].address_line2}}  {{billing_address.[0].address_line3}}</td>
                </tr>
                <tr>
                  <td class="lbl">City:</td>
                  <td>{{billing_address.[0].address_line3}}  {{billing_address.[0].address_line5}}</td>
                </tr>
                <tr>
                  <td class="lbl">Payment Mode:</td>
                  <td></td>
                </tr>
                <tr>
                  <td class="lbl" style="font-size: 10px;">Customer VAT No:</td>
                  <td>{{billing_address.[0].vat}}</td>
                </tr>
              </table>
            </div>
          </td>

          <!-- CENTER : TAX INVOICE + QR -->
          <td style="width: 20%;">
            <div class="center-box">
              <div class="inv-title-ar">فاتورة ضريبة</div>
              <div class="inv-title">TAX INVOICE</div>
              <div class="qr-wrap">{{{qrDataUri qrCodeBase64}}}</div>
            </div>
          </td>

          <!-- PAYMENT BOX -->
          <td style="width: 38%;">
              <div class="pay-box">
              <table>
                <tr>
                  <td class="lbl-en">VAT No / <span style="direction: rtl;text-align:right;">رقم ضريبة </span></td>
                  <td class="val">{{branch.[0].vat}}</td>
                </tr>
                <tr>
                  <td class="lbl-en">Invoice No / <span style="direction: rtl;text-align:right;">رقم الفاتورة</span></td>
                  <td class="val">{{basicdetails.[0].inv_no}}</td>
                </tr>
                <tr>
                  <td class="lbl-en">Invoice Date / <span style="direction: rtl;text-align:right;">تاريخ الفاتورة</span></td>
                  <td class="val">{{basicdetails.[0].inv_date}}</td>
                </tr>
                <tr>
                  <td class="lbl-en">Invoice Time / <span style="direction: rtl;text-align:right;">وقت الفاتورة</span></td>
                  <td class="val">{{basicdetails.[0].inv_time}}</td>
                </tr>
                <tr>
                  <td class="lbl-en">PO Date / <span style="direction: rtl;text-align:right;">تاريخ أمر الشراء</span></td>
                  <td class="val">{{basicdetails.[0].po_date}}</td>
                </tr>
                <tr>
                  <td class="lbl-en">PO No / <span style="direction: rtl;text-align:right;"> رقم أمر الشراء</span></td>
                  <td class="val">{{basicdetails.[0].order_no}}</td>
                </tr>
              </table>
              </div>
          </td>
        </tr>
      </tbody>
    </table>

    <!-- ITEMS TABLE -->
    <table class="items-table">
      <thead>
        <tr>
          <th style="width:5%">
            <span class="ar">الرقم</span>
            <span class="en">S.N</span>
          </th>
          <th style="width:10%">
            <span class="ar">رمز الصنف</span>
            <span class="en">Item Code</span>
          </th>
          <th style="width:50%">
            <span class="ar">الوصف</span>
            <span class="en">Description</span>
          </th>
          <th style="width:7%">
            <span class="ar">الكمية</span>
            <span class="en">QTY</span>
          </th>
          <th style="width:7%">
            <span class="ar">الوحدة</span>
            <span class="en">Unit</span>
          </th>
          <th style="width:10%">
            <span class="ar">سعر الوحدة</span>
            <span class="en">U.Rate</span>
          </th>
          <th style="width:11%">
            <span class="ar">المجموع</span>
            <span class="en">Total (Excl VAT)</span>
          </th>
        </tr>
      </thead>
      <tbody>
        {{#each itemdetails}}
        <tr>
          <td class="num">{{addOne @index}}</td>
          <td class="num">{{item_code}}</td>
          <td class="desc">
            {{item_name}}
            {{#if name_lang2}}<div class="sub-ar">{{name_lang2}}</div>{{/if}}
            {{#if description}}<div class="sub-en">{{description}}</div>{{/if}}
          </td>
          <td class="num">{{formatAmount quantity ../bcdp}}</td>
          <td class="num">{{unit}}</td>
          <td class="right">{{formatAmount price ../bcdp}}</td>
          <td class="right">{{formatAmount taxable ../bcdp}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>

    <!-- TOTALS -->
    <table class="totals-table">
      <tr style="border: 1px solid #000;">
        <td class="qty-lbl" style="border: 1px solid #000;">Total Qty</td>
        <td class="qty-val" style="border: 1px solid #000;">{{formatAmount (sumProperty itemdetails 'quantity') bcdp}}</td>
        <td class="lbl-en"  style="border: 1px solid #000;border-right:none;">Total Before VAT</td>
        <td class="lbl-ar" style="border: 1px solid #000;border-left:none;"> الإجمالي قبل ضريبة القيمة المضافة</td>
        <td class="val" style="border: 1px solid #000;"><span class="ryl">{{currencySymbol basicdetails.[0].base_country_isocode}}</span>{{formatAmount (divide basicdetails.[0].subtotal ccrate) bcdp}}</td>
      </tr>
      {{#if zatcadiscount.[0]}}
        {{#each zatcadiscount}}
        <tr>
            <td rowspan="4" colspan="2" class="words-cell" style="border: 1px solid #000;">
            {{bcamountinwords}}
            <span class="ar">{{bcamountinwordsar}}</span>
            </td>
            <td class="lbl-en" style="border: 1px solid #000;border-right:none;">{{reason_name}}</td>
            <td class="lbl-ar" style="border: 1px solid #000;border-left:none;">{{reason_name_lang2}}</td>
            <td class="val" style="border: 1px solid #000;"><span class="ryl">{{currencySymbol basicdetails.[0].base_country_isocode}}</span>{{formatAmount (divide dld ../ccrate) bcdp}}</td>
        </tr>
        {{/each}}
        <tr>
            <td class="lbl-en" style="border: 1px solid #000;border-right:none;">After Discount</td>
            <td class="lbl-ar" style="border: 1px solid #000;border-left:none;">بعد الخصم</td>
            <td class="val" style="border: 1px solid #000;"><span class="ryl">{{currencySymbol basicdetails.[0].base_country_isocode}}</span>{{formatAmount (divide (subtract basicdetails.[0].subtotal zatcadiscount.[0].dld) ccrate) bcdp}}</td>
        </tr>
        {{else}}

            {{#if (or basicdetails.[0].discount basicdetails.[0].dld)}}
            <tr>
                <td rowspan="4" colspan="2" class="words-cell" style="border: 1px solid #000;">
                {{bcamountinwords}}
                <span class="ar">{{bcamountinwordsar}}</span>
                </td>
                <td class="lbl-en" style="border: 1px solid #000;border-right:none;">Discount</td>
                <td class="lbl-ar" style="border: 1px solid #000;border-left:none;">الخصم</td>
                <td class="val" style="border: 1px solid #000;"><span class="ryl">{{currencySymbol basicdetails.[0].base_country_isocode}}</span>{{formatAmount (divide (add basicdetails.[0].discount basicdetails.[0].dld) ccrate) bcdp}}</td>
            </tr>
            <tr>
                <td class="lbl-en" style="border: 1px solid #000;border-right:none;">After Discount</td>
                <td class="lbl-ar" style="border: 1px solid #000;border-left:none;">بعد الخصم</td>
                <td class="val" style="border: 1px solid #000;"><span class="ryl">{{currencySymbol basicdetails.[0].base_country_isocode}}</span>{{formatAmount (divide (subtract basicdetails.[0].subtotal (add basicdetails.[0].discount basicdetails.[0].dld)) ccrate) bcdp}}</td>
            </tr>
        {{/if}}
    {{/if}}
      <tr>
        <td class="lbl-en" style="border: 1px solid #000;border-right:none;">VAT</td>
        <td class="lbl-ar" style="border: 1px solid #000;border-left:none;">ضريبة القيمة المضافة </td>
        <td class="val" style="border: 1px solid #000;"><span class="ryl">{{currencySymbol basicdetails.[0].base_country_isocode}}</span>{{formatAmount (divide basicdetails.[0].vatamt ccrate) bcdp}}</td>
      </tr>
      <tr>
        <td class="lbl-en" style="border: 1px solid #000;border-right:none;">Grand Total</td>
        <td class="lbl-ar" style="border: 1px solid #000;border-left:none;">المبلغ الأجملي</td>
        <td class="val" style="border: 1px solid #000;"><span class="ryl">{{currencySymbol basicdetails.[0].base_country_isocode}}</span>{{formatAmount (divide basicdetails.[0].grand_total ccrate) bcdp}}</td>
      </tr>
    </table>

    <!-- SIGNATURES -->
    <table class="sign-table">
      <tr>
        <td>
          <div class="lbl-row">
            <span class="en">RECEIVER</span><span class="ar">المستلم</span>
          </div>
          <div class="dots">..................................</div>
        </td>
        <td>
          <div class="lbl-row"><span class="en">SALESMAN</span><span class="ar">البائع</span></div>
          <div style="text-align: center;"><img src="{{Signature}}" alt="Signature" style="text-align:right;max-height:{{default datasettings.d458 '120'}}px; max-width:{{default datasettings.d458 '180'}}px;" onerror="this.style.display='none'"/></div>
          <div class="dots">..................................</div>
        </td>
      </tr>
    </table>

  </body>
</html>
