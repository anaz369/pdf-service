<body>
    <div class="section my_table">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <h1 class="text-center invoice_head">TAX INVOICE / فاتورة ضريبية</h1>
                </div>
                <div class="col-lg-12">
                    <table class="lih-24">
                        <tr>
                            <td class="bt-1"><b>■ Invoice No: {{basicdetails.[0].inv_no}} </b></td>
                            <td class="arab text-end bt-1"><b> : الفاتورة رقم■</b></td>
                        </tr>
                    </table>
                </div>
                <div class="col-lg-12">
                    <table class="table_sec8">
                        <tr>
                            <th class="text-center">
                                <span class="arab">تاريخ الفاتورة</span><br>Invoice Date
                            </th>
                            <th class="text-center">
                                <span class="arab">نوع الفاتورة</span><br>Invoice Type
                            </th>
                            <th class="text-center">
                                <span class="arab">فترة الفاتورة</span><br>Invoice Period
                            </th>
                            <th class="text-center">
                                <span class="arab">تاريخ الاستحقاق</span><br>Invoice Due
                            </th>
                            <th class="text-center">
                                <span class="arab">رقم عقد/أمر الشراء</span><br>Contract / PO No
                            </th>
                            <th class="text-center">
                                <span class="arab">تاريخ عقد/أمر الشراء</span><br>Contract/ PO Date
                            </th>
                            <th class="text-center">
                                <span class="arab">رقم المرجع أخر</span><br>Other Reference No
                            </th>
                        </tr>
                        <tr class="text-center">
                            <td>{{basicdetails.[0].inv_date}} </td>
                            <td> </td>
                            <td>{{basicdetails.[0].inv_from}} - {{basicdetails.[0].inv_to}}</td>
                            <td>{{#if basicdetails.[0].due_date}}{{basicdetails.[0].due_date}}{{/if}}</td>
                            <td>{{#if basicdetails.[0].order_no}}{{basicdetails.[0].order_no}}{{/if}}</td>
                            <td>{{#if basicdetails.[0].po_date}}{{basicdetails.[0].po_date}}{{/if}}</td>
                            <td>{{#if basicdetails.[0].reference_no}}{{basicdetails.[0].reference_no}}{{/if}}</td>
                        </tr>
                    </table>
                </div>
                <div class="col-lg-12">
                    <table class="table_sec8 mt-2">
                        <tr>
                            <td class="text-start br" colspan="4"><b>■ Our Details</b></td>
                            <td class="text-end arab bl" colspan="4"><b>تفاصيلنا ■ </b></td>
                        </tr>
                        <tr>
                            <td class="text-start bb bg-light11">From</td>
                            <td class="text-start" colspan="3"><b>{{branch.[0].name}}</b></td>
                            <td class="text-end arab" colspan="3">{{branch_lang2.[0].name}}</td>
                            <td class="text-end arab bg-light11">الإسم</td>
                        </tr>
                        <tr>
                            <td class="text-start bt bg-light11">Address</td>
                            <td class="text-start" colspan="3">{{joinAddress branch.[0] '، '}}</td>
                            <td class="text-end arab" colspan="3">{{joinAddress branch_lang2.[0] '، '}}</td>
                            <td class="text-end arab bt bg-light11">العنوان</td>
                        </tr>
                        <tr>
                            <td class="text-start bt bg-light11">VAT Reg. No</td>
                            <td class="text-start">{{branch.[0].vat}}</td>
                            <td class="text-start bg-light11">CR No </td>
                            <td class="text-start">{{branch.[0].cr_no}}</td>
                            <td class="text-end arab">{{branch_lang2.[0].vat}}</td>
                            <td class="text-end arab bg-light11">ي السجل</td>
                            <td class="text-end arab">{{branch_lang2.[0].cr_no}}</td>
                            <td class="text-end arab bt bg-light11">ي الرقم</td>
                        </tr>
                    </table>
                </div>
                <div class="col-lg-12">
                    <table class="table_sec8 mt-2">
                        <tr>
                            <td class="text-start br" colspan="4"><b>■ Customer Details</b></td>
                            <td class="text-end arab bl" colspan="4"><b>تفاصيل العميل ■ </b></td>
                        </tr>
                        <tr>
                            <td class="text-start bb bg-light11">To</td>
                            <td class="text-start" colspan="3"><b>{{billing_address.[0].name}}</b></td>
                            <td class="text-end arab" colspan="3">شركة هانا</td>
                            <td class="text-end arab bg-light11">الإسم</td>
                        </tr>
                        <tr>
                            <td class="text-start bt bg-light11">Address</td>
                            <td class="text-start" colspan="3">{{joinAddress billing_address.[0] '، '}}</td>
                            <td class="text-end arab" colspan="3">{{joinAddress billing_address_lang2.[0] '، '}}</td>
                            <td class="text-end arab bt bg-light11">العنوان</td>
                        </tr>
                        <tr>
                            <td class="text-start bt bg-light11">VAT Reg. No</td>
                            <td class="text-start">{{billing_address.[0].vat}}</td>
                            <td class="text-start bg-light11">CR No </td>
                            <td class="text-start">{{customer_details.[0].cr_no}}</td>
                            <td class="text-end arab">{{customer_details.[0].cr_no_lang2}}</td>
                            <td class="text-end arab bg-light11">ي السجل</td>
                            <td class="text-end arab">{{billing_address_lang2.[0].vat}}</td>
                            <td class="text-end arab bt bg-light11">ي الرقم</td>
                        </tr>
                    </table>
                </div>

                <div class="col-lg-12 mt-2">
                    <table class="table table_sec9 lih-20 mb-1">
                        <thead>
                            <tr>
                                <th class="text-center bg-light11"><span class="arab">م</span><br>#</th>
                                <th class="text-center bg-light11"><span class="arab">الوصف</span><br>Item Description</th>
                                <th class="text-center bg-light11"><span class="arab">الوحدة</span><br>Unit</th>
                                <th class="text-center bg-light11"><span class="arab">الكمية</span><br>Quantity</th>
                                <th class="text-center bg-light11"><span class="arab"> سعر الوحدة</span><br>Unit Rate </th>
                                <th class="text-center bg-light11"><span class="arab"> المبلغ (بدون ضريبة)</span><br>Amount</th>
                                <th class="text-center bg-light11"><span class="arab">خصم</span><br>Discount</th>
                                <th class="text-center bg-light11"><span class="arab">مبلغ ضريبة</span><br>VAT Amount</th>
                                <th class="text-center bg-light11"><span class="arab">الإجمالي (شامل ضريبة)</span><br>Total Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                             {{#each itemdetails}}
                            <tr>
                                <td class="text-center">{{addOne @index}}</td>
                                <td class="text-start">
                                    {{item_name}}
                                    {{#if name_lang2}}<div style="direction:rtl; font-size:9.5px; color:#444;">{{name_lang2}}</div>{{/if}}
                                    {{#if description}}<div style="direction:rtl; font-size:9.5px; color:#444;">{{description}}</div>{{/if}}
                                </td>
                                <td class="text-center"><{{unit}}></td>
                                <td class="text-center">{{formatAmount quantity bcdp}}</td>
                                <td class="text-end">{{formatAmount price bcdp}}</td>
                                <td class="text-end">{{formatAmount taxable bcdp}}</td>
                                <td class="text-center">{{formatAmount disc_amt bcdp}}</td>
                                <td class="text-end">{{formatAmount vat_amt bcdp}}</td>
                                <td class="text-end">{{formatAmount amount bcdp}}</td>
                            </tr>
                              {{/each}}
                            
                        </tbody>
                    </table>
                </div>
                
                <div class="col-lg-2 col-md-2 col-sm-2 text-center">
                    {{{qrDataUri qrCodeBase64}}}
                </div>
                <div class="col-lg-10 col-md-10 col-sm-10">
                    <table class="table_sec9">
                        <tr>
                            <td class="text-start"><b>Grand Total Amount (Excl. VAT)</b></td>
                            <td class="text-end bg-light11"><b>{{formatAmount (divide basicdetails.[0].subtotal ccrate) bcdp}}</b></td>
                            <td class="text-end arab"><b>(ضريبة بدون (الإجمالي ا</b></td>
                        </tr>
                        <tr>
                            <td class="text-start"><b>Total VAT Amount</b></td>
                            <td class="text-end bg-light11"><b>{{formatAmount (divide basicdetails.[0].vatamt ccrate) bcdp}}</b></td>
                            <td class="text-end arab"><b>المضافة القيمة ضريبة مبلغ إ</b></td>
                        </tr>
                        <tr>
                            <td class="text-start"><b>Grand Total Amount (Incl. VAT)</b></td>
                            <td class="text-end bg-light11"><b>{{formatAmount (divide basicdetails.[0].grand_total ccrate) bcdp}}</b></td>
                            <td class="text-end arab"><b>(ضريبة شامل (الإجمالي ا</b></td>
                        </tr>
                        <tr>
                            <td class="text-start"><b>Other retentions (5%)</b></td>
                            <td class="text-end bg-light11"><b> 393.00</b></td>
                            <td class="text-end arab"><b>(%٥) الآخر ا</b></td>
                        </tr>
                        <tr>
                            <td class="text-start"><b>Net Due Amount</b></td>
                            <td class="text-end bg-light11"><b>{{formatAmount (divide basicdetails.[0].grand_total ccrate) bcdp}}</b></td>
                            <td class="text-end arab"><b>لصافي المستحق ا</b></td>
                        </tr>
                        <tr>
                            <td colspan="3" class="text-center"><small>Amount in words :{{bcamountinwords}}</small><br><b><span class="arab">فقط</span><br>UAE Dirham Nine Thousand Thirty-Nine Only</b></td>
                        </tr>
                    </table>
                </div>
                
                 <div class="col-lg-12">
                    <div class="bd-code-snippet2s mt-1">
                        <table class="table_sec9">
                            <tr>
                                <td class="text-center bg-light11" colspan="2">Bank Details / <span class="arab">التفاصيل المصرفية</span></td>
                                <td class="text-center bg-light11">Approved by / <span class="arab">تمت الموافقة</span></td>
                                <td class="text-center bg-light11">Received by / <span class="arab">قبل من تلقى</span></td>
                            </tr>
                            <tr>
                                <td class="text-start">Bank Name / الحساب اسم </td>
                                <td class="text-start"><b>{{#if bankdetails.name}}{{bankdetails.name}}{{/if}}</b></td>
                                <td class="text-start" rowspan="5"></td>
                                <td class="text-start" rowspan="5"></td>
                            </tr>
                            <tr>
                                <td class="text-start">Bank / بن</td>
                                <td class="text-start"><b>{{#if bankdetails.branch_name}}{{bankdetails.branch_name}}{{/if}}</b></td>
                            </tr>
                            <tr>
                                <td class="text-start">Account No. / الحساب ر</td>
                                <td class="text-start"><b>{{#if bankdetails.acc_no}}{{bankdetails.acc_no}}{{/if}}</b></td>
                            </tr>
                            <tr>
                                <td class="text-start">IBAN / آيبان</td>
                                <td class="text-start"><b>{{#if bankdetails.iban_no}}{{bankdetails.iban_no}}{{/if}}</b></td>
                            </tr>
                            <tr>
                                <td class="text-start">Swift Code / السرعة رمز</td>
                                <td class="text-start"><b>{{#if bankdetails.swift_no}}{{bankdetails.swift_no}}{{/if}}</b></td>
                            </tr>
                            <tr>
                                <td class="text-start">Branch / فرع</td>
                                <td class="text-start"><b>{{#if bankdetails.branch_name}}{{bankdetails.branch_name}}{{/if}}</b></td>
                                <td class="text-center bt"><b><span class="arab">التوقيع مع الختم</span><br>Signature with Stamp</b></td>
                                <td class="text-center bt"><b><span class="arab">التوقيع مع الختم</span><br>Signature with Stamp</b></td>
                            </tr>
                        </table>
                     </div>
                </div>
                
            </div> 
        </div>
    </div>
</body>
</html>