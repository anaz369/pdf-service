<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>INVOICE - {{basicdetails.[0].inv_no}}</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: Arial, Helvetica, sans-serif;
    font-size: 11px;
    color: #333;
    background: #fff;
    line-height: 1.45;
    margin: 0 8mm;
  }
  .page { width: 100%; padding-top: 10px; }

  /* ── Header : company | INVOICE ───────────── */
  .inv-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }
  .company-name { font-weight: bold; font-size: 13px; color: #000; margin-bottom: 2px; }
  .company-info { font-size: 10px; color: #555; }
  .inv-title-wrap { text-align: right; }
  .inv-title {
    font-size: 34px;
    font-weight: 400;
    color: #9a9a9a;
    letter-spacing: 1px;
    line-height: 1;
  }
  .inv-no { font-size: 11px; color: #777; margin-top: 4px; }

  /* ── Mid row : Bill To | Balance + dates ──── */
  .mid-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-top: 20px;
  }
  .billto { max-width: 55%; }
  .billto .lbl { color: #888; font-size: 10px; margin-bottom: 2px; }
  .billto .nm  { font-weight: bold; color: #000; }
  .billto .info { font-size: 10px; color: #555; }

  .summary { text-align: right; }
  .summary .bal-lbl { color: #888; font-size: 10px; }
  .summary .bal-amt { font-weight: bold; font-size: 15px; color: #000; margin-bottom: 8px; }
  .info-table { border-collapse: collapse; margin-left: auto; }
  .info-table td { padding: 2px 0; font-size: 11px; vertical-align: top; }
  .info-table .k { color: #888; text-align: right; padding-right: 10px; white-space: nowrap; }
  .info-table .v { color: #333; text-align: left; white-space: nowrap; }

  /* ── Items table ──────────────────────────── */
  .items {
    width: 100%;
    border-collapse: collapse;
    margin-top: 22px;
  }
  .items thead th {
    background: #3a3a3a;
    color: #fff;
    font-size: 10px;
    font-weight: bold;
    padding: 7px 8px;
    text-align: right;
  }
  .items thead th.idx  { text-align: center; }
  .items thead th.desc { text-align: left; }
  .items tbody td {
    padding: 7px 8px;
    font-size: 10.5px;
    border-bottom: 1px solid #e6e6e6;
    text-align: right;
    vertical-align: top;
  }
  .items tbody td.idx  { text-align: center; color: #555; }
  .items tbody td.desc { text-align: left; }
  .items .it-name { font-weight: bold; color: #000; }
  .items .it-sub  { font-size: 9px; color: #888; }
  .items .pct { display: block; font-size: 9px; color: #999; }

  /* ── Totals ───────────────────────────────── */
  .totals-wrap { display: flex; justify-content: flex-end; margin-top: 10px; }
  .totals { border-collapse: collapse; min-width: 300px; }
  .totals td { padding: 5px 10px; font-size: 11px; }
  .totals .k { text-align: right; color: #555; }
  .totals .v { text-align: right; color: #333; white-space: nowrap; min-width: 90px; }
  .totals tr.strong td { font-weight: bold; color: #000; }
  .totals tr.grand td { font-weight: bold; color: #000; background: #efefef; }

  /* ── Words ────────────────────────────────── */
  .words {
    text-align: right;
    margin-top: 14px;
    font-size: 11px;
  }
  .words .w-lbl { color: #cf6a1a; font-weight: bold; }
  .words .w-val { font-style: italic; font-weight: bold; color: #000; }

  /* ── Notes ────────────────────────────────── */
  .notes { margin-top: 30px; font-size: 10.5px; }
  .notes .n-title { font-weight: bold; color: #000; margin-bottom: 4px; }
  .notes .n-body { color: #555; line-height: 1.6; }
</style>
</head>
<body>
<div class="page">

  {{!-- ══ HEADER ══ --}}
  <div class="inv-header">
    <div class="company">
      <div class="company-name">{{branch.[0].name}}</div>
      <div class="company-info">
        {{branch.[0].address_line1}}{{#if branch.[0].address_line2}}, {{branch.[0].address_line2}}{{/if}}<br>
        {{branch.[0].address_line3}}{{#if branch.[0].address_line4}}, {{branch.[0].address_line4}}{{/if}}{{#if branch.[0].address_code}}, {{branch.[0].address_code}}{{/if}}<br>
        {{branch.[0].address_line5}},<br>
        {{#if branch.[0].vat}}GSTIN: {{branch.[0].vat}}{{/if}}
      </div>
    </div>
    <div class="inv-title-wrap">
      <div class="inv-title">INVOICE</div>
      <div class="inv-no">{{basicdetails.[0].inv_no}}</div>
    </div>
  </div>

  {{!-- ══ BILL TO | SUMMARY ══ --}}
  <div class="mid-row">
    <div class="billto">
      <div class="lbl">Bill To</div>
      <div class="nm">{{billing_address.[0].name}}</div>
      <div class="info">
        {{billing_address.[0].address_line1}}{{#if billing_address.[0].address_line2}}, {{billing_address.[0].address_line2}}{{/if}}<br>
        {{billing_address.[0].address_line3}}{{#if billing_address.[0].address_line4}}, {{billing_address.[0].address_line4}}{{/if}}{{#if billing_address.[0].address_code}}, {{billing_address.[0].address_code}}{{/if}}<br>
        {{billing_address.[0].address_line5}}<br>
        {{#if billing_address.[0].vat}}GSTIN: {{billing_address.[0].vat}}{{/if}}
      </div>
    </div>

    <div class="summary">
      <div class="bal-lbl">Balance Due</div>
      <div class="bal-amt">{{{currencySymbol isocode}}}{{formatAmount basicdetails.[0].balance bcdp}}</div>
      <table class="info-table">
        <tr><td class="k">Invoice Date :</td><td class="v">{{basicdetails.[0].inv_date}}</td></tr>
        <tr><td class="k">Terms :</td><td class="v">{{basicdetails.[0].payment_terms}}</td></tr>
        <tr><td class="k">Due Date :</td><td class="v">{{basicdetails.[0].due_date}}</td></tr>
      </table>
    </div>
  </div>

  {{!-- ══ ITEMS ══ --}}
  <table class="items">
    <colgroup>
      <col style="width:4%"><col style="width:38%"><col style="width:12%">
      <col style="width:14%"><col style="width:14%"><col style="width:18%">
    </colgroup>
    <thead>
      <tr>
        <th class="idx">#</th>
        <th class="desc">Item &amp; Description</th>
        <th>Qty</th>
        <th>Rate</th>
        <th>Discount</th>
        <th>Amount</th>
      </tr>
    </thead>
    <tbody>
      {{#each itemdetails}}
      <tr>
        <td class="idx">{{addOne @index}}</td>
        <td class="desc">
          <span class="it-name">{{item_name}}</span>
          {{#if name_lang2}}<div class="it-sub">{{name_lang2}}</div>{{/if}}
          {{#if description}}<div class="it-sub">{{description}}</div>{{/if}}
        </td>
        <td>{{formatAmount quantity ../bcdp}}</td>
        <td>{{formatAmount price ../bcdp}}</td>
        <td>
          {{formatAmount disc_amt ../bcdp}}
          <span class="pct">{{formatAmount (multiply (divide disc_amt (multiply price quantity)) 100) 0}}%</span>
        </td>
        <td>{{formatAmount amount ../bcdp}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>

  {{!-- ══ TOTALS ══ --}}
  <div class="totals-wrap">
    <table class="totals">
      <tr>
        <td class="k">Sub Total</td>
        <td class="v">{{{currencySymbol isocode}}}{{formatAmount basicdetails.[0].subtotal bcdp}}</td>
      </tr>
      <tr>
        <td class="k">Discount</td>
        <td class="v">{{{currencySymbol isocode}}}{{formatAmount basicdetails.[0].discount bcdp}}</td>
      </tr>
      <tr class="strong">
        <td class="k">After Discount</td>
        <td class="v">{{{currencySymbol isocode}}}{{formatAmount (subtract basicdetails.[0].subtotal basicdetails.[0].discount) bcdp}}</td>
      </tr>
      <tr>
        <td class="k">Paid Amount</td>
        <td class="v">{{{currencySymbol isocode}}}{{formatAmount basicdetails.[0].received bcdp}}</td>
      </tr>
      <tr>
        <td class="k">Balance Due</td>
        <td class="v">{{{currencySymbol isocode}}}{{formatAmount basicdetails.[0].balance bcdp}}</td>
      </tr>
      <tr class="grand">
        <td class="k">Grand Total</td>
        <td class="v">{{{currencySymbol isocode}}}{{formatAmount basicdetails.[0].grand_total bcdp}}</td>
      </tr>
    </table>
  </div>

  {{!-- ══ AMOUNT IN WORDS ══ --}}
  <div class="words">
    <span class="w-lbl">Total In Words:</span>
    <span class="w-val">{{bcamountinwords}}</span>
  </div>

  {{!-- ══ NOTES ══ --}}
  <div class="notes">
    <div class="n-title">Notes:</div>
    <div class="n-body">
      {{#if invterms}}{{invterms}}<br>{{/if}}
      Thanks for your business.
    </div>
  </div>

</div>
</body>
</html>
