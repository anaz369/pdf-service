<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
  <meta charset="UTF-8"/>
  <title>Tax Invoice - </title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: Arial, sans-serif; font-size: 11px; color: #000; background: #fff; }
    .page { width: 780px; margin: 0 auto; padding: 10px 14px; }

    {{#if WatermarkCss}}
    .page::before {
      content: '';
      position: fixed; top: 0; left: 0; width: 100%; height: 100%;
      background: url('{{WatermarkCss}}') center center no-repeat;
      background-size: contain; opacity: 0.15; z-index: -1; pointer-events: none;
    }
    {{/if}}

    .ar { direction: rtl; font-family: 'Traditional Arabic', 'Simplified Arabic', Arial, sans-serif; }

    /* ══ TITLE BAR ══ */
    .title-bar {
      text-align: center;
      padding: 6px 0 2px 0;
    }
    .title-bar .en { font-size: 18px; font-weight: bold; letter-spacing: 1px; }
    .title-bar .ar-title { font-size: 16px; font-weight: bold; direction: rtl; font-family: 'Traditional Arabic', 'Simplified Arabic', Arial, sans-serif; }

    /* ══ INVOICE INFO BAR ══ */
    .inv-info-bar {
      display: flex; justify-content: space-between; align-items: center;
      padding: 3px 0; margin-bottom: 2px; font-size: 10px;
    }
    .inv-info-bar .inv-left { text-align: left; }
    .inv-info-bar .inv-right { text-align: right; }

    /* ══ CUSTOMER TABLE ══ */
    .section-title td {
      font-size: 10px;
      border: 0.5px solid #262525;
      background: #eee9e9;
      font-weight: bold;
      padding: 2px 4px;
    }

    .cust-table {
      width: 100%; border-collapse: collapse; margin-bottom: 4px;
    }
    .cust-table td {
      border: 0.5px solid #262525; padding: 1px 2px; font-size: 10px; vertical-align: middle;
    }
    .cust-table .lbl { width: 10%; font-weight: bold; background: #eee9e9;padding-left:4px; }
    .cust-table .val { padding-left:4px;}
    .cust-table .lbl-mid { width: 10%; font-weight: bold; background: #eee9e9; text-align: left;padding-left:5px;  }
    .ar-val-text{
      font-family: 'Traditional Arabic', 'Simplified Arabic', Arial, sans-serif; padding-left:6px;
    }
    .cust-table .ar-val { width: 8%;direction: rtl; text-align: right;padding-right:4px; font-family: 'Traditional Arabic', 'Simplified Arabic', Arial, sans-serif; }
    .cust-table .ar-lbl { width: 9%; direction: rtl; text-align: right;padding-right:4px;  font-weight: bold; background: #eee9e9; font-family: 'Traditional Arabic', 'Simplified Arabic', Arial, sans-serif; }

    /* ══ DATES BAR ══ */
    .dates-table {
      width: 100%; border-collapse: separate; border-spacing: 0;
      margin-bottom: 4px;  overflow: hidden;
      border: 0.5px solid #262525;
    }
    .dates-table th {
      border: 0.5px solid #262525; padding: 2px 2px; font-size: 11px;
      text-align: center; background: #eee9e9; vertical-align: middle;
    }
    .dates-table th .ar-sub { display: block; direction: rtl; font-family: 'Traditional Arabic', 'Simplified Arabic', Arial, sans-serif; font-size: 11px; color: #000; }
    .dates-table td {
      border: 0.5px solid #262525; padding: 2px 2px; font-size: 10px;
      text-align: center; vertical-align: middle;
    }

    /* ══ ITEMS TABLE ══ */
    .items-table {
      width: 100%; border-collapse: collapse; margin-bottom: 4px;
    }
    .items-table th {
      border: 0.5px solid #262525; padding: 2px 3px; font-size: 11px;
      font-weight: bold; text-align: center; vertical-align: middle;
      background: #eee9e9;
    }
    .items-table th .ar-sub { display: block; direction: rtl; font-family: 'Traditional Arabic', 'Simplified Arabic', Arial, sans-serif; font-size: 11px; color: #000; font-weight: normal; }
    .items-table td {
      border: 0.5px solid #262525; padding: 2px 4px; font-size: 10px;
      text-align: center; vertical-align: middle;
    }
    .items-table td.td-desc { text-align: left; padding-left: 6px; }
    .items-table .col-amt { text-align: right; padding-right: 4px; }

    /* ══ SUMMARY TABLE ══ */
    .summary-table {
      width: 100%; border-collapse: separate; border-spacing: 0;
      margin-bottom: 4px;  overflow: hidden;
      border: 0.5px solid #262525;
    }
    .summary-table th {
      border: 0.5px solid #262525; padding: 2px 2px; font-size: 11px;
      text-align: center; background: #eee9e9; vertical-align: middle;
    }
    .summary-table th .ar-sub { display: block; direction: rtl; font-family: 'Traditional Arabic', 'Simplified Arabic', Arial, sans-serif; font-size: 11px; color: #000; font-weight: normal; }
    .summary-table td {
      border: 0.5px solid #262525; padding: 2px 2px; font-size: 10px;
      text-align: center; vertical-align: middle;
      {{!-- font-family: 'Courier New', monospace; --}}
    }

    /* ══ AMOUNT IN WORDS ══ */
    .words-bar {
      text-align: center; font-size: 10px; font-weight: bold;
      padding: 3px 4px; margin-bottom: 3px;
      border: 0.5px solid #262525; 
    }

    /* ══ BOTTOM SECTION ══ */
    .bottom-table {
      width: 100%; border-collapse: collapse;
    }
    .bottom-table > tbody > tr > td {
      vertical-align: top; border: 0.5px solid #262525;
    }
    .td-bank { padding: 0; }
    .td-sign-qr { padding: 0; }

    /* Bank Details */
    .bank-header {
      text-align: center; font-weight: bold; font-size: 9px;
      padding: 2px 4px; background: #eee9e9;
      border-bottom: 0.5px solid #262525;
      text-decoration: underline;
    }
    .bank-inner { width: 100%; border-collapse: collapse; }
    .bank-inner td {
      border: 1px solid #ccc; padding: 2px 3px; font-size: 9px;
      vertical-align: middle; border-left: none; border-right: 1px solid #ccc;
    }
    .bank-inner td:first-child { width: 38%; font-weight: bold; font-size: 9px; }
    .bank-inner td:last-child { }
    .bottom-header {
      background: #eee9e9; text-align: center; font-weight: bold;
      font-size: 9px; padding: 2px 3px; border: 0.5px solid #262525;
    }
    .bottom-header .ar {
      display: block; direction: rtl;
      font-family: 'Traditional Arabic', 'Simplified Arabic', Arial, sans-serif;
      font-size: 9px;
    }
    .bank-lbl {
      font-weight: bold; font-size: 8px; padding: 2px 4px;
      border: 0.5px solid #262525; white-space: nowrap;
    }
    .bank-val {
      font-size: 9px; padding: 2px 4px;
      border: 0.5px solid #262525;
    }

    /* Signatures + QR */
    .sign-qr-wrap { display: flex; height: 100%; }
    .sign-col {
      flex: 1; text-align: center; padding: 6px 8px;
      border-right: 0.5px solid #262525;
      display: flex; flex-direction: column; justify-content: space-between;
    }
    .sign-col:last-of-type { border-right: none; }
    .sign-title { font-weight: bold; font-size: 9px; margin-bottom: 4px; }
    .sign-title .ar-sub { display: block; direction: rtl; font-family: 'Traditional Arabic', 'Simplified Arabic', Arial, sans-serif; font-size: 9px; color: #444; }
    .sign-bottom { font-size: 8px; color: #555; margin-top: auto; padding: 4px 2px; }
    .sign-bottom .ar-sub { display: block; direction: rtl; font-family: 'Traditional Arabic', 'Simplified Arabic', Arial, sans-serif; }
    .qr-col {
      width: 140px; text-align: center; padding: 6px;
      display: flex; align-items: center; justify-content: center;
    }
    .qr-col img { width: 100px; height: 100px; }
    .seal-img { max-height: 45px; margin: 4px auto; display: block; }
    .sig-img { max-height: 45px; margin: 4px auto; display: block; }

    /* Sign Table */
.sign-table {
  width: 100%;
  border-collapse: collapse;
  height: 100%;
}

.sign-table td {
  border-left: 0.5px solid #262525;
  vertical-align: top;
  text-align: center;
  padding: 0;
}

.sign-table td:first-child {
  border-left: none;
}

.sign-cell {
  width: 35%;
}

.qr-cell {
  width: 120px;
  padding: 0;
}

.qr-wrapper {
  height: 100%;
  display: table;
  width: 100%;
}

.qr-inner {
  text-align: center;
}

.qr-inner img {
  width: 90px;
  height: 90px;
  margin: 0 auto;
  display: block;
}
/* Titles */
.sign-title {
  font-weight: bold;
  font-size: 9px;
}

.sign-title .ar {
  display: block;
  direction: rtl;
  font-size: 9px;
}

/* Bottom text */
.sign-bottom {
  font-size: 8px;
  margin-top: auto;
  padding: 4px 2px;
}

.sign-bottom .ar {
  display: block;
  direction: rtl;
}

/* Images */
.seal-img,
.sig-img {
  max-height: 45px;
  margin: 8px auto;
  display: block;
  
}
.sign-header {
  background: #eee9e9;
  font-weight: bold;
  font-size: 9px;
  text-align: center;
  padding: 4px 6px;
  border-bottom: 0.5px solid #262525;
}

.sign-header .ar {
  display: block;
  direction: rtl;
  font-size: 9px;
}/* remove inner spacing */
.no-padding {
  padding: 0 !important;
}

/* FULL WIDTH HEADER (same as bank header) */
.sign-header-full {
  background: #eee9e9;
  text-align: center;
  font-weight: bold;
  font-size: 9px;
  padding: 2px 3px;
  border-bottom: 0.5px solid #262525;
}

/* Arabic text */
.sign-header-full .ar {
  display: block;
  direction: rtl;
  font-family: 'Traditional Arabic', 'Simplified Arabic', Arial, sans-serif;
  font-size: 9px;
}

/* content spacing */
.sign-cell {
  text-align: center;
  vertical-align: top;
  height: 100%;
  position: relative;
}
.sign-cell-content {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 100%;
  min-height: 100px;
}

/* bottom text (uses .sign-bottom defined above) */



  </style>
</head>
<body>
<div class="page">

  {{!-- ══ TITLE BAR ══ --}}
  <div class="title-bar">
    <div class="en">TAX INVOICE / <span class="ar-title">فاتورة ضريبية</span></div>
  </div>
<hr>
  {{!-- ══ INVOICE NO + VAT BAR ══ --}}
  <div class="inv-info-bar">
    <div class="inv-left" style="font-weight:bold;">
      <b>Invoice No /</b> <span class="ar">رقم الفاتورة</span>
      &nbsp;&nbsp;: {{basicdetails.[0].inv_no}}
    </div>
    <div class="inv-right" style="font-weight:bold;">
      &nbsp;&nbsp; {{#if branch.[0].vat}}{{branch.[0].vat}}{{/if}}
        : <b>VAT Number </b><span class="ar"> / الرقم الضريبي</span>
      
    </div>
  </div>

  {{!-- ══ CUSTOMER DETAILS ══ --}}
  <table class="cust-table">
    <tr class="section-title">
      <td colspan="8">To / <span class="ar">إلى التفاصيل</span></td>
    </tr>
    <tr>
      <td class="lbl" style="width: 11%;">Name</td>
      <td class="val" colspan="3" style="width: 39%;font-weight:bold;">{{billing_address.[0].name}}</td>
      <td class="ar-val" colspan="3" style="width: 42%;font-weight:bold;">{{#if billing_address_lang2.[0].name}}{{billing_address_lang2.[0].name}}{{/if}}</td>
      <td class="ar-lbl" style="width: 8%;">الاسم</td>
    </tr>
    {{#ifFlag datasettings 'd526'}}
  {{!-- d526 = "1" → shows Customer Code column --}}
  <tr>
    <td class="lbl" style="width: 11%;">Street Name</td>
    <td class="val" style="width: 16%;">{{billing_address.[0].address_line2}}</td>
    <td class="lbl-mid" style="width: 8%;">Customer Code</td>
    <td class="ar-val-text" style="text-align:left; width: 14%;">{{customer_details.[0].profile_code}}</td>
    <td class="ar-val" colspan="3" style="width: 42%;">{{billing_address_lang2.[0].address_line2}}</td>
    <td class="ar-lbl" style="width: 8%;">اسم الشارع</td>
  </tr>
{{else}}
  {{!-- d526 = "0" → no Customer Code column --}}
  <tr>
    <td class="lbl" style="width: 11%;">Street Name</td>
    <td class="val" colspan="3" style="width: 39%;">{{billing_address.[0].address_line2}}</td>
    <td class="ar-val" colspan="3" style="width: 42%;">{{billing_address_lang2.[0].address_line2}}</td>
    <td class="ar-lbl" style="width: 8%;">اسم الشارع</td>
  </tr>
{{/ifFlag}}
    <tr>
      <td class="lbl" style="width: 11%;">Building No</td>
      <td class="val" style="width: 16%;">{{#if billing_address.[0].address_line1}}{{billing_address.[0].address_line1}}{{/if}}</td>
      <td class="lbl-mid" style="width: 8%;">City</td>
      <td class="ar-val-text" style="width: 14%;">{{#if billing_address.[0].address_line4}}{{billing_address.[0].address_line4}}{{/if}}</td>
      <td class="ar-val" style="width: 14%;">{{#if billing_address_lang2.[0].address_line4}}{{billing_address_lang2.[0].address_line4}}{{/if}}</td>
      <td class="ar-lbl" style="width: 11%;">مدينة</td>
      <td class="ar-val" style="width: 16%;">{{#if billing_address_lang2.[0].address_line1}}{{billing_address_lang2.[0].address_line1}}{{/if}}</td>
      <td class="ar-lbl" style="width: 8%;"> رقم المبنى</td>
    </tr>
    <tr>
      <td class="lbl" style="width: 11%;">Addl. No</td>
      <td class="val" style="width: 16%;">{{#if customer_details.[0].additional_no}}{{customer_details.[0].additional_no}}{{/if}}</td>
      <td class="lbl-mid" style="width: 8%;">District</td>
      <td class="ar-val-text" style="width: 14%;">{{#if billing_address.[0].address_line3}}{{billing_address.[0].address_line3}}{{/if}}</td>
      <td class="ar-val" style="width: 14%;">{{#if billing_address_lang2.[0].address_line3}}{{billing_address_lang2.[0].address_line3}}{{/if}}</td>
      <td class="ar-lbl" style="width: 11%;">الحي</td>
      <td class="ar-val" style="width: 16%;">{{#if customer_details.[0].additional_no_lang2}}{{customer_details.[0].additional_no_lang2}}{{/if}}</td>
      <td class="ar-lbl" style="width: 8%;">رقم إضافي</td>
    </tr>
    <tr>
      <td class="lbl" style="width: 11%;">Postal Code</td>
      <td class="val" style="width: 16%;">{{#if billing_address.[0].address_code}}{{billing_address.[0].address_code}}{{/if}}</td>
      <td class="lbl-mid" style="width: 8%;">Country</td>
      <td class="ar-val-text" style="width: 14%;">{{#if billing_address.[0].address_line5}}{{billing_address.[0].address_line5}}{{/if}}</td>
      <td class="ar-val" style="width: 14%;">{{#if billing_address_lang2.[0].address_line5}}{{billing_address_lang2.[0].address_line5}}{{/if}}</td>
      <td class="ar-lbl" style="width: 11%;">الدولة</td>
      <td class="ar-val" style="width: 16%;">{{#if billing_address.[0].address_code}}{{billing_address.[0].address_code}}{{/if}}</td>
      <td class="ar-lbl" style="width: 8%;">رمز بريدي</td>
    </tr>
    <tr>
      <td class="lbl" style="width: 11%;">VAT Number</td>
      <td class="val" style="width: 16%;">{{#if billing_address.[0].vat}}{{billing_address.[0].vat}}{{/if}}</td>
      <td class="lbl-mid" style="width: 8%;">CRN</td>
      <td class="ar-val-text" style="width: 14%;">{{#if customer_details.[0].cr_no}}{{customer_details.[0].cr_no}}{{/if}}</td>
      <td class="ar-val" style="width: 14%;">{{#if customer_details.[0].cr_no_lang2}}{{customer_details.[0].cr_no_lang2}}{{/if}}</td>
      <td class="ar-lbl" style="width: 11%;">السجل التجاري</td>
      <td class="ar-val" style="width: 16%;">{{#if billing_address_lang2.[0].vat}}{{billing_address_lang2.[0].vat}}{{/if}}</td>
      <td class="ar-lbl" style="width: 8%;">الرقم الضريبي</td>
    </tr>
  </table>

  {{!-- ══ DATES ROW ══ --}}
  <table class="dates-table">
    <thead>
      <tr>
        <th><span class="ar-sub" style="font-weight:bold;">تاريخ الفاتورة</span>Invoice Date</th>
        <th><span class="ar-sub" style="font-weight:bold;">تاريخ العرض</span>Supply Date</th>
        <th><span class="ar-sub" style="font-weight:bold;">رقم طلب الشراء</span>Contract/PO No</th>
        <th><span class="ar-sub" style="font-weight:bold;">تاريخ الاستحقاق</span>Due Date</th>
        <th><span class="ar-sub" style="font-weight:bold;">فترة الفاتورة</span>Invoice Period</th>
        <th><span class="ar-sub" style="font-weight:bold;">رقم المرجع</span>Project / Reference No</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>{{basicdetails.[0].inv_date}}</td>
        <td>{{#if basicdetails.[0].sup_date}}{{basicdetails.[0].sup_date}}{{/if}}</td>
        <td>{{#if basicdetails.[0].order_no}}{{basicdetails.[0].order_no}}{{/if}}</td>
        <td>{{#if basicdetails.[0].due_date}}{{basicdetails.[0].due_date}}{{/if}}</td>
        <td>{{basicdetails.[0].inv_from}} - {{basicdetails.[0].inv_to}}</td>
        <td>{{#if basicdetails.[0].reference_no}}{{basicdetails.[0].reference_no}}{{/if}}</td>
      </tr>
    </tbody>
  </table>

  {{!-- ══ ITEMS TABLE ══ --}}
  <table class="items-table">
    <thead>
      <tr>
        <th style="width:4%;font-weight:bold;">#<span class="ar-sub">م</span></th>
        <th style="width:32%;font-weight:bold;">Description<span class="ar-sub">الوصف</span></th>
        <th style="width:8%;font-weight:bold;">Unit<span class="ar-sub">وحدة</span></th>
        <th style="width:8%;font-weight:bold;">QTY<span class="ar-sub">الكمية</span></th>
        <th style="width:10%;font-weight:bold;">Price<span class="ar-sub">السعر</span></th>
        <th style="width:12%;font-weight:bold;">Amount<span class="ar-sub">المبلغ</span></th>
        <th style="width:12%;font-weight:bold;">VAT {{basicdetails.[0].vat_perc}}%<span class="ar-sub">الضريبة</span></th>
        <th style="width:14%;font-weight:bold;">Amount With Tax<span class="ar-sub">المبلغ مع الضريبة</span></th>
      </tr>
    </thead>
    <tbody>
      {{#each itemdetails}}
      <tr>
        <td>{{addOne @index}}</td>
        <td class="td-desc">
          <div>{{item_name}}</div>
          {{#if name_lang2}}
          <div style="direction:rtl; font-size:px; color:#555;">{{name_lang2}}</div>
          {{/if}}
          {{#if description}}
          <div style="font-size:px; color:#777;">{{description}}</div>
          {{/if}}
        </td>
        <td>{{#if unit}}{{unit}}{{/if}}</td>
        <td>{{formatAmount quantity}}</td>
        <td class="col-amt">{{formatAmount price ../bcdp}}</td>
        <td class="col-amt">{{formatAmount (multiply price quantity) ../bcdp}}</td>
        <td class="col-amt">{{formatAmount vat_amt ../bcdp}}</td>
        <td class="col-amt">{{formatAmount amount ../bcdp}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>

  {{!-- ══ SUMMARY ══ --}}
  <table class="summary-table">
    <thead>
      <tr>
        <th><span class="ar-sub" style="font-weight: bold;">المجموع</span>Sub Total</th>
        <th><span class="ar-sub" style="font-weight: bold;">نسبة ضريبة القيمة المضافة</span>{{datasettingstextvalue.d828}}</th>
        <th><span class="ar-sub" style="font-weight: bold;">تخفيض</span>Discount</th>
        <th><span class="ar-sub" style="font-weight: bold;">المجموع</span>Total</th>
        <th><span class="ar-sub" style="font-weight: bold;">المجموع</span>Payment Made</th>
        <th><span class="ar-sub" style="font-weight: bold;">الرصيد المستحق</span>Balance Due</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>{{formatAmount (divide basicdetails.[0].subtotal ccrate) bcdp}}</td>
        <td>{{formatAmount (divide basicdetails.[0].vatamt ccrate) bcdp}}</td>
        <td>{{formatAmount (divide basicdetails.[0].discount ccrate) bcdp}}</td>
        <td>{{formatAmount (divide basicdetails.[0].grand_total ccrate) bcdp}}</td>
        <td>{{formatAmount (divide basicdetails.[0].received ccrate) bcdp}}</td>
        <td>{{formatAmount (divide basicdetails.[0].balance ccrate) bcdp}}</td>
      </tr>
    </tbody>
  </table>

  {{!-- ══ AMOUNT IN WORDS ══ --}}
  {{#if bcamountinwords}}
  <div class="words-bar" style="background: #eee9e9;">
    Total In Words : {{bcamountinwords}}
  </div>
  {{/if}}

  {{!-- ══ BOTTOM: BANK + SIGNATURES + QR ══ --}}
  <table class="bottom-table">
    <colgroup>
      <col style="width:20%;">
      <col style="width:28%;">
      <col style="width:18%;">
      <col style="width:18%;">
      <col style="width:16%;">
    </colgroup>
    {{!-- Header row --}}
    <tr>
      <td colspan="2" class="bottom-header">Bank Details <span class="ar">التفاصيل المصرفية</span></td>
      <td class="bottom-header">Prepared By<br><span class="ar">أعدت بواسطة</span></td>
      <td class="bottom-header">Received By<br><span class="ar">استلمت من قبل</span></td>
      {{!-- <td class="bottom-header">QR Code<br><span class="ar">رمز الاستجابة</span></td> --}}
      <td rowspan="6" style="vertical-align:middle; text-align:center; border:0.5px solid #262525;">
        <div class="qr-inner">
          {{{qrDataUri qrCodeBase64}}}
        </div>
      </td>
    </tr>
    {{!-- Account Name --}}
    <tr>
      <td class="bank-lbl">Account Name / <span class="ar">إسم الحساب</span></td>
      <td class="bank-val">{{bankdetails.acc_name}}</td>
      <td rowspan="4" style="vertical-align:middle; text-align:center;  border-left:0.5px solid #262525;border-right:0.5px solid #262525;border-top:0.5px solid #262525;border-bottom:none;">
        {{#if Signature}}
          <img src="{{Signature}}" style="max-height:{{default datasettings.d459 '40'}}px; max-width:{{default datasettings.d459 '60'}}px;" onerror="this.style.display='none'"/>
        {{/if}}
      </td>
      <td rowspan="4" style="vertical-align:middle; text-align:center;  border-left:0.5px solid #262525;border-right:0.5px solid #262525;border-top:0.5px solid #262525;border-bottom:none;">
      </td>
    </tr>
    {{!-- Bank Name --}}
    <tr>
      <td class="bank-lbl">Bank Name / <span class="ar">إسم البنك</span></td>
      <td class="bank-val">{{bankdetails.name}}</td>
    </tr>
    {{!-- Account Number --}}
    <tr>
      <td class="bank-lbl">Account Number / <span class="ar">رقم حساب</span></td>
      <td class="bank-val">{{bankdetails.acc_no}}</td>
    </tr>
    {{!-- IBAN --}}
    <tr>
      <td class="bank-lbl">IBAN No / <span class="ar">رقم الآيبان</span></td>
      <td class="bank-val">{{bankdetails.iban_no}}</td>
    </tr>
    {{!-- Branch Name --}}
    <tr>
      <td class="bank-lbl">Branch Name / <span class="ar">إسم الفرع</span></td>
      <td class="bank-val">{{bankdetails.branch_name}}</td>
      <td style="text-align:center; font-size:8px; padding:2px; border-left:0.5px solid #262525;border-right:0.5px solid #262525;border-bottom:0.5px solid #262525;border-top:none;">
        Signature with stamp<br><span class="ar">التوقيع مع الختم</span>
      </td>
      <td style="text-align:center; font-size:8px; padding:2px; border-left:0.5px solid #262525;border-right:0.5px solid #262525;border-bottom:0.5px solid #262525;border-top:none;">
        Signature with stamp<br><span class="ar">التوقيع مع الختم</span>
      </td>
    </tr>
  </table>

</div>
</body>
</html>
