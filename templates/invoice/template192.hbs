    width: 2px;
}
.vat{
    vertical-align: top;
}
    .qr-wrapper img {
      width: 85px;
      height: 85px;
      display: block;
    }
</style>
<body>
    <div class="section">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <h5 class="text-center mb-2 mt-2"><b> TAX INVOICE </b></h5>
                    
                </div>
                <div class="col-lg-10 col-md-10 col-sm-10 pr-0">
                    <table class="myy_table mt-1 myy_table2">
                        <tr>
                            <th><b> Invoice No</b></th>
                            <th><b>Invoice Date</b></th>
                            <th><b>PO Number</b></th>
                            <th><b>Payment Terms</b></th>
                            <th><b>Place of Supply</b></th>
                        </tr>

                        <tr>
                            <td>{{basicdetails.[0].inv_no}}</td>
                            <td>{{basicdetails.[0].inv_date}}</td>
                            <td>{{basicdetails.[0].order_no}}</td>
                            <td>{{basicdetails.[0].payment_terms}}</td>
                            <td>{{basicdetails.[0].place_of_supply}}</td>
                        </tr>
                    </table>
                    <table class="myy_table mt-1">
                        <tr>
                            <td><b>Seller Details :-</b></td>
                        </tr>

                        <tr>
                            <td>{{branch.[0].name}}</td>
                        </tr>

                        <tr>
                            <td>{{joinAddress branch.[0] '، '}}</td>
                        </tr>

                        <tr>
                            <td>GST : {{branch.[0].vat}}</td>
                        </tr>
                    </table>
                </div>
                <div class="col-lg-2 col-md-2 col-sm-2 text-center">
                       {{{qrDataUri qrCodeBase64}}}
                </div>
                <div class="col-lg-6 col-md-6 col-sm-6 pr-0">
                    <table class="myy_table mt-1">
                        <tr>
                            <td><b>Billed To :-</b></td>
                        </tr>

                        <tr>
                            <td>{{billing_address.[0].name}}</td>
                        </tr>

                        <tr>
                            <td>
                                {{joinAddress billing_address.[0] '، '}}
                            </td>
                        </tr>

                        <tr>
                            <td>GST : {{billing_address.[0].vat}}</td>
                        </tr>
                    </table>
                </div>
                <div class="col-lg-6 col-md-6 col-sm-6">
                    <table class="myy_table mt-1">
                        <tr>
                            <td><b>Shipped To :-</b></td>
                        </tr>

                        <tr>
                            <td>{{shipping_address.[0].name}}</td>
                        </tr>

                        <tr>
                            <td>
                                {{joinAddress shipping_address.[0] '، '}}
                            </td>
                        </tr>

                        <tr>
                            <td>GST : {{shipping_address.[0].vat}}</td>
                        </tr>
                    </table>
                </div>
                
                <div class="col-lg-12">
                    <table class="mt-1 myy_table myy_table2">
                        <tr>
    <th class="text-center bold">Sl<br></th>
    <th class="text-center">HSN</th>
    <th class="text-center">Description</th>
    <th class="text-center">Qty</th>
    <th class="text-center">UOM</th>
    <th class="text-center">Unit Price</th>
    <th class="text-center">Discount</th>
    <th class="text-center">Taxable</th>
    <th class="text-center">CGST</th>
    <th class="text-center">SGST</th>
    <th class="text-center">Total</th>
</tr>

{{#each itemdetails}}
<tr>
    <td class="text-center">{{addOne @index}}</td>

    <td class="text-start">{{hsn}}</td>

    <td class="text-start">
        {{item_name}}
        {{#if name_lang2}}<br>{{name_lang2}}{{/if}}
    </td>

    <td class="text-center">{{quantity}}</td>

    <td class="text-center">{{unit}}</td>

    <td class="text-end">{{formatAmount price ../bcdp}}</td>

    <td class="text-end">
        {{formatAmount discount ../bcdp}}<br>
        {{discount_perc}} %
    </td>

    <td class="text-end">{{formatAmount taxable ../bcdp}}</td>

    <td class="text-end">
        {{formatAmount cgst ../bcdp}}<br>
        {{cgst_perc}} %
    </td>

    <td class="text-end">
        {{formatAmount sgst ../bcdp}}<br>
        {{sgst_perc}} %
    </td>

    <td class="text-end">
        {{formatAmount total ../bcdp}}
    </td>
</tr>
{{/each}}
                        
                    </table>
                </div>
                <div class="col-lg-6 col-md-6 col-sm-6 pr-0">
                    <table class="mt-1 myy_table myy_table2 text-center">
                        <tr>
                            <th colspan="5" class="text-center"> Tax Summary</th>
                        </tr>
                        <tr>
                            <td>Taxable</td>
                            <td>CGST</td>
                            <td>Amount</td>
                            <td>SGST</td>
                            <td>Amount</td>
                        </tr>
                        <tr>
                            <td>7,860.00</td>
                            <td>0</td>
                            <td>0.00</td>
                            <td>0</td>
                            <td>0.00</td>
                        </tr>
                    </table>
                </div>
                <div class="col-lg-6 col-md-6 col-sm-6">
                    <table class="mt-1 myy_table myy_table2">

    <tr>
        <th>Total</th>
        <td class="text-end">
            {{basicdetails.[0].isocode}} 
            {{formatAmount basicdetails.[0].subtotal bcdp}}
        </td>
    </tr>

    <tr>
        <th>Discount</th>
        <td class="text-end">
            {{basicdetails.[0].isocode}} 
            {{formatAmount basicdetails.[0].discount bcdp}}
        </td>
    </tr>

    <tr>
        <th>Total After Discount</th>
        <td class="text-end">
            {{basicdetails.[0].isocode}} 
            {{formatAmount (subtract basicdetails.[0].subtotal basicdetails.[0].discount) bcdp}}
        </td>
    </tr>

    <tr>
        <th>CGST Amount</th>
        <td class="text-end">
            {{basicdetails.[0].isocode}} 
            {{formatAmount basicdetails.[0].cgst_total bcdp}}
        </td>
    </tr>

    <tr>
        <th>SGST Amount</th>
        <td class="text-end">
            {{basicdetails.[0].isocode}} 
            {{formatAmount basicdetails.[0].sgst_total bcdp}}
        </td>
    </tr>

    <tr>
        <th>Round Off</th>
        <td class="text-end">
            {{basicdetails.[0].isocode}} 
            {{formatAmount basicdetails.[0].round_off bcdp}}
        </td>
    </tr>

    <tr>
        <th>Grand Amount</th>
        <td class="text-end">
            {{basicdetails.[0].isocode}} 
            {{formatAmount basicdetails.[0].grand_total bcdp}}
        </td>
    </tr>

    <tr>
        <td colspan="2">
            <b>Amount In Words:</b> {{bcamountinwords}}
        </td>
    </tr>

</table>
                </div>
                <div class="col-lg-12 mt-0">
                    <table class="mt-0 myy_table myy_table2">
                        <tr>
                            <td><b>Amount In Words:</b> {{bcamountinwords}}</td>
                        </tr>
                    </table>
                </div>
                <div class="col-lg-12 mt-1">
                    <table class="myy_table myy_table2">
                        <tr>
                            <td colspan="4">Cheque should be crossed and made payable to: HANNA COMPANY</td>
                        </tr>
                        <tr>
    <th colspan="4" class="text-center">BANK DETAILS</th>
</tr>

<tr>
    <td>Beneficiary A/C Name</td>
    <td>{{bankdetails.acc_name}}</td>
    <td>Beneficiary Bank</td>
    <td>{{bankdetails.name}}</td>
</tr>

<tr>
    <td>Beneficiary Bank Branch</td>
    <td>{{bankdetails.branch_name}}</td>
    <td>Beneficiary A/C No</td>
    <td>{{bankdetails.acc_no}}</td>
</tr>

<tr>
    <td>Swift Code</td>
    <td>{{bankdetails.swift_no}}</td>
    <td>IFSC CODE</td>
    <td>{{bankdetails.iban_no}}</td>
</tr>
                    </table>
                </div>
                <div class="col-lg-12 mt-1">
    <table class="myy_table myy_table2">
        <tr>
            <td>
                <b>Terms And Conditions</b><br><br>
                
                {{basicdetails.[0].terms_and_condition}}
            </td>
        </tr>
    </table>
</div>
                
                
            </div> 
        </div>
    </div>
</body>
</html>