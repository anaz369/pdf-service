<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<title>Invoice - {{basicdetails.[0].inv_no}}</title>
<style>
body{font-family:Arial,sans-serif;font-size:9px;color:#333;margin:10px}
table{width:100%;border-collapse:collapse}
td,th{border:1px solid #333;padding:4px;vertical-align:top}
.title{font-size:18px;font-weight:bold;text-align:center;border:none}
.center{text-align:center}.right{text-align:right}
.head{font-weight:bold}
.sign{margin-top:6px;border:1px solid #000;border-collapse:collapse;width:100%;table-layout:fixed}
.sign td{border:1px solid #000;padding:3px 8px;text-align:center;vertical-align:middle;font-size:10px}
.sign tr.head td{font-weight:bold;padding:3px 8px;vertical-align:top}
.sign tr.head .sg-ar{direction:rtl;font-weight:normal;color:#222;font-size:10px;}
.sign tr.body td{height:110px;vertical-align:middle}
.sign tr.body .sg-img{max-height:90px;max-width:130px;display:inline-block}
.sign tr.notice td{background:#ffffff;text-align:center;font-size:10px;padding:4px 8px;height:auto}
.qr-tot{width:100%;border-collapse:collapse;border:none;margin-top:4px;margin-bottom:5px;}
.qr-tot > tbody > tr > td{border:none;padding:0;vertical-align:top}
.qr-tot .qr-cell{width:25%;text-align:center;padding:6px;border:none}
.qr-tot .qr-cell img{max-width:120px;max-height:120px;border:none;display:inline-block}
.qr-tot .tot-cell{width:75%;padding:0;border:none}
.qr-tot .tot-inner{width:100%;border-collapse:collapse}
.qr-tot .tot-inner td{border:1px solid #333;padding:3px 8px;font-size:10px;vertical-align:middle}
.qr-tot .tot-inner .ar-col{direction:rtl;text-align:right}
.qr-tot .tot-inner .right{text-align:right}
.hdr-info, .addr-info{margin-top:4px}
.hdr-info td, .addr-info td{padding:3px 6px;font-size:10px;vertical-align:top}
.three-wrap{
    display:flex;
    width:100%;
    gap:6px;
    margin-top:4px;
}

.left-box{
    width:38%;
}

.right-box{
    width:62%;
    display:flex;
    flex-direction:column;
    gap:6px;
}

.inner-tbl{
    width:100%;
    border-collapse:collapse;
    table-layout:fixed;
}

.inner-tbl td{
    border:1px solid #000;
    padding:3px 6px;
    font-size:9px;
    vertical-align:top;
}

.hdr-lbl{
    font-weight:bold;
}

.hdr-ar{
    text-align:center;
    font-size:8px;
    color:#555;
}
</style>
</head>
<body>

<table><tr><td class="title">TAX INVOICE / فاتورة ضريبية</td></tr></table>

<div class="three-wrap">

    <!-- TABLE 1 : TO + ADDRESS -->
    <div class="left-box">

        <table class="inner-tbl">

            <tr>
                <td class="hdr-lbl" style="width:25%;">
                    <div>To</div>
                    <div class="hdr-ar" style="text-align: left;">الى</div>
                </td>

                <td>
                    {{billing_address.[0].name}}

                    {{#if billing_address_lang2.[0].name}}
                    <div class="hdr-ar" style="text-align: left;">
                        {{billing_address_lang2.[0].name}}
                    </div>
                    {{/if}}
                </td>
            </tr>

            <tr>
                <td class="hdr-lbl">
                    <div>Address</div>
                    <div class="hdr-ar" style="text-align: left;">العنوان</div>
                </td>

                <td>

                    {{billing_address.[0].address_line1}}
                    {{billing_address.[0].address_line2}}
                    {{billing_address.[0].address_line3}}

                    <div>
                        {{billing_address.[0].address_line4}}
                        {{billing_address.[0].address_line5}}
                    </div>

                    <div>
                        VAT : {{billing_address.[0].vat}}
                    </div>

                    {{#if billing_address_lang2.[0].address_line1}}
                    <div class="hdr-ar" style="text-align: left;">
                        {{billing_address_lang2.[0].address_line1}}
                        {{billing_address_lang2.[0].address_line2}}
                        {{billing_address_lang2.[0].address_line3}}
                        {{billing_address_lang2.[0].address_line4}}
                        {{billing_address_lang2.[0].address_line5}}
                    </div>
                    {{/if}}
                </td>
            </tr>

        </table>

    </div>

    <!-- RIGHT SIDE -->
    <div class="right-box">

        <!-- TABLE 2 -->
        <table class="inner-tbl">

            <tr style="text-align: center;">

                <td class="hdr-lbl">
                    <div>Invoice No / رقم الوظيفة</div>
                </td>

                <td class="hdr-lbl">
                    <div>Invoice Date / إشارة المسلك</div>
                </td>

                <td class="hdr-lbl">
                    <div>VAT No / مرجعنا</div>
                </td>

            </tr>

            <tr style="text-align: center;">

                <td>
                    {{basicdetails.[0].inv_no}}
                </td>

                <td>
                    {{basicdetails.[0].inv_date}}
                </td>

                <td>
                    {{compprof.[0].gstin}}
                </td>

            </tr>

        </table>

        <!-- TABLE 3 -->
        <table class="inner-tbl">

            <tr style="text-align: center;">

                <td class="hdr-lbl" style="width: 50%;">
                    PO No / رقم أمر الشراء
                </td>
                <td class="hdr-lbl" style="width: 50%;">
                    DO No / رقم الوثيقة
                </td>

            </tr>

            <tr style="text-align: center;">
                <td>
                    {{basicdetails.[0].order_no}}
                </td>
                <td>
                    {{basicdetails.[0].reference_no}}
                </td>

            </tr>

        </table>

    </div>

</div>

<table style="margin-top: 5px;">
<thead>
<tr class="head">
<th style="width: 5%;">Item </br>نوع</th>
<th style="width: 40%;">Description</br>الوصف</th>
<th style="width: 7%;">Quantity</br>الكمية</th>
<th style="width: 10%;">Unit Price</br>سعر الوحدة</th>
<th style="width: 10%;">Tax Amount</br>قيمة الضريبة</th>
<th style="width: 10%;">Total Amount</br>المبلغ اإلجمالي</th>
</tr>
</thead>
<tbody>
{{#each itemdetails}}
<tr>
<td class="center">{{addOne @index}}</td>
<td>{{item_name}} {{description}}<br>{{name_lang2}}</td>
<td class="center">{{formatAmount quantity 0}}</td>
<td class="right">{{formatAmount price ../bcdp}}</td>
<td class="right">{{formatAmount vat_amt ../bcdp}}</td>
<td class="right">{{formatAmount taxable ../bcdp}}</td>
</tr>
{{/each}}
</tbody>
</table>

<table class="qr-tot">
<tr>
<td class="qr-cell">{{{qrDataUri qrCodeBase64}}}</td>
<td class="tot-cell">
<table class="tot-inner">
<tr>
    <td>Total Without VAT</td>
    <td class="ar-col">الإجمالي بدون ضريبة القيمة المضافة</td>
    <td class="right">{{formatAmount basicdetails.[0].subtotal bcdp}}</td>
</tr>
<tr>
    <td>{{datasettingstextvalue.d828}}</td>
    <td class="ar-col">إجمالي مبلغ الضريبة</td>
    <td class="right">{{formatAmount basicdetails.[0].vatamt bcdp}}</td>
</tr>
<tr>
    <td>Grand Total</td>
    <td class="ar-col">المجموع الإجمالي</td>
    <td class="right">{{formatAmount basicdetails.[0].grand_total bcdp}}</td>
</tr>
<tr>
    <td>
      <div>Total Amount In Words</div>
      <div class="ar-col">المبلغ الإجمالي بالكلمات</div>
    </td>
    <td colspan="2">
        <div>{{bcamountinwords}}</div>
        <div class="ar-col">{{bcamountinwordsar}}</div>
    </td>
</tr>
</table>
</td>
</tr>
</table>

<table>
<tr>
    <td style="text-align: center;border-bottom:none;">Cheque should be crossed and made payable to : {{branch.[0].name}}</td></tr>
</table>

<table>
<tr class="head"><th colspan="4">BANK DETAILS</th></tr>
<tr>
    <td style="width: 20%;">Beneficiary A/C Name</td>
    <td style="width: 30%;">{{bankdetails.acc_name}}</td>
    <td style="width: 20%;">Beneficiary Bank</td>
    <td style="width: 30%;">{{bankdetails.name}}</td>
</tr>
<tr>
<td>Beneficiary Bank Branch</td><td>{{bankdetails.branch_name}}</td>
<td>Beneficiary A/C No</td><td>{{bankdetails.acc_no}}</td>
</tr>
<tr>
<td>Swift Code</td><td>{{bankdetails.swift_no}}</td>
<td>IBAN No</td><td>{{bankdetails.iban_no}}</td>
</tr>
</table>

<table class="sign">
<tr class="head">
<td>
  <div>Company Stamp</div>
  <div class="sg-ar">ختم الشركة</div>
</td>
<td>
  <div>Prepared By</div>
  <div class="sg-ar">إعداد</div>
</td>
<td>
  <div>Authorized Signature</div>
  <div class="sg-ar">توقيع معتمد</div>
</td>
<td>
  <div>Received By</div>
  <div class="sg-ar">تم الاستلام بواسطة</div>
</td>
</tr>
<tr class="body">
<td>{{#if Seal}}<img class="seal-img" src="{{Seal}}" alt="Seal" style="max-height:{{default datasettings.d459 '100'}}px; max-width:{{default datasettings.d459 '180'}}px;" onerror="this.style.display='none'"/>{{/if}}</td>
<td></td>
<td>{{#if Signature}}<img class="sign-img" src="{{Signature}}" alt="Signature" style="max-height:{{default datasettings.d458 '80'}}px; max-width:{{default datasettings.d458 '180'}}px;" onerror="this.style.display='none'"/>{{/if}}</td>
<td></td>
</tr>
<tr class="notice">
<td colspan="4">******In case of any objection in this invoice, please review and reply within three days, otherwise the invoice shall stand deemed accepted.******</td>
</tr>
</table>

</body>
</html>