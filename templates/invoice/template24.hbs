<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Invoice - {{basicdetails.[0].inv_no}}</title>
<style>

*{
    margin:0;
    box-sizing:border-box;
}

body{
    font-family: Arial, Helvetica, sans-serif;
    font-size:9px;
    color:#000;
    margin:0 8mm;
}

table{
    width:100%;
    border-collapse:collapse;
}

td,th{
    padding:2px 4px;
    vertical-align:middle;
}

.title-red{
    color:#c00000;
    font-size:18px;
    font-weight:bold;
}

.section-title{
    background:#c00000;
    color:#fff;
    font-weight:bold;
    padding:3px 6px;
}

.label-ar{
    direction:rtl;
    text-align:right;
}

.center{ text-align:center; }
.right{ text-align:right; }
.bold{ font-weight:bold; }

.no-border td,
.no-border{
    border:none;
}

.items-head{
    font-weight:bold;
    text-align:center;
    border:1px solid #ccc;
}
.items-head th{
    border:1px solid #ccc;
}
.items-head td{
    border-left:1px solid #ccc;
    border-right:1px solid #ccc;
    border-top: none;
    border-bottom: none;
}
</style>
</head>
<body>

<!-- Title Bar -->

<table class="no-border" style="border:none;margin-bottom:4px;">
<tr>
<td class="no-border title-red" style="border:none;text-align:left;padding:0;">TAX INVOICE / فاتورة ضريبية</td>
</tr>
</table>


<!-- Buyer + Invoice Info + QR -->

<table style="border:none;border-collapse:collapse;width:100%;">
<tr>

<td style="border:none;padding:0;vertical-align:top;width:55%;">

<table style="width:100%;border-collapse:collapse;">

<tr>
<td colspan="3" class="section-title">
<table style="width:100%;border:none;">
<tr>
<td style="border:none;padding:0;color:#fff;">BUYER DETAILS</td>
<td style="border:none;padding:0;color:#fff;direction:rtl;text-align:right;">تفاصيل المشتري</td>
</tr>
</table>
</td>
</tr>

<tr>
<td width="25%">Name</td>
<td width="45%">{{billing_address.[0].name}}</td>
<td width="30%" class="label-ar">اسم العميل (محل الفواتير)</td>
</tr>

<tr>
<td>Building Number</td>
<td>{{billing_address.[0].address_line1}}</td>
<td class="label-ar">رقم المبنى</td>
</tr>

<tr>
<td>Street Name</td>
<td>{{billing_address.[0].address_line2}}</td>
<td class="label-ar">اسم الشارع</td>
</tr>

<tr>
<td>District</td>
<td>{{billing_address.[0].address_line3}}</td>
<td class="label-ar">الحي</td>
</tr>

<tr>
<td>City</td>
<td>{{billing_address.[0].address_line4}}</td>
<td class="label-ar">المدينة</td>
</tr>

<tr>
<td>Country</td>
<td>{{billing_address.[0].address_line5}}</td>
<td class="label-ar">البلد</td>
</tr>

<tr>
<td>Postal Code</td>
<td>{{billing_address.[0].address_code}}</td>
<td class="label-ar">الرمز البريدي</td>
</tr>

<tr>
<td>Additional NO</td>
<td>{{customer_details.[0].additional_no}}</td>
<td class="label-ar">رقم اضافي</td>
</tr>

<tr>
<td>VAT NUMBER</td>
<td>{{customer_details.[0].VAT_number}}</td>
<td class="label-ar">الرقم الضريبي</td>
</tr>

</table>

</td>

<td style="border:none;padding:0;width:2%;"></td>

<td style="border:none;padding:0;vertical-align:top;width:28%;">

<table style="width:100%;border-collapse:collapse;">

<tr>
<td width="40%">Invoice Number</td>
<td width="35%">{{basicdetails.[0].inv_no}}</td>
<td width="25%" class="label-ar">رقم الفاتورة</td>
</tr>

<tr>
<td>Invoice Date</td>
<td>{{basicdetails.[0].inv_date}}</td>
<td class="label-ar">تاريخ الفاتورة</td>
</tr>

<tr>
<td>Mode of Pay</td>
<td>{{basicdetails.[0].mode_of_pay}}</td>
<td class="label-ar">طريقة الدفع</td>
</tr>

<tr>
<td>PO Date</td>
<td>{{basicdetails.[0].po_date}}</td>
<td class="label-ar">تاريخ طلب الشراء</td>
</tr>

<tr>
<td>PO Number</td>
<td>{{basicdetails.[0].order_no}}</td>
<td class="label-ar">رقم طلب الشراء</td>
</tr>

<tr>
<td>Employee Name</td>
<td>{{basicdetails.[0].created_user}}</td>
<td class="label-ar">اسم الموظف</td>
</tr>

</table>

</td>

<td style="border:none;padding:0;width:2%;"></td>

<td style="border:none;padding:0;vertical-align:top;width:13%;text-align:center;">
<div style="border:1px solid #000;padding:4px;">
{{{qrDataUri qrCodeBase64}}}
</div>
</td>

</tr>
</table>


<!-- Items Table -->

<table style="margin-top:6px;border-collapse:collapse;width:100%;">

<thead>

<tr class="items-head">
<th width="5%">#<div>SN</div></th>
<th width="35%">Description<div class="label-ar" style="text-align: center;">الوصف</div></th>
<th width="10">QTY<div class="label-ar" style="text-align: center;">الكمية</div></th>
<th width="10">Unit<div class="label-ar" style="text-align: center;">الوحدة</div></th>
<th width="10%">U.Rate<div class="label-ar" style="text-align: center;">السعر</div></th>
<th width="10%">Amount<div class="label-ar" style="text-align: center;">المبلغ</div></th>
<th width="10%">VAT Value<div class="label-ar" style="text-align: center;">قيمة الضريبة</div></th>
<th width="10%">Total Price<div class="label-ar" style="text-align: center;">السعر الإجمالي</div></th>
</tr>

</thead>

<tbody>

{{#each itemdetails}}

<tr>
<td class="center">{{addOne @index}}</td>
<td>
{{item_name}}{{#if name_lang2}} {{name_lang2}}{{/if}}{{#if description}} {{description}}{{/if}}
</td>
<td class="center">{{quantity}}</td>
<td class="center">{{unit}}</td>
<td class="right">{{formatAmount price ../bcdp}}</td>
<td class="right">{{formatAmount taxable ../bcdp}}</td>
<td class="right">{{formatAmount tax ../bcdp}}</td>
<td class="right">{{formatAmount amount ../bcdp}}</td>
</tr>

{{/each}}

</tbody>

</table>


<!-- Footer: Prepared / Received / Bank / Totals -->

<table style="margin-top:8px;border-collapse:collapse;width:100%;page-break-inside:avoid;break-inside:avoid;">
<tr>

<td valign="top" style="width:20%;">
<div class="bold" style="padding:2px 0;">Prepared By:</div>
<div style="padding:3px 0;">Name: </div>
<div style="padding:3px 0;">Date: </div>
<div style="padding:3px 0;">Signature: </div>
</td>

<td valign="top" style="width:20%;">
<div class="bold" style="padding:2px 0;">Received By: <span class="label-ar">الاستلم</span></div>
<div style="padding:3px 0;">Name: </div>
<div style="padding:3px 0;">Date: </div>
<div style="padding:3px 0;">Signature: </div>
</td>

<td valign="top" style="width:30%;">
<div class="bold" style="padding:2px 0;">Bank Details</div>
<div style="padding:2px 0;">Bank Name: {{bankdetails.name}}</div>
<div style="padding:2px 0;">A/c Name: {{bankdetails.acc_name}}</div>
<div style="padding:2px 0;">A/c No: {{bankdetails.acc_no}}</div>
<div style="padding:2px 0;">IBAN: {{bankdetails.iban_no}}</div>
<div style="padding:2px 0;">SWIFT: {{bankdetails.swift_no}}</div>
</td>

<td valign="top" style="width:30%;padding:0;">
<table style="width:100%;border-collapse:collapse;">

<tr>
<td>Total Amount</td>
<td class="right">{{formatAmount basicdetails.[0].subtotal bcdp}}</td>
<td class="label-ar">إجمالي المبلغ</td>
</tr>

<tr>
<td>Handling commission</td>
<td class="right">{{formatAmount basicdetails.[0].dld bcdp}}</td>
<td class="label-ar">عمولة المناولة</td>
</tr>

<tr>
<td>Net Amount</td>
<td class="right">{{formatAmount (subtract basicdetails.[0].subtotal basicdetails.[0].dld) bcdp}}</td>
<td class="label-ar">صافي المبلغ</td>
</tr>

<tr>
<td>VAT</td>
<td class="right">{{formatAmount basicdetails.[0].vatamt bcdp}}</td>
<td class="label-ar">ضريبة القيمة المضافة</td>
</tr>

<tr class="bold">
<td>Grand Total</td>
<td class="right">{{formatAmount basicdetails.[0].grand_total bcdp}}</td>
<td class="label-ar">الإجمالي الكلي</td>
</tr>

</table>
</td>

</tr>
</table>

</body>
</html>
