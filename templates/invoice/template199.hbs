<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <title>Tax Invoice - {{basicdetails.[0].inv_no}}</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: Arial, sans-serif;
      font-size: 10px;
      color: #000;
      background: #fff;
    }

    .page {
      width: 750px;
      margin: 0 auto;
      padding: 10px 15px;
    }

    /* ── Title ──────────────────────────────────── */
.invoice-title {
  text-align: center;
  font-size: 22px;
  font-weight: bold;
  margin-bottom: 8px;
  letter-spacing: 1px;
}

/* TABLE */
.invoice-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 10px;
  border: 1px solid #ccc;   /* outer border */
}

/* CELLS */
.invoice-table td {
  padding: 4px 6px;
  vertical-align: top;
}

/* VERTICAL DIVIDER (center line) */
.vl {
  border-left: 1px solid #ccc;
}

/* HORIZONTAL LINES */
.bt { border-top: 1px solid #ccc; }
.bb { border-bottom: 1px solid #ccc; }

/* LABEL */
.label {
  font-weight: bold;
  width: 18%;
}

/* DARK HEADER */
.dark-header {
  background: #292727;
  color: #fff;
  font-weight: bold;
}
    /* ── Two-column layout ─────────────────────── */
    /* ── Two-column layout ─────────────────────── */
    /* ── Two-column layout ─────────────────────── */
    /* ── Two-column layout ─────────────────────── */
    .row {
      display: flex;
      flex-wrap: wrap;
    }
    .col-left {
      flex: 0 0 50%;
      max-width: 50%;
      padding-right: 10px;
    }
    .col-right {
      flex: 0 0 50%;
      max-width: 50%;
      padding-left: 10px;
    }
    .col-full {
      flex: 0 0 100%;
      max-width: 100%;
    }

    /* ── Field rows ────────────────────────────── */
    .field-row {
      display: flex;
      align-items: baseline;
      margin-bottom: 2px;
      font-size: 10px;
      line-height: 1.5;
    }
    .field-lbl {
      font-weight: bold;
      min-width: 130px;
      flex-shrink: 0;
      font-size: 10px;
    }
    .field-val {
      font-size: 10px;
      color: #000;
    }

    /* ── Bordered section ──────────────────────── */
    .bordered-section {
      border: 1px solid #000;
      padding: 4px 8px;
      margin-top: 6px;
    }
    .bordered-section .field-row {
      border-bottom: 1px solid #ddd;
      padding: 1px 0;
    }
    .bordered-section .field-row:last-child {
      border-bottom: none;
    }

    /* ── Billing items table ───────────────────── */
    .billing-table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 6px;
    }
    .billing-table th {
      background: #292727;
      color:#fff;
      font-size: 9px;
      font-weight: bold;
      padding: 4px 3px;
      text-align: center;
      border: 1px solid #000;
    }
    .billing-table td {
      padding: 3px 4px;
      font-size: 10px;
      border: 1px solid #ccc;
      text-align: center;
      vertical-align: middle;
    }
    .billing-table td.td-desc { text-align: left; }
    .billing-table td.td-right { text-align: right; }

    /* ── Totals section ────────────────────────── */

    .totals-row {
        display: table;
        width: 100%;
        border: 1px solid #ccc;
        border-top: none;
        font-size: 10px;
    }

    .totals-row span {
        display: table-cell;
       
        width: 100%;
        padding-top: 3px;
        padding-bottom: 3px;
        padding-right: 2px;
        text-align: right;
        vertical-align: middle;
    }

    .t-lbl {
        width: 80%;
    }

    .t-val {
        width: 10%;
        border-left: 1px solid #ccc;
        font-weight: bold;
    }

    /* ── VAT + TOTAL SECTION ───────────────────── */

        .vat-wrapper {
        width: 100%;              /* adjust (50%–65%) based on your layout */
        margin-left: auto;       /* push to right side */
        }

        /* VAT table */
        .vat-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 10px;
        }

        .vat-table th,
        .vat-table td {
            border: 1px solid #ccc;
            padding: 4px 6px;
            text-align: center;
        }
        .vat-table td {
            border-top:1px solid #000;
        }
        .vat-table th {
            background: #f5f5f5;
            border-top: none;
            font-weight: bold;
        }

        /* GRAND TOTAL */
        .grand-total {
        width: 100%;
        border-collapse: collapse;
        font-size: 10px;
        }

        .grand-total td {
        border: 1px solid #ccc;
        border-top: none;
        padding-top: 6px;
        padding-left:3px;
        padding-right:3px;
        padding-bottom: 6px;
        font-weight: bold;
        background: #f9f9f9;
        }

        .grand-total .label {
            text-align: right;
            border-left: none;
        }
        .grand-total .label1 {
            text-align: left;
            border-right: none;
            padding-left:3px;
        }

        .grand-total .value {
        text-align: right;
        {{!-- border-top:1px solid #000; --}}
        }

        /* ── Amount in words ───────────────────────── */

        .amount-words {
        margin-top: 6px;
        font-size: 10px;
        font-weight: bold;
        }

        /* ── Bank section ─────────────────────────── */

        .bank-section {
            border:1px solid #ccc;
            border-top:none;
            font-size: 10px;
            padding-left:4px;
            padding-bottom:4px;
        }
    /* ── Prepared / Signature ──────────────────── */
    .sig-wrap {
      display: flex;
      justify-content: space-between;
      margin-top: 20px;
      padding-top: 5px;
    }
    .sig-col {
      flex: 0 0 45%;
    }
    .sig-col .sig-label {
      font-weight: bold;
      font-size: 10px;
      margin-bottom: 4px;
    }
    .sig-col .sig-name {
      font-size: 10px;
      font-weight: bold;
      text-transform: uppercase;
      margin-top: 4px;
    }

    /* ── Terms ──────────────────────────────────── */
    .terms-section {
      margin-top: 8px;
      font-size: 9px;
      line-height: 1.6;
    }
    .terms-section .terms-title {
      font-weight: bold;
      font-size: 9px;
      margin-bottom: 2px;
    }

    /* ── Company footer ────────────────────────── */
    .company-footer {
      margin-top: 10px;
      border-top: 1px solid #000;
      padding-top: 4px;
      width:100%;
    }
    .company-footer .footer-left {
      font-size: 8px;
      line-height: 1.5;
    }
    .qr-wrapper img {
      width: 120px;
      height: 120px;
      text-align:right;
    }
  </style>
</head>
<body>
<div class="page">

  {{!-- ══ TITLE ══ --}}
  <div class="invoice-title">TAX INVOICE</div>

<table class="invoice-table">

<!-- HEADER -->
<tr>
  <td class="dark-header">Billed To :</td>
  <td>{{billing_address.[0].name}}</td>
  <td class="label vl">Invoice #:</td>
  <td>{{basicdetails.[0].inv_no}}</td>
</tr>

<tr>
  <td class="label vl">VAT Reg No:</td>
  <td class="">{{customer_details.[0].VAT_number}}</td>
  <td class="label vl">Invoice Date:</td>
  <td class="">{{basicdetails.[0].inv_date}}</td>
</tr>

<!-- ADDRESS BLOCK -->
<tr>
  <td class="label vl" rowspan="2">Address :</td>
  <td class="">
        {{#if billing_address.[0].address_line1}}
            {{billing_address.[0].address_line1}}{{#if billing_address.[0].address_line2}}, {{/if}}
        {{/if}}

        {{#if billing_address.[0].address_line2}}
            {{billing_address.[0].address_line2}}{{#if billing_address.[0].address_line4}}, {{/if}}
        {{/if}}

        {{#if billing_address.[0].address_line4}}
            {{billing_address.[0].address_line4}}
        {{/if}}
  </td>
  <td class="label vl">Our VAT Reg No:</td>
  <td class="">{{branch.[0].vat}}</td>
</tr>

<tr>
  <td class="">
        {{#if billing_address.[0].address_line3}}
            {{billing_address.[0].address_line3}}{{#if billing_address.[0].address_line5}}, {{/if}}
        {{/if}}

        {{#if billing_address.[0].address_line5}}
            {{billing_address.[0].address_line5}}
        {{/if}}
  </td>
  <td class="label vl bt">Job #:</td>
  <td class="bt">{{basicdetails.[0].logisticsjobno}}</td>
</tr>

<tr>
    <td class="label">Tel / Fax :</td>
    <td class="">{{customer_details.[0].contact_no1}}</td>
    <td class="label vl">HBL No:</td>
    <td>{{basicdetails.[0].hbl_no}}</td>
</tr>

<tr>
  <td class="label bt">Attn :</td>
  <td class="bt">{{basicdetails.[0].attention}}</td>
  <td class="label vl">MBL No:</td>
  <td class="">{{basicdetails.[0].mbl_no}}</td>
</tr>

{{!-- <tr>
  <td class="label bt"></td>
  <td class="bt"></td>
  <td class="label vl bt">Carrier :</td>
  <td class="bt"></td>
</tr> --}}

<!-- SHIPPING -->
<tr>
  <td class="label bt">POL</td>
  <td class="bt">{{basicdetails.[0].port_of_loading}}</td>
  <td class="label vl bt">Vessel Name :</td>
  <td class="bt">{{basicdetails.[0].vessel_name}}</td>
</tr>

<tr>
  <td class="label">POD</td>
  <td>{{basicdetails.[0].port_of_delivery}}</td>
  {{!-- <td class="label vl">Voyage No :</td> --}}
  <td class="label vl"></td>
  <td></td>
</tr>

<tr>
  <td class="label bt">Shipper :</td>
  <td class="bt">{{basicdetails.[0].shipper_name}}</td>
  <td class="label vl bt">ETD :</td>
  <td class="bt">{{basicdetails.[0].etd_date}}</td>
</tr>

<!-- SHIPPER ADDRESS -->
<tr>
  <td class="label" rowspan="2">Address :</td>
  <td class="">
    {{basicdetails.[0].shipper_address}}
  </td>
  <td class="label vl">ETA:</td>
  <td class="">{{basicdetails.[0].eta_date}}</td>
</tr>

<tr>
    <td class="">
        {{basicdetails.[0].shipper_country}}
    </td>
    <td class="label vl bt">Pcs &amp; Vol./Weight :</td>
    <td class="bt">
        {{!-- {{basicdetails.[0].packages}} --}}
        {{#if basicdetails.[0].no_pcs}} {{basicdetails.[0].no_pcs}} Pcs {{/if}}
        {{#if basicdetails.[0].gross_weight}} / {{basicdetails.[0].gross_weight}} {{basicdetails.[0].weight_unit}} {{/if}}
    </td>
</tr>

<tr>
  <td class="label">Tel / Fax :</td>
  <td class=""></td>
  <td class="label vl">Order Ref # :</td>
  <td class="">{{basicdetails.[0].job_reference}}</td>
</tr>

<!-- FULL WIDTH -->
<tr>
  <td class="label bt">Containers :</td>
  <td class="bt" colspan="3">{{basicdetails.[0].container_size}}</td>
</tr>

<tr>
  <td class="label bt">No. Of Containers :</td>
  <td colspan="3" class="bt">{{basicdetails.[0].container_no}}</td>
</tr>

<tr>
  <td class="label bb bt">Remarks :</td>
  <td class="bb bt" colspan="3">{{basicdetails.[0].remark}}</td>
</tr>

</table>

  {{!-- ══ BILLING TABLE ══ --}}
  <table class="billing-table">
    <thead>
      <tr>
        <th style="width:28%;">Billing</th>
        <th style="width:5%;">Cur</th>
        <th style="width:5%;">Qty</th>
        <th style="width:8%;">Rate</th>
        <th style="width:10%;">FC Amount</th>
        <th style="width:9%;">Ex Rate</th>
        <th style="width:10%;">Amount<br>SAR</th>
        <th style="width:5%;">VAT<br>%</th>
        <th style="width:10%;">VAT<br>Amount</th>
        <th style="width:10%;">Total<br>Amount</th>
      </tr>
    </thead>
    <tbody>
      {{#each itemdetails}}
      <tr>
        <td class="td-desc">
          {{addOne @index}}. {{item_name}}
          {{#if name_lang2}}<br><span style="direction:rtl; font-size:9px;">{{name_lang2}}</span>{{/if}}
          {{#if description}}<br><span style="direction:rtl; font-size:9px;">{{description}}</span>{{/if}}
        </td>
        <td></td>
        <td>{{formatAmount quantity ../bcdp}}</td>
        <td class="td-right">{{formatAmount price ../bcdp}}</td>
        <td class="td-right">{{formatAmount taxable ../bcdp}}</td>
        <td class="td-right">{{#if ../ccrate}}{{../ccrate}}{{/if}}</td>
        <td class="td-right">{{formatAmount taxable ../bcdp}}</td>
        <td>{{vat_perc}}%</td>
        <td class="td-right">{{formatAmount vat_amt ../bcdp}}</td>
        <td class="td-right">{{formatAmount amount ../bcdp}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>

  {{!-- ══ TOTALS ══ --}}
  <div class="totals-wrap">

    {{!-- Subtotals row --}}
    <div class="totals-row">
        <span class="t-lbl" style="width:80%;"></span>
        <span class="t-val" style="width:10%;">
            {{formatAmount basicdetails.[0].vatamt bcdp}}
        </span>
        <span class="t-val" style="width:10%;">
            {{formatAmount basicdetails.[0].grand_total bcdp}}
        </span>
    </div>

    <!-- ══ VAT + TOTAL WRAPPER (RIGHT SIDE) ══ -->
    <div class="vat-wrapper">

        <!-- VAT SUMMARY -->
        <table class="vat-table">
            <tr>
            <th style="width: 55%;"></th>
            <th style="border-bottom:1px solid #000;">VAT %</th>
            <th style="border-bottom:1px solid #000;">Amount without VAT</th>
            <th style="border-bottom:1px solid #000;">VAT Amount</th>
            </tr>
            <tr>
            <td></td>
            <td style="border-bottom: 1px solid #000;">{{itemdetails.[0].vat_perc}}%</td>
            <td style="border-bottom: 1px solid #000;">
                {{formatAmount (subtract basicdetails.[0].grand_total basicdetails.[0].vatamt) bcdp}}
            </td>
            <td style="border-bottom: 1px solid #000;width: 13.3%;">
                {{formatAmount basicdetails.[0].vatamt bcdp}}
            </td>
            </tr>
        </table>

        <!-- GRAND TOTAL -->
        <table class="grand-total">
            <tr>
            <td class="label1" style="width: 55%;">{{basicdetails.[0].isocode}} {{bcamountinwords}}</td>
            <td class="label" style="width: 31.7%;">
                Total Payable Amount (Including VAT) :
            </td>
            <td class="value" style="width: 13.3%;">
                {{basicdetails.[0].currency_isocode}} {{formatAmount basicdetails.[0].grand_total bcdp}}
            </td>
            </tr>
        </table>
    </div>


    <!-- ══ BANK DETAILS ══ -->
    <div class="bank-section">
        <div><b>Bank Details:</b></div>
        <div>
            Please Arrange Payment In Favour of 
            <b>{{branch.[0].name}}</b>
        </div>
    </div>

  {{!-- ══ PREPARED BY / FINANCE MANAGER ══ --}}
  {{!-- ══ SIGNATURE ROW ══ --}}
<table width="100%" style="margin-top:20px; font-size:10px;">
  <tr>
    
    <!-- LEFT SIDE -->
    <td width="15%">
      <b>Prepared By  :</b>
    </td>

    <td width="35%">
      <span style="margin-left:5px;">
        {{basicdetails.[0].created_user}}
      </span>
      
      <!-- line only under value -->
      <div style="border-bottom:1px solid #000; width:60%; margin-top:3px;"></div>
    </td>

    <!-- RIGHT SIDE -->
    <td width="20%" align="right">
      <b>Finance Manager  :</b>
      
      <!-- empty line for signature -->
    </td>
    <td width="35%" align="right">
    </td>

  </tr>
</table>


{{!-- ══ TERMS ══ --}}
{{#if invterms}}
<div style="margin-top:10px; font-size:9px;">
  <b>Terms:</b><br>
  {{{nl2br basicdetails.[0].terms_and_condition}}}
</div>
{{/if}}


{{!-- ══ QR (BOTTOM RIGHT) ══ --}}
<table width="100%" style="margin-top:15px;">
  <tr>
    <td width="70%"></td>
    <td class="qr-wrapper" width="30%" align="right">
      {{{qrDataUri qrCodeBase64}}}
    </td>
  </tr>
</table>

</div>
</body>
</html>
