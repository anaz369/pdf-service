<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="UTF-8">
    <title>Invoice - {{basicdetails.[0].inv_no}}</title>
    <style>
        @page {
            size: 220mm 280mm;
            margin: 0;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        html, body {
            width: 220mm;
            height: 280mm;
        }

        .page {
            position: relative;
            width: 220mm;
            height: 280mm;
            page-break-after: always;
            overflow: hidden;
        }

        .page:last-child {
            page-break-after: auto;
        }

        .page-bg {
            position: absolute;
            top: 0;
            left: 0;
            width: 220mm;
            height: 280mm;
            z-index: 0;
            display: block;
        }

        .f {
            position: absolute;
            font-family: Arial, sans-serif;
            font-size: 8.5pt;
            color: #000;
            line-height: 1;
            white-space: nowrap;
            z-index: 1;
        }

        /* ── Meta fields ───────────────────────── */
        .f-div-full {
            position: absolute;
            top: 20.5mm;
        }

        .f-blnk    { top: 54.2mm;  left: 40.4mm;  width: 5mm; }
        .f-date    { top: 47.9mm;  left: 131.4mm;  width: 60mm; }
        .f-inv     { top: 47.9mm;  left: 177mm;   width: 46mm; }
        .f-ccode   { top: 54.1mm;  left: 139.5mm; width: 30mm; }
        .f-name    { top: 49.9mm;  left: 22.4mm;  width: 105mm; overflow: hidden; text-overflow: ellipsis; }
        .f-contact { top: 58.3mm;  left: 139.8mm; width: 42mm;  overflow: hidden; text-overflow: ellipsis; }
        .f-address { top: 54.3mm;  left: 22.4mm; width: 80mm; white-space: normal; line-height: 1.3; }
        /* ── Items table ───────────────────────── */
        .items-wrap {
            position: absolute;
            top: 100.5mm;
            left: 3.6mm;
            width: 213.2mm;
            max-height: 158.9mm;
            overflow: hidden;
            z-index: 1;
        }

        .items-table {
            width: 215mm;
            border-collapse: collapse;
            table-layout: fixed;
        }

        .items-table td {
            border: none;
            padding: 0 1mm;
            min-height: 8.8mm;
            vertical-align: middle;
            font-family: Arial, sans-serif;
            font-size: 8.5pt;
            color: #000;
            overflow: hidden;
            white-space: nowrap;
        }

        .items-table td.c-desc {
            white-space: normal;
            word-break: break-word;
            overflow-wrap: break-word;
        }

        .c-code  { width: 7.6mm; }
        .c-sno   { width: 8mm; text-align: right; }
        .c-s   { width: 8mm; text-align: left; }
        .c-desc  { width: 88mm; text-align: left; }
        .c-qty   { width: 11mm; text-align: center; }
        .c-unit  { width: 11mm; text-align: left; }
        .c-price { width: 20mm; text-align: center; }
        .c-amt   { width: 15mm; text-align: right; }
        .c-test  { width: 17mm; text-align: right; }

        /* ── Footer ────────────────────────────── */
        .f-words { top: 220.7mm; left: 35.6mm; width: 130mm; font-size: 8pt; overflow: hidden; text-overflow: ellipsis; }
        .f-total { top: 220.2mm; left: 162mm;  width: 31mm;  text-align: right; padding-right: 2mm; font-weight: bold; }
        .f-remark { top: 225.2mm; left: 36mm;  width: 31mm;  text-align: right; padding-right: 2mm; }
        .related-invoices {
  border: 1px solid #ddd;
  border-radius: 6px;
  padding: 10px 14px;
  margin-top: 10px;
  background: #fafafa;
}
.ri-title {
  font-weight: bold;
  font-size: 11px;
  margin-bottom: 8px;
  text-transform: uppercase;
  letter-spacing: 0.3px;
}
.ri-list {
  padding-left: 20px;
  margin: 0;
}
.ri-list li {
  font-size: 11px;
  line-height: 2;
  color: #000;
}
.ri-list li.ri-total {
  font-weight: bold;
  list-style: none;
  margin-left: -20px;
  margin-top: 4px;
  padding-top: 4px;
  border-top: 1px solid #ddd;
}
    </style>
</head>
<body>

{{!-- ── PAGE 1 ─────────────────────────────────── --}}
<div class="page">

    {{!-- Background letterhead image --}}
    {{#if LetterheadImageUrl}}
    <img class="page-bg" src="{{LetterheadImageUrl}}" alt="">
    {{/if}}
    <div class="f-div-full">
        {{!-- Meta fields — root scope, no prefix needed --}}
        <div class="f f-blnk"></div>
        <div class="f f-date">{{basicdetails.[0].inv_date}}</div>
        <div class="f f-inv">{{basicdetails.[0].inv_no}}</div>
        <div class="f f-ccode">{{basicdetails.[0].salesman_name}}</div>
        <div class="f f-name">{{billing_address.[0].name}}</div>
        <div class="f f-address">{{joinAddress billing_address.[0]}}</div>
        <div class="f f-contact">{{customer_details.[0].contact_no1}}</div>
    </div>
    <div class="items-wrap">
        <table class="items-table"><tbody>
        {{#each pageItems}}
            <tr>
              
                <td class="c-sno">{{addOffset @index ../startIndex}}</td>
                <td class="c-s"></td>
                {{!-- <td class="c-code">{{item_code}}</td> --}}
                {{!-- <td class="c-desc">{{item_name}}
                    {{#if name_lang2}}
                        <span class="rtl" style="display:block; font-size:9px;">{{name_lang2}}</span>
                    {{/if}}
                    {{#if description}}
                    {{#neq description item_name}}
                        <small style="color:#555; display:block;">{{description}}</small>
                    {{/neq}}
                    {{/if}}</td> --}}
                    <td class="c-desc">
    
                        <!-- Row for Names -->
                        <div style="display:flex; justify-content:space-between; align-items:center;">
                            
                            <!-- English (Left) -->
                            <span style="text-align:left;">
                                {{item_name}}
                            </span>

                            <!-- Lang2 (Right - RTL) -->
                            {{#if name_lang2}}
                                <span class="rtl" style="font-size:9px; direction:rtl; text-align:right;">
                                    {{name_lang2}}
                                </span>
                            {{/if}}

                        </div>

                        <!-- Description -->
                        {{#if description}}
                            {{#neq description item_name}}
                                <div style="color:#555; margin-top:2px; font-size:10px;">
                                    {{description}}
                                </div>
                            {{/neq}}
                        {{/if}}

                    </td>
                <td class="c-qty">{{formatAmount quantity ../bcdp}}</td>
                <td class="c-unit">{{unit}}</td>
                <td class="c-price">{{formatAmount price ../bcdp}}</td>
                <td class="c-amt">{{formatAmount amount ../bcdp}}</td>
                <td class="c-test"></td>
            </tr>
        {{/each}}
        </tbody></table>
    </div>

    {{#if isLastPage}}
    <div class="f f-words">{{bcamountinwords}}</div>
    <div class="f f-total">{{formatAmount (divide basicdetails.[0].grand_total ccrate) bcdp}}</div>
    <div class="f f-remark">{{basicdetails.[0].terms_and_condition}}</div>
    {{/if}}

</div>

{{!-- ── EXTRA PAGES (page 2, 3...) ──────────────── --}}
{{!--
    Inside {{#each extraPages}} we are one level deep.
    Root data needs ../ prefix to access:
      ../basicdetails.[0]
      ../billing_address.[0]
      ../customer_details.[0]
      ../bcamountinwords
--}}
{{#each extraPages}}
<div class="page">

    {{!-- Background letterhead image --}}
    {{#if ../LetterheadImageUrl}}
    <img class="page-bg" src="{{../LetterheadImageUrl}}" alt="">
    {{/if}}

    {{!-- Meta fields repeat on every page — use ../ to reach root --}}
    <div class="f f-inv">{{../basicdetails.[0].inv_no}}</div>
    <div class="f f-date">{{../basicdetails.[0].inv_date}}</div>
    <div class="f f-ccode">{{../basicdetails.[0].salesman_name}}</div>
    <div class="f f-name">{{../billing_address.[0].name}}</div>
    <div class="f f-contact">{{../customer_details.[0].contact_no1}}</div>

    <div class="items-wrap">
        <table class="items-table"><tbody>
        {{#each this.pageItems}}
            <tr>
                <td class="c-sno">{{addOffset @index ../startIndex}}</td>
                <td class="c-code">{{item_code}}</td>
                <td class="c-desc">{{item_name}}</td>
                <td class="c-qty">{{quantity}}</td>
                <td class="c-unit">{{unit}}</td>
                <td class="c-price">{{price}}</td>
                <td class="c-amt">{{amount}}</td>
            </tr>
        {{/each}}
        </tbody></table>
    </div>

    {{!-- Footer only on last page — two levels deep here (each extraPages > each pageItems) --}}
    {{#if this.isLastPage}}
    <div class="f f-words">{{../bcamountinwords}}</div>
    <div class="f f-total">{{formatAmount (divide basicdetails.[0].grand_total ccrate) bcdp}}</div>
    <div class="f f-remark">{{basicdetails.[0].terms_and_condition}}</div>
    {{/if}}

</div>
{{/each}}

</body>
</html>
