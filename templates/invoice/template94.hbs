<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>INVOICE - {{basicdetails.[0].inv_no}}</title>
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        font-family: "IBM Plex Sans Arabic", Arial, sans-serif;
        font-size: 10px;
        line-height: 1.3;
        color: #000;
        margin: 0 4mm;
      }

      .ar {
        direction: rtl;
      }
      .lbl {
        
        font-weight: 700;
      }
      .lbl .ar {
        display: block;
        direction: rtl;
        font-weight: 700;
      }

      /* ── TITLE ────────────────────────────────────── */
      .doc-title {
        text-align: center;
        font-size: 18px;
        font-weight: 800;
        letter-spacing: 0.5px;
        margin-bottom: 6px;
      }

      table {
        border-collapse: collapse;
        width: 100%;
        table-layout: fixed;
      }

      /* ── HEADER (Invoice No / Date / VAT) ─────────── */
      .hdr td {
        font-size: 9px;
        border: 1px solid #000;
        padding: 4px 6px;
        text-align: center;
        vertical-align: middle;
      }
      .hdr td.val {
        font-weight: 600;
      }

      /* ── TO / ADDRESS + RIGHT TABLES ──────────────── */
      .info-table td {
        border: 1px solid #000;
        padding: 4px 6px;
        vertical-align: top;
      }
      .info-table .head {
        
        font-weight: 700;
        text-align: center;
      }
      .info-table .head .ar {
        display: block;
        direction: rtl;
      }
      .nb {
        border: none !important;
      }
      .inner {
        border-collapse: collapse;
        width: 100%;
      }
      .inner td {
        font-size: 9px;
        border: 1px solid #000;
        padding: 4px 6px;
        vertical-align: top;
      }

      /* ── ITEMS TABLE ──────────────────────────────── */
      .items-table {
        margin-top: 8px;
        font-size: 10px;
      }
      .items-table th,
      .items-table td {
        border: 1px solid #000;
        padding: 4px 5px;
        vertical-align: top;
      }
      .items-table thead th {
        
        text-align: center;
        line-height: 1.2;
      }
      .items-table thead th .ar {
        display: block;
        direction: rtl;
        font-size: 9px;
      }
      .items-table td.num {
        text-align: center;
      }
      .items-table td.right {
        text-align: right;
      }
      .items-table .desc .sub {
        color: #555;
        font-size: 9px;
      }

      /* ── TOTALS ───────────────────────────────────── */
      .totals-wrap {
        margin-top: 8px;
      }
      .totals-wrap > tbody > tr > td {
        vertical-align: top;
        border: none;
      }
      .qr-cell {
        text-align: center;
        vertical-align: middle;
      }
      .qr-cell img {
        width: 110px;
        height: 110px;
        object-fit: contain;
      }
      .totals-table td {
        font-size:10px;
        border: 1px solid #000;
        padding: 5px 8px;
        vertical-align: middle;
      }
      .totals-table .t-lbl {
        
        font-weight: 700;
        width: 30%;
      }
      .totals-table .t-ar {
        
        text-align: right;
        direction: rtl;
        font-weight: 700;
      }
      .totals-table .t-val {
        width: 18%;
        text-align: right;
        font-weight: 700;
      }
      .totals-table .words {
        
        font-weight: 600;
      }
      .totals-table .words .ar {
        display: block;
        direction: rtl;
        text-align: right;
      }

      /* ── CHEQUE / BANK ────────────────────────────── */
      .cheque {
        border: 1px solid #000;
        padding: 5px 6px;
        font-weight: 600;
      }
      .bank-title {
        
        font-weight: 700;
        text-align: center;
        border: 1px solid #000;
        border-top: none;
        border-bottom: none;
        padding: 4px;
      }
      .bank-table td {
        font-size: 9px;
        border: 1px solid #000;
        padding: 5px 8px;
      }
      .bank-table td.lbl {
        width: 22%;
      }

      /* ── SIGNATURES ───────────────────────────────── */
      .sign-table td {
        border: 1px solid #000;
        border-top: none;
        width: 25%;
        height: 90px;
        vertical-align: top;
        padding: 5px 6px;
      }
      .sign-table .s-head {
        font-size: 9px;
        font-weight: 700;
        text-align: center;
      }
      .sign-table .s-head .ar {
        display: block;
        direction: rtl;
      }
      .sign-table .s-body {
        font-size: 9px;
        text-align: center;
        margin-top: 4px;
      }
      .sign-table .s-body img {
        max-height: 70px;
        max-width: 120px;
      }

      .foot-note {
        text-align: center;
        font-weight: 700;
        margin-top: 6px;
      }
    </style>
  </head>
  <body>

    <!-- TITLE -->
    <div class="doc-title">TAX INVOICE / <span class="ar">فاتورة ضريبية</span></div>

    <!-- HEADER: Invoice No / Date / VAT No -->
    <table class="hdr">
      <tr>
        <td class="lbl" style="width:11%">Invoice No.<span class="ar">رقم الفاتورة</span></td>
        <td class="val" style="width:23%">{{basicdetails.[0].inv_no}}</td>
        <td class="lbl" style="width:11%">Invoice Date<span class="ar">تاريخ الفاتورة</span></td>
        <td class="val" style="width:21%">{{basicdetails.[0].inv_date}}</td>
        <td class="lbl" style="width:11%">VAT No.<span class="ar">الرقم الضريبي</span></td>
        <td class="val" style="width:23%">{{branch.[0].vat}}</td>
      </tr>
    </table>

    <!-- TO / ADDRESS + RIGHT TABLES -->
    <table class="info-table" style="border-top:none;">
      <tr>
        <td style="width:45%;border-top:none;">
          <table class="inner" style="border:none;">
            <tr>
              <td class="lbl nb" style="width:22%">To<span class="ar">إلى</span></td>
              <td class="nb">{{billing_address.[0].name}}<div class="ar">{{billing_address_lang2.[0].name}}</div></td>
            </tr>
            <tr>
              <td class="lbl nb" style="vertical-align:top;">Address<span class="ar">العنوان</span></td>
              <td class="nb">
                {{billing_address.[0].address_line1}}<br/>
                {{billing_address.[0].address_line2}}<br/>
                {{billing_address.[0].address_line4}}<br/>
                {{billing_address.[0].address_line3}}<br/>
                {{billing_address.[0].address_code}}<br/>
                VAT: {{billing_address.[0].vat}}
              </td>
            </tr>
          </table>
        </td>
        <td style="width:55%;border-top:none;padding:0;">
          <table class="inner">
            <tr>
              <td class="head" style="width:33%">Job No</td>
              <td class="head" style="width:34%">Customer Code</td>
              <td class="head" style="width:33%">Our Reference</td>
            </tr>
            <tr>
              <td style="text-align:center;">{{basicdetails.[0].logisticsjobno}}</td>
              <td style="text-align:center;">{{customer_details.[0].profile_code}}</td>
              <td style="text-align:center;">{{basicdetails.[0].reference_no}}</td>
            </tr>
          </table>
          <table class="inner" style="border-top:none;">
            <tr>
              <td class="head" style="width:25%">Customer Declaration No</td>
              <td class="head" style="width:25%">Bayan No</td>
              <td class="head" style="width:25%">Final Bayan Date</td>
              <td class="head" style="width:25%">BL No / WB No/ POD No</td>
            </tr>
            <tr>
              <td style="text-align:center;">&nbsp;</td>
              <td style="text-align:center;">&nbsp;</td>
              <td style="text-align:center;">&nbsp;</td>
              <td style="text-align:center;">&nbsp;</td>
            </tr>
          </table>
        </td>
      </tr>
    </table>

    <!-- ITEMS TABLE -->
    <table class="items-table">
      <thead>
        <tr>
          <th style="width:5%">Item<span class="ar">نوع</span></th>
          <th style="width:33%">Description<span class="ar">وصف</span></th>
          <th style="width:8%">Quantity<span class="ar">كمية</span></th>
          <th style="width:7%">UOM<span class="ar">وحدة</span></th>
          <th style="width:11%">Unit Price<span class="ar">سعر الوحدة</span></th>
          <th style="width:9%">Discount<span class="ar">تخفيض</span></th>
          <th style="width:13%">Tax Amount {{itemdetails.[0].vat_perc}}%<span class="ar">قيمة الضريبة</span></th>
          <th style="width:14%">Total Amount<span class="ar">المبلغ الإجمالي</span></th>
        </tr>
      </thead>
      <tbody>
        {{#each itemdetails}}
        <tr>
          <td class="num">{{addOne @index}}</td>
          <td class="desc">
            {{item_name}}
            {{#if name_lang2}}<span class="sub">{{name_lang2}}</span>{{/if}}
            {{#if description}}<span class="sub">{{description}}</span>{{/if}}
          </td>
          <td class="num">{{formatAmount quantity ../bcdp}}</td>
          <td class="num">{{unit}}</td>
          <td class="right">{{formatAmount price ../bcdp}}</td>
          <td class="right">{{formatAmount disc_amt ../bcdp}}</td>
          <td class="right">{{formatAmount vat_amt ../bcdp}}</td>
          <td class="right">{{formatAmount taxable ../bcdp}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>

    <!-- TOTALS + QR -->
    <table class="totals-wrap">
      <tr>
        <td class="qr-cell" style="width:32%">{{{qrDataUri qrCodeBase64}}}</td>
        <td style="width:68%">
          <table class="totals-table">
            <tr>
              <td class="t-lbl">Total Without VAT</td>
              <td class="t-ar">إجمالي المبلغ بدون ضريبة القيمة المضافة</td>
              <td class="t-val">{{formatAmount basicdetails.[0].subtotal bcdp}}</td>
            </tr>
            <tr>
              <td class="t-lbl">{{itemdetails.[0].vat_perc}}% VAT</td>
              <td class="t-ar">إجمالي ضريبة القيمة المضافة</td>
              <td class="t-val">{{formatAmount basicdetails.[0].vatamt bcdp}}</td>
            </tr>
            <tr>
              <td class="t-lbl">Total</td>
              <td class="t-ar">الإجمالي</td>
              <td class="t-val">{{formatAmount basicdetails.[0].grand_total bcdp}}</td>
            </tr>
            <tr>
              <td class="t-lbl">Total Amount In Words</td>
              <td class="words" colspan="2">
                {{bcamountinwords}}
                <span class="ar">{{bcamountinwordsar}}</span>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>

    <!-- CHEQUE -->
    <div class="cheque">Cheque should be crossed and made payable to:{{branch.[0].name}}</div>

    <!-- BANK DETAILS -->
    <div class="bank-title">BANK DETAILS</div>
    <table class="bank-table" style="border-top:none;">
      <tr>
        <td class="lbl">Beneficiary A/C Name</td>
        <td>{{bankdetails.acc_name}}</td>
        <td class="lbl">Beneficiary Bank</td>
        <td>{{bankdetails.name}}</td>
      </tr>
      <tr>
        <td class="lbl">Beneficiary Bank Branch</td>
        <td>{{bankdetails.branch_name}}</td>
        <td class="lbl">Beneficiary A/C No</td>
        <td>{{bankdetails.acc_no}}</td>
      </tr>
      <tr>
        <td class="lbl">Swift Code</td>
        <td>{{bankdetails.swift_no}}</td>
        <td class="lbl">IBAN No</td>
        <td>{{bankdetails.iban_no}}</td>
      </tr>
    </table>

    <!-- SIGNATURES -->
    <table class="sign-table">
      <tr>
        <td>
          <div class="s-head">Company Stamp<span class="ar">ختم الشركة</span></div>
          <div class="s-body">{{#if Seal}}<img src="{{Seal}}" alt="" onerror="this.style.display='none'"/>{{/if}}</div>
        </td>
        <td>
          <div class="s-head">Prepared By<span class="ar">إعداد</span></div>
          <div class="s-body">{{basicdetails.[0].created_user}}</div>
        </td>
        <td>
          <div class="s-head">Authorized Signature<span class="ar">توقيع معتمد</span></div>
          <div class="s-body">{{#if Signature}}<img src="{{Signature}}" alt="" onerror="this.style.display='none'"/>{{/if}}</div>
        </td>
        <td>
          <div class="s-head">Received By<span class="ar">تم الاستلام بواسطة</span></div>
          <div class="s-body"></div>
        </td>
      </tr>
    </table>

    <!-- FOOTER NOTE -->
    <div class="foot-note">******In case of any objection in this invoice, please review and reply within three days, otherwise the invoice shall stand deemed accepted.******</div>

  </body>
</html>
