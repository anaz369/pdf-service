<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>INVOICE - {{basicdetails.[0].inv_no}}</title>
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        font-family: "IBM Plex Sans Arabic", Arial, sans-serif;
        font-size: 9px;
        line-height: 1.3;
        color: #000;
        margin: 0 4mm;
      }

      .ar {
        direction: rtl;
      }

      table {
        border-collapse: collapse;
        width: 100%;
        table-layout: fixed;
      }

      /* ── TITLE ────────────────── */
      .doc-title {
        text-align: center;
        font-size: 20px;
        font-weight: 800;
        color: #b72031;
        margin-bottom: 6px;
      }
      .doc-title .ar{
         color: #606261;
      }

      /* ── TOP : BUYER | INFO ───────────────────────── */
      .top-wrap > tbody > tr > td {
        vertical-align: top;
        border: none;
        padding: 0 4px;
      }
      .buyer,
      .info {
        
      }
      .buyer td,
      .info td {
        font-size: 9.5px;
        border: 1px solid #bfbfbf;
        padding: 4px 6px;
        vertical-align: middle;
      }
      .buyer td.lbl {
        font-weight: 700;
      }
      .info td.lbl {
        background-color:#ccc;
        font-weight: 700;
        width: 30%;
      }
      .info td.arl {
        background-color:#ccc;
        font-weight: 700;
      }
      .buyer td.arl,
      .info td.arl {
        font-weight: 700;
        text-align: right;
        direction: rtl;
        width: 24%;
      }

      /* ── ITEMS TABLE ──────────────────────────────── */
      .items-table {
        margin-top: 8px;
      }
      .items-table th,
      .items-table td {
        font-size: 9px;
        border: 1px solid #bfbfbf;
        padding: 3px 5px;
        vertical-align: top;
      }
      .items-table thead th {
        font-size: 10px;
        text-align: center;
        line-height: 1.2;
      }
      .items-table thead th .ar {
        display: block;
        direction: rtl;
        font-weight: 700;
      }
      .items-table thead th .en {
        display: block;
        font-weight: 700;
      }
      .items-table td.num {
        text-align: center;
      }
      .items-table td.right {
        text-align: right;
      }
      .items-table tbody tr {
        page-break-inside: avoid;
        break-inside: avoid;
      }

      /* ── MID : QR | TOTALS ────────────────────────── */
      .mid {
        margin-top: 8px;
      }
      .mid > tbody > tr > td {
        vertical-align: top;
        padding: 0;
      }
      .mid .qrcell {
        text-align: center;
        vertical-align: middle;
        padding: 6px;
      }
      .mid .qrcell .qr-wrap {
        width: 120px;
        height: 120px;
        margin: 0 auto;
        overflow: hidden;
      }
      .mid .qrcell .qr-wrap img {
        width: 100%;
        height: auto;
        max-width: 120px;
        max-height: 120px;
      }
      .totals2 td {
        border: 1px solid #bfbfbf;
        padding: 5px 8px;
        font-size: 9.5px;
        vertical-align: middle;
      }
      .totals2 .tl {
        width: 72%;
      }
      .totals2 .tl .ar {
        float: right;
        direction: rtl;
      }
      .totals2 .tv {
        text-align: right;
        width: 28%;
      }
      .totals2 .b .tl,
      .totals2 .b .tv {
        font-weight: 700;
      }

      /* ── AMOUNT IN WORDS ──────────────────────────── */
      .words-bar {
        margin-top: 6px;
      }
      .words-bar td {
        font-size: 9.5px;
        border: 1px solid #bfbfbf;
        padding: 5px 8px;
      }
      .words-bar .words-en {
        width: 55%;
      }
      .words-bar .words-ar {
        width: 45%;
        text-align: right;
        direction: rtl;
      }

      /* ── FOOTER : BANK | SIGNATURES ───────────────── */
      .footer{
          width:100%;
          border-collapse:collapse;
          table-layout:fixed;
          margin-top:8px;
      }

      .footer td{
          border:1px solid #000;
          padding:5px;
          font-size:10px;
          vertical-align:top;
      }

      .footer .fhd{
          background:#d9d9d9;
          padding:4px 8px;
      }

      .footer .fhd table{
          width:100%;
          border-collapse:collapse;
      }

      .footer .fhd table td{
          border:none;
          padding:0;
      }

      .sig{
          height:110px;
          text-align:center;
          vertical-align:middle!important;
      }

      .sig img{
          max-width:120px;
          max-height:95px;
      }

      .bank-lines{
          width:100%;
          border-collapse:collapse;
      }

      .bank-lines td{
          border:none;
          padding:3px 2px;
      }

      .bank-lines .bl{
          width:38%;
      }

      .bank-lines .bc{
          width:6%;
          text-align:center;
      }

      .rb .ar{
        text-align: left;

      }

      /* ── FOOTER BLOCK : kept together, pushed to next page if needed ── */

      .footer-block {
          overflow: hidden;
          page-break-inside: avoid;
          break-inside: avoid;
      }

      /* ── FOOTER NOTE ──────────────────────────────── */
      .note-text {
        text-align: center;
        font-weight: 700;
        font-size: 11px;
        color: #b72031;
        margin-top: 8px;
      }
    </style>
  </head>
  <body>

    <!-- TITLE -->
    <div class="doc-title">TAX INVOICE / <span class="ar">فاتورة ضريبية</span></div>

    <!-- TOP : BUYER | INFO -->
    <table class="top-wrap">
      <tr>
        <!-- BUYER DETAILS -->
        <td style="width:58%">
          <table class="buyer">
            <colgroup>
                <col style="width:20%;">
                <col style="width:60%;">
                <col style="width:20%;">
            </colgroup>
            <tr>
              <td style="border: 1px solid #bfbfbf;border-right:none;font-weight:700;">BUYER DETAILS</td>
              <td style="border: 1px solid #bfbfbf;border-right:none;border-left:none;"></td>
              <td style="border: 1px solid #bfbfbf;border-left:none;font-weight:700;" class="ar">تفاصيل العميل</td>
            </tr>
            <tr>
              <td class="lbl">Name</td>
              <td>{{billing_address.[0].name}}</td>
              <td class="arl">الاسم</td>
            </tr>
            <tr>
              <td class="lbl">VAT Number</td>
              <td>{{billing_address.[0].vat}}</td>
              <td class="arl">الرقم الضريبي</td>
            </tr>
            <tr>
              <td class="lbl">Contact No</td>
              <td>{{customer_details.[0].contact_no1}}</td>
              <td class="arl">رقم الاتصال</td>
            </tr>
            <tr>
              <td class="lbl">Address</td>
              <td>{{joinAddress billing_address.[0] ', '}}</td>
              <td class="arl">العنوان</td>
            </tr>
          </table>
        </td>

        <!-- INFO -->
        <td style="width:42%">
          <table class="info">
            <colgroup>
              <col style="width:29%;">
              <col style="width:44%;">
              <col style="width:27%;">
          </colgroup>
            <tr><td class="lbl">Invoice No</td><td style="text-align: center;">{{basicdetails.[0].inv_no}}</td><td class="arl">رقم الفاتورة</td></tr>
            <tr><td class="lbl">Invoice Date</td><td style="text-align: center;">{{basicdetails.[0].inv_date}}</td><td class="arl">تاريخ الفاتورة</td></tr>
            <tr><td class="lbl">DN No</td><td style="text-align: center;">{{basicdetails.[0].deliverynote_no}}</td><td class="arl">رقم الإشعار</td></tr>
            <tr><td class="lbl">DN Date</td><td style="text-align: center;">{{basicdetails.[0].deliverynote_date}}</td><td class="arl">تاريخ الإشعار</td></tr>
            <tr><td class="lbl">Mode of Pay</td style="text-align: center;"><td>{{basicdetails.[0].modeofpayment}}</td><td class="arl">طريقة الدفع</td></tr>
            <tr><td class="lbl">PO No</td><td style="text-align: center;">{{basicdetails.[0].order_no}}</td><td class="arl">رقم أمر الشراء</td></tr>
            <tr><td class="lbl">PO Date</td><td style="text-align: center;">{{basicdetails.[0].po_date}}</td><td class="arl">تاريخ أمر الشراء</td></tr>
            <tr><td class="lbl">Payment Terms</td><td style="text-align: center;">{{basicdetails.[0].payment_terms}}</td><td class="arl">شروط الدفع</td></tr>
          </table>
        </td>
      </tr>
    </table>

    <!-- ITEMS TABLE -->
    <table class="items-table">
      <thead>
        <tr>
          <th style="width:5%"><span class="ar">م</span><span class="en">S.N</span></th>
          <th style="width:35%"><span class="ar">الوصف</span><span class="en">Description</span></th>
          <th style="width:8%"><span class="ar">الكمية</span><span class="en">QTY</span></th>
          <th style="width:8%"><span class="ar">الوحدة</span><span class="en">Unit</span></th>
          <th style="width:10%"><span class="ar">سعر الوحدة</span><span class="en">U.Rate</span></th>
          <th style="width:10%"><span class="ar">مبلغ</span><span class="en">Amount</span></th>
          <th style="width:12%"><span class="ar">قيمة الضريبة</span><span class="en">VAT Value</span></th>
          <th style="width:12%"><span class="ar">القيمة الاجمالي</span><span class="en">Total Price</span></th>
        </tr>
      </thead>
      <tbody>
        {{#each itemdetails}}
        <tr>
          <td class="num">{{addOne @index}}</td>
          <td>{{item_name}}{{name_lang2}}{{description}}</td>
          <td class="num">{{formatAmount quantity ../bcdp}}</td>
          <td class="num">{{unit}}</td>
          <td class="right">{{formatAmount price ../bcdp}}</td>
          <td class="right">{{formatAmount taxable ../bcdp}}</td>
          <td class="right">{{formatAmount vat_amt ../bcdp}}</td>
          <td class="right">{{formatAmount amount ../bcdp}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>

    <!-- MID : QR | TOTALS -->
    <table class="mid">
      <tr>
        <td class="qrcell" style="width:40%">
          <div class="qr-wrap">{{{qrDataUri qrCodeBase64}}}</div>
        </td>
        <td style="width:60%;padding:0;vertical-align:top">
          <table class="totals2">
            <tr>
              <td class="tl">Total Amount / <span>المبلغ الإجمالي</span></td>
              <td class="tv">{{formatAmount (divide basicdetails.[0].subtotal ccrate) bcdp}}</td>
            </tr>
            {{#if zatcadiscount.[0]}}
              {{#each zatcadiscount}}
                <tr>
                  <td class="tl">{{reason_name}} / <span>{{reason_name_lang2}}</span></td>
                  <td class="tv">{{formatAmount (divide dld ../ccrate) ../bcdp}}</td>
                </tr>
                {{/each}}
                <tr class="b">
                  <td class="tl">Net Amount / <span>صافي المجموع</span></td>
                  <td class="tv">{{formatAmount (divide (subtract basicdetails.[0].subtotal zatcadiscount.[0].dld) ccrate) bcdp}}</td>
                </tr>
            {{else}}

              {{#if (or basicdetails.[0].discount basicdetails.[0].dld)}}
              <tr>
                <td class="tl">Discount / <span>الخصم</span></td>
                <td class="tv">{{formatAmount (divide (add basicdetails.[0].discount basicdetails.[0].dld) ccrate) bcdp}}</td>
              </tr>
              <tr class="b">
                <td class="tl">Net Amount / <span>صافي المجموع</span></td>
                <td class="tv">{{formatAmount (divide (subtract basicdetails.[0].subtotal (add basicdetails.[0].discount basicdetails.[0].dld)) ccrate) bcdp}}</td>
              </tr>
              {{/if}}

          {{/if}}
            <tr>
              <td class="tl">{{datasettingstextvalue.d828}} / <span>ضريبة القيمة المضافة</span></td>
              <td class="tv">{{formatAmount (divide basicdetails.[0].vatamt ccrate) bcdp}}</td>
            </tr>
            <tr class="b">
              <td class="tl">Grand Total / <span>المبلغ الإجمالي</span></td>
              <td class="tv">{{formatAmount (divide basicdetails.[0].grand_total ccrate) bcdp}}</td>
            </tr>
          </table>
        </td>
      </tr>
    </table>

    <!-- AMOUNT IN WORDS -->
    <table class="words-bar">
      <tr>
        <td class="words-en">{{bcamountinwords}}</td>
        <td class="words-ar">{{bcamountinwordsar}}</td>
      </tr>
    </table>

    <!-- FOOTER BLOCK : bank/signatures (kept together) -->
    <div class="footer-block">

    <!-- FOOTER : BANK | SIGNATURES -->
    <table class="footer" cellpadding="0" cellspacing="0">
      <tr>
          <td class="fhd" style="width:31%;">
              <table width="100%">
                  <tr>
                      <td style="border:none;padding:0;font-weight:bold;">Bank Details</td>
                      <td style="border:none;padding:0;text-align:right;direction:rtl;font-weight:bold;">تفاصيل البنك</td>
                  </tr>
              </table>
          </td>

          <td class="fhd" style="width:23%;">
              <table width="100%">
                  <tr>
                      <td style="border:none;padding:0;font-weight:bold;">Prepared By</td>
                      <td style="border:none;padding:0;text-align:right;direction:rtl;font-weight:bold;">أعدت بواسطة</td>
                  </tr>
              </table>
          </td>

          <td class="fhd" style="width:23%;">
              <table width="100%">
                  <tr>
                      <td style="border:none;padding:0;font-weight:bold;">Approved By</td>
                      <td style="border:none;padding:0;text-align:right;direction:rtl;font-weight:bold;">تمت بواسطة</td>
                  </tr>
              </table>
          </td>

          <td class="fhd" style="width:23%;">
              <table width="100%">
                  <tr>
                      <td style="border:none;padding:0;font-weight:bold;">Received By</td>
                      <td style="border:none;padding:0;text-align:right;direction:rtl;font-weight:bold;">الاستلام</td>
                  </tr>
              </table>
          </td>

      </tr>

      <tr>

          <td class="bankcell">
              <table class="bank-lines">
                  <tr><td class="bl">Bank Name</td><td class="bc">:</td><td>{{bankdetails.name}}</td></tr>
                  <tr><td class="bl">A/C Name</td><td class="bc">:</td><td>{{bankdetails.acc_name}}</td></tr>
                  <tr><td class="bl">A/C No</td><td class="bc">:</td><td>{{bankdetails.acc_no}}</td></tr>
                  <tr><td class="bl">IBAN</td><td class="bc">:</td><td>{{bankdetails.iban_no}}</td></tr>
                  <tr><td class="bl">SWIFT</td><td class="bc">:</td><td>{{bankdetails.swift_no}}</td></tr>
              </table>
          </td>

          <td class="sig">
              {{#if Seal}}
              <img class="seal-img" src="{{Seal}}" alt="Seal" style="max-height:{{default datasettings.d459 '120'}}px; max-width:{{default datasettings.d459 '180'}}px;" onerror="this.style.display='none'"/>
              {{/if}}
          </td>

          <td class="sig">
              {{#if Signature}}
              <img src="{{Signature}}" alt="Signature" style="text-align:right;max-height:{{default datasettings.d458 '120'}}px; max-width:{{default datasettings.d458 '180'}}px;" onerror="this.style.display='none'"/>
              {{/if}}
          </td>

          <td class="rb">
              <div style="margin-bottom:28px;">Name :<br><span class="ar">الاسم</span></div>
              <div style="margin-bottom:28px;">Signature :<br><span class="ar">التوقيع</span></div>
              <div>Date :<br><span class="ar">التاريخ</span></div>
          </td>

      </tr>

  </table>

    </div><!-- /footer-block -->

  </body>
</html>
