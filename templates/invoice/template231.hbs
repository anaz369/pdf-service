<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{MyInvoisDocument.document_info.type_display}} - {{MyInvoisDocument.document.inv_no}}</title>
    <style>
        /* PAGE SETUP */
        /* PAGE SETUP */
        @page {
            size: A4;
            margin-top: 140px;
            margin-bottom: 40px;
            margin-left: 10px; 

            margin-right: 10px;
        }

        @page :first {
            margin-top: 133px;
        }


        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: Arial, sans-serif;
            font-size: 8pt;
            line-height: 1.2;
            color: #000;
            margin: 0 !important;
            padding: 0 !important;
            position: relative;
        }

        {{#if UseBGWatermark}}
        {{#if WatermarkCss}}
        /* WATERMARK - Fixed position on ALL pages, only in content area */
        body::after {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: url('{{{WatermarkCss}}}');
            background-repeat: no-repeat;
            background-position: 0 0;
            background-size: 100% auto;
            background-origin: border-box; 
            opacity: 0.30;
            pointer-events: none;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }
        {{/if}}
        {{/if}}

        .page1 {
            width: 100%;
            padding: 5mm;
            padding-bottom: 5px;
            margin: 0;
            z-index: 1;
            position: relative;
            background: transparent;
        }

        /* HEADER SECTION */
        .header {
            display: flex;
            justify-content: space-between;
            margin-bottom: 10px;
            padding-bottom: 6px;
            border-bottom: 2px solid #000;
            page-break-inside: avoid;
        }

        .header-left {
            flex: 1;
        }

        .header-right {
            text-align: right;
        }

        .company-name {
            font-weight: bold;
            font-size: 10pt;
            margin-bottom: 2px;
        }

        .header-info {
            font-size: 7pt;
            line-height: 1.3;
        }

        .self-billed-badge {
            display: inline-block;
            background: #fbbf24;
            color: #000;
            padding: 2px 6px;
            border-radius: 3px;
            font-size: 6.5pt;
            font-weight: bold;
            margin-left: 6px;
        }

        .original-reference-section {
            margin: 8px 0;
            border: 1px solid #999;
            background: #fffbeb;
            page-break-inside: avoid;
        }

        .original-reference-title {
            background: #fef3c7;
            padding: 4px 8px;
            font-weight: bold;
            font-size: 8pt;
            border-bottom: 1px solid #999;
        }

        .original-reference-content {
            padding: 6px;
            font-size: 7pt;
            line-height: 1.4;
        }

        .party-section {
            display: flex;
            gap: 8px;
            margin: 10px 0;
            page-break-inside: avoid;
        }

        .party-box {
            border: 1px solid #999;
            padding: 6px;
            background: #fafafa;
            page-break-inside: avoid;
        }

        .supplier-box {
            flex: 1.2;
        }

        .customer-box {
            flex: 1;
        }

        .invoice-box {
            flex: 0.75;
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
            padding: 8px 6px;
        }

        .party-label {
            font-weight: bold;
            margin-bottom: 4px;
            font-size: 8pt;
        }

        .party-name {
            font-weight: bold;
            margin-bottom: 3px;
            font-size: 8.5pt;
        }

        .party-details {
            font-size: 7pt;
            line-height: 1.3;
        }

        .document-title {
            text-align: right;
            font-size: 16pt;
            font-weight: bold;
            letter-spacing: 2px;
            color: #444;
            padding: 6px 0 8px 0;
            margin-bottom: 5px;
        }

        .qr-code {
            width: 100px;
            height: 100px;
            border: 2px solid #000;
            margin: 6px 0;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #fff;
        }

        .qr-code img {
            width: 95px;
            height: 95px;
        }

        .qr-placeholder {
            width: 80px;
            height: 80px;
            background: #f0f0f0;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 7pt;
            color: #666;
        }

        .invoice-meta {
            font-size: 6.5pt;
            line-height: 1.5;
            text-align: left;
            width: 100%;
        }

        .table-section {
            margin: 10px 0;
            page-break-after: auto;
        }

        .section-title {
            background: #e0e0e0;
            padding: 4px 8px;
            font-weight: bold;
            font-size: 8pt;
            border: 1px solid #999;
            display: flex;
            justify-content: space-between;
            page-break-after: avoid;
        }

        .currency-label {
            font-weight: normal;
            font-size: 7pt;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 8px;
        }

        th, td {
            border: 1px solid #999;
            padding: 3px 4px;
            text-align: left;
            font-size: 7pt;
        }

        th {
            background: #f0f0f0;
            font-weight: bold;
        }

        td.number {
            text-align: center;
        }

        td.amount {
            text-align: right;
            font-family: 'Courier New', monospace;
        }

        tbody tr {
            page-break-inside: avoid;
        }

        .sub-table {
            margin: 8px 0;
            page-break-inside: avoid;
        }

        .sub-table table {
            margin-bottom: 6px;
        }

        .abbreviations {
            font-size: 6.5pt;
            margin: 6px 0;
            padding: 4px;
            background: #fafafa;
            border: 1px solid #ddd;
        }

        .summary-section {
            display: flex;
            gap: 10px;
            margin: 10px 0;
            page-break-inside: avoid;
        }

        .summary-left {
            flex: 1;
        }

        .summary-right {
            flex: 1;
        }

        .summary-table {
            width: 100%;
        }

        .summary-table td {
            padding: 3px 6px;
            font-size: 7pt;
        }

        .summary-table .label {
            text-align: left;
            font-weight: normal;
        }

        .summary-table .value {
            text-align: right;
            font-weight: normal;
            font-family: 'Courier New', monospace;
        }

        .total-row {
            font-weight: bold !important;
            background: #f0f0f0;
        }

        .info-section {
            margin: 8px 0;
            border: 1px solid #999;
            page-break-inside: avoid;
        }

        .info-title {
            background: #e0e0e0;
            padding: 4px 8px;
            font-weight: bold;
            font-size: 8pt;
            border-bottom: 1px solid #999;
        }

        .info-content {
            padding: 6px;
            min-height: 20px;
            font-size: 7pt;
        }

        .info-table {
            width: 100%;
        }

        .info-table th {
            background: #f0f0f0;
            font-weight: bold;
            text-align: center;
            padding: 3px;
        }

        .info-table td {
            padding: 3px 6px;
            text-align: center;
        }

        /* SEAL & SIGNATURE SECTION */
        .seal-signature-section {
            display: flex;
            justify-content: flex-end;
            margin: 16px 0 6px 0;
            page-break-inside: avoid;
        }

        .seal-signature-box {
            text-align: center;
            min-width: 160px;
            max-width: 220px;
        }

        .seal-signature-images {
            position: relative;
            display: inline-block;
            width: 150px;
            height: 100px;
            margin-bottom: 4px;
        }

        .seal-img {
            position: absolute;
            width: 90px;
            height: 90px;
            object-fit: contain;
            bottom: 0;
            left: 0;
            opacity: 0.85;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }

        .signature-img {
            position: absolute;
            width: 130px;
            height: 60px;
            object-fit: contain;
            bottom: 10px;
            right: 0;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }

        .seal-only .seal-img,
        .signature-only .signature-img {
            position: static;
            display: block;
            margin: 0 auto;
        }

        .seal-only {
            width: 90px;
            height: 90px;
        }

        .signature-only {
            width: 130px;
            height: 60px;
        }

        .seal-signature-line {
            border-top: 1px solid #000;
            margin-top: 4px;
            padding-top: 3px;
            font-size: 7pt;
            font-weight: bold;
        }

        .seal-signature-name {
            font-size: 7pt;
            font-weight: bold;
        }

        @media print {
            body {
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
            }
        }
    </style>
</head>
<body>
    <div class="page1">
        <!-- Document Title -->
        <div class="document-title">{{upper MyInvoisDocument.document_info.type_display}}</div>

        <!-- Header Section -->
       
        <div class="header">
            <div class="header-left">
                <div class="company-name">
                    {{upper MyInvoisDocument.supplier.name}}
                    {{#if MyInvoisDocument.document_info.is_self_billed}}
                    <span class="self-billed-badge">SELF-BILLED</span>
                    {{/if}}
                </div>
                <div class="header-info">
                    <strong>Tax Identification Number (TIN) :</strong> {{MyInvoisDocument.supplier.tin}}
                </div>
            </div>
            <div class="header-right">
                <div class="header-info">
                    <strong>Invoice No:</strong> {{MyInvoisDocument.document.inv_no}}<br>
                    <strong>E-Invoice No:</strong> {{default MyInvoisDocument.myinvois.long_id (default MyInvoisDocument.myinvois.submission_uid '----')}}<br>
                    <strong>UUID:</strong> {{default MyInvoisDocument.doc_details.uuid '----'}}
                </div>
            </div>
        </div>

        <!-- Original Invoice Reference (for Credit/Debit Notes) -->
        {{#if MyInvoisDocument.document_info.has_original_reference}}
        {{#if MyInvoisDocument.myinvois.original_reference}}
        <div class="original-reference-section">
            <div class="original-reference-title">Original e-Invoice Reference Number(s)</div>
            <div class="original-reference-content">
                <strong>UUID:</strong> {{default MyInvoisDocument.myinvois.original_reference.uuid '----'}}<br>
                <strong>Invoice Number:</strong> {{default MyInvoisDocument.myinvois.original_reference.number '----'}}<br>
                <strong>Invoice Date:</strong> {{formatDate MyInvoisDocument.myinvois.original_reference.date}}<br>
                {{#if MyInvoisDocument.myinvois.original_reference.reason}}
                <strong>Reason:</strong> {{MyInvoisDocument.myinvois.original_reference.reason}}
                {{/if}}
            </div>
        </div>
        {{/if}}
        {{/if}}

        <!-- Party Information Section -->
        <div class="party-section">
            <!-- Supplier -->
            <div class="party-box supplier-box">
                <div class="party-label">{{#if MyInvoisDocument.document_info.is_self_billed}}FROM (Vendor):{{else}}FROM:{{/if}}</div>
                <div class="party-name">{{upper MyInvoisDocument.supplier.name}}</div>
                <div class="party-details">
                    <strong>TIN:</strong> {{MyInvoisDocument.supplier.tin}}<br>
                    {{#if MyInvoisDocument.supplier.id_type}}
                    <strong>ID Type/Number:</strong> {{MyInvoisDocument.supplier.id_type}}/{{MyInvoisDocument.supplier.id_no}}<br>
                    {{/if}}
                    {{#if MyInvoisDocument.supplier.sst_no}}
                    <strong>SST Registration Number:</strong> {{MyInvoisDocument.supplier.sst_no}}<br>
                    {{/if}}
                    {{#if MyInvoisDocument.supplier.tourism_tax_reg_no}}
                    <strong>Tourism Tax Reg No:</strong> {{MyInvoisDocument.supplier.tourism_tax_reg_no}}<br>
                    {{/if}}
                    {{#if MyInvoisDocument.supplier.email}}
                    <strong>Email:</strong> {{MyInvoisDocument.supplier.email}}<br>
                    {{/if}}
                    {{#if MyInvoisDocument.supplier.contact_no}}
                    <strong>Telephone:</strong> {{MyInvoisDocument.supplier.contact_no}}<br>
                    {{/if}}
                    <strong>Address:</strong> {{nl2br MyInvoisDocument.supplier.address_formatted}}<br>
                    {{#if MyInvoisDocument.supplier.msic_code}}
                    <strong>MSIC Code:</strong> {{MyInvoisDocument.supplier.msic_code}}<br>
                    {{/if}}
                    {{#if MyInvoisDocument.supplier.msic_description}}
                    <strong>Business Activity:</strong> {{MyInvoisDocument.supplier.msic_description}}
                    {{/if}}
                </div>
            </div>

            <!-- Buyer -->
            <div class="party-box customer-box">
                <div class="party-label">{{#if MyInvoisDocument.document_info.is_self_billed}}TO (Company):{{else}}TO:{{/if}}</div>
                <div class="party-name">{{upper MyInvoisDocument.buyer.name}}</div>
                <div class="party-details">
                    <strong>TIN:</strong> {{MyInvoisDocument.buyer.tin}}<br>
                    {{#if MyInvoisDocument.buyer.id_type}}
                    <strong>ID Type/Number:</strong> {{MyInvoisDocument.buyer.id_type}}/{{MyInvoisDocument.buyer.id_no}}<br>
                    {{/if}}
                    {{#if MyInvoisDocument.buyer.sst_no}}
                    <strong>SST Registration Number:</strong> {{MyInvoisDocument.buyer.sst_no}}<br>
                    {{/if}}
                    {{#if MyInvoisDocument.buyer.email}}
                    <strong>Email:</strong> {{MyInvoisDocument.buyer.email}}<br>
                    {{else}}
                    <strong>Email:</strong> ----<br>
                    {{/if}}
                    {{#if MyInvoisDocument.buyer.contact_no}}
                    <strong>Telephone:</strong> {{MyInvoisDocument.buyer.contact_no}}<br>
                    {{/if}}
                    <strong>Address:</strong> {{nl2br MyInvoisDocument.buyer.address_formatted}}
                </div>
            </div>

            <!-- Invoice Box -->
            <div class="party-box invoice-box">
                <div class="qr-code">
                    {{#if MyInvoisDocument.myinvois.qr_code}}
                    <img src="{{MyInvoisDocument.myinvois.qr_code}}" alt="QR Code" />
                    {{else}}
                    <div class="qr-placeholder">QR Code</div>
                    {{/if}}
                </div>
                <div class="invoice-meta">
                    <strong>e-Invoice No:</strong> {{default MyInvoisDocument.myinvois.long_id (default MyInvoisDocument.myinvois.submission_uid '----')}}<br>
                    <strong>UUID:</strong> {{default MyInvoisDocument.doc_details.uuid '----'}}<br>
                    <strong>Issuance Date:</strong> {{formatDate MyInvoisDocument.myinvois.issuance_date}}<br>
                    <strong>Submission Date:</strong> {{formatDate MyInvoisDocument.myinvois.submission_date}}<br>
                    <strong>Validation Date:</strong> {{formatDate MyInvoisDocument.myinvois.validation_date}}
                </div>
            </div>
        </div>

        <!-- Line Items Section -->
        <div class="table-section">
            <div class="section-title">
                <span>Line Items</span>
                <span class="currency-label">Currency Code: <strong>{{default MyInvoisDocument.doc_details.currency_code 'MYR'}}</strong></span>
            </div>
            <table>
                <thead>
                    <tr>
                        <th style="width: 25px;">No.</th>
                        <th style="width: 45px;">Code</th>
                        <th>Description</th>
                        <th style="width: 45px;">Qty</th>
                        <th style="width: 30px;">UOM</th>
                        <th style="width: 60px;">Unit Price</th>
                        <th style="width: 60px;">Subtotal</th>
                        <th style="width: 55px;">(A) Disc</th>
                        <th style="width: 55px;">(B) Fee</th>
                        <th style="width: 75px;">Total Ex Tax</th>
                        <th style="width: 55px;">(C) Tax</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each MyInvoisDocument.items}}
                    <tr>
                        <td class="number">{{inc @index}}</td>
                        <td class="number">{{#if classification_codes}}{{classification_codes.[0].code}}{{else}}---{{/if}}</td>
                        <td>
                            {{default item_name description}}
                            {{#if item_description}}<div style="font-size: 7pt; color: #333; margin-top: 1px;"><strong>{{item_description}}</strong></div>{{/if}}
                        </td>
                        <td class="amount">{{formatCurrency quantity}}</td>
                        <td class="number">{{default unit_code 'EA'}}</td>
                        <td class="amount">{{formatCurrency price}}</td>
                        <td class="amount">{{formatCurrency (multiply price quantity)}}</td>
                        <td class="amount">{{formatCurrency disc_amt}}</td>
                        <td class="amount">{{formatCurrency charge_amt}}</td>
                        <td class="amount">{{formatCurrency taxable}}</td>
                        <td class="amount">{{formatCurrency vat_amt}}</td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>

            <!-- Sub-tables for each item -->
            {{#each MyInvoisDocument.items}}
            {{#if (gt disc_amt 0)}}
            <div class="sub-table">
                <table style="width: 55%;">
                    <tr>
                        <td colspan="4" style="font-weight: bold; background: #f5f5f5;">(A) Discount - Item {{inc @index}}</td>
                    </tr>
                    <tr>
                        <th style="width: 30px;">No.</th>
                        <th style="width: 75px;">Amount</th>
                        <th style="width: 90px;">Discount Rate (%)</th>
                        <th>Description</th>
                    </tr>
                    <tr>
                        <td class="number">1</td>
                        <td class="amount">{{formatCurrency disc_amt}}</td>
                        <td class="amount">{{disc_perc}}% | --</td>
                        <td>--</td>
                    </tr>
                </table>
            </div>
            {{/if}}

            {{#if (gt charge_amt 0)}}
            <div class="sub-table">
                <table style="width: 55%;">
                    <tr>
                        <td colspan="4" style="font-weight: bold; background: #f5f5f5;">(B) Fee / Charges - Item {{inc @index}}</td>
                    </tr>
                    <tr>
                        <th style="width: 30px;">No.</th>
                        <th style="width: 75px;">Amount</th>
                        <th style="width: 90px;">Fee/Charge Rate (%)</th>
                        <th>Description</th>
                    </tr>
                    <tr>
                        <td class="number">1</td>
                        <td class="amount">{{formatCurrency charge_amt}}</td>
                        <td class="amount">{{charge_perc}}% | --</td>
                        <td>--</td>
                    </tr>
                </table>
            </div>
            {{/if}}

            {{#if tax_types}}
            {{#if (length tax_types)}}
            <div class="sub-table">
                <table style="width: 65%;">
                    <tr>
                        <td colspan="6" style="font-weight: bold; background: #f5f5f5;">(C) Total Tax Amount - Item {{inc @index}}</td>
                    </tr>
                    <tr>
                        <th style="width: 30px;">No.</th>
                        <th>Tax Type</th>
                        <th style="width: 65px;">No of Units</th>
                        <th style="width: 70px;">Rate/Unit</th>
                        <th style="width: 55px;">Tax Rate</th>
                        <th style="width: 70px;">Amount</th>
                    </tr>
                    {{#each tax_types}}
                    <tr>
                        <td class="number">{{inc @index}}</td>
                        <td>{{tax_name}}</td>
                        <td class="amount">0.00</td>
                        <td class="amount">0.00</td>
                        <td class="amount">{{rate}}%</td>
                        <td class="amount">{{formatCurrency tax_amt}}</td>
                    </tr>
                    {{/each}}
                </table>
            </div>
            {{/if}}
            {{/if}}
            {{/each}}

            <div class="abbreviations">
                <strong>Abbreviations:</strong> Code - Classification Code, UOM - Unit of Measurement, (..) - Additional data present
            </div>
        </div>

        <!-- Summary Section -->
        <div class="summary-section">
            <div class="summary-left">
                <!-- Tax summary would go here -->
                <table class="summary-table" style="margin-top: 8px;">
                    <tr>
                        <td style="font-weight: bold;">Currency Code</td>
                    </tr>
                    <tr>
                        <td><strong>{{default MyInvoisDocument.doc_details.currency_code 'MYR'}}</strong></td>
                    </tr>
                    <tr>
                        <td style="font-weight: bold;">Exchange Rate</td>
                    </tr>
                    <tr>
                        <td>{{default MyInvoisDocument.doc_details.exchange_rate '----'}}</td>
                    </tr>
                </table>
            </div>

            <div class="summary-right">
                <table class="summary-table">
                    <tr>
                        <td class="label">Total Tax Amount</td>
                        <td class="value">{{formatCurrency MyInvoisDocument.document.vat}}</td>
                    </tr>
                    <tr>
                        <td class="label">Total Net Amount</td>
                        <td class="value">{{formatCurrency (divide MyInvoisDocument.document.total MyInvoisDocument.document.ccrate)}}</td>
                    </tr>
                    {{#if (gt MyInvoisDocument.document.dld 0)}}
                    <tr>
                        <td class="label">{{MyInvoisDocument.document_info.type_display}} Additional Discount Amount (DLD)</td>
                        <td class="value">{{formatCurrency MyInvoisDocument.document.dld}}</td>
                    </tr>
                    {{/if}}
                    {{#if (gt MyInvoisDocument.document.dlc 0)}}
                    <tr>
                        <td class="label">{{MyInvoisDocument.document_info.type_display}} Additional Fee / Charge Amount (DLC)</td>
                        <td class="value">{{formatCurrency MyInvoisDocument.document.dlc}}</td>
                    </tr>
                    {{/if}}
                    <tr class="total-row">
                        <td class="label"><strong>Total Payable Amount</strong></td>
                        <td class="value"><strong>{{formatCurrency (divide MyInvoisDocument.document.grand_total MyInvoisDocument.document.ccrate)}}</strong></td>
                    </tr>
                </table>
            </div>
        </div>

        <!-- DLD Section -->
        {{#if (gt MyInvoisDocument.document.dld 0)}}
        <div class="info-section">
            <div class="info-title">{{MyInvoisDocument.document_info.type_display}} Additional Discount Details (DLD)</div>
            <div class="info-content">
                <table class="info-table">
                    <tr>
                        <th>Discount Rate (%)</th>
                        <th>Amount</th>
                        <th>Description</th>
                    </tr>
                    <tr>
                        <td>{{formatCurrency MyInvoisDocument.document.discount_rate}}</td>
                        <td>{{formatCurrency MyInvoisDocument.document.dld}}</td>
                        <td>{{default MyInvoisDocument.doc_details.discount_description '----'}}</td>
                    </tr>
                </table>
            </div>
        </div>
        {{/if}}

        <!-- DLC Section -->
        {{#if (gt MyInvoisDocument.document.dlc 0)}}
        <div class="info-section">
            <div class="info-title">{{MyInvoisDocument.document_info.type_display}} Additional Fee / Charge Details (DLC)</div>
            <div class="info-content">
                <table class="info-table">
                    <tr>
                        <th>Fee/Charge Rate (%)</th>
                        <th>Amount</th>
                        <th>Description</th>
                    </tr>
                    <tr>
                        <td>{{formatCurrency MyInvoisDocument.document.fee_rate}}</td>
                        <td>{{formatCurrency MyInvoisDocument.document.dlc}}</td>
                        <td>{{default MyInvoisDocument.doc_details.fee_description '----'}}</td>
                    </tr>
                </table>
            </div>
        </div>
        {{/if}}

        <!-- Bank Details Section -->
        {{#if MyInvoisDocument.bank.name}}
        <div class="info-section">
            <div class="info-title">Bank Details</div>
            <div class="info-content">
                <strong>Bank Name:</strong> {{MyInvoisDocument.bank.name}}<br>
                {{#if MyInvoisDocument.bank.acc_name}}
                <strong>Account Name:</strong> {{MyInvoisDocument.bank.acc_name}}<br>
                {{/if}}
                {{#if MyInvoisDocument.bank.acc_no}}
                <strong>Account No:</strong> {{MyInvoisDocument.bank.acc_no}}
                {{/if}}
            </div>
        </div>
        {{/if}}

        <!-- Seal & Signature Section -->
        {{#if MyInvoisDocument.supplier.seal}}
        <div class="seal-signature-section">
            <div class="seal-signature-box">
                {{#if MyInvoisDocument.supplier.signature}}
                <div class="seal-signature-images">
                    <img class="seal-img" src="{{MyInvoisDocument.supplier.seal}}" alt="Seal" />
                    <img class="signature-img" src="{{MyInvoisDocument.supplier.signature}}" alt="Signature" />
                </div>
                {{else}}
                <div class="seal-signature-images seal-only">
                    <img class="seal-img" src="{{MyInvoisDocument.supplier.seal}}" alt="Seal" />
                </div>
                {{/if}}
                <div class="seal-signature-line">Authorised Signature &amp; Stamp</div>
                <div class="seal-signature-name">{{upper MyInvoisDocument.supplier.name}}</div>
            </div>
        </div>
        {{else}}
        {{#if MyInvoisDocument.supplier.signature}}
        <div class="seal-signature-section">
            <div class="seal-signature-box">
                <div class="seal-signature-images signature-only">
                    <img class="signature-img" src="{{MyInvoisDocument.supplier.signature}}" alt="Signature" />
                </div>
                <div class="seal-signature-line">Authorised Signature</div>
                <div class="seal-signature-name">{{upper MyInvoisDocument.supplier.name}}</div>
            </div>
        </div>
        {{/if}}
        {{/if}}
    </div>
</body>
</html>
