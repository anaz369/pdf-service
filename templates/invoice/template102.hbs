<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<title>Invoice - {{basicdetails.[0].inv_no}}</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: Arial, Helvetica, sans-serif;
    font-size: 10px;
    color: #000;
    background: #fff;
  }

  .page {
    margin: 0 8mm;
    background: #fff;
  }

   /* ══════════════════════════════════════
     TOP SECTION  (two equal halves)
     LEFT  : Bill To address + VAT/CR
     RIGHT : TAX INVOICE title + meta rows
  ══════════════════════════════════════ */
  .top-section {
    display: flex;
    align-items: flex-start;
    width: 100%;

  }

  /* ── LEFT COLUMN ── */
  .left-col {
    width: 48%;
  }

  /* Bill To heading */
  .bill-to-heading {
    font-weight: bold;
    font-size: 11.5px;
  }

  /* English address block */
  .addr-en-ar {
    display: flex;
    gap: 0;
  }

  .addr-en {
    width: 50%;
    font-size: 11px;
  }

  .addr-ar {
    width: 50%;
    font-size: 11px;
    text-align: right;
    direction: ltr;
  }

  /* Arabic "تمت محاسبته عل" heading */
  .addr-ar-heading {
    font-weight: bold;
    font-size: 11.5px;
    direction: rtl;
    text-align: right;
  }

  /* VAT / CR rows — with top border line separating from address */

  .vat-cr-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 11px;
  }

  .vat-cr-en {
    white-space: nowrap;
  }

  .vat-cr-ar {
    direction: rtl;
    text-align: right;
    font-size: 11px;
    color: #000;
  }

    .center-col{
        width: 2%;
    }
  /* ── RIGHT COLUMN ── */
  .right-col {
    width: 50%;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
  }

  /* TAX INVOICE title */
  .invoice-title {
    width: 100%;
    text-align: center;
    font-size: 20px;
    font-weight: bold;
    margin-bottom: 8px;
    direction: rtl;
  }

  /* Meta table — sits in right column */
  .meta-table {
    width: 100%;
    border-collapse: collapse;
  }

  .meta-table td {
    padding: 2.5px 4px;
    font-size: 11px;
    vertical-align: middle;
    white-space: nowrap;
  }

  /* Col 1: English label */
  .meta-table td.m-label {
    font-weight: normal;
    color: #000;
  }

  /* Col 2: Value */
  .meta-table td.m-value {
    color: #000;
    padding-right: 3px;
  }

  /* Col 3: Arabic label */
  .meta-table td.m-ar {
    direction: rtl;
    text-align: right;
    color: #000;
    font-size: 11px;
  }

  /* ─── ITEMS TABLE ─── */
  .items-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 10px;
    margin-bottom: 0;
  }

  .items-table thead tr th {
    background-color: #000;
    color: #ffffff;
    text-align: center;
    padding: 4px 4px;
    font-size: 9px;
    font-weight: bold;
    border: 1px solid #fff;
    line-height: 1.35;
  }

  .items-table thead th .ar {
    display: block;
    font-size: 8.5px;
     font-weight: bold;
    direction: rtl;
  }

  .items-table tbody td {
    padding: 4px 5px;
    text-align: center;
    font-size: 9.5px;
    vertical-align: middle;
  }

  .items-table tbody td.desc {
    text-align: left;
    padding-left: 6px;
  }

  .items-table tbody td.sl {
    font-weight: 600;
    width: 22px;
  }


  /* ─── BOTTOM SECTION ─── */
  .bottom-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-top: 8px;
    gap: 16px;
  }

  .terms-col {
    width: 48%;
    flex: 1;
    font-size: 9.5px;
    line-height: 1.7;
    padding-top: 2px;
  }

  .terms-col .terms-heading {
    font-weight: bold;
    font-size: 9.5px;
  }

  /* ─── TOTALS TABLE ─── */
  .totals-table {
    width: 53.5%;
    border-collapse: collapse;
    flex-shrink: 0;
  }

  .totals-table td {
    border: 1px solid #000;
    padding: 2px 4px;
    font-size: 9.5px;
    vertical-align: middle;
  }

  /* Col 1: label (en) */
  .totals-table td.t-label {
    text-align: left;
  }

  /* Col 2: label (ar) */
  .totals-table td.t-label-ar {
    direction: rtl;
    text-align: right;
    font-size: 9px;
  }

  /* Col 3: amount */
  .totals-table td.t-amount {
    text-align: right;
  }

  /* ─── AMOUNT IN WORDS ─── */
  .words-box {
    margin-top: 10px;
    border: 1.5px solid black;
  }

  .words-header {
    background: #000;
    color: #fff;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 5px 10px;
    font-weight: bold;
    font-size: 9.5px;
  }

  .words-header .ar {
    direction: rtl;
    font-size: 9.5px;
    font-weight: bold;

  }

  .words-body {
    padding: 6px 10px;
    font-size: 9.5px;
    background: #fff;
  }

  /* ─── BANK ACCOUNT DETAILS + QR ─── */
  .bank-section {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-top: 14px;
  }

  .bank-col {
    width: 60%;
  }

  .bank-heading {
    padding: 2px 4px;
    font-weight: bold;
    font-size: 11px;
    margin-bottom: 6px;
  }

  .bank-table {
    border-collapse: collapse;
  }

  .bank-table td {
    padding: 2px 4px;
    font-size: 10px;
    vertical-align: top;
  }

  .bank-table td.b-label {
    width: 130px;
  }

  .qr-col {
    width: 40%;
    text-align: right;
  }

  .qr-col img {
    width: 120px;
    height: 120px;
    display: inline-block;
  }

</style>
</head>
<body>
<div class="page">

  <!-- ══ TOP SECTION ══ -->
  <div class="top-section">

    <!-- LEFT: Bill To address -->
    <div class="left-col">

      <!-- Row 1: English heading | Arabic heading -->
      <div class="addr-en-ar" style="margin-bottom:4px;">
        <div class="addr-en">
          <div class="bill-to-heading">Bill To</div>
        </div>
        <div class="addr-ar">
          <div style="font-weight:bold;font-size:11.5px;margin-bottom:5px;">تمت محاسبته على</div>
        </div>
      </div>

      <!-- Row 2: English address lines | Arabic address lines -->
      <div class="addr-en-ar">
        <div class="addr-en">
          {{billing_address.[0].name}}<br>
          {{billing_address.[0].address_line1}}<br>
          {{billing_address.[0].address_line2}}<br>
          {{billing_address.[0].address_line3}}<br>
          {{billing_address.[0].address_line4}}<br>
          {{billing_address.[0].address_line5}}
        </div>
        <div class="addr-ar">
          {{billing_address_lang2.[0].name}}<br>
          {{billing_address_lang2.[0].address_line1}}<br>
          {{billing_address_lang2.[0].address_line2}}<br>
          {{billing_address_lang2.[0].address_line3}}<br>
          {{billing_address_lang2.[0].address_line4}}<br>
          {{billing_address_lang2.[0].address_line5}}
        </div>
      </div>

      <!-- VAT / CR rows -->
      <div class="vat-cr-block">
        <div class="vat-cr-row">
          <span class="vat-cr-en">VAT Number : {{billing_address.[0].vat}}</span>
        </div>
        <div class="vat-cr-row">
          <span class="vat-cr-en">CR Number &nbsp;: {{customer_details.[0].cr_no}}</span>
        </div>
      </div>

    </div><!-- /left-col -->
    <div class="center-col"></div>
    <!-- RIGHT: Title + Meta -->
    <div class="right-col">

      <!-- TAX INVOICE title -->
      <div class="invoice-title"> فاتورة ضريبية&nbsp;&nbsp; TAX INVOICE</div>

      <!-- Meta rows -->
      <table class="meta-table">
        <tbody>
          <tr>
            <td class="m-label" style="width: 24%;">Invoice Number</td>
            <td class="m-value" style="width: 49%;">{{basicdetails.[0].inv_no}}</td>
            <td class="m-ar" style="width: 27%;">رقم الفاتورة</td>
          </tr>
          <tr>
            <td class="m-label">Invoice Date</td>
            <td class="m-value">{{basicdetails.[0].inv_date}}</td>
            <td class="m-ar">تاريخ الفاتورة</td>
          </tr>
          <tr>
            <td class="m-label">Delivery Date</td>
            <td class="m-value"></td>
            <td class="m-ar"> تاريخ التسليم</td>
          </tr>
          <tr>
            <td class="m-label">P O Number</td>
            <td class="m-value">{{basicdetails.[0].order_no}}</td>
            <td class="m-ar">رقم طلب الشراء</td>
          </tr>
          <tr>
            <td class="m-label">P O Date</td>
            <td class="m-value">{{basicdetails.[0].po_date}}</td>
            <td class="m-ar">تاريخ أمر الشراء</td>
          </tr>
          <tr>
            <td class="m-label">Reference No</td>
            <td class="m-value">{{basicdetails.[0].reference_no}}</td>
            <td class="m-ar">رقم المرجع</td>
          </tr>
            <tr>
            <td class="m-label">VAT Number</td>
            <td class="m-value">{{branch.[0].vat}}</td>
            <td class="m-ar">ضريبة القيمة المضافة</td>
          </tr>
        </tbody>
      </table>

    </div><!-- /right-col -->

  </div><!-- /top-section -->


  <!-- ══ ITEMS TABLE ══ -->
  <table class="items-table">
    <thead>
      <tr>
        <th style="width: 4%;">Sl<br><span class="ar">رقم</span></th>
        <th style="width: 30%;">Item Description<br><span class="ar">وصف السلعة</span></th>
        <th style="width: 8%;">Qty<br><span class="ar">كمية</span></th>
        <th style="width: 8%;">UOM<br><span class="ar">وحدة</span></th>
        <th style="width: 12%;">Unit Rate<br><span class="ar">معدل الوحدة</span></th>
        <th style="width: 12%;">Total<br><span class="ar">المجموع</span></th>
        <th style="width: 12%;">{{datasettingstextvalue.d828}}<br><span class="ar">قيمة الضريبة</span></th>
        <th style="width: 14%;">Grand Total<br><span class="ar">المجموع الإجمالي</span></th>
      </tr>
    </thead>
    <tbody>
      {{#each itemdetails}}
      <tr>
        <td class="sl">{{addOne @index}}</td>
        <td class="desc">{{item_name}}{{name_lang2}}{{description}}</td>
        <td style="text-align: center;">{{formatAmount quantity ../bcdp}}</td>
        <td style="text-align: center;">{{unit}}</td>
        <td style="text-align: right;">{{formatAmount price ../bcdp}}</td>
        <td style="text-align: right;">{{formatAmount taxable ../bcdp}}</td>
        <td style="text-align: right;">{{formatAmount vat_amt ../bcdp}}</td>
        <td style="text-align: right;">{{formatAmount amount ../bcdp}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>

  <!-- ══ BOTTOM: Terms + Totals ══ -->
  <div class="bottom-row">

    <div class="terms-col">
      <div class="terms-heading">Terms and Conditions :</div>
      <div>{{invterms}}</div>
    </div>

    <table class="totals-table">
      <tr>
        <td class="t-label" style="width:30.33%;">Subtotal</td>
        <td class="t-label-ar" style="width: 27%;">المجموع الفرعي</td>
        <td class="t-amount" style="width: 39.67%;">{{formatAmount (divide basicdetails.[0].subtotal ccrate) bcdp}}</td>
      </tr>
        {{#if zatcadiscount}}
            {{#each zatcadiscount}}
            <tr>
                <td class="t-label">{{reason_name}}</td>
                <td class="t-label-ar">{{reason_name_lang2}}</td>
                <td class="t-amount">{{formatAmount (divide dld ../ccrate) ../bcdp}}</td>
            </tr>
            {{/each}}
        {{else}}
            <tr>
                <td class="t-label">Discount</td>
                <td class="t-label-ar">تخفيض</td>
                <td class="t-amount">{{formatAmount (divide basicdetails.[0].discount ccrate) bcdp}}</td>
            </tr>
        {{/if}}
      <tr>
        <td class="t-label">{{datasettingstextvalue.d828}}</td>
        <td class="t-label-ar">ضريبة القيمة المضافة</td>
        <td class="t-amount">{{formatAmount (divide basicdetails.[0].vatamt ccrate) bcdp}}</td>
      </tr>
      <tr>
        <td class="t-label">Total Amount</td>
        <td class="t-label-ar">المبلغ الإجمالي</td>
        <td class="t-amount">{{formatAmount (divide basicdetails.[0].grand_total ccrate) bcdp}}</td>
      </tr>
    </table>

  </div>

  <!-- ══ AMOUNT IN WORDS ══ -->
  <div class="words-box">
    <div class="words-header">
      <span>Total Amount in Words</span>
      <span class="ar">المبلغ الإجمالي بالكلمات</span>
    </div>
    <div class="words-body">
      {{bcamountinwords}}
    </div>
  </div>

  <!-- ══ BANK ACCOUNT DETAILS + QR ══ -->
  <div class="bank-section">

    <div class="bank-col">
      <div class="bank-heading">Bank Account Details</div>
      <table class="bank-table">
        <tr><td class="b-label">Bank Name</td><td>: {{bankdetails.name}}</td></tr>
        <tr><td class="b-label">Account Name</td><td>: {{bankdetails.acc_name}}</td></tr>
        <tr><td class="b-label">Account Number</td><td>: {{bankdetails.acc_no}}</td></tr>
        <tr><td class="b-label">IBAN No</td><td>: {{bankdetails.iban_no}}</td></tr>
        <tr><td class="b-label">SWIFT No</td><td>: {{bankdetails.swift_no}}</td></tr>
        <tr><td class="b-label">Branch Name</td><td>: {{bankdetails.branch_name}},</td></tr>
      </table>
    </div>

    <div class="qr-col">
      {{{qrDataUri qrCodeBase64}}}
    </div>

  </div>

</div>
</body>
</html>
