<html xmlns="http://www.w3.org/1999/xhtml">
<head>
<meta charset="utf-8">
<meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
<meta http-equiv="X-UA-Compatible" content="IE=edge" />
<meta name="format-detection" content="telephone=yes" />
<title>137</title>
   <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<style>
    .invoice_head{
    font-weight: 500;
    font-size: 16px;
    margin-bottom: 5px;
    color: #000;
    text-align: center;
    }
    table{
        width: 100%;
        font-family: Tahoma, sans-serif;
        font-size: 12px;
        vertical-align: top;
    }
    .tablee{
        border: 1px solid #646464;
        font-size: 12px;
    }
    .tablee th{
        padding: 5px 8px;
        color: #000;
        font-weight: normal;
        background-color: #cdcdcd;
        border: 1px solid #646464;
    }
    .tablee td{
        padding: 5px 8px;
        color: #000;
        border: 1px solid #646464;
        vertical-align: top;
        line-height: 16px;
    }
     .tablee1{
        border: 1px solid #646464;
        font-size: 12px;
    }

    .tablee1 td{
        padding: 5px 8px;
        color: #000;
        vertical-align: top;
        background-color: #fff;
        line-height: 16px;
    }
    .table_b{
        border-top: 1px solid #000;
    }
</style>
</head>
<body>
    <div class="section">
        <div class="container">
            <div class="row">
                <div class="col-lg-12 mt-3">
                    <table class="">
                        <tr>
                            <td>INV NO </td>
                            <td>: {{basicdetails.[0].inv_no}}</td>
                            <td class="text-end">{{basicdetails.[0].inv_no_arabic}} :</td>
                            <td class="text-end">رقم الفاتورة</td>
                        </tr>
                        <tr>
                            <td>INV DATE </td>
                            <td>: {{basicdetails.[0].inv_date}}</td>
                            <td class="text-end"> :</td>
                            <td class="text-end">تاريخ الفاتورة</td>
                        </tr>
                        <tr>
                            <td>DESCRIPTION</td>
                            <td>: {{basicdetails.[0].description_of_goods}}</td>
                            <td class="text-end">:</td>
                            <td class="text-end">الوصف</td>
                        </tr>
                    </table>
                </div>
                <div class="col-lg-12 mt-3">
                    <table class="table_b">
                        <tr>
                            <th>{{billing_address.[0].name}}</th>
                            <th>{{billing_address_lang2.[0].name}}</th>
                            <td class="text-end">ALL PRICES ARE IN {{basicdetails.[0].isocode}} /موجودة األسعار جميع </td>
                        </tr>
                        {{#if billing_address.[0].address_line1}}
                        <tr>
                            <th>{{billing_address.[0].address_line1}}</th>
                            <th>{{billing_address_lang2.[0].address_line1}}</th>
                        </tr>
                        {{/if}}
                        {{#if billing_address.[0].address_line2}}
                        <tr>
                            <th>{{billing_address.[0].address_line2}}</th>
                            <th>{{billing_address_lang2.[0].address_line2}}</th>
                        </tr>
                        {{/if}}
                        {{#if billing_address.[0].address_line3}}
                        <tr>
                            <th>{{billing_address.[0].address_line3}}</th>
                            <th>{{billing_address_lang2.[0].address_line3}}</th>
                        </tr>
                        {{/if}}
                        {{#if billing_address.[0].address_line4}}
                        <tr>
                            <th>{{billing_address.[0].address_line4}}</th>
                            <th>{{billing_address_lang2.[0].address_line4}}</th>
                        </tr>
                        {{/if}}
                        {{#if billing_address.[0].address_line5}}
                        <tr>
                            <th>{{billing_address.[0].address_line5}}</th>
                            <th>{{billing_address_lang2.[0].address_line5}}</th>
                        </tr>
                        {{/if}}
                        {{#if billing_address.[0].vat}}
                        <tr>
                            <th>{{billing_address.[0].vat}}</th>
                            <th>رقم ضريبة العميل</th>
                        </tr>
                        {{/if}}
                    </table>
                </div>

                <div class="col-lg-12 mt-4">
                    <table class="tablee">
                        <thead>
                            <tr>
                                <th class="text-center">TKT NO<br>رقم التذكرة</th>
                                <th class="text-center">PAX<br>اسم الراكب</th>
                                <th class="text-center">SECTOR<br>قسم</th>
                                <th class="text-center">AIRLINE<br>شركة طيران</th>
                                <th class="text-center">TRAVEL DATES<br>مواعيد السفر</th>
                                <th class="text-center">FARE<br>أجرة</th>
                                <th class="text-center">SERVICE <br>CHARGE<br>تكلفة الخدمة</th>
                                <th class="text-center">VAT<br>ضريبة القيمة <br>  المضافة </th>
                                <th class="text-center">TOTAL<br>المجموع</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#each itemdetails}}
                            <tr>
                                <td class="text-end">{{pnr}}</td>
                                <td class="text-end">{{passenger_name}}</td>
                                <td class="text-end">{{sector}}</td>
                                <td class="text-end">{{transportation}}</td>
                                <td class="text-end">{{description}}</td>
                                <td class="text-end">{{formatAmount price ../bcdp}}</td>
                                <td class="text-end">{{formatAmount disc_amt ../bcdp}}</td>
                                <td class="text-end">{{formatAmount tax ../bcdp}}</td>
                                <td class="text-end">{{formatAmount amount ../bcdp}}</td>
                            </tr>
                            {{/each}}
                        </tbody>
                    </table>
                </div>

                <div class="col-lg-12 mt-0">
                    <table class="tablee1">
                        <tr>
                            <td rowspan="8">{{bcamountinwords}}</td>
                            <td class="text-end">TOTAL FARE: </td>
                            <td class="text-end">{{formatAmount basicdetails.[0].subtotal bcdp}}</td>
                        </tr>
                        <tr>
                            <td class="text-end">الأجرة الكلية :</td>
                            <td class="text-end"></td>
                        </tr>
                        <tr>
                            <td class="text-end">TOTAL EXCLUSIVE OF VAT:</td>
                            <td class="text-end">{{formatAmount basicdetails.[0].subtotal bcdp}}</td>
                        </tr>
                        <tr>
                            <td class="text-end">الإجمالي باستثناء ضريبة القيمة المضافة :</td>
                            <td class="text-end"></td>
                        </tr>
                        <tr>
                            <td class="text-end">VAT:</td>
                            <td class="text-end">{{formatAmount basicdetails.[0].vatamt bcdp}}</td>
                        </tr>
                        <tr>
                            <td class="text-end">ضريبة القيمة المضافة :</td>
                            <td class="text-end"></td>
                        </tr>
                        <tr>
                            <td class="text-end">TOTAL INCLUSIVE OF VAT:</td>
                            <td class="text-end">{{formatAmount basicdetails.[0].grand_total bcdp}}</td>
                        </tr>
                        <tr>
                            <td class="text-end">الإجمالي شامل ضريبة القيمة المضافة :</td>
                            <td class="text-end"></td>
                        </tr>
                    </table>
                </div>
                <div class="col-lg-2 col-md-2 col-sm-2 mt-3">
                    <table class="tablee1">
                        <tr>
                            <td class="text-center">
                                {{#if qrCodeBase64}}
                                {{{qrDataUri qrCodeBase64}}}
                                {{/if}}
                            </td>
                        </tr>
                    </table>
                </div>
                <div class="col-lg-10 col-md-10 col-sm-10 mt-3">
                    {{#if invterms}}
                    <p>{{{nl2br invterms}}}</p>
                    {{/if}}
                </div>
                <div class="col-lg-4 col-md-4 col-sm-4 mt-3">
                    {{#if bankdetails}}
                    <table>
                        <tr>
                            <th colspan="2">OUR BANK ACCOUNT DETAILS:</th>
                        </tr>
                        {{#if bankdetails.name}}
                        <tr>
                            <td>BANK NAME </td>
                            <td>: {{bankdetails.name}}</td>
                        </tr>
                        {{/if}}
                        {{#if bankdetails.branch_name}}
                        <tr>
                            <td>BRANCH NAME </td>
                            <td>: {{bankdetails.branch_name}}</td>
                        </tr>
                        {{/if}}
                        {{#if bankdetails.acc_name}}
                        <tr>
                            <td>BENEFICIARY NAME</td>
                            <td>: {{bankdetails.acc_name}}</td>
                        </tr>
                        {{/if}}
                        {{#if bankdetails.acc_no}}
                        <tr>
                            <td>ACCOUNT NUMBER</td>
                            <td>: {{bankdetails.acc_no}}</td>
                        </tr>
                        {{/if}}
                        {{#if bankdetails.iban_no}}
                        <tr>
                            <td>IBAN NUMBER</td>
                            <td>: {{bankdetails.iban_no}}</td>
                        </tr>
                        {{/if}}
                    </table>
                    {{/if}}
                </div>
                <div class="col-lg-8 col-md-8 col-sm-8 mt-3">
                    <table class="text-center">
                        <tr>
                            <th>
                                Signature
                                {{#if Signature}}<br><img src="{{Signature}}" alt="Signature" style="max-height:40px; max-width:80px; margin-top:4px;"/>{{/if}}
                            </th>
                            <th>
                                Stamp
                                {{#if Seal}}<br><img src="{{Seal}}" alt="Seal" style="max-height:60px; max-width:60px; margin-top:4px;"/>{{/if}}
                            </th>
                        </tr>
                    </table>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
