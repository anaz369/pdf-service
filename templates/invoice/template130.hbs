<html xmlns="http://www.w3.org/1999/xhtml">
<head>
<meta charset="utf-8">
<meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
<meta http-equiv="X-UA-Compatible" content="IE=edge" />
<meta name="format-detection" content="telephone=yes" />
<title>130</title>
   <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<style>
    .invoice_head{
    font-weight: 500;
    font-size: 16px;
    margin-bottom: 5px;
    color: #000;
    text-align: center;
    }
    table{
        width: 100%;
        font-family: Tahoma, sans-serif;
        font-size: 12px;
        vertical-align: top;
    }
    .tablee{
        border: 1px solid #6b6b6b;
        font-size: 12px;
    }
    .tablee th{
        padding: 5px 8px;
        color: #000;
        font-weight: normal;
        background-color: #eaeeea;
    }
    .tablee td{
        padding: 5px 8px;
        color: #000;
        border: 1px solid #6b6b6b;
        vertical-align: top;
        background-color: #f4f7f4;
        line-height: 16px;
    }
     .tablee1{
        border: 1px solid #6b6b6b;
        font-size: 12px;
    }
    .tablee1 th{
        padding: 5px 8px;
        color: #000;
        font-weight: normal;
        background-color: #eaeeea;
        border: 1px solid #6b6b6b;
    }
    .tablee1 th p{
        margin-bottom: 0;
        display: flex;

    }
    .tablee1 th p span{
        flex: auto;
        border-right: #fff solid 1px;
        padding: 8px 0px;
    }
    .tablee1 th p span:last-child{
        border-right: 0px;
    }
    .tablee1 td{
        padding: 5px 8px;
        color: #000;
        border: 1px solid #6b6b6b;
        vertical-align: top;
        background-color: #fff;
        line-height: 16px;
    }

</style>
</head>
<body>
    <div class="section">
        <div class="container">
            <div class="row">
                <div class="col-lg-12 mt-3">
                    <h5 class="invoice_head">TAX INVOICE /  ضريبية فاتورة</h5>
                </div>
                <div class="col-lg-5 col-md-5 col-sm-5 mt-3">
                    <table class="tablee">
                        <tr>
                            <th>Bill To :</th>
                            <th class="text-end">فاتورة إلى</th>
                        </tr>
                        <tr>
                            <td>{{billing_address.[0].name}}<br>
{{#if billing_address.[0].address_line1}}{{billing_address.[0].address_line1}}<br>{{/if}}
{{#if billing_address.[0].address_line2}}{{billing_address.[0].address_line2}}<br>{{/if}}
{{#if billing_address.[0].address_line3}}{{billing_address.[0].address_line3}}<br>{{/if}}
{{#if billing_address.[0].address_line4}}{{billing_address.[0].address_line4}}<br>{{/if}}
{{#if billing_address.[0].address_line5}}{{billing_address.[0].address_line5}}<br>{{/if}}
{{#if billing_address.[0].address_code}}{{billing_address.[0].address_code}}<br>{{/if}}
{{#if billing_address.[0].vat}}VAT : {{billing_address.[0].vat}}<br>{{/if}}
{{#if customer_details.[0].contact_no1}}Ph : {{customer_details.[0].contact_no1}}{{/if}}</td>
                            <td class="text-end">
{{#if billing_address_lang2.[0].name}}{{billing_address_lang2.[0].name}}<br>{{/if}}
{{#if billing_address_lang2.[0].address_line1}}{{billing_address_lang2.[0].address_line1}}<br>{{/if}}
{{#if billing_address_lang2.[0].address_line2}}{{billing_address_lang2.[0].address_line2}}<br>{{/if}}
{{#if billing_address_lang2.[0].address_line3}}{{billing_address_lang2.[0].address_line3}}<br>{{/if}}
{{#if billing_address_lang2.[0].address_line4}}{{billing_address_lang2.[0].address_line4}}<br>{{/if}}
{{#if billing_address_lang2.[0].address_line5}}{{billing_address_lang2.[0].address_line5}}<br>{{/if}}
{{#if billing_address_lang2.[0].address_code}}{{billing_address_lang2.[0].address_code}}<br>{{/if}}
{{#if billing_address_lang2.[0].vat}}{{billing_address_lang2.[0].vat}}{{/if}}
                            </td>
                        </tr>
                    </table>
                </div>
                <div class="col-lg-2 col-md-2 col-sm-2 mt-3 pe-0 ps-0">
                    <table class="tablee">
                        <tr>
                            <td>Cust No</td>
                            <td>{{customer_details.[0].profile_code}}</td>
                        </tr>
                        <tr>
                            <td>Inv No. </td>
                            <td>{{basicdetails.[0].inv_no}}</td>
                        </tr>
                        <tr>
                            <td>Inv Date. </td>
                            <td>{{basicdetails.[0].inv_date}}</td>
                        </tr>
                        <tr>
                            <td>Due Date</td>
                            <td>{{basicdetails.[0].due_date}}</td>
                        </tr>
                        <tr>
                            <td>Page No.</td>
                            <td>1/1</td>
                        </tr>
                    </table>
                </div>
                <div class="col-lg-5 col-md-5 col-sm-5 mt-3">
                    <table class="tablee">
                        <tr>
                            <th>Ship To :</th>
                            <th class="text-end">مرسل إلى</th>
                        </tr>
                        <tr>
                            <td>{{shipping_address.[0].name}}<br>
{{#if shipping_address.[0].address_line1}}{{shipping_address.[0].address_line1}}<br>{{/if}}
{{#if shipping_address.[0].address_line2}}{{shipping_address.[0].address_line2}}<br>{{/if}}
{{#if shipping_address.[0].address_line3}}{{shipping_address.[0].address_line3}}<br>{{/if}}
{{#if shipping_address.[0].address_line4}}{{shipping_address.[0].address_line4}}<br>{{/if}}
{{#if shipping_address.[0].address_line5}}{{shipping_address.[0].address_line5}}<br>{{/if}}
{{#if shipping_address.[0].address_code}}{{shipping_address.[0].address_code}}{{/if}}</td>
                            <td class="text-end">
{{#if shipping_address_lang2.[0].name}}{{shipping_address_lang2.[0].name}}<br>{{/if}}
{{#if shipping_address_lang2.[0].address_line1}}{{shipping_address_lang2.[0].address_line1}}<br>{{/if}}
{{#if shipping_address_lang2.[0].address_line2}}{{shipping_address_lang2.[0].address_line2}}<br>{{/if}}
{{#if shipping_address_lang2.[0].address_line3}}{{shipping_address_lang2.[0].address_line3}}<br>{{/if}}
{{#if shipping_address_lang2.[0].address_line4}}{{shipping_address_lang2.[0].address_line4}}<br>{{/if}}
{{#if shipping_address_lang2.[0].address_line5}}{{shipping_address_lang2.[0].address_line5}}<br>{{/if}}
{{#if shipping_address_lang2.[0].address_code}}{{shipping_address_lang2.[0].address_code}}{{/if}}
                            </td>
                        </tr>
                    </table>
                </div>


                <div class="col-lg-12">
                    <table class="tablee1 mt-1">
                        <tr>
                            <th>
                                <p>
                                    <span>Salesman No</span>
                                    <span class="text-end">رقم البائع</span>
                                </p>
                            </th>
                            <th>
                                <p>
                                    <span>P.O.No</span>
                                    <span class="text-end">أمر الشراء</span>
                                </p>
                            </th>
                            <th>
                                <p>
                                    <span>Shipping Date</span>
                                    <span class="text-end">تاريخ الشحن</span>
                                </p>
                            </th>
                            <th>
                                <p>
                                    <span>Payment Terms</span>
                                    <span class="text-end">شروط السداد</span>
                                </p>
                            </th>
                            <th>
                                <p>
                                    <span>VAT %</span>
                                    <span class="text-end">الضريبة</span>
                                </p>
                            </th>
                        </tr>
                        <tr>
                            <td class="text-center">{{basicdetails.[0].salesman_no}}</td>
                            <td class="text-center">{{basicdetails.[0].reference_no}}</td>
                            <td class="text-center">{{basicdetails.[0].sup_date}}</td>
                            <td class="text-center">{{#if customer_details.[0].credit_period}}{{customer_details.[0].credit_period}} Days{{/if}}</td>
                            <td class="text-center">{{#if datasettings.d581}}{{datasettings.d581}} %{{/if}}</td>
                        </tr>
                    </table>
                </div>


                <div class="col-lg-12 mt-0">
                    <table class="tablee1">
                        <thead>
                            <tr>
                                <th class="text-center">التسلس<br>Sl.No</th>
                                <th class="text-center">شفرة<br>Code</th>
                                <th class="text-center">البيانات<br>Description</th>
                                <th class="text-center">الوحدة<br>UOS</th>
                                <th class="text-center">الكمية<br>Qty</th>
                                <th class="text-center">السعر الوحدة<br>UOS Price</th>
                                <th class="text-center">الخصم<br>Disc</th>
                                <th class="text-center">السعر الصافي<br>Net Price</th>
                                <th class="text-center">المجموع الفرعي<br> (بدون ضريبة) <br>Subtotal<br>(w/o vat)</th>
                                <th class="text-center">الضريبة<br>VAT</th>
                                <th class="text-center">الإجمالي<br>Net Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#each itemdetails}}
                            <tr>
                                <td class="text-center">{{addOne @index}}</td>
                                <td class="text-center">{{item_code}}</td>
                                <td class="text-start">{{item_name}}{{#if name_lang2}}<br>{{name_lang2}}{{/if}}{{#if description}} {{description}}{{/if}}</td>
                                <td class="text-center">{{unit}}</td>
                                <td class="text-center">{{formatAmount quantity ../bcdp}}</td>
                                <td class="text-end">{{formatAmount price ../bcdp}}</td>
                                <td class="text-end">{{formatAmount disc_amt ../bcdp}}</td>
                                <td class="text-end">{{formatAmount (subtract price disc_amt) ../bcdp}}</td>
                                <td class="text-end">{{formatAmount taxable ../bcdp}}</td>
                                <td class="text-end">{{formatAmount tax ../bcdp}}</td>
                                <td class="text-end">{{formatAmount amount ../bcdp}}</td>
                            </tr>
                            {{/each}}
                        </tbody>
                    </table>
                </div>

                <div class="col-lg-12 mt-0">
                    <table class="tablee1">
                        <tr>
                            <td class="text-center" rowspan="5">
                                {{#if qrCodeBase64}}
                                {{{qrDataUri qrCodeBase64}}}
                                {{/if}}
                            </td>
                            <td rowspan="3">
                                {{#if bcamountinwords}}
                                <p>Amount in Words :</p>
                                <p>{{bcamountinwords}}</p>
                                {{/if}}
                                {{#if bcamountinwordsar}}
                                <p class="text-end">: بالكلمات {{bcamountinwordsar}}</p>
                                {{/if}}
                            </td>
                            <th class="text-center">(بدون ضريبة) <br>Subtotal</th>
                            <th class="text-center">المجموع الفرعي<br> w/o VAT</th>
                            <td class="text-end">{{formatAmount basicdetails.[0].subtotal bcdp}}</td>
                        </tr>
                        <tr>
                            <th class="text-center">VAT Total</th>
                            <th class="text-center">الضريبة إجمالي </th>
                            <td class="text-end">{{formatAmount basicdetails.[0].vatamt bcdp}}</td>
                        </tr>
                        <tr>
                            <th class="text-center" colspan="2"><b>الصافي الإجمالي  <br>Grand Total</b></th>
                            <td class="text-end"><b>{{formatAmount basicdetails.[0].grand_total bcdp}}</b></td>
                        </tr>
                        <tr>
                            <th class="text-center"> البـــــائـــع: الاسم، التوقيع، رقم الجوال<br><b>Salesman:</b> Name, Signature, Mobile</th>
                            <th class="text-center" colspan="3">العميل: الاسم، التوقيع، الختم، رقم الجوال<br><b>Customer :</b> Name, Signature, Stamp, Mobile No</th>
                        </tr>
                        <tr>
                            <td>
                                {{basicdetails.[0].salesman_name}}
                                {{#if Signature}}<br><img src="{{Signature}}" alt="Signature" style="max-height:40px; max-width:80px;"/>{{/if}}
                            </td>
                            <td colspan="3">
                                {{#if Seal}}<img src="{{Seal}}" alt="Seal" style="max-height:60px; max-width:60px;"/>{{/if}}
                            </td>
                        </tr>
                    </table>
                </div>

            </div>
        </div>
    </div>
</body>
</html>
