<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <title>Final Invoice - {{MyInvoisDocument.document.inv_no}}</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: Arial, sans-serif;
      font-size: 11px;
      color: #000;
      background: #fff;
    }

    .page {
      width: 750px;
      margin: 0 auto;
      padding: 15px 30px;
    }

    /* ── Title ──────────────────────────────────── */
    .invoice-title {
      text-align: center;
      font-size: 16px;
      font-weight: bold;
      margin-bottom: 15px;
      text-decoration: underline;
    }

    /* ── Header layout ─────────────────────────── */
    .header-wrap {
      display: flex;
      justify-content: space-between;
      margin-bottom: 10px;
    }
    .header-left {
      flex: 0 0 55%;
    }
    .header-right {
      flex: 0 0 42%;
    }

    /* ── Field rows ────────────────────────────── */
    .field-row {
      display: flex;
      align-items: baseline;
      margin-bottom: 2px;
      font-size: 11px;
      line-height: 1.6;
    }
    .field-lbl {
      font-weight: bold;
      min-width: 140px;
      flex-shrink: 0;
      font-size: 11px;
    }
    .field-val {
      font-size: 11px;
      color: #000;
    }

    /* ── Shipping row ──────────────────────────── */
    .shipping-wrap {
      display: flex;
      justify-content: space-between;
      margin-bottom: 12px;
      margin-top: 8px;
    }
    .shipping-wrap .ship-col {
      flex: 1;
    }
    .shipping-wrap .field-lbl {
      min-width: 120px;
    }

    /* ── Items table ───────────────────────────── */
    .items-table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 8px;
    }
    .items-table th {
      background: #fff;
      font-size: 10px;
      font-weight: bold;
      padding: 4px 4px;
      text-align: center;
      border: 1px solid #000;
    }
    .items-table td {
      padding: 3px 4px;
      font-size: 10px;
      border: 1px solid #000;
      text-align: center;
      vertical-align: middle;
    }
    .items-table td.td-desc { text-align: left; }
    .items-table td.td-right { text-align: right; }

    /* ── Footer totals ─────────────────────────── */
    .footer-wrap {
      display: flex;
      justify-content: space-between;
      margin-top: 0;
    }
    .footer-left {
      flex: 0 0 48%;
    }
    .footer-right {
      flex: 0 0 50%;
    }

    .totals-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 10px;
    }
    .totals-table td {
      padding: 3px 5px;
      border: 1px solid #000;
      font-size: 10px;
    }
    .totals-table td.t-lbl {
      font-weight: bold;
      text-align: right;
    }
    .totals-table td.t-val {
      text-align: right;
    }

    /* ── Bank + Signature ──────────────────────── */
    .bank-sig-wrap {
      display: flex;
      justify-content: space-between;
      margin-top: 10px;
    }
    .bank-col {
      flex: 0 0 48%;
      font-size: 10px;
      line-height: 1.6;
    }
    .sig-col {
      flex: 0 0 48%;
      text-align: center;
    }
    .sig-line {
      border-top: 1px solid #000;
      margin-top: 40px;
      padding-top: 4px;
      font-weight: bold;
      font-size: 11px;
      text-align: center;
    }
  </style>
</head>
<body>
<div class="page">

  {{!-- ══ TITLE ══ --}}
  <div class="invoice-title">FINAL INVOICE</div>

  {{!-- ══ HEADER: Invoice To (left) | Details (right) ══ --}}
  <div class="header-wrap">

    {{!-- LEFT — Invoice To (Buyer) --}}
    <div class="header-left">
      <div class="field-row">
        <span class="field-lbl">INVOICE TO</span>
      </div>
      <div class="field-row">
        <span class="field-val" style="font-weight: bold;">{{MyInvoisDocument.buyer.name}}</span>
      </div>
      {{#if MyInvoisDocument.buyer.address_formatted}}
      <div class="field-row">
        <span class="field-val">{{{nl2br MyInvoisDocument.buyer.address_formatted}}}</span>
      </div>
      {{/if}}
      <div class="field-row">
        <span class="field-lbl">ATTN :</span>
        <span class="field-val">{{#if basicdetails.[0].attn}}{{basicdetails.[0].attn}}{{/if}}</span>
      </div>
      <div class="field-row">
        <span class="field-lbl">PHONE NO</span>
        <span class="field-val">; {{#if MyInvoisDocument.buyer.contact_no}}{{MyInvoisDocument.buyer.contact_no}}{{/if}}</span>
      </div>
    </div>

    {{!-- RIGHT — Invoice Details --}}
    <div class="header-right">
      <div class="field-row">
        <span class="field-lbl">PORT NAME</span>
        <span class="field-val">{{#if basicdetails.[0].port_of_delivery}}{{basicdetails.[0].port_of_delivery}}{{/if}}</span>
      </div>
      <div class="field-row">
        <span class="field-lbl">INVOICE NO</span>
        <span class="field-val">{{MyInvoisDocument.document.inv_no}}</span>
      </div>
      <div class="field-row">
        <span class="field-lbl">INVOICE DATE</span>
        <span class="field-val">{{formatDate MyInvoisDocument.myinvois.issuance_date}}</span>
      </div>
      <div class="field-row">
        <span class="field-lbl">PO NO</span>
        <span class="field-val">{{#if basicdetails.[0].order_no}}{{basicdetails.[0].order_no}}{{/if}}</span>
      </div>
      <div class="field-row">
        <span class="field-lbl">DUE DATE</span>
        <span class="field-val">{{#if basicdetails.[0].due_date}}{{basicdetails.[0].due_date}}{{/if}}</span>
      </div>
      <div class="field-row">
        <span class="field-lbl">PAYMENT TERM</span>
        <span class="field-val">{{#if basicdetails.[0].payment_terms}}{{basicdetails.[0].payment_terms}}{{/if}}</span>
      </div>
      <div class="field-row">
        <span class="field-lbl">CURRENCY</span>
        <span class="field-val">{{default MyInvoisDocument.doc_details.currency_code 'MYR'}}</span>
      </div>
    </div>

  </div>

  {{!-- ══ SHIPPING DETAILS ══ --}}
  <div class="shipping-wrap">
    <div class="ship-col">
      <div class="field-row">
        <span class="field-lbl">VESSEL NAME :</span>
        <span class="field-val">{{#if basicdetails.[0].vessel_name}}{{basicdetails.[0].vessel_name}}{{/if}}</span>
      </div>
      <div class="field-row">
        <span class="field-lbl">VOY NO :</span>
        <span class="field-val">{{#if basicdetails.[0].voyage_no}}{{basicdetails.[0].voyage_no}}{{/if}}</span>
      </div>
    </div>
    <div class="ship-col">
      <div class="field-row">
        <span class="field-lbl">ARRIVED :</span>
        <span class="field-val">{{#if basicdetails.[0].eta_date}}{{basicdetails.[0].eta_date}}{{/if}}</span>
      </div>
      <div class="field-row">
        <span class="field-lbl">ACTIVITY :</span>
        <span class="field-val">{{#if basicdetails.[0].activity}}{{basicdetails.[0].activity}}{{/if}}</span>
      </div>
    </div>
    <div class="ship-col">
      <div class="field-row">
        <span class="field-lbl">SAILED</span>
        <span class="field-val">{{#if basicdetails.[0].etd_date}}{{basicdetails.[0].etd_date}}{{/if}}</span>
      </div>
    </div>
  </div>

  {{!-- ══ ITEMS TABLE ══ --}}
  <table class="items-table">
    <thead>
      <tr>
        <th style="width:5%;">NO</th>
        <th style="width:35%;">DESCRIPTION</th>
        <th style="width:15%;">TOTAL IN MYR</th>
        <th style="width:10%;">SST</th>
        <th style="width:15%;">DISCOUNT</th>
        <th style="width:20%;">TOTAL IN USD</th>
      </tr>
    </thead>
    <tbody>
      {{#each MyInvoisDocument.items}}
      <tr>
        <td>{{inc @index}}</td>
        <td class="td-desc">
          {{default item_name description}}
        </td>
        <td class="td-right">{{formatCurrency taxable}}</td>
        <td class="td-right">{{formatCurrency vat_amt}}</td>
        <td class="td-right">{{formatCurrency disc_amt}}</td>
        <td class="td-right">{{formatCurrency amount}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>

  {{!-- ══ FOOTER: Words + Totals ══ --}}
  <div class="footer-wrap">

    {{!-- LEFT — In Words --}}
    <div class="footer-left">
      <div style="font-weight: bold; font-size: 11px; margin-top: 4px;">IN WORDS:</div>
      <div style="font-size: 10px; margin-top: 2px;">{{bcamountinwords}}</div>
    </div>

    {{!-- RIGHT — Totals --}}
    <div class="footer-right">
      <table class="totals-table">
        <tr>
          <td class="t-lbl">SUB TOTAL</td>
          <td class="t-val">{{default MyInvoisDocument.doc_details.currency_code 'MYR'}} {{formatCurrency MyInvoisDocument.document.total}}</td>
          <td class="t-val">{{#if MyInvoisDocument.doc_details.exchange_rate}}USD {{formatCurrency (divide MyInvoisDocument.document.total MyInvoisDocument.doc_details.exchange_rate)}}{{/if}}</td>
        </tr>
        <tr>
          <td class="t-lbl">SST</td>
          <td class="t-val">{{formatCurrency MyInvoisDocument.document.vat}}</td>
          <td class="t-val">{{#if MyInvoisDocument.doc_details.exchange_rate}}{{formatCurrency (divide MyInvoisDocument.document.vat MyInvoisDocument.doc_details.exchange_rate)}}{{/if}}</td>
        </tr>
        <tr>
          <td class="t-lbl">DISCOUNT</td>
          <td class="t-val">{{#if MyInvoisDocument.document.dld}}{{formatCurrency MyInvoisDocument.document.dld}}{{/if}}</td>
          <td class="t-val">{{#if MyInvoisDocument.doc_details.exchange_rate}}{{#if MyInvoisDocument.document.dld}}{{formatCurrency (divide MyInvoisDocument.document.dld MyInvoisDocument.doc_details.exchange_rate)}}{{/if}}{{/if}}</td>
        </tr>
        <tr>
          <td class="t-lbl">ADVANCE</td>
          <td class="t-val">{{#if basicdetails.[0].aa}}{{formatAmount basicdetails.[0].aa bcdp}}{{/if}}</td>
          <td class="t-val"></td>
        </tr>
        <tr>
          <td class="t-lbl" style="font-weight: bold;">TOTAL AMOUNT</td>
          <td class="t-val" style="font-weight: bold;">{{default MyInvoisDocument.doc_details.currency_code 'MYR'}} {{formatCurrency MyInvoisDocument.document.grand_total}}</td>
          <td class="t-val" style="font-weight: bold;">{{#if MyInvoisDocument.doc_details.exchange_rate}}USD {{formatCurrency (divide MyInvoisDocument.document.grand_total MyInvoisDocument.doc_details.exchange_rate)}}{{/if}}</td>
        </tr>
      </table>
    </div>

  </div>

  {{!-- ══ BANK DETAILS + SIGNATURE ══ --}}
  <div class="bank-sig-wrap">

    {{!-- LEFT — Bank Details --}}
    <div class="bank-col">
      <div style="font-weight: bold; margin-bottom: 4px;">BANK ACCOUNT DETAILS</div>
      {{#if bankdetails.acc_name}}<div>{{bankdetails.acc_name}}</div>{{/if}}
      {{#if bankdetails.acc_no}}<div>{{bankdetails.acc_no}}</div>{{/if}}
      {{#if bankdetails.iban_no}}<div>{{bankdetails.iban_no}}</div>{{/if}}
      {{#if bankdetails.swift_no}}<div>{{bankdetails.swift_no}}</div>{{/if}}

      {{#if bankdetails.name}}<div style="margin-top: 8px;">{{bankdetails.name}}</div>{{/if}}
      {{#if bankdetails.branch_name}}<div>{{bankdetails.branch_name}}</div>{{/if}}
    </div>

    {{!-- RIGHT — For Company + Signature --}}
    <div class="sig-col">
      <div style="font-weight: bold; font-size: 11px; margin-top: 10px;">FOR {{upper MyInvoisDocument.supplier.name}}</div>

      {{#if Seal}}
      <div style="margin-top: 8px;">
        <img src="{{Seal}}" alt="Seal" style="max-height:{{default datasettings.d458 '50'}}px; max-width:{{default datasettings.d458 '80'}}px;" onerror="this.style.display='none'"/>
      </div>
      {{/if}}

      {{#if Signature}}
      <div style="margin-top: 5px;">
        <img src="{{Signature}}" alt="Signature" style="max-height:{{default datasettings.d459 '50'}}px; max-width:{{default datasettings.d459 '80'}}px;" onerror="this.style.display='none'"/>
      </div>
      {{/if}}

      <div class="sig-line">AUTHORISED SIGNATURE</div>
    </div>

  </div>

</div>
</body>
</html>
