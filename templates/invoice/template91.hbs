<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>INVOICE - {{basicdetails.[0].inv_no}}</title>
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        font-family: "IBM Plex Sans Arabic", Arial, sans-serif;
        font-size: 9px;
        line-height: 1.3;
        color: #000;
        margin: 0 4mm;
      }

      .ar {
        direction: rtl;
      }

      table {
        border-collapse: collapse;
        width: 100%;
        table-layout: fixed;
      }

      /* ── TITLE ────────────────────────────────────── */
      .doc-title {
        text-align: center;
        font-size: 10px;
        font-weight: 800;
        margin-bottom: 6px;
      }

      /* ── TOP : CUSTOMER | INFO | QR ───────────────── */
      .top-wrap > tbody > tr > td {
        vertical-align: top;
        border: none;
        padding: 0 3px;
      }
      .cust {
        border: 1px solid #000;
      }
      .cust td {
        font-size: 9px;
        padding: 2px 6px;
        vertical-align: top;
      }
      .cust .chead {
        font-weight: 700;
        border-bottom: 1px solid #000;
      }
      .cust .arl {
        text-align: right;
        direction: rtl;
      }
      .info td {
        font-size: 9px;
        border: 1px solid #000;
        padding: 3px 6px;
        vertical-align: middle;
      }
      .info td.lbl {
        font-weight: 700;
        width: 42%;
      }
      .qr-cell {
        text-align: center;
        vertical-align: middle;
      }
      .qr-cell img {
        width: 95px;
        height: 95px;
        object-fit: contain;
      }

      /* ── SHIPMENT BANDS ───────────────────────────── */
      .ship {
        margin-top: 6px;
      }
      .ship th,
      .ship td {
        font-size: 9px;
        border: 1px solid #000;
        padding: 3px 4px;
        text-align: center;
        vertical-align: middle;
        line-height: 1.2;
      }
      .ship thead th {
        background: #ececec;
        font-weight: 700;
      }

      /* ── ITEMS TABLE ──────────────────────────────── */
      .items-table {
        margin-top: 6px;
      }
      .items-table th,
      .items-table td {
        font-size: 9px;
        border: 1px solid #000;
        padding: 4px 5px;
        vertical-align: top;
      }
      .items-table thead th {
        background: #ececec;
        text-align: center;
        line-height: 1.2;
      }
      .items-table thead th .ar {
        display: block;
        direction: rtl;
        font-size: 8px;
      }
      .items-table td.num {
        text-align: center;
      }
      .items-table td.right {
        text-align: right;
      }

      /* ── BANK + TOTALS ────────────────────────────── */
      .bt-wrap {
        margin-top: 6px;
      }
      .bt-wrap > tbody > tr > td {
        vertical-align: top;
        border: none;
        padding: 0;
      }
      .bank th,
      .bank td {
        font-size: 9px;
        border: 1px solid #000;
        padding: 4px 6px;
        vertical-align: middle;
      }
      .bank .bhead {
        background: #ececec;
        font-weight: 700;
        text-align: center;
      }
      .bank td.lbl {
        font-weight: 600;
        width: 40%;
      }
      .totals td {
        font-size: 9px;
        border: 1px solid #000;
        padding: 4px 6px;
        vertical-align: middle;
      }
      .totals td.lbl {
        font-weight: 600;
        width: 30%;
      }
      .totals td.arl {
        text-align: right;
        direction: rtl;
        width: 45%;
      }
      .totals td.val {
        text-align: right;
        width: 25%;
      }
      .totals .due td {
        font-weight: 700;
      }
      .totals .words-en td {
        font-weight: 600;
      }

      /* ── TERMS + SIGN ─────────────────────────────── */
      .terms {
        margin-top: 6px;
        border: 1px solid #000;
        border-bottom: none;
        padding: 4px 6px;
      }
      .terms .thead {
        font-weight: 700;
        margin-bottom: 2px;
      }
      .terms .thead .ar {
        direction: rtl;
      }
      .sign-table td {
        font-size: 9px;
        border: 1px solid #000;
        width: 25%;
        vertical-align: top;
        padding: 4px 6px;
      }
      .sign-table .s-head {
        text-align: center;
        font-weight: 700;
        border-bottom: none;
      }
      .sign-table .s-head .ar {
        display: block;
        direction: rtl;
        font-weight: 400;
      }
      .sign-table .s-body {
        text-align: center;
        height: 70px;
      }
      .sign-table .s-body img {
        max-height: 65px;
        max-width: 120px;
      }
    </style>
  </head>
  <body>

    <!-- TITLE -->
    <div class="doc-title"><span class="ar">فاتورة ضريبية</span> / TAX INVOICE</div>

    <!-- TOP : CUSTOMER | INFO | QR -->
    <table class="top-wrap">
      <tr>
        <td style="width:44%">
          <table class="cust">
            <tr><td class="chead" colspan="2">Customer</td></tr>
            <tr><td>{{billing_address.[0].name}}</td><td class="arl">{{billing_address_lang2.[0].name}}</td></tr>
            <tr><td>{{billing_address.[0].address_line1}}</td><td class="arl">{{billing_address_lang2.[0].address_line1}}</td></tr>
            <tr><td>{{billing_address.[0].address_line2}}</td><td class="arl">{{billing_address_lang2.[0].address_line2}}</td></tr>
            <tr><td>{{billing_address.[0].address_line3}}</td><td class="arl">{{billing_address_lang2.[0].address_line3}}</td></tr>
            <tr><td>{{billing_address.[0].address_line4}}</td><td class="arl">{{billing_address_lang2.[0].address_line4}}</td></tr>
            <tr><td>{{billing_address.[0].address_line5}}</td><td class="arl">{{billing_address_lang2.[0].address_line5}}</td></tr>
            <tr><td>VAT No:{{billing_address.[0].vat}}</td><td class="arl">{{billing_address_lang2.[0].vat}}</td></tr>
          </table>
        </td>
        <td style="width:34%">
          <table class="info">
            <tr><td class="lbl">Invoice No</td><td>: {{basicdetails.[0].inv_no}}</td></tr>
            <tr><td class="lbl">Invoice Date</td><td>: {{basicdetails.[0].inv_date}}</td></tr>
            <tr><td class="lbl">Invoice Due Date</td><td>: {{basicdetails.[0].due_date}}</td></tr>
            <tr><td class="lbl">Reference No</td><td>: {{basicdetails.[0].reference_no}}</td></tr>
            <tr><td class="lbl">PO No</td><td>: {{basicdetails.[0].order_no}}</td></tr>
          </table>
        </td>
        <td class="qr-cell" style="width:22%">{{{qrDataUri qrCodeBase64}}}</td>
      </tr>
    </table>

    <!-- SHIPMENT BAND A -->
    <table class="ship">
      <thead>
        <tr>
          <th style="width:11%">Job No</th>
          <th style="width:9%">POL</th>
          <th style="width:9%">POD</th>
          <th style="width:12%">HBL / HAWB</th>
          <th style="width:12%">MBL / MAWB</th>
          <th style="width:11%">ETA</th>
          <th style="width:11%">ETD</th>
          <th style="width:13%">Chargeable Weight</th>
          <th style="width:12%">Volume/Measurement</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>{{basicdetails.[0].logisticsjobno}}</td>
          <td>{{basicdetails.[0].port_of_loading}}</td>
          <td>{{basicdetails.[0].port_of_delivery}}</td>
          <td>{{basicdetails.[0].hbl_no}}</td>
          <td>{{basicdetails.[0].mbl_no}}</td>
          <td>{{basicdetails.[0].eta_date}}</td>
          <td>{{basicdetails.[0].etd_date}}</td>
          <td>{{basicdetails.[0].chargeable_weight}}</td>
          <td>{{basicdetails.[0].diamension}}</td>
        </tr>
      </tbody>
    </table>

    <!-- SHIPMENT BAND B -->
    <table class="ship" style="border-top:none;">
      <thead>
        <tr>
          <th style="width:16%">Consignee Name</th>
          <th style="width:18%">Shipper/ Supplier/ Exporter Name</th>
          <th style="width:13%">Container Size</th>
          <th style="width:14%">Shipment Term</th>
          <th style="width:15%">Shipment/ Service Type</th>
          <th style="width:12%">No of pieces</th>
          <th style="width:12%">Gross Weight</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>{{basicdetails.[0].consignee_name}}</td>
          <td>{{basicdetails.[0].shipper_name}}</td>
          <td>{{basicdetails.[0].container_size}}</td>
          <td>{{basicdetails.[0].shipment_term}}</td>
          <td>{{default basicdetails.[0].service_type "OTHER SERVICES"}}</td>
          <td>{{basicdetails.[0].no_pcs}}</td>
          <td>{{basicdetails.[0].gross_weight}}</td>
        </tr>
      </tbody>
    </table>

    <!-- ITEMS TABLE -->
    <table class="items-table">
      <thead>
        <tr>
          <th style="width:5%">Item<span class="ar">عرض</span></th>
          <th style="width:47%">Description<span class="ar">الوصف</span></th>
          <th style="width:12%">Quantity<span class="ar">الكميه</span></th>
          <th style="width:12%">Unit Price<span class="ar">سعر الوحده</span></th>
          <th style="width:12%">Tax Amount<span class="ar">قيمه الضريبه</span></th>
          <th style="width:12%">Total Amount<span class="ar">المبلغ الإجمالي</span></th>
        </tr>
      </thead>
      <tbody>
        {{#each itemdetails}}
        <tr>
          <td class="num">{{addOne @index}}</td>
          <td>{{item_name}}{{name_lang2}}{{description}}</td>
          <td class="num">{{formatAmount quantity ../bcdp}}</td>
          <td class="right">{{formatAmount price ../bcdp}}</td>
          <td class="right">{{formatAmount vat_amt ../bcdp}}</td>
          <td class="right">{{formatAmount amount ../bcdp}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>

    <!-- BANK + TOTALS -->
    <table class="bt-wrap">
      <tr>
        <td style="width:48%">
          <table class="bank">
            <tr><td class="bhead" colspan="2">BANK DETAILS</td></tr>
            <tr><td class="lbl">Bank Name</td><td>{{bankdetails.name}}</td></tr>
            <tr><td class="lbl">Account Name</td><td>{{bankdetails.acc_name}}</td></tr>
            <tr><td class="lbl">Beneficiary Bank Branch</td><td>{{bankdetails.branch_name}}</td></tr>
            <tr><td class="lbl">Beneficiary A/c No</td><td>{{bankdetails.acc_no}}</td></tr>
            <tr><td class="lbl">Swift Code</td><td>{{bankdetails.swift_no}}</td></tr>
            <tr><td class="lbl">IBAN No</td><td>{{bankdetails.iban_no}}</td></tr>
          </table>
        </td>
        <td style="width:4%"></td>
        <td style="width:48%">
          <table class="totals">
            <tr>
              <td class="lbl">Sub Total</td>
              <td class="arl">اجمالي المبلغ المستحق</td>
              <td class="val">{{formatAmount (add basicdetails.[0].subtotal basicdetails.[0].discount) bcdp}}</td>
            </tr>
            <tr>
              <td class="lbl">Discount</td>
              <td class="arl">تخفيض</td>
              <td class="val">{{formatAmount basicdetails.[0].discount bcdp}}</td>
            </tr>
            <tr>
              <td class="lbl">Total Amount Excluding VAT</td>
              <td class="arl">المبلغ الإجمالي باستثناء ضريبة القيمة المضافة</td>
              <td class="val">{{formatAmount (subtract basicdetails.[0].subtotal basicdetails.[0].discount) bcdp}}</td>
            </tr>
            <tr>
              <td class="lbl">VAT</td>
              <td class="arl">ضريبة القيمة المضافة</td>
              <td class="val">{{formatAmount basicdetails.[0].vatamt bcdp}}</td>
            </tr>
            <tr class="due">
              <td class="lbl">Total Amount Including VAT</td>
              <td class="arl">المبلغ الإجمالي شامل ضريبة القيمة المضافة</td>
              <td class="val">{{formatAmount basicdetails.[0].grand_total bcdp}}</td>
            </tr>
            <tr class="words-en">
              <td class="lbl">Total Amount In Words</td>
              <td colspan="2">{{bcamountinwords}}</td>
            </tr>
            <tr>
              <td class="arl" colspan="3">{{bcamountinwordsar}}</td>
            </tr>
          </table>
        </td>
      </tr>
    </table>

    <!-- TERMS -->
    <div class="terms">
      <div class="thead">Terms And Conditions / <span class="ar">الأحكام والشروط</span></div>
      <div>{{invterms}}</div>
    </div>

    <!-- SIGNATURES -->
    <table class="sign-table">
      <tr>
        <td class="s-head">Company Stamp<span class="ar">ختم الشركة</span></td>
        <td class="s-head">Prepared By<span class="ar">أعدت بواسطة</span></td>
        <td class="s-head">Authorized Signature<span class="ar">توقيع معتمد</span></td>
        <td class="s-head">Received By<span class="ar">استلمت من قبل</span></td>
      </tr>
      <tr>
        <td class="s-body">{{#if Seal}}<img src="{{Seal}}" alt="" onerror="this.style.display='none'"/>{{/if}}</td>
        <td class="s-body">{{basicdetails.[0].created_user}}</td>
        <td class="s-body">{{#if Signature}}<img src="{{Signature}}" alt="" onerror="this.style.display='none'"/>{{/if}}</td>
        <td class="s-body"></td>
      </tr>
    </table>

  </body>
</html>
