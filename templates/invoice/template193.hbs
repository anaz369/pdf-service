<body>
    <div class="section">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <h5 class="text-center invoice_head mb-2 mt-2"><b> <span>TAX INVOICE</span> / فاتورة ضريبية </b></h5>
                    
                </div>
                <div class="col-lg-8 col-md-8 col-sm-8 pr-0">
                    <table class="myy_table mt-1 myy_table2">
    <tr>
        <th colspan="2" class="bg-light1"><b>BUYER DETAILS</b></th>
    </tr>

    <tr>
        <td>Name</td>
        <td>{{billing_address.[0].name}}</td>
    </tr>

    <tr>
        <td>Building Number</td>
        <td>{{billing_address.[0].address_line1}}</td>
    </tr>

    <tr>
        <td>Street Name</td>
        <td>{{billing_address.[0].address_line2}}</td>
    </tr>

    <tr>
        <td>City</td>
        <td>{{billing_address.[0].address_line3}}</td>
    </tr>

    <tr>
        <td>District</td>
        <td>{{billing_address.[0].address_line4}}</td>
    </tr>

    <tr>
        <td>Country</td>
        <td>{{billing_address.[0].address_line5}}</td>
    </tr>

    <tr>
        <td>TRN Number</td>
        <td>{{customer_details.[0].VAT_number}}</td>
    </tr>

    <tr>
        <td>PO Box Number</td>
        <td>{{billing_address.[0].address_code}}</td>
    </tr>

    <tr>
        <td>Customer Email</td>
        <td>{{customer_details.[0].email}}</td>
    </tr>

</table>
                </div>
                <div class="col-lg-4 col-md-4 col-sm-4">
                    <table class="myy_table mt-1 myy_table2">
    <tr>
        <th colspan="2" class="bg-light1"><b>INVOICE DETAILS</b></th>
    </tr>

    <tr>
        <td>Invoice Number</td>
        <td>{{basicdetails.[0].inv_no}}</td>
    </tr>

    <tr>
        <td>Invoice Date</td>
        <td>{{basicdetails.[0].inv_date}}</td>
    </tr>

    <tr>
        <td>Reference Number</td>
        <td>{{basicdetails.[0].reference_no}}</td>
    </tr>

    <tr>
        <td>PO No</td>
        <td>{{basicdetails.[0].order_no}}</td>
    </tr>

    <tr>
        <td>PO Date</td>
        <td>{{basicdetails.[0].po_date}}</td>
    </tr>

    <tr>
        <td>Project</td>
        <td>{{basicdetails.[0].project_name}}</td>
    </tr>

    <tr>
        <td>Project Value</td>
        <td>{{basicdetails.[0].project_cost}}</td>
    </tr>

</table>
                </div>
                
                
                <div class="col-lg-12">
                    <table class="mt-1 myy_table myy_table6">
                        <tr>
                            <th class="text-center bold" width="5%">م  <br>S.N</th>
                            <th class="text-center" width="64%">الوصف<br>Description</th>
                            <th class="text-center" width="10%">الكمية<br>QTY</th>
                            <th class="text-center" width="9%">الوحدة<br>Unit</th>
                            <th class="text-center" width="12%">القيمه الاجمالي<br>Total Price</th>
                        </tr>
                        {{#each itemdetails}}
                        <tr>
    <td class="text-center">{{addOne @index}}</td>

    <td class="text-start">
         <div>{{item_name}}</div>
        {{#if name_lang2}}
            <div style="direction:rtl; font-size:9px; color:#555;">
                {{name_lang2}}
            </div>
        {{/if}}
        {{#if description}}
            <div style="font-size:9px; color:#777;">
                {{description}}
            </div>
        {{/if}}
    </td>

    <td class="text-center">{{quantity}}</td>

    <td class="text-center">{{unit}}</td>

    <td class="text-end">
        {{formatAmount amount ../bcdp}}
    </td>
</tr>    {{/each}} 
                        
                    </table>
                </div>
                <div class="qr-wrapper col-lg-2 col-md-2 col-sm-2 pr-0">
                       {{{qrDataUri qrCodeBase64}}}
                </div>
                <div class="col-lg-10 col-md-10 col-sm-10">
                    <table class="mt-0 myy_table myy_table2">

    <tr>
        <td class="text-end">Total</td>
        <td class="text-end w-15">
            {{basicdetails.[0].isocode}} 
            {{formatAmount basicdetails.[0].subtotal bcdp}}
        </td>
    </tr>

    <tr>
        <td class="text-end">Advance Recovery</td>
        <td class="text-end">
            {{basicdetails.[0].isocode}} 
            {{formatAmount basicdetails.[0].aa bcdp}}
        </td>
    </tr>
{{#if zatcadiscount.[0].dld}}

    <tr>
        <td class="text-end">{{zatcadiscount.[0].reason_name}}</td>
        <td class="text-end">
            {{basicdetails.[0].isocode}} 
            {{formatAmount zatcadiscount.[0].dld bcdp}}
        </td>
    </tr>
{{/if}}
    <tr>
        <td class="text-end">Advance Recovery</td>
        <td class="text-end">
            
        </td>
    </tr>

    <tr>
        <td class="text-end">Total Amount Claimed ( Without 5% VAT )</td>
        <td class="text-end">
            {{basicdetails.[0].isocode}} 
            {{formatAmount (subtract basicdetails.[0].subtotal basicdetails.[0].discount) bcdp}}
        </td>
    </tr>

    <tr>
        <td class="text-end">VAT {{basicdetails.[0].vat_perc}}%</td>
        <td class="text-end">
            {{basicdetails.[0].isocode}} 
            {{formatAmount basicdetails.[0].vatamt bcdp}}
        </td>
    </tr>

    <tr>
        <td class="text-end">Total Amount Claimed ( With 5% VAT )</td>
        <td class="text-end">
            {{basicdetails.[0].isocode}} 
            {{formatAmount basicdetails.[0].grand_total bcdp}}
        </td>
    </tr>

    <tr>
        <td colspan="2">
            <b>Amount In Words:</b> {{bcamountinwords}}
        </td>
    </tr>

</table>
                </div>
                
                <div class="col-lg-12 mt-4">
                    <table class="myy_table myy_table2">
    
    <tr>
        <th colspan="4" class="text-center">BANK DETAILS</th>
    </tr>

    <tr>
        <td class="w-15 br">Account Name</td>
        <td class="bl w-35">: {{bankdetails.acc_name}}</td>
        <td class="w-15 br">Bank Name</td>
        <td class="bl w-35">: {{bankdetails.name}}</td>
    </tr>

    <tr>
        <td class="w-15 br">Account Number</td>
        <td class="bl w-35">: {{bankdetails.acc_no}}</td>
        <td class="w-15 br">Branch Name</td>
        <td class="bl w-35">: {{bankdetails.branch_name}}</td>
    </tr>

    <tr>
        <td class="w-15 br">IBAN Number</td>
        <td class="bl w-35">: {{bankdetails.iban_no}}</td>
        <td class="w-15 br">SWIFT Code</td>
        <td class="bl w-35">: {{bankdetails.swift_no}}</td>
    </tr>

</table>
                </div>
                <div class="col-lg-12 mt-1">
                    <table class="fs-11">
    <tr>
        <td>
            <b>Note</b><br><br>
            
            {{basicdetails.[0].terms_and_condition}}<br><br>
        </td>
    </tr>

    <tr>
        <td>
            <b>THANKS & REGARDS</b><br><br>
            
            {{basicdetails.[0].salesman_name}}
        </td>
    </tr>
</table>
                </div>
                
                
            </div> 
        </div>
    </div>
</body>
</html>