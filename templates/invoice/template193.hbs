.invoice {
    width: 420px;
    margin: 20px auto;
    background: #f5f5f5;
    padding: 15px;
    color: #000;
    font-size: 10px;
    font-family: "Open Sans",sans-serif;
}

.center { text-align: center; }
.bold { font-weight: bold; }
.small { font-size: 10px; }

hr {
    border: none;
    border-top: 1px dashed #000;
    margin: 10px 0;
}
.hr {
    border: none;
    border-top: 2px solid #000;
    margin: 5px 0;
    opacity: 1;
}

.tabled {
    width: 100%;
    border-collapse: collapse;
    margin-top: 10px;
}

.tabled th, .tabled td {
    padding: 6px 4px;
    text-align: left;
    font-size: 10px;
}

.tabled th {
    border-bottom: 1px solid #000;
}

.tabled td:last-child,
.tabled th:last-child {
    text-align: right;
}

.total-row {
    display: flex;
    justify-content: space-between;
    margin-top: 8px;
}
.total-row1 {
    display: flex;
    justify-content: flex-start;
    margin-top: 8px;
}
.total-row1 div:last-child{
    padding-left: 0px;
    content: ":";
}
.total-row1 div:first-child{
    width: 30%;
}

.footer {
    text-align: center;
    margin-top: 10px;
}

.box_table{
        margin: 30px;
        display: block;
    }
    table th{
        font-weight: 600;
    }
    .table_sec td{
        font-weight: 400;
        line-height: 16px;
        border: 1px solid #76716a;
        padding: 2px 0;
        padding-left: 5px;
        padding-right: 5px;
        border-bottom: 0;
        border-right: 0;
        font-size: 10px;
        vertical-align: top;
    }
    .table_sec th{
        font-size: 10px;
        color: #26323e;
        padding: 2px 5px;
        border: 1px solid #76716a;
        border-bottom: 0;
        border-right: 0;
    }
    .table_sec tr:last-child td{
        border-bottom: 1px solid #b9bcbf;
    }
    .table_sec tr td:last-child{
        border-right: 1px solid #b9bcbf;
    }
    .table_sec tr:last-child th{
        border-bottom: 1px solid #76716a;
    }
    .table_sec tr th:last-child{
        border-right: 1px solid #76716a;
    }
.my_table table{
