    vertical-align: middle !important;
}
.myy_table{
    border: 1px solid #ccc;
}
.myy_table td{
    padding: 2px 8px;
    color: #282727;
    font-weight: 600;
    font-size: 9px;
}
.myy_table th{
    background-color: #f2f2f2;
    padding: 2px 8px;
    color: #282727;
    font-weight: 600;
    font-size: 10px;
}
.myy_table1 td{
    border: 1px solid #ccc;
}
.myy_table1 th{
    border: 1px solid #ccc;
    line-height: 26px;
}
.myy_table2 td{
    border: 1px solid #ccc;
}
.myy_table2 th{
    border: 1px solid #ccc;
    font-weight: bold;
    background-color: #fff;
    color: #000;
}
.myy_table3 th{
    background-color: #19aec6;
