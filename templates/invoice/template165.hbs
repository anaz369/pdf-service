<html xmlns="http://www.w3.org/1999/xhtml">
<head>
<meta charset="utf-8">
<meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
<meta http-equiv="X-UA-Compatible" content="IE=edge" />
<meta name="format-detection" content="telephone=yes" />
<title>165</title>
   <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<style>
    .invoice_head{
    font-weight: 700;
    font-size: 28px;
    margin-bottom: 15px;
        color: #54649a;
}
.invoice_head span{
    color: #b72031;
}
    table{
        width: 100%;
        font-family: Tahoma, sans-serif;
        font-size: 12px;
        vertical-align: top;
    }
    .table_sample{
        vertical-align: top;
    }
    .table_sample td{
        padding: 4px 4px;
        color: #fff;
        font-size: 11px;
        line-height: 18px;
        background-color: #5768a0;
        font-weight: normal;
    }
    .tablee1{
        border-bottom: 1px solid #444;
    }
    .tablee1 th{
       padding: 4px 4px;
        color: #fff;
        background-color: #444444;
        font-size: 12px;
        font-weight: normal;
    }
    .tablee1 td{
       padding: 4px 4px;
        color: #000;
        font-size: 11px;
        border-bottom: 1px solid #444;
    }
    .tablee2{
        border: 2px solid #344767;
    }
    .tablee2 th{
        padding: 4px 4px;
        color: #fff;
        background-color: #344767;
        font-size: 12px;
    }
    .tablee2 td{
        padding: 4px 4px;
        color: #000;
        font-size: 11px;
    }
    .table_black{
        border: 2px solid #000;
    }
    .table_black td{
        padding: 4px 4px;
        color: #000;
        font-size: 11px;
        vertical-align: top;
        border: 2px solid #000;
    }
    .bg-gray{
        background-color: #f2f2f2;
    }
    .blue_box{
        border: 1px solid #dddddd;
        font-size: 12px;
    }
    .blue_box th{
        background-color: #5768a0;
        color: #fff;
        padding: 4px 4px;
        border: 1px solid #dddddd;
        font-weight: normal;
        line-height: 24px;
        font-size: 12px;
    }
    .blue_box td{
        padding: 4px 4px;
        color: #000;
        font-size: 11px;
        border: 1px solid #dddddd;
    }
</style>
</head>
<body>
    <div class="section">
        <div class="container">
            <div class="row">
                <h1 class="invoice_head mb-0">TAX INVOICE</h1>
                <h6><b>ر تاريخ / Issue Date :</b>{{basicdetails.[0].inv_date}}</h6>
                <div class="col-lg-12">
                    <table class="table_sample">
                        <tr>
                            <td>Invoice No:</td>
                            <td class="text-center">{{basicdetails.[0].inv_no}}</td>
                            <td class="text-end">رقم الفاتورة</td>
                        </tr>

                    </table>
                </div>
                <div class="col-lg-6 col-md-6 col-sm-6 mt-0">
                    <table class="blue_box">
                        <tr>
                            <th colspan="2">Company Name & Address</th>
                        </tr>
                        <tr>
                            <td colspan="2">
                                <h6 class="mb-0"><b>{{branch.[0].name}}</b></h6><br>
                                {{#if branch.[0].address_line1}}{{branch.[0].address_line1}}, {{/if}}{{#if branch.[0].address_line2}}{{branch.[0].address_line2}}, {{/if}}{{#if branch.[0].address_line4}}{{branch.[0].address_line4}}, {{/if}}{{#if branch.[0].address_line3}}{{branch.[0].address_line3}}, {{/if}}{{#if branch.[0].address_code}}{{branch.[0].address_code}}, {{/if}}{{#if branch.[0].address_line5}}{{branch.[0].address_line5}}{{/if}}
                            </td>
                        </tr>
                        <tr>
                            <td><b>VAT No: {{#if branch.[0].vat}}{{branch.[0].vat}}{{/if}}</b></td>
                            <td><b>CR No: {{#if branch.[0].cr_no}}{{branch.[0].cr_no}}{{/if}}</b></td>
                        </tr>
                    </table>
                    <table class="blue_box">
                        <tr>
                            <th colspan="2">Client Name & Address</th>
                        </tr>
                        <tr>
                            <td colspan="2">
                                <h6 class="mb-0"><b>{{billing_address.[0].name}}</b></h6><br>
                                {{#if billing_address.[0].address_line1}}{{billing_address.[0].address_line1}}, {{/if}}{{#if billing_address.[0].address_line2}}{{billing_address.[0].address_line2}}, {{/if}}{{#if billing_address.[0].address_line4}}{{billing_address.[0].address_line4}}, {{/if}}{{#if billing_address.[0].address_line3}}{{billing_address.[0].address_line3}}, {{/if}}{{#if billing_address.[0].address_line5}}{{billing_address.[0].address_line5}}{{/if}}
                            </td>
                        </tr>
                        <tr>
                            <td><b>VAT No: {{#if billing_address.[0].vat}}{{billing_address.[0].vat}}{{/if}}</b></td>
                            <td><b>CR No: {{#if customer_details.[0].cr_no}}{{customer_details.[0].cr_no}}{{/if}}</b></td>
                        </tr>
                    </table>
                </div>
                <div class="col-lg-6 col-md-6 col-sm-6 mt-0">
                    <table class="blue_box">
                        <tr>
                            <th class="text-end" colspan="2">اسم الشركة والعنوان</th>
                        </tr>
                        <tr>
                            <td colspan="2" class="text-end">
                                <h6 class="mb-0"><b>{{#if branch_lang2.[0].name}}{{branch_lang2.[0].name}}{{/if}}</b></h6><br>
                                {{#if branch_lang2.[0].address_line1}}{{branch_lang2.[0].address_line1}}, {{/if}}{{#if branch_lang2.[0].address_line2}}{{branch_lang2.[0].address_line2}}, {{/if}}{{#if branch_lang2.[0].address_line4}}{{branch_lang2.[0].address_line4}}{{/if}}{{#if branch_lang2.[0].address_line3}}{{branch_lang2.[0].address_line3}}, {{/if}}{{#if branch_lang2.[0].address_line5}}{{branch_lang2.[0].address_line5}} {{/if}}
                            </td>
                        </tr>
                        <tr>
                            <td><b>CR no: {{#if branch_lang2.[0].cr_no}}{{branch_lang2.[0].cr_no}}{{/if}}</b></td>
                            <td class="text-end"><b>{{#if branch_lang2.[0].vat}}{{branch_lang2.[0].vat}}{{/if}} :ضريبة رق</b></td>
                        </tr>
                    </table>
                    <table class="blue_box">
                        <tr>
                            <th colspan="2" class="text-end">سم الشركة والعنوان</th>
                        </tr>
                        <tr>
                            <td colspan="2" class="text-end">
                                <h6 class="mb-0"><b>{{#if billing_address_lang2.[0].name}}{{billing_address_lang2.[0].name}}{{/if}}</b></h6><br>
                                {{#if billing_address_lang2.[0].address_line1}}{{billing_address_lang2.[0].address_line1}}, {{/if}}{{#if billing_address_lang2.[0].address_line2}}{{billing_address_lang2.[0].address_line2}}, {{/if}}{{#if billing_address_lang2.[0].address_line4}}{{billing_address_lang2.[0].address_line4}}, {{/if}}{{#if billing_address_lang2.[0].address_line3}}{{billing_address_lang2.[0].address_line3}}, {{/if}}{{#if billing_address_lang2.[0].address_line5}}{{billing_address_lang2.[0].address_line5}}{{/if}}
                            </td>
                        </tr>
                        <tr>
                            <td><b>CR No:{{#if customer_details.[0].cr_no_lang2}}{{customer_details.[0].cr_no_lang2}}{{/if}}</b></td>
                            <td class="text-end"><b>{{#if billing_address_lang2.[0].vat}}{{billing_address_lang2.[0].vat}}{{/if}} :ضريبة ر</b></td>
                        </tr>
                    </table>
                </div>

                <div class="col-lg-12 mt-1">
                    <table class="blue_box">
                        <tr>
                            <th class="text-center">قم السلعة<br>Item No</th>
                            <th class="text-center">وصف الخدمة<br>Description of Service</th>
                            <th class="text-center">كمية<br>Quantity</th>
                            <th class="text-center">سعر الوحدة<br>Unit Price</th>
                            <th class="text-center">الإجمالي<br>Total</th>
                            <th class="text-center">ضريبة<br>VAT Rate</th>
                            <th class="text-center">مبلغ ضريبة<br>VAT Amount</th>
                        </tr>
                        {{#each itemdetails}}
                        <tr>
                            <td class="text-center">{{addOne @index}}</td>
                            <td class="text-start">{{item_name}}{{#if name_lang2}}<br>{{name_lang2}}{{/if}}</td>
                            <td class="text-center">{{formatAmount quantity}}</td>
                            <td class="text-end">{{formatAmount price ../bcdp}}</td>
                            <td class="text-end">{{formatAmount (multiply price quantity) ../bcdp}}</td>
                            <td class="text-center">{{../basicdetails.[0].vat_perc}}%</td>
                            <td class="text-end">{{formatAmount vat_amt ../bcdp}}</td>
                        </tr>
                        {{/each}}

                    </table>
                </div>
                <div class="col-lg-2 col-md-2 col-sm-2 mt-0 pe-0">
                    <table class="blue_box">
                        <tr>
                            <td>{{{qrDataUri qrCodeBase64}}}</td>
                        </tr>
                    </table>
                </div>
                <div class="col-lg-10 col-md-10 col-sm-10 mt-0">
                    <table class="blue_box">
                        <tr>
                            <td class="text-start">Subtotal (Excluding VAT) /(ضريبة شامل غـير (الفرعي الإجمالي</td>
                            <td class="text-end">{{formatAmount (divide basicdetails.[0].subtotal ccrate) bcdp}}</td>
                        </tr>
                        <tr>
                            <td class="text-start">Total VAT ({{basicdetails.[0].vat_perc}}%) / (%{{basicdetails.[0].vat_perc}})ضريبة ا</td>
                            <td class="text-end">{{formatAmount (divide basicdetails.[0].vatamt ccrate) bcdp}}</td>
                        </tr>
                        <tr>
                            <td class="text-start">Total Amount Payable / المستحق الإجمالي ا</td>
                            <td class="text-end">{{formatAmount (divide basicdetails.[0].grand_total ccrate) bcdp}}</td>
                        </tr>
                    </table>
                    <table class="blue_box mt-2">
                        <tr>
                            <td>Amount in Words<br>/ المبلغ بالكلمات</td>
                            <td class="text-end">{{#if bcamountinwords}}{{bcamountinwords}}{{/if}}</td>
                        </tr>
                    </table>
                </div>
                <div class="col-lg-6 col-md-6 col-sm-6 mt-4">
                    <p>لاستحقاق تاريخ/Due Date:{{#if basicdetails.[0].due_date}}{{basicdetails.[0].due_date}}{{/if}}</p>
                    <table class="blue_box">
                        <tr>
                            <th colspan="3">Bank Details:</th>
                        </tr>
                        {{#if bankdetails.acc_name}}
                        <tr>
                            <td>Account Holder's Name</td>
                            <td>:</td>
                            <td>{{bankdetails.acc_name}}</td>
                        </tr>
                        {{/if}}
                        {{#if bankdetails.name}}
                         <tr>
                            <td>Bank Name</td>
                            <td>:</td>
                             <td>{{bankdetails.name}}</td>
                        </tr>
                        {{/if}}
                        {{#if bankdetails.acc_no}}
                        <tr>
                            <td>Account No</td>
                            <td>:</td>
                            <td>{{bankdetails.acc_no}}</td>
                        </tr>
                        {{/if}}
                        {{#if bankdetails.iban_no}}
                        <tr>
                            <td>IBAN</td>
                            <td>:</td>
                            <td>{{bankdetails.iban_no}}</td>
                        </tr>
                        {{/if}}
                        {{#if bankdetails.branch_name}}
                        <tr>
                            <td>Branch and Swift Code</td>
                            <td>:</td>
                            <td>{{bankdetails.branch_name}}</td>
                        </tr>
                        {{/if}}
                    </table>
                </div>

            </div>
        </div>
    </div>
</body>
</html>