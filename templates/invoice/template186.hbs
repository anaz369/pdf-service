<html xmlns="http://www.w3.org/1999/xhtml">
<head>
<meta charset="utf-8">
<meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
<meta http-equiv="X-UA-Compatible" content="IE=edge" />
<meta name="format-detection" content="telephone=yes" />
<title>Tax Invoice - {{basicdetails.[0].inv_no}}</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<style>
  body{
    font-family: "Open Sans",sans-serif !important;
}
.h1,.h2,.h3,.h4,.h5,.h6,h1,h2,h3,h4,h5,h6{margin-top:0;margin-bottom:0;}
.table>:not(caption)>*>* { padding: 0.3rem 0.3rem; }
table{ width: 100%; }
.bg-dark{ background-color: #1a1a1a; }
.bg{background-color:#f2f2f2;}
.bg-light{background-color:#ecf7f9;}
.bg-light1{background-color:#d9dbdb !important;}
.arab{ font-family: 'Noto Sans Arabic', Arial, sans-serif; }
.text-gold{ color: #db9600 !important; }
.head-light{
    border-bottom: 1px solid #d7d7d7;
    background-color: #fbfbfb;
    padding: 8px 15px;
    font-weight: 600;
    font-size: 11px;
}
.table_n th{ background-color: #1a1a1a; color: #fff; font-size: 11px; line-height: 18px; }
.table_n th span{ font-family: 'Noto Sans Arabic', Arial, sans-serif; font-weight: 500; font-size: 9px; color: #ddd; }
.table_n1{ border: 1px solid #ededed; border-radius: 10px; font-size: 10px; }
.table_n1 td:last-child{ text-align: right; }
.tabn td:last-child{ font-weight: 600; }
.tabn td:first-child{ font-weight: 400; color: #8b8b8b; }
.tabn tr{ border-bottom: 1px solid #dee2e6; }
.amount{
    background-color: #fffbe6;
    border: 1px solid #f2e49d;
    padding: 8px;
    width: 100%;
    border-radius: 10px;
}
.amount h5{ color: #d1b53f; font-size: 10px; font-weight: 600; margin-bottom: 6px; }
.amount h6{ color: #1a1a1a; font-weight: 600; }
.bank{
    background-color: #fff;
    border: 1px solid #d0d0d0;
    padding: 8px;
    width: 100%;
    margin-top: 4px;
    border-radius: 10px;
}
.bank h5{ color: #1a1a1a; font-size: 10px; font-weight: 600; margin-bottom: 6px; border-bottom: 1px solid #dee2e6; padding-bottom: 6px; }
.bank h6{ color: #1a1a1a; font-weight: 600; }
.tabn1 td{ font-weight: 600; color: #1a1a1a; }
.tabn1 tr{ border-bottom: 1px solid #dee2e6; }
.center { text-align: center; }
.bold { font-weight: bold; }
.small { font-size: 10px; }
hr { border: none; border-top: 1px dashed #000; margin: 10px 0; }
.hr { border: none; border-top: 2px solid #000; margin: 5px 0; opacity: 1; }
.tabled { width: 100%; border-collapse: collapse; margin-top: 10px; }
.tabled th, .tabled td { padding: 6px 4px; text-align: left; font-size: 10px; }
.tabled th { border-bottom: 1px solid #000; }
.tabled td:last-child, .tabled th:last-child { text-align: right; }
.total-row { display: flex; justify-content: space-between; margin-top: 8px; }
.total-row1 { display: flex; justify-content: flex-start; margin-top: 8px; }
.total-row1 div:first-child{ width: 30%; }
.footer { text-align: center; margin-top: 10px; }
.box_table{ margin: 30px; display: block; }
table th{ font-weight: 600; }
.table_sec td{
    font-weight: 400;
    line-height: 16px;
    border: 1px solid #76716a;
    padding: 2px 0;
    padding-left: 5px;
    padding-right: 5px;
    border-bottom: 0;
    border-right: 0;
    font-size: 10px;
    vertical-align: top;
}
.table_sec th{
    font-size: 10px;
    color: #26323e;
    padding: 2px 5px;
    border: 1px solid #76716a;
    border-bottom: 0;
    border-right: 0;
}
.table_sec tr:last-child td{ border-bottom: 1px solid #b9bcbf; }
.table_sec tr td:last-child{ border-right: 1px solid #b9bcbf; }
.table_sec tr:last-child th{ border-bottom: 1px solid #76716a; }
.table_sec tr th:last-child{ border-right: 1px solid #76716a; }
.my_table table{ font-size: 10px; line-height: 16px; }
.my_table table th{ font-weight: 700; }
.invoice_head{ font-weight: 700; font-size: 22px; margin-bottom: 15px; }
.invoice_head span{ color: #b72031; }
.b{ font-weight: 600; }
.bd-code-snippet{ border: 1px solid #acaeaf; border-radius: 6px; padding: 8px; }
.bd-code-snippet2{ border: 1px solid #272727; border-radius: 0px; padding: 8px; }
.boxx_table td{ padding: 8px; }
.boxx_table th{ border-bottom: 1px solid #acaeaf; padding: 8px; }
.boxx_table th b{ font-weight: 400; }
.boxx_table th:first-child{ border-right: 1px solid #acaeaf; }
.boxx_table1 td{ padding: 8px; border-bottom: 1px solid #acaeaf; border-right: 1px solid #acaeaf; text-align: center; }
.boxx_table1 td:last-child{ border-right: 0px; }
.boxx_table1 th{ border-bottom: 2px solid #707070; border-right: 1px solid #acaeaf; padding: 8px; text-align: center; }
.boxx_table1 th b{ font-weight: 400; }
.boxx_table1 th:last-child{ border-right: 0px; }
.w-10{ width: 10%; }
.w-15{ width: 15%; }
.border-dark td{ border: 1px solid #272727 !important; }
.lih-20{ line-height: 20px !important; }
.lih-24{ line-height: 24px !important; }
.pl-0{ padding-left: 0px !important; }
.pr-0{ padding-right: 0px !important; }
.bb{ border-bottom: 0px !important; }
.br{ border-right: 0px !important; }
.bl{ border-left: 0px !important; }
.bt{ border-top: 0px !important; }
.br-1{ border-right: 1px solid #acaeaf !important; }
.bt-1{ border-top: 1px solid #272727 !important; }
.fw-400{ font-weight: 400; }
.box_d{ border: 1px solid #272727 !important; padding: 8px 12px; }
.vam{ vertical-align: middle !important; }
.myy_table{ border: 1px solid #ccc; }
.myy_table td{ padding: 2px 8px; color: #282727; font-weight: 600; font-size: 9px; }
.myy_table th{ background-color: #f2f2f2; padding: 2px 8px; color: #282727; font-weight: 600; font-size: 10px; }
.myy_table1 td{ border: 1px solid #ccc; }
.myy_table1 th{ border: 1px solid #ccc; line-height: 26px; }
.myy_table2 td{ border: 1px solid #ccc; }
.myy_table2 th{ border: 1px solid #ccc; font-weight: bold; background-color: #fff; color: #000; }
.myy_table3 th{ background-color: #19aec6; color: #fff; font-weight: 600; font-size: 10px; line-height: 24px; border: 1px solid #fff; padding: 2px 8px; }
.myy_table3 td{ padding: 2px 8px; color: #282727; font-weight: 600; font-size: 9px; border-bottom: 1px solid #ccc; line-height: 24px; }
.myy_table4{ border: 1px solid #000; }
.myy_table4 td{ padding: 2px 8px; color: #282727; font-weight: 600; font-size: 9px; }
.myy_table4 th{ padding: 2px 8px; color: #000; font-weight: bold; font-size: 10px; border-bottom: 1px solid #000; }
.myy_table5{ border: 1px solid #000; }
.myy_table5 td{ padding: 10px 8px; color: #282727; font-weight: 600; font-size: 10px; }
.myy_table5 th{ padding: 8px 8px; color: #000; font-weight: bold; font-size: 10px; border-bottom: 1px solid #000; }
.bt-1px{ border-top: 1px solid #000; }
.bl-1px{ border-left: 1px solid #000; }
.bg_red{ background-color: #f54343; color: #fff !important; }
.fs-11{ font-size: 10px; }
.fs-13{ font-size: 15px; }
.w-10px{ width: 11px; }
.w-2px{ width: 2px; }
.vat{ vertical-align: top; }
.qr-wrapper img { width: 120px; height: 120px; display: block; margin: 0 auto; }
</style>

<body>
    <div class="section my_table">
        <div class="container">
            <div class="row">

                {{!-- ── Title ─────────────────────────────────── --}}
                <div class="col-lg-12">
                    <h1 class="text-center invoice_head">
                        <span>TAX INVOICE</span> - <span class="arab">فاتورة ضريبية</span>
                    </h1>
                </div>

                {{!-- ── Invoice + Company Info + QR ────────────── --}}
                <div class="col-lg-9 col-md-9 col-sm-9">
                    <div class="bd-code-snippet">
                        <table class="table table-borderless" cellpadding="0" cellspacing="0" border="0">
                            <tbody>
                                <tr>
                                    <td class="text-start">Invoice No</td>
                                    <td class="text-center">{{basicdetails.[0].inv_no}}</td>
                                    <td class="text-end arab">رقم الفاتورة</td>
                                </tr>
                                <tr>
                                    <td class="text-start">Invoice Date</td>
                                    <td class="text-center">{{basicdetails.[0].inv_date}}</td>
                                    <td class="text-end arab">تاريخ الفاتورة</td>
                                </tr>
                                <tr>
                                    <td class="text-start">Company Name</td>
                                    <td class="text-center">{{billing_address.[0].name}}</td>
                                    <td class="text-end arab">ن اس</td>
                                </tr>
                                <tr>
                                    <td class="text-start">Company VAT</td>
                                    <td class="text-center">{{customer_details.[0].VAT_number}}</td>
                                    <td class="text-end arab">الرقم الضریبي للعمیل</td>
                                </tr>
                                <tr>
                                    <td class="text-start">Company Address</td>
                                    <td class="text-center">{{joinAddress billing_address.[0]}}</td>
                                    <td class="text-end arab">كة ع</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                {{!-- ── QR Code ─────────────────────────────────── --}}
                <div class="col-lg-3 col-md-3 col-sm-3 text-center">
                    <div class="qr-wrapper">
                        {{{qrDataUri qrCodeBase64}}}
                    </div>
                </div>

                {{!-- ── VAT Rate + Supply Date ──────────────────── --}}
                <div class="col-lg-12">
                    <div class="bd-code-snippet mt-2">
                        <table>
                            <tr>
                                <td>VAT rate / <span class="arab">الفاتورة تاري</span></td>
                                <td>VAT ({{basicdetails.[0].vat_perc}}%)</td>
                                <td>Date of supply / <span class="arab">التوريد تاريخ</span> :
                                    {{#if basicdetails.[0].sup_date}}{{basicdetails.[0].sup_date}}{{else}}{{basicdetails.[0].inv_date}}{{/if}}
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>

                {{!-- ── Items Table ──────────────────────────────── --}}
                <div class="col-lg-12 mt-2">
                    <table cellpadding="0" cellspacing="0" border="0" class="table table_sec">
                        <thead>
                            <tr>
                                <th class="text-center bg-light"><span class="arab"></span></th>
                                <th class="text-center bg-light"><span class="arab">التفاصیل</span></th>
                                <th class="text-center bg-light"><span class="arab">سعر الوحدة</span></th>
                                <th class="text-center bg-light"><span class="arab">الكمیة</span></th>
                                <th class="text-center bg-light"><span class="arab">المجموع الفرعي</span></th>
                                <th class="text-center bg-light"><span class="arab">مبلغ ضريبة القيمة</span></th>
                                <th class="text-center bg-light"><span class="arab">المجموع</span></th>
                            </tr>
                            <tr>
                                <th class="text-center bg-light">#</th>
                                <th class="text-center bg-light">Particulars</th>
                                <th class="text-center bg-light">Unit price</th>
                                <th class="text-center bg-light">Quantity</th>
                                <th class="text-center bg-light">Subtotal</th>
                                <th class="text-center bg-light">VAT amount</th>
                                <th class="text-center bg-light">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#each itemdetails}}
                            <tr>
                                <td class="text-center">{{addOne @index}}</td>
                                <td class="text-center">
                                    {{item_name}}
                                    {{#if name_lang2}}<div class="arab" style="font-size:9px; color:#555;">{{name_lang2}}</div>{{/if}}
                                    {{#if description}}<div style="font-size:9px; color:#777;">{{description}}</div>{{/if}}
                                </td>
                                <td class="text-center">{{formatAmount price ../bcdp}}</td>
                                <td class="text-center">{{formatAmount quantity ../bcdp}}</td>
                                <td class="text-center">{{formatAmount taxable ../bcdp}}</td>
                                <td class="text-center">{{formatAmount tax ../bcdp}}</td>
                                <td class="text-center">{{formatAmount amount ../bcdp}}</td>
                            </tr>
                            {{/each}}

                            {{!-- Totals row --}}
                            {{#with basicdetails.[0]}}
                            <tr>
                                <td class="text-center" colspan="2">Total</td>
                                <td class="text-center"></td>
                                <td class="text-center">{{formatAmount subtotal ../bcdp}}</td>
                                <td class="text-center">{{formatAmount subtotal ../bcdp}}</td>
                                <td class="text-center">{{formatAmount vatamt ../bcdp}}</td>
                                <td class="text-center">{{formatAmount grand_total ../bcdp}}</td>
                            </tr>
                            {{/with}}
                        </tbody>
                    </table>
                </div>

                {{!-- ── Financial Summary ────────────────────────── --}}
                <div class="col-lg-12">
                    <table class="table table-bordered mb-0">
                        <tbody>
                            <tr>
                                <td class="text-primary">
                                    Invoice taxable amount / <span class="arab">الضریبة قبل الفاتورة إ</span>
                                </td>
                                <td class="text-end">
                                    {{basicdetails.[0].isocode}} {{formatAmount basicdetails.[0].subtotal bcdp}}
                                </td>
                            </tr>
                            <tr>
                                <td class="text-primary">
                                    VAT total in VAT ({{basicdetails.[0].vat_perc}}%) / <span class="arab">المضافة القيمة ضريبة مبلغ</span>
                                </td>
                                <td class="text-end">
                                    {{basicdetails.[0].isocode}} {{formatAmount basicdetails.[0].vatamt bcdp}}
                                </td>
                            </tr>
                            <tr>
                                <td class="text-primary">
                                    Invoice Gross Total (Amount includes VAT) / <span class="arab">مضافة قیمة ضریبة متضمن الفاتورة قیمة إ</span>
                                </td>
                                <td class="text-end">
                                    {{basicdetails.[0].isocode}} {{formatAmount basicdetails.[0].grand_total bcdp}}
                                </td>
                            </tr>
                            {{#if (gt basicdetails.[0].received 0)}}
                            <tr>
                                <td class="text-primary">
                                    Advance / <span class="arab">المدفوع</span>
                                </td>
                                <td class="text-end">
                                    {{basicdetails.[0].isocode}} {{formatAmount basicdetails.[0].received bcdp}}
                                </td>
                            </tr>
                            {{/if}}
                            <tr>
                                <td class="text-primary">
                                    Balance / <span class="arab">الباقي</span>
                                </td>
                                <td class="b text-end">
                                    {{basicdetails.[0].isocode}} {{formatAmount basicdetails.[0].balance bcdp}}
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                {{!-- ── Terms and Conditions ────────────────────── --}}
                {{#if invterms}}
                <div class="col-lg-12">
                    <table class="table table-bordered">
                        <tr>
                            <td>
                                <b>Terms and Conditions :-</b><br>
                                {{invterms}}
                            </td>
                        </tr>
                    </table>
                </div>
                {{/if}}

            </div>
        </div>
    </div>
</body>
</html>
