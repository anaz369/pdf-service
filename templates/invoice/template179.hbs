<body>
    <div class="section my_table">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    
                </div>
                <div class="col-lg-12">
                    <div class="bd-code-snippet21">
                        <table class="lih-24">
                <tr>
                    <td class="arab w-25">1 of 1 : الصفحة رقم </td>
                    <td class="w-50">
                        <h5 class="text-center"><b>Invoice / فاتورة </b></h5>
                    </td>
                    <td class="arab text-end">
                        {{basicdetails.[0].inv_date}} : التا
                    </td>
                </tr>
            </table>
                        <table class="lih-24">
                <tr>
                    <td>
                        <b>No Invoice Sales Credit :</b>
                        <span class="box_d">{{basicdetails.[0].inv_no}}</span>
                    </td>
                    <td class="arab text-start">فاتورة مبيعات آجلة رقم :</td>
                    <td class="arab text-end">
                        {{basicdetails.[0].reference_no}} : رقم المرجع
                    </td>
                </tr>

                <tr>
                    <td><b>Cust Name</b> : {{billing_address.[0].name}}</td>
                    <td></td>
                    <td class="text-end">
                        {{billing_address_lang2.[0].name}} :<b>لعميل ا</b>
                    </td>
                </tr>

                <tr>
                    <td>
                        <b>Address</b> : {{joinAddress billing_address.[0] ','}}
                    </td>
                    <td></td>
                    <td class="text-end"></td>
                </tr>
            </table>
                    </div>
                </div>

                <div class="col-lg-12 mt-2">
                    <table cellpadding="0" cellspacing="0" border="0" class="table table_sec border-dark lih-20 mb-0">
                        <thead>
                            <table class="table_sec">
                            <thead>
                                <tr>
                                    <th class="text-center"><span class="arab">م</span><br> SL NO</th>
                                    <th class="text-center"><span class="arab">سم الصنف</span><br> Description</th>
                                    <th class="text-center"><span class="arab">باركود</span><br> Barcode</th>
                                    <th class="text-center"><span class="arab">الوحدة</span><br> Unit</th>
                                    <th class="text-center"><span class="arab">الكمية</span><br> Qty</th>
                                    <th class="text-center w-10"><span class="arab">السعر</span><br> Price</th>
                                    <th class="text-center w-10"><span class="arab">الاجمالي</span><br> Total</th>
                                </tr>
                            </thead>

                            <tbody>
                                {{#each itemdetails}}
                                <tr>
                                    <td class="text-center">{{addOne @index}}</td>
                                    <td class="text-center">{{item_name}}</td>
                                    <td class="text-center">{{barcode}}</td>
                                    <td class="text-center">{{unit}}</td>
                                    <td class="text-center">{{quantity}}</td>
                                    <td class="text-center">{{formatAmount price ../bcdp}}</td>
                                    <td class="text-end">{{formatAmount amount ../bcdp}}</td>
                                </tr>
                                {{/each}}

                            <tr>
                                <td class="text-center"><br><br><br><br></td>
                                <td class="text-center"></td>
                                <td class="text-center"></td>
                                <td class="text-center"></td>
                                <td class="text-center"></td>
                                <td class="text-center"></td>
                                <td class="text-end"></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                
                <div class="col-lg-12">
                    <table class="table_sec border-dark">

            <tr>
                <td rowspan="6" class="bt w-15" style="border-top: 0 !important;">
                  
                </td>

                <td><b>Account Name</b></td>
                <td class="text-center">{{bankdetails.acc_name}}</td>
                <td class="arab text-end">اسم الحساب</td>

                <td class="text-center vam" rowspan="2"><b>Sub Total</b></td>
                <td class="text-end vam" rowspan="2">
                    {{formatAmount basicdetails.[0].subtotal bcdp}}
                </td>
            </tr>

            <tr>
                <td><b>Account No</b></td>
                <td class="text-center">{{bankdetails.acc_no}}</td>
                <td class="arab text-end">رقم الحساب</td>
            </tr>

            <tr>
                <td><b>IBAN</b></td>
                <td class="text-center">{{bankdetails.iban_no}}</td>
                <td class="arab text-end">رقم الايبان</td>

                <td class="text-center vam" rowspan="2"><b>Discount</b></td>
                <td class="text-end vam" rowspan="2">
                    {{formatAmount basicdetails.[0].discount bcdp}}
                </td>
            </tr>

            <tr>
                <td><b>Bank Name</b></td>
                <td class="text-center">{{bankdetails.name}}</td>
                <td class="arab text-end">اسم البنك</td>
            </tr>

            <tr>
                <td><b>SWIFT Code</b></td>
                <td class="text-center">{{bankdetails.swift_no}}</td>
                <td class="arab text-end">رمز السويفت</td>

                <td class="text-center vam" rowspan="2"><b>Grand Total</b></td>
                <td class="text-end vam" rowspan="2">
                    {{formatAmount basicdetails.[0].grand_total bcdp}}
                </td>
            </tr>

            <tr>
                <td><b>Branch Name</b></td>
                <td class="text-center">{{bankdetails.branch_name}}</td>
                <td class="arab text-end">اسم الفرع</td>
            </tr>

            <tr>
                <td colspan="6">
                    <b>{{bcamountinwords}}</b>
                </td>
            </tr>

            <tr>
                <td colspan="6"><b>&nbsp;</b></td>
            </tr>

        </table>
                </div>
                
                
                
            </div> 
        </div>
    </div>
</body>
