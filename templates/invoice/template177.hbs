<body>
    <div class="section my_table">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <h1 class="text-center invoice_head">VAT INVOICE / فاتورة ضريبية</h1>
                </div>
                <div class="col-lg-6 col-md-6 col-sm-6">
                    <div class="bd-code-snippet21">
    <table>
        <tr>
            <td style="vertical-align: top;">Buyer / مشتر</td>
            <td style="vertical-align: top;">:</td>
            <td>
                <b>
                    {{billing_address.[0].name}} / 
                    <span class="arab">{{billing_address_lang2.[0].name}}</span>
                </b>
            </td>
        </tr>

        <tr>
            <td style="vertical-align: top;">Profile Code / لعميل رم</td>
            <td style="vertical-align: top;">:</td>
            <td>{{customer_details.[0].profile_code}}</td>
        </tr>

        <tr>
            <td style="vertical-align: top;">Address / العنوان</td>
            <td style="vertical-align: top;">:</td>
            <td>
                {{joinAddress billing_address.[0] '، '}}
            </td>
        </tr>

        <tr>
            <td>Phone / الهاتف</td>
            <td>:</td>
            <td>{{customer_details.[0].contact_no1}}</td>
        </tr>

        <tr>
            <td>VAT / ضريبة</td>
            <td>:</td>
            <td>{{customer_details.[0].VAT_number}}</td>
        </tr>
    </table>
</div>
                </div>
                <div class="col-lg-6 col-md-6 col-sm-6">
                    <div class="bd-code-snippet21">
    <table>
        <tr>
            <td style="vertical-align: top;"> Invoice Number / رقم الفاتورة</td>
            <td style="vertical-align: top;">:</td>
            <td>{{basicdetails.[0].inv_no}}</td>
        </tr>

        <tr>
            <td style="vertical-align: top;">Invoice Date /  تاريخ الفاتورة</td>
            <td style="vertical-align: top;">:</td>
            <td>{{basicdetails.[0].inv_date}}</td>
        </tr>

        <tr>
            <td>Due Date / تاريخ الاستحقاق</td>
            <td>:</td>
            <td>{{basicdetails.[0].due_date}}</td>
        </tr>
        
    </table>
</div>
                </div>
               
                <div class="col-lg-12 mt-2">
                    <table cellpadding="0" cellspacing="0" border="0" class="table table_sec border-dark lih-20 mb-1">
                        <thead>
                            <tr>
    <th class="text-center bg-light1">Ticket No<br><span class="arab">رقم التذكرة</span></th>
    <th class="text-center bg-light1">Passanger Name<br><span class="arab">سم الراكب</span></th>
    <th class="text-center bg-light1">Sector<br><span class="arab">قسم</span></th>
    <th class="text-center bg-light1">Airline<br><span class="arab">شركة الطيران</span></th>
    <th class="text-center bg-light1">Travel Date<br><span class="arab">تواريخ السفر</span></th>
    <th class="text-center bg-light1">Fare<br><span class="arab">الأجرة</span></th>
    <th class="text-center bg-light1">Service Charge<br><span class="arab">رسوم الخدمة</span></th>
    <th class="text-center bg-light1">VAT<br><span class="arab">رقم ضريبة</span></th>
    <th class="text-center bg-light1">Total<br><span class="arab">الإجمالي</span></th>
</tr>
</thead>

<tbody>
{{#each itemdetails}}
<tr>
    <td class="text-center"></td>
    <td class="text-center"></td>
    <td class="text-center"></td>
    <td class="text-center"></td>
    <td class="text-center"></td>
    <td class="text-end"></td>
    <td class="text-end"></td>
    <td class="text-end">{{formatAmount vat_amt ../bcdp}}</td>
    <td class="text-end">{{formatAmount amount ../bcdp}}</td>
</tr>
{{/each}}
                            <tr>
    <td class="text-end" colspan="8" style="border-right: 0px !important;border-bottom: 0px !important;">
        Total Fare / <span class="arab">جرة إجمالي :</span>
    </td>
    <td class="text-end" style="border: 0px !important;border-right: 1px solid #272727 !important;">
        {{basicdetails.[0].isocode}} {{formatAmount basicdetails.[0].subtotal bcdp}}
    </td>
</tr>

<tr>
    <td class="text-end" colspan="8" style="border: 0px !important;border-left: 1px solid #272727 !important;">
        Total Excl. VAT / <span class="arab">ضريبة بدون الإجمالي :</span>
    </td>
    <td class="text-end" style="border: 0px !important;border-right: 1px solid #272727 !important;">
      
    </td>
</tr>

<tr>
    <td class="text-end" colspan="8" style="border: 0px !important;border-left: 1px solid #272727 !important;">
        Total VAT Amount / <span class="arab">ضريبة مبلغ إجمالي :</span>
    </td>
    <td class="text-end" style="border: 0px !important;border-right: 1px solid #272727 !important;">
        {{basicdetails.[0].isocode}} {{formatAmount basicdetails.[0].vatamt bcdp}}
    </td>
</tr>

<tr>
    <td class="text-end br" style="border: 0px !important;border-left: 1px solid #272727 !important;" colspan="8">
        Total Incl. VAT / <span class="arab">ضريبة شامل الإجمالي :</span>
    </td>
    <td class="text-end" style="border: 0px !important;border-right: 1px solid #272727 !important;">
        {{basicdetails.[0].isocode}} {{formatAmount basicdetails.[0].grand_total bcdp}}
    </td>
</tr>

<tr>
    <td class="text-start" colspan="9">
        <b>Total Amount in Words / ً <span class="arab">كتابة المبلغ إ</span></b> : 
        {{bcamountinwords}} / 
    </td>
</tr>
                        </tbody>
                    </table>
                </div>
                
                <div class="col-lg-12">
                    <div class="bd-code-snippet2">
                        <table>
    <tr>
        <td colspan="3" class="text-center"><b>BANK DETAILS</b></td>
        <td></td>
    </tr>

    <tr>
        <td>Bank Name / <span class="arab">البنك اسم </span></td>
        <td>:</td>
        <td>{{bankdetails.name}}</td>
        <td rowspan="6" class="text-end">
            {{{qrDataUri qrCodeBase64}}}
        </td>
    </tr>

    <tr>
        <td>Account Name / <span class="arab">لحساب ا</span></td>
        <td>:</td>
        <td>{{bankdetails.acc_name}}</td>
    </tr>

    <tr>
        <td>Bank Branch / <span class="arab">فرع البنك</span></td>
        <td>:</td>
        <td>{{bankdetails.branch_name}}</td>
    </tr>

    <tr>
        <td>A/c No / <span class="arab">رقم الحساب</span></td>
        <td>:</td>
        <td>{{bankdetails.acc_no}}</td>
    </tr>

    <tr>
        <td>IBAN No / <span class="arab">رقم الآيبان</span></td>
        <td>:</td>
        <td>{{bankdetails.iban_no}}</td>
    </tr>

    <tr>
        <td>SWIFT No / <span class="arab">رمز السويفت</span></td>
        <td>:</td>
        <td>{{bankdetails.swift_no}}</td>
    </tr>
</table>
                    </div>
                </div>
                
                 <div class="col-lg-12">
                    <div class="bd-code-snippet2 mt-1">
                        <table>
                            <tr>
                                <td class="text-center">Authorized Signatury / <span class="arab">المعتمد التوقيع</span></td>
                                <td class="text-center">Authorized Stamp / <span class="arab">المعتمد الختم</span></td>
                                <td class="text-center">Received by / <span class="arab">قبل من تلقى</span></td>
                            </tr>
                            <tr>
                                <td>
                                {{#if signature}}
                                        <img src="{{signature}}" alt="Seal" style="max-height:{{default datasettings.d459 '40'}}px; max-width:{{default datasettings.d459 '60'}}px;" onerror="this.style.display='none'"/>
                                {{/if}}
                                </td>
                                <td>
                                    {{#if Seal}}
                                        <img src="{{Seal}}" alt="Seal" style="max-height:{{default datasettings.d458 '40'}}px; max-width:{{default datasettings.d458 '60'}}px;" onerror="this.style.display='none'"/>
                                    {{/if}}
                                </td>
                                <td></td>
                            </tr>
                        </table>
                     </div>
                </div>
                
            </div> 
        </div>
    </div>
</body>
</html>