<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>INVOICE - {{basicdetails.[0].inv_no}}</title>
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        font-family: "IBM Plex Sans Arabic", Arial, sans-serif;
        font-size: 11px;
        line-height: 1.3;
        color: #000;
        margin: 0 4mm;
      }

      .ar {
        direction: rtl;
      }

      /* ── TOP TITLES ───────────────────────────────── */
      .title-row {
        width: 100%;
        border-collapse: collapse;
        table-layout: fixed;
        margin-bottom: 2px;
      }
      .title-row td {
        vertical-align: bottom;
        padding: 0 4px 2px;
      }
      .title-copy {
        text-align: center;
        font-weight: 700;
        font-size: 13px;
      }
      .title-inv {
        text-align: right;
        font-weight: 700;
        font-size: 13px;
      }

      /* ── HEADER ROW : QR | CUSTOMER | BRANCH ───────── */
      .header-row {
        width: 100%;
        border-collapse: collapse;
        table-layout: fixed;
      }
      .header-row > tbody > tr > td {
        vertical-align: top;
        padding: 0 4px;
      }
      .qr-cell {
        text-align: center;
        vertical-align: top;
      }
      .qr-cell img {
        width: 130px;
        height: 130px;
        object-fit: contain;
      }

      .info-box {
        border: 1px solid #000;
        border-radius: 12px;
        overflow: hidden;
        height: 100%;
      }
      .info-box table {
        width: 100%;
        font-size: 11px;
      }
      .info-box td {
        padding: 3px 8px;
        vertical-align: top;
      }
      .info-box td.lbl {
        width: 42%;
        font-weight: 700;
        white-space: nowrap;
      }
      .info-box td.sep {
        width: 8px;
        text-align: center;
      }

      /* ── ITEMS TABLE ──────────────────────────────── */
      .items-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 8px;
        font-size: 9px;
        border:1px solid #464646;
      }
      .items-table th,
      .items-table td {
        border: 1px solid #6b6b6b;
        padding: 3px 4px;
        vertical-align: top;
        font-weight: 700;
      }
      .items-table thead th {
        text-align: center;
        font-weight: 700;
        background-color:#D3D3D3;
        line-height: 1.25;
      }
      .items-table thead th .en {
        display: block;
        font-size: 10px;
      }
      .items-table thead th .ar {
        display: block;
        font-size: 10px;
        font-weight: 700;
      }
      .items-table td.num {
        text-align: center;
      }
      .items-table td.right {
        text-align: right;
      }
      .items-table .filler td {
        height: 250px;
      }

      /* ── FOOTER TOTALS ────────────────────────────── */
      .foot-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 11px;
        table-layout: fixed;
      }
      .foot-table td {
        border: 1px solid #6b6b6b;
        border-top: none;
        padding: 6px 8px;
        vertical-align: middle;
      }
      .foot-table .dn-cell {
        font-weight: 700;
      }
      .foot-table .words {
        font-weight: 600;
        vertical-align: top;
      }
      .foot-table .t-lbl-en {
        width: 18%;
        font-weight: 700;
        text-align: left;
      }
      .foot-table .t-lbl-ar {
        width: 16%;
        text-align: right;
        font-weight: 700;
        direction: rtl;
      }
      .foot-table .t-val {
        width: 12%;
        text-align: right;
        font-weight: 700;
      }

      /* ── COMPANY / SIGNATURE ──────────────────────── */
      .footer {
        margin-top: 6px;
      }
      .footer .company {
        font-weight: 700;
        font-size: 12px;
      }
      .footer .sign img {
        max-height: 60px;
        max-width: 160px;
        margin-top: 4px;
      }
    </style>
  </head>
  <body>

    <!-- TOP TITLES -->
    <table class="title-row">
      <tbody>
        <tr>
          <td style="width:20%"></td>
          <td class="title-copy" style="width:42%">CUSTOMER COPY</td>
          <td class="title-inv" style="width:38%">TAX INVOICE</td>
        </tr>
      </tbody>
    </table>

    <!-- HEADER ROW : QR | CUSTOMER | BRANCH -->
    <table class="header-row">
      <tbody>
        <tr>
          <!-- QR -->
          <td class="qr-cell" style="width:20%">
            {{{qrDataUri qrCodeBase64}}}
          </td>

          <!-- CUSTOMER BOX -->
          <td style="width:42%">
            <div class="info-box">
              <table>
                <tr>
                  <td class="lbl">Customer</td>
                  <td class="sep">:</td>
                  <td>{{billing_address.[0].name}}</td>
                </tr>
                <tr>
                  <td class="lbl">Customer Address</td>
                  <td class="sep">:</td>
                  <td>{{billing_address.[0].name}} {{billing_address.[0].address_line1}}{{billing_address.[0].address_line2}} {{billing_address.[0].address_line3}}{{billing_address.[0].address_line4}}{{billing_address.[0].address_line5}}{{billing_address.[0].address_code}}</td>
                </tr>
                <tr>
                  <td class="lbl">Contact Person</td>
                  <td class="sep">:</td>
                  <td>{{customer_details.[0].name}}</td>
                </tr>
                <tr>
                  <td class="lbl">Contact Phone</td>
                  <td class="sep">:</td>
                  <td>{{customer_details.[0].contact_no1}}</td>
                </tr>
                <tr>
                  <td class="lbl">Contact VAT No</td>
                  <td class="sep">:</td>
                  <td>{{billing_address.[0].vat}}</td>
                </tr>
              </table>
            </div>
          </td>

          <!-- BRANCH BOX -->
          <td style="width:38%">
            <div class="info-box">
              <table>
                <tr>
                  <td class="lbl">Branch Code</td>
                  <td class="sep">:</td>
                  <td>{{basicdetails.[0].branchname}}</td>
                </tr>
                <tr>
                  <td class="lbl">Voucher No</td>
                  <td class="sep">:</td>
                  <td>{{basicdetails.[0].inv_no}}</td>
                </tr>
                <tr>
                  <td class="lbl">Voucher Date</td>
                  <td class="sep">:</td>
                  <td>{{basicdetails.[0].inv_date}}</td>
                </tr>
                <tr>
                  <td class="lbl">Sales Man</td>
                  <td class="sep">:</td>
                  <td>{{basicdetails.[0].salesman_name}}</td>
                </tr>
                <tr>
                  <td class="lbl">Ref No</td>
                  <td class="sep">:</td>
                  <td>{{basicdetails.[0].reference_no}}</td>
                </tr>
                <tr>
                  <td class="lbl">VAT No</td>
                  <td class="sep">:</td>
                  <td>{{branch.[0].vat}}</td>
                </tr>
              </table>
            </div>
          </td>
        </tr>
      </tbody>
    </table>

    <!-- ITEMS TABLE -->
    <table class="items-table">
      <thead>
        <tr>
          <th style="width:5%"><span class="en">Sl No</span><span class="ar">التسلسل</span></th>
          <th style="width:9%"><span class="en">Code</span><span class="ar">شفرة</span></th>
          <th style="width:15%"><span class="en">Delivery City Name</span><span class="ar">اسم مدينة التسليم</span></th>
          <th style="width:20%"><span class="en">Description</span><span class="ar">وصف</span></th>
          <th style="width:12%"><span class="en">Customer Name</span><span class="ar">اسم العميل</span></th>
          <th style="width:11%"><span class="en">Delivery Date</span><span class="ar">تاريخ التسليم</span></th>
          <th style="width:6%"><span class="en">Unit</span><span class="ar">وحدة</span></th>
          <th style="width:7%"><span class="en">Rate</span><span class="ar">معدل</span></th>
          <th style="width:7%"><span class="en">Quantity</span><span class="ar">كمية</span></th>
          <th style="width:8%"><span class="en">Amount</span><span class="ar">كمية</span></th>
        </tr>
      </thead>
      <tbody>
        $tripcount=0;
        if($unit=='Trip') { $tripcount++;  }
        {{#each itemdetails}}
        <tr>
          <td class="num">{{addOne @index}}</td>
          <td>{{item_code}}</td>
          <td>{{item_name}}</td>
          <td>{{description}}</td>
          <td>{{passenger_name}}</td>
          <td></td>
          <td class="num">{{unit}}</td>
          <td class="right">{{formatAmount price ../bcdp}}</td>
          <td class="right">{{formatAmount quantity ../bcdp}}</td>
          <td class="right">{{formatAmount (multiply price quantity) ../bcdp}}</td>
        </tr>
        {{/each}}
        <tr class="filler">
          <td></td><td></td><td></td><td></td><td></td>
          <td></td><td></td><td></td><td></td><td></td>
        </tr>
      </tbody>
    </table>

    <!-- FOOTER TOTALS -->
    <table class="foot-table">
      <tr>
        <td class="dn-cell">Total Delivery Notes : {{tripcount}}</td>
        <td class="t-lbl-en">Total Value</td>
        <td class="t-lbl-ar">القيمة الاجمالية</td>
        <td class="t-val">{{formatAmount (divide basicdetails.[0].subtotal ccrate) bcdp}}</td>
      </tr>
      <tr>
        <td class="words" rowspan="2">{{bcamountinwords}}</td>
        <td class="t-lbl-en">{{datasettingstextvalue.d828}}</td>
        <td class="t-lbl-ar">القيمة الضريبية</td>
        <td class="t-val">{{formatAmount (divide basicdetails.[0].vatamt ccrate) bcdp}}</td>
      </tr>
      <tr>
        <td class="t-lbl-en">Net Amount</td>
        <td class="t-lbl-ar">المبلغ الصافي</td>
        <td class="t-val">{{formatAmount (divide basicdetails.[0].grand_total ccrate) bcdp}}</td>
      </tr>
    </table>

    <!-- COMPANY / SIGNATURE -->
    <div class="footer">
      <div class="company">{{compprof.name}}</div>
      <div class="sign">
        {{#if Signature}}<img src="{{Signature}}" alt="Signature" style="text-align:right;max-height:{{default datasettings.d458 '120'}}px; max-width:{{default datasettings.d458 '180'}}px;" onerror="this.style.display='none'"/>{{/if}}
      </div>
    </div>

  </body>
</html>
