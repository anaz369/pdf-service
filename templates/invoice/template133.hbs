<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>INVOICE - {{basicdetails.[0].inv_no}}</title>
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        font-family: "IBM Plex Sans Arabic", Arial, sans-serif;
        font-size: 10px;
        line-height: 1.4;
        color: #000;
        margin: 0 4mm;
      }

      .ar {
        direction: rtl;
      }

      table {
        border-collapse: collapse;
        width: 100%;
        table-layout: fixed;
      }

      /* ── HEADER : TITLE | VAT TABLE ───────────────── */
      .head-wrap {
        margin-bottom: 8px;
      }
      .head-wrap > tbody > tr > td {
        vertical-align: top;
        border: none;
        padding: 0;
      }
      .title-cell {
        font-size: 22px;
        font-weight: 800;
        vertical-align: middle !important;
      }
      .title-cell .ar {
        font-weight: 800;
        color: #555;
      }
      .vat-table {
        border: 1px solid #000;
      }
      .vat-table td {
        border: 1px solid #000;
        padding: 3px 6px;
        text-align: center;
        font-size: 8.5px;
        vertical-align: middle;
      }
      .vat-table .vh .en {
        display: block;
        font-weight: 700;
      }
      .vat-table .vh .ar {
        display: block;
        direction: rtl;
        color: #444;
      }
      .vat-table .vv {
        font-size: 9px;
      }

      /* ── BILL TO / SHIP TO ────────────────────────── */
      .party-wrap > tbody > tr > td {
        font-size: 9px;
        vertical-align: top;
        border: none;
      }
      .party {
        border: 1px solid #000;
      }
      .party .phead {
        font-weight: 700;
        text-align: center;
        border-bottom: 1px solid #000;
        padding: 4px 8px;
        display: flex;
        justify-content: space-between;
      }
      .party .phead .ar {
        direction: rtl;
      }
      .party .pbody {
        padding: 8px 10px;
        line-height: 1.7;
        min-height: 110px;
      }

      /* ── ITEMS TABLE ──────────────────────────────── */
      .items-table {
        border: 1px solid #000;
      }
      .items-table th,
      .items-table td {
        font-size: 10px;
        border: 1px solid #000;
        padding: 4px 6px;
        vertical-align: middle;
      }
      .items-table thead th {
        text-align: center;
        line-height: 1.3;
      }
      .items-table thead th .ar {
        display: block;
        direction: rtl;
        font-weight: 700;
      }
      .items-table thead th .en {
        display: block;
        font-weight: 700;
      }
      .items-table td.num {
        text-align: center;
      }
      .items-table td.right {
        text-align: right;
      }
      .items-table tbody td {
        border-top: none;
        border-bottom: none;
      }
      .items-table tbody tr:last-child td {
        border-bottom: 1px solid #000;
      }

      /* ── CNF + TOTALS ─────────────────────────────── */
      .sum-wrap {
        margin-top: 3px;
        font-size: 11px;
        border: 1px solid #000;
        border-top: none;
        table-layout: fixed;
      }
      .sum-wrap td {
        border: 1px solid #000;
        padding: 5px 8px;
        vertical-align: top;
      }
      .sum-wrap .cnf {
        color: red;
        font-weight: 700;
        vertical-align: top;
      }
      .sum-wrap .sum-lbl .ar {
        font-weight: 700;
      }
      .sum-wrap .sum-lbl .en {
        display: block;
        font-weight: 700;
      }
      .sum-wrap .sum-val {
        text-align: right;
        font-weight: 700;
        vertical-align: middle;
      }

      /* ── FOOTER : BANK | QR ───────────────────────── */
      .foot-wrap {
        margin-top: 8px;
      }
      .foot-wrap > tbody > tr > td {
        vertical-align: top;
        border: none;
        padding: 0 4px;
      }
      .bank-box {
        border: 1px solid #000;
        padding: 8px 10px;
      }
      .bank-box .bhead {
        font-size: 11px;
        font-weight: 700;
        margin-bottom: 4px;
      }
      .bank-box table {
        border-collapse: collapse;
      }
      .bank-box td {
        padding: 2px 2px;
        font-size: 9.5px;
        border: none;
      }
      .bank-box td.bl {
        width: 36%;
      }
      .bank-box td.bc {
        width: 6%;
      }
      .qr-foot {
        text-align: center;
        vertical-align: middle;
      }
      .qr-foot .qr-wrap {
        width: 110px;
        height: 110px;
        margin: 0 auto;
        overflow: hidden;
      }
      .qr-foot .qr-wrap img {
        width: 100%;
        height: auto;
        max-width: 110px;
        max-height: 110px;
      }
    </style>
  </head>
  <body>

    <!-- HEADER : TITLE | VAT TABLE -->
    <table class="head-wrap">
      <tr>
        <td class="title-cell" style="width:48%">VAT Invoice &nbsp;&nbsp;<span class="ar">فاتورة ضريبية</span></td>
        <td style="width:52%">
          <table class="vat-table">
            <tr>
              <td class="vh"><span class="en">Our VAT No</span><span class="ar">لدينا ضريبة رقم</span></td>
              <td class="vh"><span class="en">VAT No</span><span class="ar">رقم ضريبة</span></td>
              <td class="vh"><span class="en">Date</span><span class="ar">التاريخ</span></td>
              <td class="vh"><span class="en">Inv No</span><span class="ar">رقم الفاتورة</span></td>
            </tr>
            <tr>
              <td class="vv">{{branch.[0].vat}}</td>
              <td class="vv">{{billing_address.[0].vat}}</td>
              <td class="vv">{{basicdetails.[0].inv_date}}</td>
              <td class="vv">{{basicdetails.[0].inv_no}}</td>
            </tr>
          </table>
        </td>
      </tr>
    </table>

    <!-- BILL TO / SHIP TO -->
    <table class="party-wrap">
      <tr>
        <td style="width:49.5%">
          <div class="party">
            <div class="phead"><span>Bill To</span><span class="ar">فاتورة الى</span></div>
            <div class="pbody">
              {{billing_address.[0].name}}<br/>
              {{billing_address.[0].address_line1}}<br/>
              {{billing_address.[0].address_line2}}<br/>
              {{billing_address.[0].address_line4}} - {{billing_address.[0].address_code}}<br/>
              {{billing_address.[0].address_line3}}<br/>
              {{billing_address.[0].address_line5}}
            </div>
          </div>
        </td>
        <td style="width:1%"></td>
        <td style="width:49.5%">
          <div class="party">
            <div class="phead"><span>Ship To</span><span class="ar">الشحن الى</span></div>
            <div class="pbody">
              {{shipping_address.[0].name}}<br/>
              {{shipping_address.[0].address_line1}}<br/>
              {{shipping_address.[0].address_line2}}<br/>
              {{shipping_address.[0].address_line4}} - {{shipping_address.[0].address_code}}<br/>
              {{shipping_address.[0].address_line3}}<br/>
              {{shipping_address.[0].address_line5}}
            </div>
          </div>
        </td>
      </tr>
    </table>

    <!-- ITEMS TABLE -->
    <table class="items-table" style="margin-top:8px;">
      <thead>
        <tr>
          <th style="width:14%"><span class="ar">الوزن القائم</span><span class="en">Gross Weight Kgs</span></th>
          <th style="width:13%"><span class="ar">مجموع الكرتون</span><span class="en">Total Cartoons</span></th>
          <th style="width:31%"><span class="ar">البيان</span><span class="en">Description</span></th>
          <th style="width:13%"><span class="ar">السعر الكيلو</span><span class="en">Price Kgs</span></th>
          <th style="width:13%"><span class="ar">الوزن الصافي</span><span class="en">Net Weight Kgs</span></th>
          <th style="width:16%"><span class="ar">السعر الاجمالي</span><span class="en">Total Amount</span></th>
        </tr>
      </thead>
      <tbody>
        {{#each itemdetails}}
        <tr>
          <td class="num"></td>
          <td class="num"></td>
          <td>{{item_name}}{{name_lang2}}{{description}}</td>
          <td class="right"><span style="font-size: 13px;">{{currencySymbol ../basicdetails.[0].base_country_isocode}}</span>{{formatAmount price ../bcdp}}</td>
          <td class="num">{{formatAmount quantity ../bcdp}}</td>
          <td class="right"><span style="font-size: 13px;">{{currencySymbol ../basicdetails.[0].base_country_isocode}}</span>{{formatAmount amount ../bcdp}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>

    <!-- CNF + TOTALS -->
    <table class="sum-wrap">
      <tr>
        <td class="cnf" rowspan="3" style="width:56%">CNF</td>
        <td class="sum-lbl" style="width:28%"><span class="ar">الاجمالي</span><span class="en">Total</span></td>
        <td class="sum-val" style="width:16%"><span style="font-size:15px;">{{currencySymbol basicdetails.[0].base_country_isocode}}</span>{{formatAmount (divide basicdetails.[0].subtotal ccrate) bcdp}}</td>
      </tr>
      <tr>
        <td class="sum-lbl"><span class="ar">ضريبة القيمة المضافة</span><span class="en">{{datasettingstextvalue.d828}}</span></td>
        <td class="sum-val"><span style="font-size:15px;">{{currencySymbol basicdetails.[0].base_country_isocode}}</span>{{formatAmount (divide basicdetails.[0].vatamt ccrate) bcdp}}</td>
      </tr>
      <tr>
        <td class="sum-lbl"><span class="ar">المبلغ الاجمالي</span><span class="en">Total Amount</span></td>
        <td class="sum-val"><span style="font-size:15px;">{{currencySymbol basicdetails.[0].base_country_isocode}}</span>{{formatAmount (divide basicdetails.[0].grand_total ccrate) bcdp}}</td>
      </tr>
    </table>

    <!-- FOOTER : BANK | QR -->
    <table class="foot-wrap">
      <tr>
        <td style="width:55%">
          <div class="bank-box">
            <div class="bhead">Bank Details For Remittance:</div>
            <table>
              <tr><td class="bl">Account Name</td><td class="bc">:</td><td style="font-weight: bold;">{{bankdetails.acc_name}}</td></tr>
              <tr><td class="bl">Bank</td><td class="bc">:</td><td style="font-weight: bold;">{{bankdetails.name}}</td></tr>
              <tr><td class="bl">Swift</td><td class="bc">:</td><td style="font-weight: bold;">{{bankdetails.swift_no}}</td></tr>
              <tr><td class="bl">IBAN</td><td class="bc">:</td><td style="font-weight: bold;">{{bankdetails.iban_no}}</td></tr>
            </table>
          </div>
        </td>
        <td class="qr-foot" style="width:45%">
          <div class="qr-wrap">{{{qrDataUri qrCodeBase64}}}</div>
        </td>
      </tr>
    </table>

  </body>
</html>
