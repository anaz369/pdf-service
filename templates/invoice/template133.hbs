<html xmlns="http://www.w3.org/1999/xhtml">
<head>
<meta charset="utf-8">
<meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
<meta http-equiv="X-UA-Compatible" content="IE=edge" />
<meta name="format-detection" content="telephone=yes" />
<title>133</title>
   <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<style>
    table{
        width: 100%;
        font-family: Tahoma, sans-serif;
        font-size: 12px;
        vertical-align: top;
    }
    .tablee{
        border: 1px solid #000;
        font-size: 11px;
    }
    .tablee th{
        padding: 5px 8px;
        color: #000;
        font-weight: bold;
        background-color: #fff;
        border-bottom: 1px solid #000;
    }
    .tablee td{
        padding: 5px 8px;
        color: #000;
        vertical-align: top;
        line-height: 16px;
    }
    .tablee3{
        border: 1px solid #000;
        font-size: 11px;
    }
    .tablee3 th{
        padding: 5px 8px;
        color: #000;
        font-weight: bold;
    }
    .tablee3 td{
        padding: 5px 8px;
        color: #000;
        vertical-align: top;
        line-height: 16px;
    }
     .tablee1{
        border: 1px solid #000;
        font-size: 11px;
    }

    .tablee1 td{
        padding: 5px 8px;
        color: #000;
        vertical-align: top;
        background-color: #fff;
        line-height: 16px;
        border: 1px solid #000;
    }
    .tablee1 th{
        padding: 5px 8px;
        color: #000;
        font-weight: bold;
        border: 1px solid #000;
        vertical-align: top;
    }
    .table_b{
        border-top: 1px solid #000;
    }
    .invoice_head {
        font-weight: 700;
        font-size: 30px;
        margin-bottom: 15px;
    }
    .invoice_head span {
        color: #b72031;
    }
    .table_black{
        border: 1px solid #000;
    }
    .table_black th{
        padding: 6px 8px;
        color: #000;
        border: 1px solid #000;
        font-size: 11px;
        font-weight: bold;
    }
    .table_black td{
        padding: 6px 8px;
        color: #000;
        border: 1px solid #000;
        vertical-align: top;
    }
    .bt_1 {
    border-top: 1px solid #c0c0c0;
}
    .br_1 {
    border-right: 1px solid #c0c0c0;
}
    .lih-20{
        line-height: 20px !important;
    }
</style>
</head>
<body>
    <div class="section">
        <div class="container">
            <div class="row">
                <div class="col-lg-6 col-md-6 col-sm-6 mt-3">
                    <h1 class="text-start invoice_head">VAT Invoice ضريبة فاتورة </h1>
                </div>
                <div class="col-lg-6 col-md-6 col-sm-6 mt-3">
                    <table class="table_black">
                        <tr>
                            <th class="text-center">Our VAT No<br>لدينا رقم ضريبة</th>
                            <th class="text-center">VAT No<br>رقم ضريبة</th>
                            <th class="text-center">Date<br>التاريخ</th>
                            <th class="text-center">Inv No<br>رقم الفاتورة</th>
                        </tr>
                        <tr>
                            <td class="text-center">{{branch.[0].vat}}</td>
                            <td class="text-center">{{billing_address.[0].vat}}</td>
                            <td class="text-center">{{basicdetails.[0].inv_date}}</td>
                            <td class="text-center">{{basicdetails.[0].inv_no}}</td>
                        </tr>
                    </table>
                </div>
                <div class="col-lg-6 col-md-6 col-sm-6 mt-1">
                    <table class="tablee">
                        <tr>
                            <th class="text-center">Bill To</th>
                            <th class="text-center">فاتورة الى</th>
                        </tr>
                        <tr>
                            <td class="text-start" colspan="2">
                                 {{billing_address.[0].name}}<br>
                                 {{#if billing_address.[0].address_line1}}{{billing_address.[0].address_line1}}<br>{{/if}}
                                 {{#if billing_address.[0].address_line2}}{{billing_address.[0].address_line2}}<br>{{/if}}
                                 {{#if billing_address.[0].address_line3}}{{billing_address.[0].address_line4}} - {{billing_address.[0].address_code}}<br>{{/if}}
                                 {{#if billing_address.[0].address_line3}}{{billing_address.[0].address_line3}}<br>{{/if}}
                                 {{#if billing_address.[0].address_line5}}{{billing_address.[0].address_line5}}{{/if}}
                            </td>
                        </tr>
                    </table>
                </div>
                <div class="col-lg-6 col-md-6 col-sm-6 mt-1">
                    <table class="tablee">
                        <tr>
                            <th class="text-center">Ship To</th>
                            <th class="text-center">الشحن الى</th>
                        </tr>
                        <tr>
                            <td class="text-start" colspan="2">
                                 {{shipping_address.[0].name}}<br>
                                 {{#if shipping_address.[0].address_line1}}{{shipping_address.[0].address_line1}}<br>{{/if}}
                                 {{#if shipping_address.[0].address_line2}}{{shipping_address.[0].address_line2}}<br>{{/if}}
                                 {{#if shipping_address.[0].address_line3}}{{shipping_address.[0].address_line4}} - {{shipping_address.[0].address_code}}<br>{{/if}}
                                 {{#if shipping_address.[0].address_line3}}{{shipping_address.[0].address_line3}}<br>{{/if}}
                                 {{#if shipping_address.[0].address_line5}}{{shipping_address.[0].address_line5}}{{/if}}
                            </td>
                        </tr>
                    </table>
                </div>
                <div class="col-lg-12 mt-2">
                    <table class="tablee1">
                        <thead>
                            <tr>
                                <th class="text-center">الوزن القائم<br>Gross Weight Kgs</th>
                                <th class="text-center">مجموع الكرتون<br>Total Cartoons</th>
                                <th class="text-center">البيان<br>Description</th>
                                <th class="text-center">السعر الكيلو<br>Price Kgs</th>
                                <th class="text-center">الوزن الصافي <br>Net Weight Kgs</th>
                                <th class="text-center">السعر الاجمالي<br>Total Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#each itemdetails}}
                            <tr>
                                <td class="text-center">{{formatAmount gross_weight ../bcdp}}</td>
                                <td class="text-center">{{formatAmount quantity ../bcdp}}</td>
                                <td class="text-start">{{item_name}}{{#if name_lang2}} {{name_lang2}}{{/if}}{{#if description}} {{description}}{{/if}}</td>
                                <td class="text-end">{{formatAmount price ../bcdp}}</td>
                                <td class="text-center">{{formatAmount quantity ../bcdp}}</td>
                                <td class="text-end">{{formatAmount amount ../bcdp}}</td>
                            </tr>
                            {{/each}}

                        </tbody>
                    </table>
                </div>
                <div class="col-lg-12 mt-0">
                    <table class="table_black">
                        <tr>
                            <th rowspan="{{#if (gt basicdetails.[0].discount 0)}}4{{else}}3{{/if}}" class="text-danger w-75">CNF</th>
                            <th> الاجمالي  <br>Total</th>
                            <td class="text-end">{{formatAmount basicdetails.[0].subtotal bcdp}}</td>
                        </tr>
                        {{#if (gt basicdetails.[0].discount 0)}}
                        <tr>
                            <th>الخصم <br>Discount</th>
                            <td class="text-end">- {{formatAmount basicdetails.[0].discount bcdp}}</td>
                        </tr>
                        {{/if}}
                        <tr>
                            <th>ضريبة القيمة المضافة <br>Value Added Tax {{#if datasettingstextvalue.d828}}{{datasettingstextvalue.d828}}{{else}}15%{{/if}}</th>
                            <td class="text-end">{{formatAmount basicdetails.[0].vatamt bcdp}}</td>
                        </tr>
                        <tr>
                            <th>المبلغ الاجمالي <br>Total Amount</th>
                            <td class="text-end">{{formatAmount basicdetails.[0].grand_total bcdp}}</td>
                        </tr>
                    </table>
                </div>
                <div class="col-lg-4 col-md-4 col-sm-4 mt-2">
                    {{#if bankdetails}}
                    <table class="tablee3">
                        <tr>
                            <th colspan="3">Bank Details For Remittance:</th>
                        </tr>
                        {{#if bankdetails.acc_name}}
                        <tr>
                            <td>Account Name</td>
                            <td>:</td>
                            <th>{{bankdetails.acc_name}}</th>
                        </tr>
                        {{/if}}
                        {{#if bankdetails.name}}
                        <tr>
                            <td>Bank</td>
                            <td>:</td>
                            <th>{{bankdetails.name}}</th>
                        </tr>
                        {{/if}}
                        {{#if bankdetails.swift_no}}
                        <tr>
                            <td>Swift</td>
                            <td>:</td>
                            <th>{{bankdetails.swift_no}}</th>
                        </tr>
                        {{/if}}
                        {{#if bankdetails.iban_no}}
                        <tr>
                            <td>IBAN</td>
                            <td>:</td>
                            <th>{{bankdetails.iban_no}}</th>
                        </tr>
                        {{/if}}
                    </table>
                    {{/if}}
                </div>
                <div class="col-lg-4 col-md-4 col-sm-4 mt-2 text-center">
                    {{#if qrCodeBase64}}
                    {{{qrDataUri qrCodeBase64}}}
                    {{/if}}
                </div>
                <div class="col-lg-4 col-md-4 col-sm-4 mt-2 text-center">
                    {{#if Seal}}<img src="{{Seal}}" alt="Seal" style="max-height:60px; max-width:60px; display:block; margin:0 auto 4px;"/>{{/if}}
                    {{#if Signature}}<img src="{{Signature}}" alt="Signature" style="max-height:40px; max-width:80px; display:block; margin:0 auto 4px;"/>{{/if}}
                    <div style="font-size:11px; font-weight:bold; margin-top:4px;">{{basicdetails.[0].created_user}}</div>
                    <div style="font-size:10px; color:#666;">Authorised Signatory</div>
                </div>

            </div>
        </div>
    </div>
</body>
</html>
