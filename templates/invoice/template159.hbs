<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>INVOICE - {{basicdetails.[0].inv_no}}</title>

<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: #ffffff;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 10px;
    color: #000;
    line-height: 1.4;
    margin: 0 8mm;
  }

  .page { width: 100%; margin: 0 auto; padding-top: 6px; }

  /* ── Shared ──────────────────────────────── */
  .label-ar { direction: rtl; text-align: right; }
  .center   { text-align: center; }
  .right    { text-align: right; }
  .bold     { font-weight: bold; }


  /* ── Invoice header table (Bill To + QR + Invoice Info) ── */
  .invoice-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
  }
  .invoice-table td {
    padding: 4px 6px;
    vertical-align: top;
  }
  .invoice-table table {
    border-collapse: separate;
    border-spacing: 0;
  }
  .invoice-table table td {
    padding: 3px 5px;
  }

  /* ── Top : Bill To + QR + Invoice Info ───── */
  .top-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
    margin-top: 4px;
  }
  .top-table > tbody > tr > td {
    vertical-align: top;
    padding: 0;
    border: none;
  }

  .bill-to-cell {
    width: 38%;
    padding-right: 8px;
  }
  .bill-to-title {
    font-weight: bold;
    font-size: 11px;
    border-bottom: 1px solid #000;
    padding-bottom: 2px;
    margin-bottom: 4px;
  }
  .bill-to-row {
    display: table;
    width: 100%;
    padding: 1px 0;
  }
  .bill-to-row .en {
    display: table-cell;
    width: 60%;
    text-align: left;
  }
  .bill-to-row .ar {
    display: table-cell;
    width: 40%;
    direction: rtl;
    text-align: right;
  }
  .bill-to-row .lbl {
    font-weight: bold;
  }

  .qr-cell {
    width: 24%;
    text-align: center;
    padding: 0 6px;
  }
  .qr-cell .qr-box {
    display: inline-block;
    padding: 4px;
    border: 1px solid #000;
  }

  .invoice-info-cell {
    width: 38%;
    padding-left: 8px;
  }
  .invoice-info-title {
    text-align: center;
    font-size: 16px;
    font-weight: bold;
    margin-bottom: 6px;
  }
  .invoice-info-table {
    width: 100%;
    border-collapse: collapse;
  }
  .invoice-info-table td {
    padding: 2px 4px;
    font-size: 10px;
    border: none;
    vertical-align: top;
  }
  .invoice-info-table .lbl-en {
    font-weight: bold;
    width: 35%;
  }
  .invoice-info-table .val {
    width: 35%;
    text-align: center;
  }
  .invoice-info-table .lbl-ar {
    width: 30%;
    direction: rtl;
    text-align: right;
    font-weight: bold;
  }


  /* ── Items table ─────────────────────────── */
  .items-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
    margin-top: 8px;
  }
  .items-table th,
  .items-table td {
    border: 1px solid #fff;
    padding: 2px 4px;
    font-size: 10px;
    vertical-align: middle;
  }
  .items-table thead th {
    background: #344767;
    border: 1px solid #ffffff;
    color: #fff;
    font-weight: bold;
    text-align: center;
  }
  .items-table thead .head-en {
    border-bottom: none;
  }
  .items-table thead .head-ar th {
    border-top: none;
    direction: rtl;
  }
  .items-table td {
    font-size: 9px;
  }
  .items-table tbody td.c { text-align: center; }
  .items-table tbody td.r { text-align: right; }


  /* ── Terms + Summary ─────────────────────── */
  .summary-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
    margin-top: 12px;
    page-break-inside: avoid;
    break-inside: avoid;
  }
  .summary-table > tbody > tr > td {
    vertical-align: top;
    padding: 0;
    border: none;
  }

  .terms-cell {
    width: 55%;
    padding-right: 10px;
  }
  .terms-title {
    font-weight: bold;
    padding-bottom: 2px;
  }
  .terms-body {
    font-size: 10px;
    line-height: 1.5;
  }

  .totals-cell {
    width: 45%;
  }
  .totals-inner {
    width: 100%;
    border-collapse: collapse;
    border: 1px solid #000;
  }
  .totals-inner td {
    padding: 3px 6px;
    font-size: 10px;
    border: 1px solid #000;
  }
  .totals-inner .lbl-en {
    width: 35%;
  }
  .totals-inner .lbl-ar {
    width: 35%;
    direction: rtl;
    text-align: right;
  }
  .totals-inner .val {
    width: 30%;
    text-align: right;
  }

  /* ── Footer : Amount in Words ────────────── */
  .words-wrap {
    width: 100%;
    margin-top: 8px;
    border: 1px solid #000;
    page-break-inside: avoid;
    break-inside: avoid;
  }
  .words-bar {
    width: 100%;
    background: #344767;
    color: #fff;
    padding: 4px 8px;
  }
  .words-bar table {
    width: 100%;
    border: none;
  }
  .words-bar td {
    border: none;
    padding: 0;
    color: #fff;
    font-weight: bold;
  }
  .words-bar .en  { text-align: left; }
  .words-bar .ar  { direction: rtl; text-align: right; }
  .words-text {
    padding: 5px 8px;
    font-size: 10px;
    border-top: 1px solid #000;
  }
  .words-text table {
    width: 100%;
    border: none;
  }
  .words-text td {
    border: none;
    padding: 0;
    vertical-align: top;
  }
  .words-text .en { text-align: left; width: 60%; }
  .words-text .ar { direction: rtl; text-align: right; width: 40%; }

  /* ── Bank Account Details ────────────────── */
  .bank-wrap {
    margin-top: 12px;
    page-break-inside: avoid;
    break-inside: avoid;
  }
  .bank-title {
    font-weight: bold;
    font-size: 11px;
    margin-bottom: 8px;
  }
  .bank-table {
    border-collapse: collapse;
  }
  .bank-table td {
    padding: 1px 4px;
    font-size: 10px;
    vertical-align: top;
  }
  .bank-table .bk-lbl { white-space: nowrap; }
  .bank-table .bk-sep { padding: 1px 12px; }
</style>
</head>

<body>
<div class="page">


<table class="invoice-table" style="width: 100%;font-family: arial;padding: 4px;margin-top: 10px;font-size: 10px;" cellspacing="0">
  <tr>
    <td style="width: 45%;padding: 0 6px;vertical-align: top;">
      <table style="width: 100%;font-family: arial;padding: 0;margin-top: 10px;font-size: 10px;" cellspacing="0">
        <tr>
            <td style="text-align: left;font-weight:bold;">Bill To</td>
            <td style="text-align: right;font-weight:bold;"> فاتوره إلى</td>
        </tr>
        <tr>
          <td style="text-align: left;">
            {{billing_address.[0].name}}<br>
            {{{joinAddress billing_address.[0] '<br>'}}}

          </td>
          {{#if billing_address_lang2.[0].name}}
          <td colspan="2" style="text-align: right;">
                {{billing_address_lang2.[0].name}}<br>
                {{{joinAddress billing_address_lang2.[0] '<br>'}}}
          </td>
          {{/if}}
        </tr>
        <tr>
            <td style="text-align: left;">VAT Number : {{customer_details.[0].VAT_number}}</td>
        </tr>
        <tr>
            <td style="text-align: left;">CR Number : {{customer_details.[0].cr_no}}</td>
        </tr>
      </table>
    </td>
    <td style="width: 55%;padding: 0 6px;vertical-align: top;">
      <table style="width: 100%;font-family: arial;padding: 0;margin-top: 10px;font-size: 10px;" cellspacing="0">
          <tr>
              <td colspan="3" style="text-align: center;vertical-align: middle;font-size: 14px;padding: 4px;">
                <div style="display: inline-block;text-align: center;">{{{qrDataUri qrCodeBase64}}}</div>
              </td>
          </tr>
      </table>
      <table style="width: 100%;font-family: arial;margin-top: 10px;" cellspacing="0">
          <tr>
              <td colspan="3" style=";text-align: center;font-size: 20px;">TAX INVOICE <span> فاتورة ضريبية </span></td>
          </tr>
          <tr>
              <td style="text-align: left;" width="24%">Invoice Number</td>
              <td style="text-align: left;" width="52%">{{basicdetails.[0].inv_no}}</td>
              <td style="text-align: right;" width="24%">رقم الفاتورة</td>
          </tr>
          <tr>
              <td style="text-align: left;">Invoice Date</td>
              <td style="text-align: left;">{{basicdetails.[0].inv_date}}</td>
              <td style="text-align: right;">تاريخ الفاتورة</td>
          </tr>
          <tr>
              <td style="text-align: left;">Invoice Time</td>
              <td style="text-align: left;">{{basicdetails.[0].inv_time}}</td>
              <td style="text-align: right;">وقت الفاتورة</td>
          </tr>
          <tr>
              <td style="text-align: left;">P O Number</td>
              <td style="text-align: left;">{{basicdetails.[0].order_no}}</td>
              <td style="text-align: right;">رقم طلب الشراء</td>
          </tr>						
          <tr>
              <td style="text-align: left;">P O Date</td>
              <td style="text-align: left;">{{basicdetails.[0].po_date}}</td>
              <td style="text-align: right;">تاريخ أمر الشراء</td>
          </tr>
          <tr>
              <td style="text-align: left;">Reference No</td>
              <td style="text-align: left;">{{basicdetails.[0].reference_no}}</td>
              <td style="text-align: right;">رقم المرجع</td>
          </tr>
        </table>
    </td>
  </tr>
</table>




  <!-- Items -->
  <table class="items-table">
    <thead>
      <tr class="head-en">
        <th style="width:4%;">Sl </br>م</th>
        <th style="width:38%;">Item Description </br>وصف السلعة</th>
        <th style="width:6%;">Qty </br>الكمية</th>
        <th style="width:7%;">UOM </br>وحدة </th>
        <th style="width:10%;">Unit Rate </br>معدل الوحدة</th>
        <th style="width:11%;">Total </br>المجموع</th>
        <th style="width:11%;">{{datasettingstextvalue.d828}} </br>قيمة الضريبة</th>
        <th style="width:13%;">Grand Total </br>المجموع الإجمالي</th>
      </tr>
    </thead>
    <tbody>
      {{#each itemdetails}}
      <tr>
        <td class="c">{{addOne @index}}</td>
        <td>{{item_name}}{{#if name_lang2}}<br>{{name_lang2}}{{/if}}{{#if description}}<br>{{description}}{{/if}}</td>
        <td class="c">{{quantity}}</td>
        <td class="c">{{unit}}</td>
        <td class="r">{{formatAmount price ../bcdp}}</td>
        <td class="r">{{formatAmount taxable ../bcdp}}</td>
        <td class="r">{{formatAmount tax ../bcdp}}</td>
        <td class="r">{{formatAmount amount ../bcdp}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>


  <!-- Terms + Summary -->
  <table class="summary-table">
    <tr>

      <td class="terms-cell">
        <div class="terms-title">Terms and Conditions :</div>
        <div class="terms-body">{{basicdetails.[0].terms_and_condition}}</div>
      </td>

      <td class="totals-cell">
        <table class="totals-inner">
          <tr>
            <td class="lbl-en">Subtotal</td>
            <td class="lbl-ar">المجموع الفرعي</td>
            <td class="val">{{formatAmount (divide basicdetails.[0].subtotal ccrate) bcdp}}</td>
          </tr>
          {{#if zatcadiscount.[0]}}
            {{#each zatcadiscount}}
              <tr>
                <td class="lbl-en">{{reason_name}}</td>
                <td class="lbl-ar">{{reason_name_lang2}}</td>
                <td class="val">{{formatAmount (divide dld ../ccrate) bcdp}}</td>
              </tr>
            {{/each}}
            {{else}}

              {{#if (or basicdetails.[0].discount basicdetails.[0].dld)}}
              <tr>
                <td class="lbl-en">Discount</td>
                <td class="lbl-ar">تخفيض</td>
                <td class="val">{{formatAmount (add basicdetails.[0].subtotal basicdetails.[0].dld) bcdp}}</td>
              </tr>
              {{/if}}
          {{/if}}
          <tr>
            <td class="lbl-en">{{datasettingstextvalue.d828}}</td>
            <td class="lbl-ar">ضريبة القيمة المضافة</td>
            <td class="val">{{formatAmount (divide basicdetails.[0].vatamt ccrate) bcdp}}</td>
          </tr>
          <tr class="grand">
            <td class="lbl-en">Total Amount in {{basicdetails.[0].base_country_isocode}}</td>
            <td class="lbl-ar">المبلغ الإجمالي</td>
            <td class="val">{{formatAmount (divide basicdetails.[0].grand_total ccrate) bcdp}}</td>
          </tr>
        </table>
      </td>

    </tr>
  </table>


  <!-- Amount in Words -->
  <div class="words-wrap">
    <div class="words-bar">
      <table>
        <tr>
          <td class="en">Total Amount in Words</td>
          <td class="ar">المبلغ الإجمالي بالكلمات</td>
        </tr>
      </table>
    </div>
    <div class="words-text">
      <table>
        <tr>
          <td class="en">{{bcamountinwords}}</td>
          <td class="ar">{{bcamountinwordsar}}</td>
        </tr>
      </table>
    </div>
  </div>


  <!-- Bank Account Details -->
  {{#if bankdetails.name}}
  <div class="bank-wrap">
    <div class="bank-title">Bank Account Details</div>
    <table class="bank-table">
      <tr><td class="bk-lbl">Bank Name</td><td class="bk-sep">:</td><td class="bk-val">{{bankdetails.name}}</td></tr>
      <tr><td class="bk-lbl">Account Name</td><td class="bk-sep">:</td><td class="bk-val">{{bankdetails.acc_name}}</td></tr>
      <tr><td class="bk-lbl">Account Number</td><td class="bk-sep">:</td><td class="bk-val">{{bankdetails.acc_no}}</td></tr>
      <tr><td class="bk-lbl">IBAN No</td><td class="bk-sep">:</td><td class="bk-val">{{bankdetails.iban_no}}</td></tr>
      <tr><td class="bk-lbl">SWIFT No</td><td class="bk-sep">:</td><td class="bk-val">{{bankdetails.swift_no}}</td></tr>
      <tr><td class="bk-lbl">Branch Name</td><td class="bk-sep">:</td><td class="bk-val">{{bankdetails.branch_name}}</td></tr>
    </table>
  </div>
  {{/if}}

</div>
</body>
</html>
