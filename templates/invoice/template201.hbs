<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="UTF-8">
    <title>Invoice - {{basicdetails.[0].inv_no}}</title>
    <style>
        @page {
            size: 302px auto;
            margin: 0;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: Arial, sans-serif;
            font-size: 11px;
            line-height: 1.4;
            background: #fff;
            color: #000;
            width: 302px;
        }

        .thermal {
            width: 302px;
            padding: 6px 8px;
        }

        /* ── Arabic text ───────────────────────────
           Use system Arabic fonts — no Google Fonts
           needed. These are always available in
           Puppeteer's Chromium on Lambda/Linux.
        ─────────────────────────────────────────── */
        .ar {
            font-family: 'Traditional Arabic', 'Arabic Typesetting',
                         'Scheherazade New', 'Amiri', Arial, sans-serif;
            direction: rtl;
            unicode-bidi: embed;
        }

        /* ── Company Header ────────────────────── */
        .company-header {
            text-align: center;
            padding-bottom: 6px;
            border-bottom: 1px dashed #000;
            margin-bottom: 5px;
        }

        .company-name {
            font-size: 14px;
            font-weight: bold;
            text-transform: uppercase;
        }

        .company-meta {
            font-size: 10px;
            line-height: 1.6;
        }

        /* ── Meta row ──────────────────────────── */
        .meta-row {
            display: flex;
            justify-content: space-between;
            font-size: 10px;
            margin-bottom: 5px;
        }

        /* ── Section divider ───────────────────── */
        .divider {
            border: none;
            border-top: 1px dashed #000;
            margin: 4px 0;
        }

        .section-label {
            font-size: 10px;
            font-weight: bold;
            text-align: center;
            border-top: 1px dashed #000;
            border-bottom: 1px dashed #000;
            padding: 2px 0;
            margin: 4px 0;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        /* ── Bill To ───────────────────────────── */
        .bill-to {
            font-size: 10px;
            margin-bottom: 4px;
            line-height: 1.5;
        }

        .bill-to .customer-name {
            font-weight: bold;
            font-size: 11px;
        }

        /* ── Invoice title ─────────────────────── */
        .inv-title {
            text-align: center;
            font-size: 12px;
            font-weight: bold;
            border-top: 1px solid #000;
            border-bottom: 1px solid #000;
            padding: 3px 0;
            margin: 5px 0;
        }

        /* ── Items table ───────────────────────── */
        .items-table {
            width: 100%;
            border-collapse: collapse;
            margin: 4px 0;
            font-size: 10px;
        }

        .items-table thead tr {
            border-top: 1px solid #000;
            border-bottom: 1px solid #000;
        }

        .items-table th {
            padding: 2px 2px;
            font-weight: bold;
            font-size: 10px;
            text-align: left;
        }

        .items-table th.r { text-align: right; }
        .items-table th.c { text-align: center; }
        .items-table td.r { text-align: right; white-space: nowrap; }
        .items-table td.c { text-align: center; }

        .items-table tbody tr {
            border-bottom: 1px dashed #ccc;
        }

        .items-table tbody tr:last-child {
            border-bottom: 1px solid #000;
        }

        .items-table td {
            padding: 3px 2px;
            vertical-align: top;
        }

        .item-name-en {
            font-weight: bold;
            display: block;
        }

        .item-name-ar {
            font-size: 9px;
            color: #333;
            display: block;
            text-align: right;
            direction: rtl;
        }

        /* ── Totals ────────────────────────────── 
           Two columns only: label (EN + AR stacked)
           and amount. Avoids squishing issue.
        ─────────────────────────────────────────── */
        .totals {
            width: 100%;
            border-collapse: collapse;
            font-size: 10px;
            margin: 4px 0;
        }

        .totals td {
            padding: 2px 2px;
            vertical-align: top;
        }

        .totals td.lbl {
            width: 75%;
        }

        .totals td.lbl .en {
            display: block;
            font-size: 10px;
        }

        .totals td.lbl .ar {
            display: block;
            font-size: 9px;
            color: #444;
            text-align: right;
            direction: rtl;
        }

        .totals td.amt {
            width: 25%;
            text-align: right;
            white-space: nowrap;
            vertical-align: middle;
            font-weight: bold;
        }

        .totals tr.total-due {
            border-top: 1px solid #000;
            border-bottom: 1px solid #000;
        }

        .totals tr.total-due td {
            font-size: 11px;
            font-weight: bold;
            padding: 3px 2px;
        }

        /* ── Amount in words ───────────────────── */
        .amount-words {
            text-align: center;
            font-size: 10px;
            padding: 4px 2px;
            border-top: 1px dashed #000;
            border-bottom: 1px dashed #000;
            margin: 4px 0;
            line-height: 1.6;
        }

        /* ── Footer ────────────────────────────── */
        .footer {
            text-align: center;
            font-size: 10px;
            padding-top: 5px;
            color: #333;
        }
    </style>
</head>
<body>
<div class="thermal">

    {{!-- ── Company Header ─────────────────────── --}}
    <div class="company-header">
        <div class="company-name">{{branch.[0].name}}</div>
        {{#if branch_lang2.[0].name}}
        <div class="ar" style="font-size:12px; font-weight:bold;">{{branch_lang2.[0].name}}</div>
        {{/if}}
        <div class="company-meta">
            {{#if branch.[0].cr_no}}C.R.: {{branch.[0].cr_no}}<br>{{/if}}
            {{#if branch.[0].vat}}VAT : {{branch.[0].vat}}<br>{{/if}}
            {{joinAddress branch.[0]}}
        </div>
    </div>

    {{!-- ── Date + Invoice No ──────────────────── --}}
    <div class="meta-row">
        <span>Date : {{basicdetails.[0].inv_date}}</span>
        <span>Invoice : {{basicdetails.[0].inv_no}}</span>
    </div>

    {{!-- ── Bill To ──────────────────────────────── --}}
    <div class="section-label">Bill To</div>

    <div class="bill-to">
        <div class="customer-name">{{billing_address.[0].name}}</div>
        {{#if billing_address.[0].address_line1}}
        <div>{{joinAddress billing_address.[0]}}</div>
        {{/if}}
        {{#if customer_details.[0].VAT_number}}
        <div>VAT : {{customer_details.[0].VAT_number}}</div>
        {{/if}}
        {{#if customer_details.[0].cr_no}}
        <div>C.R.: {{customer_details.[0].cr_no}}</div>
        {{/if}}
    </div>

    {{!-- ── Invoice Title ──────────────────────── --}}
    <div class="inv-title">
        INVOICE &nbsp;-&nbsp; <span class="ar">فاتورة ضريبية</span>
    </div>

    {{!-- ── Items Table ──────────────────────────── --}}
    <table class="items-table">
        <thead>
            <tr>
                <th style="width:36%;">ITEM</th>
                <th class="c" style="width:9%;">QTY</th>
                <th class="r" style="width:18%;">RATE</th>
                <th class="r" style="width:13%;">TAX</th>
                <th class="r" style="width:24%;">AMOUNT</th>
            </tr>
        </thead>
        <tbody>
        {{#each itemdetails}}
            <tr>
                <td>
                    {{!-- item_name only — description causes the "false" issue
                         when it's a boolean or same as item_name --}}
                    <span class="item-name-en">{{item_name}}</span>
                    {{#if name_lang2}}
                    <span class="item-name-ar ar">{{name_lang2}}</span>
                    {{/if}}
                </td>
                <td class="c">{{quantity}}</td>
                <td class="r">{{price}}</td>
                <td class="r">{{tax}}</td>
                <td class="r">{{amount}}</td>
            </tr>
        {{/each}}
        </tbody>
    </table>

    {{!-- ── Totals ──────────────────────────────── --}}
    {{#with basicdetails.[0]}}
    <table class="totals">
        <tr>
            <td class="lbl">
                <span class="en">Total Taxable Amount</span>
                <span class="ar">الإجمالي الواضع للضريبة (غير شاملة ضريبة القيمة المضافة)</span>
            </td>
            <td class="amt">{{subtotal}}</td>
        </tr>
        <tr>
            <td class="lbl">
                <span class="en">VAT</span>
                <span class="ar">مجموع ضريبة القيمة المضافة - VAT</span>
            </td>
            <td class="amt">{{vatamt}}</td>
        </tr>
        {{#neq discount "0.00"}}
        {{#if discount}}
        <tr>
            <td class="lbl">
                <span class="en">Discount</span>
                <span class="ar">الخصم</span>
            </td>
            <td class="amt">{{discount}}</td>
        </tr>
        {{/if}}
        {{/neq}}
        <tr class="total-due">
            <td class="lbl">
                <span class="en">Total</span>
                <span class="ar">اجمالي المبلغ المستحق</span>
            </td>
            <td class="amt">{{balance}}</td>
        </tr>
    </table>
    {{/with}}

    {{!-- ── Amount in Words ─────────────────────── --}}
    <div class="amount-words">
        {{#if bcamountinwordsar}}
        <div class="ar">{{bcamountinwordsar}}</div>
        {{/if}}
        {{#if bcamountinwords}}
        <div>{{bcamountinwords}}</div>
        {{/if}}
    </div>

    {{!-- ── Footer ────────────────────────────────── --}}
    <div class="footer">Thank you !</div>

</div>
</body>
</html>
