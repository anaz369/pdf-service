<html xmlns="http://www.w3.org/1999/xhtml">
<head>
<meta charset="utf-8">
<meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
<meta http-equiv="X-UA-Compatible" content="IE=edge" />
<meta name="format-detection" content="telephone=yes" />
<title>128</title>
   <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<style>
    .invoice_head{
    font-weight: 600;
    font-size: 20px;
    margin-bottom: 15px;
}
.invoice_head span{
    color: #b72031;
}
    table{
        width: 100%;
        font-family: Arial, sans-serif;
        font-size: 13px;
        vertical-align: top;
    }
    .table_sample{
        font-size: 12px;
    }
    .table_sample td{
        padding: 4px 8px;
        color: #000;
        font-size: 12px;
        line-height: 18px;
    }
    .tablee{
        border: 2px solid #bfbfbf;
        line-height: 20px;
        font-size: 12px;
    }
    .tablee th{
        padding: 3px 8px;
        color: #000;
        border: 2px solid #bfbfbf;
        background-color: #eee;
        vertical-align: top;
        font-weight: normal;
    }
    .tablee td{
        padding: 3px 8px;
        color: #000;
        border: 2px solid #bfbfbf;
        vertical-align: top;
    }
    .tablee td b{
        font-size: 12px;
    }
    .tablee2{
        border: 2px solid #bfbfbf;
    }
    .tablee2 th{
        padding: 6px 8px;
        color: #000;
        font-size: 14px;
    }
    .tablee2 td{
        padding: 6px 8px;
        color: #000;
    }
    .table_black{
        border: 2px solid #bfbfbf;
    }
    .table_black th{
        padding: 6px 8px;
        color: #000;
        vertical-align: top;
        border: 2px solid #bfbfbf;
    }
</style>
</head>
<body>
    <div class="section">
        <div class="container">
            <div class="row">

                <div class="col-lg-5 col-md-5 col-sm-5">
                    <table class="table_sample">
                        <tr>
                            <td>Buyer / م</td>
                            <td>:</td>
                            <td><b>{{billing_address.[0].name}}{{#if billing_address_lang2.[0].name}}<br>{{billing_address_lang2.[0].name}}{{/if}}</b></td>
                        </tr>
                        <tr>
                            <td>Address / العنوان : </td>
                            <td>:</td>
                            <td>{{joinAddress billing_address.[0]}}</td>
                        </tr>
                        <tr>
                            <td>Phone / هاتف</td>
                            <td>:</td>
                            <td>{{customer_details.[0].contact_no1}}</td>
                        </tr>
                        <tr>
                            <td>VAT / ض</td>
                            <td>:</td>
                            <td>{{billing_address.[0].vat}}</td>
                        </tr>
                    </table>
                </div>
                <div class="col-lg-3 col-md-3 col-sm-3">
                    <h5 class="text-center mb-2 mt-2"><b> TAX INVOICE <br> فاتورة ضريبة </b></h5>
                </div>
                <div class="col-lg-4 col-md-4 col-sm-4">
                    <table class="table_sample">
                        <tr>
                            <td>Hijri Date <br>الهجري تاريخ</td>
                            <td>:</td>
                            <td></td>
                        </tr>
                        <tr>
                            <td>Date التاريخ</td>
                            <td>:</td>
                            <td>{{basicdetails.[0].inv_date}}</td>
                        </tr>
                        <tr>
                            <td>Number رقم  #</td>
                            <td>:</td>
                            <td>{{basicdetails.[0].inv_no}}</td>
                        </tr>
                        <tr>
                            <td>Mode of Pay</td>
                            <td>:</td>
                            <td>CREDIT BILL / الائتمان فاتورة</td>
                        </tr>
                    </table>
                </div>
                <div class="col-lg-12 mt-1">
                    <table class="text-center tablee">
                        <tr>
                            <th>Customer Code العميل رمز</th>
                            <th>LPO No رقم طلب الشراء</th>
                            <th>LPO Date تاريخ طلب الشراء</th>
                            <th>Consultant مستشار</th>
                            <th>Branch الفرع</th>
                        </tr>
                        <tr>
                            <td><b>{{customer_details.[0].profile_code}}</b></td>
                            <td>{{basicdetails.[0].reference_no}}</td>
                            <td>{{basicdetails.[0].po_date}}</td>
                            <td>{{basicdetails.[0].salesman_name}}</td>
                            <td>{{basicdetails.[0].branchname}}</td>
                        </tr>
                    </table>
                </div>
                <div class="col-lg-12 mt-2">
                    <table class="tablee">
                        <tr>
                            <th class="text-center">#</th>
                            <th class="text-center">Item/ Product<br>السلعة/ المنتج</th>
                            <th class="text-center">Service Description<br>وصف الخدمة</th>
                            <th class="text-center">Quantity<br>كمية</th>
                            <th class="text-center">Unit Price<br>سعر الوحدة</th>
                            <th class="text-center">Taxable Amount<br>للضريبة المبغ الخاضع</th>
                            <th class="text-center">TAX Rate<br>الضريبة معدل</th>
                            <th class="text-center">Tax({{basicdetails.[0].isocode}})<br>الضريبة</th>
                            <th>Amount<br>مبلغ</th>
                        </tr>
                        {{#each itemdetails}}
                        <tr>
                            <td class="text-center">{{addOne @index}}</td>
                            <td class="text-start">{{item_name}}{{#if name_lang2}}<br>{{name_lang2}}{{/if}}</td>
                            <td class="text-start">{{description}}</td>
                            <td class="text-end">{{formatAmount quantity ../bcdp}}</td>
                            <td class="text-end">{{formatAmount price ../bcdp}}</td>
                            <td class="text-end">{{formatAmount taxable ../bcdp}}</td>
                            <td class="text-end">{{vat_perc}}</td>
                            <td class="text-end">{{formatAmount tax ../bcdp}}</td>
                            <td class="text-end">{{formatAmount amount ../bcdp}}</td>
                        </tr>
                        {{/each}}
                        <tr>
                            <td class="text-end border-bottom-0" colspan="6"><b>Total without VAT المضافة القيمة ضريبة بدون الإجمال</b></td>
                            <td class="text-end border-bottom-0" colspan="3"><b>{{basicdetails.[0].isocode}} {{formatAmount basicdetails.[0].subtotal bcdp}}</b></td>
                        </tr>
                        <tr>
                            <td class="text-end border-top-0 border-bottom-0" colspan="6"><b>Total Taxable Amount للضريبة الخاضع المبلغ إجمال</b></td>
                            <td class="text-end border-top-0 border-bottom-0" colspan="3"><b>{{basicdetails.[0].isocode}} {{formatAmount basicdetails.[0].subtotal bcdp}}</b></td>
                        </tr>
                        {{#if (gt basicdetails.[0].vatamt 0)}}
                        <tr>
                            <td class="text-end border-top-0 border-bottom-0" colspan="6"><b>Total VAT Amount المضافة القيمة ضريبة مبلغ إجما</b></td>
                            <td class="text-end border-top-0 border-bottom-0" colspan="3"><b>{{basicdetails.[0].isocode}} {{formatAmount basicdetails.[0].vatamt bcdp}}</b></td>
                        </tr>
                        {{/if}}
                        {{#if (gt basicdetails.[0].discount 0)}}
                        <tr>
                            <td class="text-end border-top-0 border-bottom-0" colspan="6"><b>Discount الخصم</b></td>
                            <td class="text-end border-top-0 border-bottom-0" colspan="3"><b>- {{basicdetails.[0].isocode}} {{formatAmount basicdetails.[0].discount bcdp}}</b></td>
                        </tr>
                        {{/if}}
                        <tr>
                            <td class="text-end border-top-0 border-bottom-0" colspan="6"><b>Total Including VAT المضافة القيمة ضريبة متضمن اإلجمال</b></td>
                            <td class="text-end border-top-0 border-bottom-0" colspan="3"><b>{{basicdetails.[0].isocode}} {{formatAmount basicdetails.[0].grand_total bcdp}}</b></td>
                        </tr>
                        {{#if bcamountinwords}}
                        <tr>
                            <td class="text-start border-top-0 border-bottom-0" colspan="6"><b>Amount: {{bcamountinwords}}</b></td>
                            <td class="text-end border-top-0 border-bottom-0" colspan="3"><b></b></td>
                        </tr>
                        {{/if}}
                        {{#if bcamountinwordsar}}
                        <tr>
                            <td class="text-end border-top-0" colspan="6"><b>: مبلغ {{bcamountinwordsar}}</b></td>
                            <td class="text-end border-top-0" colspan="3"><b></b></td>
                        </tr>
                        {{/if}}
                    </table>
                </div>
                {{#if invterms}}
                 <div class="col-lg-12 mt-2">
                     <table class="tablee2">
                         <tr>
                            <th colspan="3">Remarks ملاحظات</th>
                        </tr>
                        <tr>
                            <td colspan="3">{{{nl2br invterms}}}</td>
                        </tr>
                     </table>
                </div>
                {{/if}}

                <div class="col-lg-12 mt-2">
                    <table class="tablee2">

                        <tr>
                            <td>
                                {{#if bankdetails}}
                                <table class="table_black">
                                    <tr>
                                        <th colspan="3">BANK DETAILS</th>
                                    </tr>
                                    {{#if bankdetails.name}}
                                    <tr>
                                        <td>Bank Name</td>
                                        <td>:</td>
                                        <td>{{bankdetails.name}}</td>
                                    </tr>
                                    {{/if}}
                                    {{#if bankdetails.acc_name}}
                                    <tr>
                                        <td>Account Name</td>
                                        <td>:</td>
                                        <td>{{bankdetails.acc_name}}</td>
                                    </tr>
                                    {{/if}}
                                    {{#if bankdetails.branch_name}}
                                    <tr>
                                        <td>Bank Branch</td>
                                        <td>:</td>
                                        <td>{{bankdetails.branch_name}}</td>
                                    </tr>
                                    {{/if}}
                                    {{#if bankdetails.acc_no}}
                                    <tr>
                                        <td>A/c No</td>
                                        <td>:</td>
                                        <td>{{bankdetails.acc_no}}</td>
                                    </tr>
                                    {{/if}}
                                    {{#if bankdetails.iban_no}}
                                    <tr>
                                        <td>IBAN No</td>
                                        <td>:</td>
                                        <td>{{bankdetails.iban_no}}</td>
                                    </tr>
                                    {{/if}}
                                    {{#if bankdetails.swift_no}}
                                    <tr>
                                        <td>SWIFT Code</td>
                                        <td>:</td>
                                        <td>{{bankdetails.swift_no}}</td>
                                    </tr>
                                    {{/if}}
                                </table>
                                {{/if}}
                            </td>
                            <th>
                                {{#if qrCodeBase64}}
                                {{{qrDataUri qrCodeBase64}}}
                                {{/if}}
                            </th>
                            <th>
                                <table>
                                    <tr>
                                        <th colspan="2">{{branch.[0].name}}</th>
                                    </tr>
                                    <tr>
                                        <td><b>Printed By :</b><br>طبعت بواسطة</td>
                                        <td>{{basicdetails.[0].salesman_name}}</td>
                                    </tr>
                                    <tr>
                                        <td><b>Prepared By :</b><br>اعدت بواسطة</td>
                                        <td>{{basicdetails.[0].created_user}}</td>
                                    </tr>
                                    {{#if Seal}}
                                    <tr>
                                        <td colspan="2" class="text-center"><img src="{{Seal}}" alt="Seal" style="max-height:60px; max-width:60px;"/></td>
                                    </tr>
                                    {{/if}}
                                    {{#if Signature}}
                                    <tr>
                                        <td colspan="2" class="text-center"><img src="{{Signature}}" alt="Signature" style="max-height:40px; max-width:80px;"/></td>
                                    </tr>
                                    {{/if}}
                                </table>
                            </th>
                        </tr>
                    </table>
                </div>

            </div>
        </div>
    </div>
</body>
</html>
