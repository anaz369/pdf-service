<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Invoice - {{basicdetails.[0].inv_no}}</title>

<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: #ffffff;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 10px;
    color: #222;
    line-height: 1.55;
    margin: 0 8mm;
  }

  .page { width: 100%; margin: 0 auto; padding-top: 6px; }

  .ar { direction: rtl; }

  /* ── Top: Bill/Ship | Title/Meta + QR ───────── */
  .top-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
  }
  .top-table > tbody > tr > td {
    vertical-align: top;
    padding: 0;
    font-size: 10px;
  }
  .bill-block { padding-right: 14px; }
  .bill-label { font-weight: bold; margin-bottom: 4px; }
  .bill-name { font-weight: bold; }
  .bill-line { line-height: 1.55; }
  .bill-spacer { height: 14px; }

  .title-meta-block { text-align: right; }
  .main-title {
    font-size: 24px;
    font-weight: bold;
    color: #2a4d7b;
    margin-bottom: 6px;
  }
  .main-title .ar { direction: rtl; }
  .inv-no { color: #2a4d7b; font-weight: bold; margin-bottom: 8px; }

  .meta-table {
    width: auto;
    border-collapse: collapse;
    margin-left: auto;
  }
  .meta-table td {
    padding: 2px 4px;
    font-size: 10px;
    vertical-align: top;
  }
  .meta-table .mt-lbl { font-weight: bold; text-align: right; padding-right: 6px; }
  .meta-table .mt-sep { padding: 2px 4px; }
  .meta-table .mt-val { text-align: left; padding-right: 10px; }
  .meta-table .mt-ar { direction: rtl; text-align: right; color: #555; }

  .qr-wrap {
    text-align: center;
    margin-top: 20px;
  }
  .qr-wrap img { display: inline-block; max-width: 130px; max-height: 130px; border: 1px solid #ccc;  }

  /* ── Items table ───────────────────────────── */
  .items-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
    margin-top: 14px;
  }
  .items-table thead th {
    background: #2a4d7b;
    color: #ffffff;
    text-align: left;
    font-weight: bold;
    padding: 6px 8px;
    font-size: 10px;
    vertical-align: top;
  }
  .items-table .head-ar { display: block; direction: rtl; font-weight: normal; color: #e0e6ee; font-size: 9px; }
  .items-table tbody td {
    padding: 5px 8px;
    font-size: 10px;
    vertical-align: middle;
  }
  .items-table .center { text-align: center; }
  .items-table .right  { text-align: right; }
  .items-table .left   { text-align: left; }
  .items-table .sl { color: #2a4d7b; text-align: center; font-weight: bold; }
  .items-table .name-col { font-weight: bold; }

  /* ── Totals ───────────────────────────────── */
  .totals-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 6px;
  }
  .totals-table td {
    padding: 4px 8px;
    font-size: 10px;
  }
  .totals-table .t-spacer { width: 60%; }
  .totals-table .t-lbl { text-align: right; font-weight: bold; width: 20%; }
  .totals-table .t-val { text-align: right; width: 20%; }

  /* ── Words / Terms ───────────────────────── */
  .words-line { margin-top: 14px; font-size: 10px; }
  .terms-line { margin-top: 8px; font-size: 10px; }

  /* ── Bank Details ─────────────────────────── */
  .bank-block { margin-top: 22px; font-size: 10px; }
  .bank-title { font-weight: bold; margin-bottom: 6px; }
  .bank-table { border-collapse: collapse; }
  .bank-table td {
    padding: 2px 0;
    font-size: 10px;
    vertical-align: top;
    line-height: 1.6;
  }
  .bank-table .bk-lbl { width: 140px; }
  .bank-table .bk-sep { width: 16px; padding: 2px 6px; }
  .bank-table .bk-val { width: auto; }
</style>
</head>
<body>

<div class="page">

  <!-- Top: Bill To/Shipped To (left) | Title + Meta + QR (right) -->
  <table class="top-table">
    <tr>
      <td style="width:50%;">
        <div class="bill-block">
          <div class="bill-label">Bill To</div>
          <div class="bill-name">{{billing_address.[0].name}}</div>
          {{#if billing_address.[0].address_line2}}<div class="bill-line">{{billing_address.[0].address_line2}}</div>{{/if}}
          {{#if billing_address.[0].address_line3}}<div class="bill-line">{{billing_address.[0].address_line3}}</div>{{/if}}
          {{#if billing_address.[0].address_line4}}<div class="bill-line">{{billing_address.[0].address_line4}}</div>{{/if}}
          {{#if billing_address.[0].address_line5}}<div class="bill-line">{{billing_address.[0].address_line5}}</div>{{/if}}
          {{#if customer_details.[0].cr_no}}<div class="bill-line">CR No : {{customer_details.[0].cr_no}}{{#if billing_address.[0].vat}} | VAT : {{billing_address.[0].vat}}{{/if}}</div>{{/if}}

          <div class="bill-spacer"></div>

          <div class="bill-label">Shipped To</div>
          <div class="bill-name">{{shipping_address.[0].name}}</div>
          {{#if shipping_address.[0].address_line2}}<div class="bill-line">{{shipping_address.[0].address_line2}}</div>{{/if}}
          {{#if shipping_address.[0].address_line3}}<div class="bill-line">{{shipping_address.[0].address_line3}}</div>{{/if}}
          {{#if shipping_address.[0].address_line4}}<div class="bill-line">{{shipping_address.[0].address_line4}}</div>{{/if}}
          {{#if shipping_address.[0].address_line5}}<div class="bill-line">{{shipping_address.[0].address_line5}}</div>{{/if}}
        </div>
      </td>
      <td style="width:50%;">
        <div class="title-meta-block">
          <div class="main-title">TAX INVOICE / <span class="ar">فاتورة ضريبية</span></div>
          <div class="inv-no"># {{basicdetails.[0].inv_no}}</div>
          <table class="meta-table">
            <tr>
              <td class="mt-lbl" style="font-size: 12px;">Balance Due</td>
              <td class="mt-sep" style="font-size: 12px;">:</td>
              <td class="mt-val" colspan="2"><span style="font-size: 13px;">{{currencySymbol basicdetails.[0].base_country_isocode}}</span>{{formatAmount (divide basicdetails.[0].balance ccrate) bcdp}}</td>
            </tr>
            <tr>
              <td class="mt-lbl">Invoice Date</td>
              <td class="mt-sep">:</td>
              <td class="mt-val">{{basicdetails.[0].inv_date}}</td>
              <td class="mt-ar">تاريخ الفاتورة</td>
            </tr>
            <tr>
              <td class="mt-lbl">Due Date</td>
              <td class="mt-sep">:</td>
              <td class="mt-val">{{basicdetails.[0].due_date}}</td>
              <td class="mt-ar">تاريخ الإستحقاق</td>
            </tr>
            <tr>
              <td colspan="4" class="qr-wrap" style="text-align: right;">{{{qrDataUri qrCodeBase64}}}</td>
            </tr>
          </table>
        </div>
      </td>
    </tr>
  </table>

  <!-- Items table -->
  <table class="items-table">
    <colgroup>
      <col style="width:4%">
      <col style="width:27%">
      <col style="width:8%">
      <col style="width:7%">
      <col style="width:9%">
      <col style="width:10%">
      <col style="width:14%">
      <col style="width:21%">
    </colgroup>
    <thead>
      <tr>
        <th class="center">
          Sl
          <span class="head-ar">سري</span>
        </th>
        <th>
          Item Description
          <span class="head-ar">وصف السلعة</span>
        </th>
        <th class="center">
          Quantity
          <span class="head-ar">كمية</span>
        </th>
        <th class="center">
          UOM
          <span class="head-ar">وحدة</span>
        </th>
        <th class="right">
          Rate
          <span class="head-ar">معدل</span>
        </th>
        <th class="right">
          Total
          <span class="head-ar">المجموع</span>
        </th>
        <th class="right">
          VAT
          <span class="head-ar">ضريبة القيمة</span>
        </th>
        <th class="right">
          Total Amount
          <span class="head-ar">المبلغ الإجمالي</span>
        </th>
      </tr>
    </thead>
    <tbody>
      {{#each itemdetails}}
      <tr>
        <td class="sl">{{addOne @index}}</td>
        <td class="name-col">
          {{item_name}}
          {{#if name_lang2}}<div style="font-weight:normal;">{{name_lang2}}{{#if description}} {{description}}{{/if}}</div>{{/if}}
        </td>
        <td class="center">{{formatAmount quantity 0}}</td>
        <td class="center">{{unit}}</td>
        <td class="right">{{formatAmount price ../bcdp}}</td>
        <td class="right">{{formatAmount taxable ../bcdp}}</td>
        <td class="right">{{formatAmount vat_amt ../bcdp}}</td>
        <td class="right">{{formatAmount amount ../bcdp}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>

  <!-- Totals -->
  <table class="totals-table">
    <tr>
      <td class="t-spacer"></td>
      <td class="t-lbl">Subtotal</td>
      <td class="t-val">{{formatAmount (divide basicdetails.[0].subtotal ccrate) bcdp}}</td>
    </tr>
    {{#if zatcadiscount.[0]}}
            {{#each zatcadiscount}}
            <tr>
              <td class="t-spacer"></td>
              <td class="t-lbl">{{reason_name}}</td>
              <td class="t-val">(-) {{formatAmount (divide dld ../ccrate) bcdp}}</td>
            </tr>
            {{/each}}
            {{else}}

              {{#if (or basicdetails.[0].discount basicdetails.[0].dld)}}
                <tr>
                  <td class="t-spacer"></td>
                  <td class="t-lbl">Discount</td>
                  <td class="t-val">(-) {{formatAmount (divide (add basicdetails.[0].discount basicdetails.[0].dld) ccrate) bcdp}}</td>
                </tr>
              {{/if}}
          {{/if}}
    <tr>
      <td class="t-spacer"></td>
      <td class="t-lbl">VAT</td>
      <td class="t-val">{{formatAmount (divide basicdetails.[0].vatamt ccrate) bcdp}}</td>
    </tr>
    <tr>
      <td class="t-spacer"></td>
      <td class="t-lbl">Grand Total</td>
      <td class="t-val"><span style="font-size: 15px;">{{currencySymbol basicdetails.[0].base_country_isocode}}</span>{{formatAmount (divide basicdetails.[0].grand_total ccrate) bcdp}}</td>
    </tr>
    <tr>
      <td class="t-spacer"></td>
      <td class="t-lbl">Balance Due</td>
      <td class="t-val"><span style="font-size: 15px;">{{currencySymbol basicdetails.[0].base_country_isocode}}</span>{{formatAmount (divide basicdetails.[0].balance ccrate) bcdp}}</td>
    </tr>
  </table>

  <!-- Words / Terms -->
  <div class="words-line">Amount in words: {{bcamountinwords}}</div>
  <div class="terms-line">Terms :{{#if basicdetails.[0].terms_and_condition}}{{basicdetails.[0].terms_and_condition}}{{/if}}</div>

  <!-- Bank Account Details -->
  <div class="bank-block">
    <div class="bank-title">Bank Account Details</div>
    <table class="bank-table">
      <tr>
        <td class="bk-lbl">Bank Name</td>
        <td class="bk-sep">:</td>
        <td class="bk-val">{{bankdetails.name}}</td>
      </tr>
      <tr>
        <td class="bk-lbl">Account Name</td>
        <td class="bk-sep">:</td>
        <td class="bk-val">{{bankdetails.acc_name}}</td>
      </tr>
      <tr>
        <td class="bk-lbl">Account Number</td>
        <td class="bk-sep">:</td>
        <td class="bk-val">{{bankdetails.acc_no}}</td>
      </tr>
      <tr>
        <td class="bk-lbl">IBAN No</td>
        <td class="bk-sep">:</td>
        <td class="bk-val">{{bankdetails.iban_no}}</td>
      </tr>
      <tr>
        <td class="bk-lbl">SWIFT Code</td>
        <td class="bk-sep">:</td>
        <td class="bk-val">{{bankdetails.swift_no}}</td>
      </tr>
      <tr>
        <td class="bk-lbl">Branch</td>
        <td class="bk-sep">:</td>
        <td class="bk-val">{{bankdetails.branch_name}}</td>
      </tr>
    </table>
  </div>

</div>

</body>
</html>
