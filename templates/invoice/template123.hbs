<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>INVOICE - {{basicdetails.[0].inv_no}}</title>
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        font-family: "IBM Plex Sans Arabic", Arial, sans-serif;
        font-size: 9.5px;
        line-height: 1.35;
        color: #000;
        margin: 0 4mm;
      }

      .ar {
        direction: rtl;
      }

      table {
        width: 100%;
        table-layout: fixed;
      }

      /* ── TITLE ────────────────────────────────────── */
      .doc-title {
        text-align: center;
        margin-bottom: 6px;
        color: #000;
      }
      .doc-title .t-ar {
        font-size: 15px;
        font-weight: 700;
        direction: rtl;
      }
      .doc-title .t-en {
        font-size: 20px;
        font-weight: 800;
        letter-spacing: 0.5px;
      }

      /* ── TOP : INFO | QR ──────────────────────────── */
      .top-wrap {
        border-collapse: collapse;
        margin-bottom: 6px;
      }
      .top-wrap > tbody > tr > td {
        vertical-align: top;
        border: none;
        padding: 0;
      }
      .top-table {
        border-collapse: collapse;
        border: 1px solid #ccc;
      }
      .top-table td {
        font-size: 9.5px;
        border: 1px solid #ccc;
        padding: 5px 8px;
        vertical-align: middle;
      }
      .top-table td.lbl {
        width: 36%;
        text-align: left;
        background-color: #f5f5f5;
      }
      .top-table td.lbl .ar {
        display: block;
        direction: rtl;
        font-size: 9px;
      }
      .top-table td.val {
        width: 64%;
        background-color: #f5f5f5;
      }
      .qr-cell {
        text-align: center;
        vertical-align: middle;
      }
      .qr-cell .qr-wrap {
        width: 150px;
        height: 150px;
        margin: 0 auto;
        overflow: hidden;
      }
      .qr-cell .qr-wrap img {
        width: 100%;
        height: auto;
        max-width: 150px;
        max-height: 150px;
      }

      /* ── BANK BAND ────────────────────────────────── */
      .bank-band {
        border-collapse: collapse;
        margin-top: 5px;;
        border: 1px solid #ccc;
        border-top: none;
      }
      .bank-band td {
        font-size: 9.5px;
        border: 1px solid #ccc;
        padding: 5px 8px;
        vertical-align: middle;
      }
      .bank-band td.lbl {
        background-color: #f5f5f5;
        width: 22%;
      }
      .bank-band td.val {
        width: 56%;
      }
      .bank-band td.arl {
        width: 22%;
        text-align: right;
        direction: rtl;
      }

      /* ── SELLER / BUYER ───────────────────────────── */

      .party-wrap {
          width: 100%;
          border-collapse: collapse;
          border-spacing: 0;
          margin-top: 6px;
      }

      .party-wrap > tbody > tr > td {
          vertical-align: top;
          border: none;
          padding: 0;
      }

      .party {
          width: 100%;
          border-collapse: collapse;
          border-spacing: 0;
          table-layout: fixed;
      }

      .party td {
          font-size: 9px;
          border: 1px solid #ccc;
          padding: 4px 6px;
          vertical-align: middle;
      }

      .party .phead {
          background: #f5f5f5;
      }

      .party .phead .ar {
          float: right;
          direction: rtl;
      }

      .party td.lbl {
          width: 20%;
          background: #f5f5f5;
      }

      .party td.val {
          width: 60%;
      }

      .party td.val .ar {
          display: block;
          direction: rtl;
          text-align: right;
          margin-top: 2px;
      }

      .party td.arl {
          width: 20%;
          text-align: right;
          direction: rtl;
      }
      /* ── ITEMS TABLE ──────────────────────────────── */
      .items-table {
        border-collapse: collapse;
        margin-top: 6px;
      }
      .items-table th,
      .items-table td {
        font-size: 9px;
        border: 1px solid #ccc;
        padding: 4px 5px;
        vertical-align: middle;
      }
      .items-table thead th {
        background-color: #f5f5f5;
        text-align: center;
        line-height: 1.3;
      }
      .items-table thead th .ar {
        display: block;
        direction: rtl;
      }
      .items-table thead th .en {
        display: block;
        font-size: 8.5px;
      }
      .items-table td.num {
        text-align: center;
      }
      .items-table td.right {
        text-align: right;
      }
      .items-table td.desc .sub-ar {
        direction: rtl;
        font-size: 8.5px;
        color: #444;
      }
      .items-table td.desc .sub-en {
        font-size: 8.5px;
        color: #444;
      }

      /* ── TOTALS ───────────────────────────────────── */
      .totals-table {
        border-collapse: collapse;
        margin-top: 6px;
      }
      .totals-table td {
        font-size: 9.5px;
        border: 1px solid #ccc;
        padding: 5px 8px;
        vertical-align: middle;
      }
      .totals-table td.terms-cell {
        width: 32%;
        vertical-align: top;
      }
      .totals-table td.terms-cell .terms-head {
        font-weight: 700;
        margin-bottom: 2px;
      }
      .totals-table td.lbl {
        background-color: #f5f5f5;
        width: 18%;
      }
      .totals-table td.arl {
        background-color: #f5f5f5;
        text-align: right;
        direction: rtl;
        width: 30%;
      }
      .totals-table td.val {
        text-align: right;
        width: 20%;
      }
      .totals-table .words {
        text-align: center;
      }
      .totals-table .words .ar {
        display: block;
        direction: rtl;
      }

      /* ── SIGNATURES ───────────────────────────────── */
      .sign-table {
        border-collapse: collapse;
        margin-top: 6px;
      }
      .sign-table td {
        font-size: 9px;
        border: 1px solid #ccc;
        width: 25%;
        vertical-align: top;
        padding: 4px 6px;
      }
      .sign-table .s-head {
        text-align: center;
        font-weight: 700;
      }
      .sign-table .s-head .ar {
        display: block;
        direction: rtl;
        font-weight: 400;
      }
      .sign-table .s-body {
        text-align: center;
        height: 60px;
      }
      .sign-table .s-body img {
        max-height: 55px;
        max-width: 120px;
      }
    </style>
  </head>
  <body>

    <!-- TITLE -->
    <div class="doc-title">
      <div class="t-ar">فاتورة ضريبية</div>
      <div class="t-en">TAX INVOICE</div>
    </div>

    <!-- TOP : INVOICE INFO | QR -->
    <table class="top-wrap">
      <tr>
        <td style="width:62%;padding-right:8px;">
          <table class="top-table">
            <tr>
              <td class="lbl">Invoice Number<span class="ar">رقم الفاتورة</span></td>
              <td class="val">{{basicdetails.[0].inv_no}}</td>
            </tr>
            <tr>
              <td class="lbl">Invoice Issue Date<span class="ar">تاريخ إصدار الفاتورة</span></td>
              <td class="val">{{basicdetails.[0].inv_date}}</td>
            </tr>
            <tr>
              <td class="lbl">PO Number<span class="ar">رقم طلب الشراء</span></td>
              <td class="val">{{basicdetails.[0].order_no}}</td>
            </tr>
            <tr>
              <td class="lbl">PO Date<span class="ar">تاريخ أمر الشراء</span></td>
              <td class="val">{{basicdetails.[0].po_date}}</td>
            </tr>
            <tr>
              <td class="lbl">Payment Mode<span class="ar">وضع الدفع</span></td>
              <td class="val"></td>
            </tr>
          </table>
        </td>
        <td class="qr-cell" style="width:38%;">
          <div class="qr-wrap">{{{qrDataUri qrCodeBase64}}}</div>
        </td>
      </tr>
    </table>

    <!-- BANK BAND -->
    <table class="bank-band">
      <tr>
        <td class="lbl">Bank Name</td>
        <td class="val">{{bankdetails.name}}</td>
        <td class="arl">اسم البنك</td>
      </tr>
      <tr>
        <td class="lbl">Account Name</td>
        <td class="val">{{bankdetails.acc_name}}</td>
        <td class="arl">إسم الحساب</td>
      </tr>
      <tr>
        <td class="lbl">Account No</td>
        <td class="val">{{bankdetails.acc_no}}</td>
        <td class="arl">رقم الحساب</td>
      </tr>
      <tr>
        <td class="lbl">IBAN No</td>
        <td class="val">{{bankdetails.iban_no}}</td>
        <td class="arl">رقم (IBAN)</td>
      </tr>
    </table>

    <!-- SELLER / BUYER -->
    <table class="party-wrap" cellpadding="0" cellspacing="0">
      <tr>

          <!-- SELLER -->
        <td style="width:50%;padding-right:3px;">
            <table class="party">
                <colgroup>
                    <col style="width:20%">
                    <col style="width:60%">
                    <col style="width:20%">
                </colgroup>

                <tr>
                    <td class="phead" colspan="3">
                        Seller
                        <span class="ar">المورد</span>
                    </td>
                </tr>

                <tr>
                    <td class="lbl">Name</td>
                    <td class="val">
                        {{branch.[0].name}}
                        <span class="ar">{{branch_lang2.[0].name}}</span>
                    </td>
                    <td class="arl">الاسم</td>
                </tr>

                <tr>
                    <td class="lbl">Building No</td>
                    <td class="val">{{branch.[0].address_line1}}</td>
                    <td class="arl">رقم المبني</td>
                </tr>

                <tr>
                    <td class="lbl">Street</td>
                    <td class="val">{{branch.[0].address_line2}}</td>
                    <td class="arl">اسم الشارع</td>
                </tr>

                <tr>
                    <td class="lbl">District</td>
                    <td class="val">{{branch.[0].address_line3}}</td>
                    <td class="arl">الحي</td>
                </tr>

                <tr>
                    <td class="lbl">City</td>
                    <td class="val">{{branch.[0].address_line4}}</td>
                    <td class="arl">المدينة</td>
                </tr>

                <tr>
                    <td class="lbl">Country</td>
                    <td class="val">{{branch.[0].address_line5}}</td>
                    <td class="arl">البلد</td>
                </tr>

                <tr>
                    <td class="lbl">Postal Code</td>
                    <td class="val">{{branch.[0].address_code}}</td>
                    <td class="arl">الرمز البريدي</td>
                </tr>

                <tr>
                    <td class="lbl">VAT No</td>
                    <td class="val">{{branch.[0].vat}}</td>
                    <td class="arl">الرقم الضريبي</td>
                </tr>
            </table>
        </td>

        <!-- BUYER -->
        <td style="width:50%;padding-left:3px;">
            <table class="party">
                <colgroup>
                    <col style="width:20%">
                    <col style="width:60%">
                    <col style="width:20%">
                </colgroup>

                <tr>
                    <td class="phead" colspan="3">
                        Buyer
                        <span class="ar">العميل</span>
                    </td>
                </tr>

                <tr>
                    <td class="lbl">Name</td>
                    <td class="val">
                        {{billing_address.[0].name}}
                        <span class="ar">{{billing_address_lang2.[0].name}}</span>
                    </td>
                    <td class="arl">الاسم</td>
                </tr>

                <tr>
                    <td class="lbl">Building No</td>
                    <td class="val">{{billing_address.[0].address_line1}}</td>
                    <td class="arl">رقم المبني</td>
                </tr>

                <tr>
                    <td class="lbl">Street</td>
                    <td class="val">{{billing_address.[0].address_line2}}</td>
                    <td class="arl">اسم الشارع</td>
                </tr>

                <tr>
                    <td class="lbl">District</td>
                    <td class="val">{{billing_address.[0].address_line3}}</td>
                    <td class="arl">الحي</td>
                </tr>

                <tr>
                    <td class="lbl">City</td>
                    <td class="val">{{billing_address.[0].address_line4}}</td>
                    <td class="arl">المدينة</td>
                </tr>

                <tr>
                    <td class="lbl">Country</td>
                    <td class="val">{{billing_address.[0].address_line5}}</td>
                    <td class="arl">البلد</td>
                </tr>

                <tr>
                    <td class="lbl">Postal Code</td>
                    <td class="val">{{billing_address.[0].address_code}}</td>
                    <td class="arl">الرمز البريدي</td>
                </tr>

                <tr>
                    <td class="lbl">VAT No</td>
                    <td class="val">{{billing_address.[0].vat}}</td>
                    <td class="arl">الرقم الضريبي</td>
                </tr>
            </table>
        </td>
      </tr>
  </table>

    <!-- ITEMS TABLE -->
    <table class="items-table">
      <thead>
        <tr>
          <th style="width:4%"><span class="ar">الرقم</span><span class="en">#</span></th>
          <th style="width:9%"><span class="ar">رمز الصنف</span><span class="en">Item Code</span></th>
          <th style="width:31%"><span class="ar">الاسم والوصف</span><span class="en">Item &amp; description</span></th>
          <th style="width:7%"><span class="ar">الكمية</span><span class="en">Qty</span></th>
          <th style="width:7%"><span class="ar">الوحدة</span><span class="en">Unit</span></th>
          <th style="width:10%"><span class="ar">سعرالوحدة</span><span class="en">Price</span></th>
          <th style="width:10%"><span class="ar">المبلغ بدون ضريبة</span><span class="en">Without VAT</span></th>
          <th style="width:10%"><span class="ar">قيمة الضريبة</span><span class="en">VAT Amount</span></th>
          <th style="width:12%"><span class="ar">الاجمالي مع الضريبة</span><span class="en">Total inc. VAT</span></th>
        </tr>
      </thead>
      <tbody>
        {{#each itemdetails}}
        <tr>
          <td class="num">{{addOne @index}}</td>
          <td class="num">{{item_code}}</td>
          <td class="desc">
            {{item_name}}
            {{#if name_lang2}}<div class="sub-ar">{{name_lang2}}</div>{{/if}}
            {{#if description}}<div class="sub-en">{{description}}</div>{{/if}}
          </td>
          <td class="num">{{formatAmount quantity ../bcdp}}</td>
          <td class="num">{{unit}}</td>
          <td class="right">{{formatAmount price ../bcdp}}</td>
          <td class="right">{{formatAmount taxable ../bcdp}}</td>
          <td class="right">{{formatAmount vat_amt ../bcdp}}</td>
          <td class="right">{{formatAmount amount ../bcdp}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>

    <!-- TERMS + TOTALS -->
    <table class="totals-table">
      <tr>
        <td class="terms-cell" rowspan="6">
          <div class="terms-head">Terms&amp;Condition</div>
          <div>{{basicdetails.[0].terms_and_condition}}</div>
        </td>
        <td class="lbl">Total Without VAT</td>
        <td class="arl">الإجمالي بدون ضريبة</td>
        <td class="val">{{formatAmount (divide basicdetails.[0].subtotal ccrate) bcdp}}</td>
      </tr>
      {{#if zatcadiscount.[0]}}

                    {{#each zatcadiscount}}
                    <tr>
                        <td class="lbl">{{reason_name}}</td>
                        <td class="arl">{{reason_name_lang2}}</td>
                        <td class="val">{{formatAmount (divide dld ../ccrate) ../bcdp}}</td>
                    </tr>
                    {{/each}}

                    <tr>
                      <td class="lbl">After Discount</td>
                      <td class="arl">بعد الخصم</td>
                      <td class="val">{{formatAmount (divide (subtract basicdetails.[0].subtotal zatcadiscount.[0].dld) ccrate) bcdp}}</td>
                    </tr>
                {{else}}

                    {{#if (or basicdetails.[0].discount basicdetails.[0].dld)}}
                    <tr>
                        <td class="lbl">Discount</td>
                        <td class="arl">الخصم</td>
                        <td class="val">{{formatAmount (divide basicdetails.[0].subtotal ccrate) bcdp}}</td>
                    </tr>
                    <tr>
                      <td class="lbl">After Discount</td>
                      <td class="arl">بعد الخصم</td>
                      <td class="val">{{formatAmount (divide (subtract basicdetails.[0].subtotal (add basicdetails.[0].discount basicdetails.[0].dld)) ccrate) bcdp}}</td>
                    </tr>
                    {{/if}}

                {{/if}}
      <tr>
        <td class="lbl">Discount</td>
        <td class="arl">الخصومات</td>
        <td class="val">{{formatAmount basicdetails.[0].discount bcdp}}{{formatAmount (divide basicdetails.[0].subtotal ccrate) bcdp}}</td>
      </tr>
      <tr>
        <td class="lbl">After Discount</td>
        <td class="arl">بعد الخصم</td>
        <td class="val">{{formatAmount (subtract basicdetails.[0].subtotal basicdetails.[0].discount) bcdp}}</td>
      </tr>
      <tr>
        <td class="lbl">{{datasettingstextvalue.d828}}</td>
        <td class="arl">ضريبة القيمة المضافة</td>
        <td class="val">{{formatAmount (divide basicdetails.[0].vatamt ccrate) bcdp}}</td>
      </tr>
      <tr>
        <td class="lbl">Total With VAT in {{basicdetails.[0].base_country_isocode}}</td>
        <td class="arl">المجموع شامل الضريبة</td>
        <td class="val">{{formatAmount (divide basicdetails.[0].grand_total ccrate) bcdp}}</td>
      </tr>
      <tr>
        <td class="words" colspan="3"> <span class="ar">المبلغ كتابه بريال السعودي : {{bcamountinwordsar}}</span>
          {{bcamountinwords}}
        </td>
      </tr>
    </table>

    <!-- SIGNATURES -->
    {{!-- <table class="sign-table">
      <tr>
        <td class="s-head">Company Stamp<span class="ar">ختم الشركة</span></td>
        <td class="s-head">Prepared By<span class="ar">أعدت بواسطة</span></td>
        <td class="s-head">Authorized Signature<span class="ar">توقيع معتمد</span></td>
        <td class="s-head">Received By<span class="ar">استلمت من قبل</span></td>
      </tr>
      <tr>
        <td class="s-body">{{#if Seal}}<img src="{{Seal}}" alt="" onerror="this.style.display='none'"/>{{/if}}</td>
        <td class="s-body">{{basicdetails.[0].created_user}}</td>
        <td class="s-body">{{#if Signature}}<img src="{{Signature}}" alt="" onerror="this.style.display='none'"/>{{/if}}</td>
        <td class="s-body"></td>
      </tr> --}}
    </table>

  </body>
</html>
