</style>
<body>
    <div class="section">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <h5 class="text-center mb-2 mt-2"><b> TAX INVOICE </b></h5>
                    
                </div>
                <div class="col-lg-4 col-md-4 col-sm-4 pr-0">
                    <table class="myy_table mt-1 myy_table1">
                        <tr>
                            <td><b>Billed To</b></td>
                            <td>{{billing_address.[0].name}}</td>
                        </tr>

                        <tr>
                            <td colspan="2">
                               {{joinAddress billing_address.[0] '، '}}
                            </td>
                        </tr>
                    </table>
                </div>
                <div class="col-lg-4 col-md-4 col-sm-4 pr-0">
                    <table class="myy_table mt-1 myy_table1">
                        <tr>
                            <td><b>Shipped To</b></td>
                            <td>{{shipping_address.[0].name}}</td>
                        </tr>

                        <tr>
                            <td colspan="2">
                                {{joinAddress shipping_address.[0] '، '}}
                            </td>
                        </tr>
                    </table>
                </div>
                <div class="col-lg-4 col-md-4 col-sm-4">
                    <table class="myy_table mt-1 myy_table1 text-center">
                        <tr>
                            <td style="font-weight: bold;"><b>Invoice No</b></td>
                            <td style="font-weight: bold;"><b>Invoice Date</b></td>
                        </tr>
                        <tr>
                            <td>
                                {{#if basicdetails.[0].inv_no}}
                                    {{basicdetails.[0].inv_no}}
                                {{/if}}
                            </td>
                            <td>
                                {{#if basicdetails.[0].inv_date}}
                                    {{basicdetails.[0].inv_date}}
                                {{/if}}
                            </td>
                        </tr>
                    </table>
                </div>
                
                <div class="col-lg-12">
                    <table class="mt-1 myy_table myy_table2">
                        <tr>
                            <th class="text-center bold" width="4%">Sl</th>
                            <th class="text-center"  width="9%">HSN</th>
                            <th class="text-center" width="19%">Description</th>
                            <th class="text-center" width="6%">Qty</th>
                            <th class="text-center" width="8%">UOM</th>
                            <th class="text-center" width="9%">Unit Price</th>
                            <th class="text-center" width="9%">Discount</th>
                            <th class="text-center" width="10%">Taxable</th>
                            <th class="text-center" width="8%">GST</th>
                            <th class="text-center" width="8%">CESS</th>
                            <th class="text-center" width="10%">Total</th>
                        </tr>
                        {{#each itemdetails}}
                            <tr>
                                <td class="text-center">{{addOne @index}}</td>

                                <td class="text-start">{{hsn}}</td>

                                <td class="text-start">
                                    <div>{{item_name}}</div>
                                    {{#if name_lang2}}
                                        <div style="direction:rtl; font-size:9px; color:#555;">
                                            {{name_lang2}}
                                        </div>
                                    {{/if}}
                                    {{#if description}}
                                        <div style="font-size:9px; color:#777;">
                                            {{description}}
                                        </div>
                                    {{/if}}
                                </td>

                                <td class="text-center">{{quantity}}</td>
                                <td class="text-center">{{unit}}</td>

                                <td class="text-end">{{formatAmount price ../bcdp}}</td>

                                <td class="text-end">
                                    {{formatAmount disc_amt ../bcdp}}<br>
                                    {{disc_perc}} %
                                </td>

                                <td class="text-end">{{formatAmount taxable ../bcdp}}</td>

                                <td class="text-end">
                                    {{formatAmount vat_amt ../bcdp}}<br>
                                    {{vat_perc}} %
                                </td>

                                <td class="text-end">
                                    {{formatAmount other_tax ../bcdp}}<br>
                                    {{other_tax_perc}} %
                                </td>

                                <td class="text-end">
                                    {{formatAmount amount ../bcdp}}
                                </td>
                            </tr>
                            {{/each}}
                    </table>
                </div>
                <div class="col-lg-6 col-md-6 col-sm-6 pr-0">
                    <table class="mt-1 myy_table myy_table2 text-center">
                        <tr>
                            <th colspan="5" class="text-center"> Tax Summary</th>
                        </tr>
                        <tr>
                            <td>Taxable</td>
                            <td>GST</td>
                            <td>Amount</td>
                            <td>CESS</td>
                            <td>Amount</td>
                        </tr>
                        <tr>
                            <td>7,860.00</td>
                            <td>0</td>
                            <td>0.00</td>
                            <td>0</td>
                            <td>0.00</td>
                        </tr>
                    </table>
                </div>
                <div class="col-lg-6 col-md-6 col-sm-6">
                    <table class="mt-1 myy_table myy_table2">
                        <tr>
                            <th>Total</th>
                            <td class="text-end">
                                {{basicdetails.[0].isocode}} 
                                {{formatAmount basicdetails.[0].subtotal bcdp}}
                            </td>
                        </tr>

                        {{#if basicdetails.[0].discount}}
                        <tr>
                            <th>Discount</th>
                            <td class="text-end">
                                {{basicdetails.[0].isocode}} 
                                {{formatAmount basicdetails.[0].discount bcdp}}
                            </td>
                        </tr>
                        {{/if}}

                        <tr>
                            <th>Total Before GST</th>
                            <td class="text-end">
                                {{basicdetails.[0].isocode}} 
                                {{formatAmount basicdetails.[0].subtotal bcdp}}
                            </td>
                        </tr>

                        <tr>
                            <th>GST Amount</th>
                            <td class="text-end">
                                {{basicdetails.[0].isocode}} 
                                {{formatAmount basicdetails.[0].igst bcdp}}
                            </td>
                        </tr>

                        <tr>
                            <th>Cess Amount</th>
                            <td class="text-end">
                                {{basicdetails.[0].isocode}} 
                                {{formatAmount basicdetails.[0].cess bcdp}}
                            </td>
                        </tr>

                        <tr>
                            <th>Round Off</th>
                            <td class="text-end">
                                {{basicdetails.[0].isocode}} 
                                {{formatAmount basicdetails.[0].round_off bcdp}}
                            </td>
                        </tr>

                        <tr>
                            <th>Total Amount</th>
                            <td class="text-end">
                                <b>
                                    {{basicdetails.[0].isocode}} 
                                    {{formatAmount basicdetails.[0].grand_total bcdp}}
                                </b>
                            </td>
                        </tr>

                        <tr>
                            <td colspan="2">
                                <b>Amount In Words:</b> {{bcamountinwords}}
                            </td>
                        </tr>

                    </table>
                </div>

                <div class="col-lg-12 mt-1">
                    <table class="myy_table myy_table2">
                        <tr>
                            <td colspan="4">
                                Cheque should be crossed and made payable to: {{compprof.name}}
                            </td>
                        </tr>

                        <tr>
                            <th colspan="4" class="text-center">BANK DETAILS</th>
                        </tr>

                        <tr>
                            <td>Beneficiary A/C Name</td>
                            <td>{{bankdetails.acc_name}}</td>
                            <td>Beneficiary Bank</td>
                            <td>{{bankdetails.name}}</td>
                        </tr>

                        <tr>
                            <td>Beneficiary Bank Branch</td>
                            <td>{{bankdetails.branch_name}}</td>
                            <td>Beneficiary A/C No</td>
                            <td>{{bankdetails.acc_no}}</td>
                        </tr>

                        <tr>
                            <td>Swift Code</td>
                            <td>{{bankdetails.swift_no}}</td>
                            <td>IFSC CODE</td>
                            <td>{{bankdetails.iban_no}}</td>
                        </tr>

                    </table>
                </div>
                <div class="col-lg-12 mt-1">
                    <table class="myy_table myy_table2">
                        <tr>
                            <td style="color: #000;">
                                <b>Terms And Conditions</b><br>
                                {{basicdetails.[0].terms_and_condition}}
                            </td>
                        </tr>
                    </table>
                </div>
                <div class="col-lg-12 mt-1">
                    <table class="myy_table myy_table2 text-center lih-24">
                        <tr>
                            <td>Company Stamp</td>
                            <td>Prepared By</td>
                            <td>Authorized Signature</td>
                            <td>Received By</td>
                        </tr>
                        <tr>
                            
                            <td>
                                {{#if Seal}}
                                    <img src="{{Seal}}" alt="Seal" style="max-height:{{default datasettings.d458 '40'}}px; max-width:{{default datasettings.d458 '60'}}px;" onerror="this.style.display='none'"/>
                                {{/if}}
                            </td>
                            <td></td>
                            <td></td>
                            <td></td>
                        </tr>
                        <tr>
                            <td colspan="4">****** In case of any objection in this invoice, please review and reply within three days, otherwise the invoice shall stand deemed accepted. ******</td>
                        </tr>
                    </table>
                </div>
                
            </div> 
        </div>
    </div>
</body>
</html>