    text-align: center;
}
.boxx_table1 th b{
    font-weight: 400;
}
.boxx_table1 th:last-child{
    border-right: 0px solid #ccc;
}
.w-10{
    width: 10%;
}
.w-15{
    width: 15%;
}
.border-dark td{
    border: 0.1px solid #272727 !important;
}
.lih-20{
