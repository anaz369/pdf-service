}

.bb{
    border-bottom: 0px !important;
}
.br{
    border-right: 0px !important;
}
.bl{
    border-left: 0px !important;
}
.bt{
    border-top: 0px !important;
}
.br-1{
    border-right: 0.1px solid #ccc !important;
}
.bt-1{
    border-top: 0.1px solid #272727 !important;
}
.fw-400{
    font-weight: 400;
}
.box_d{
    border: 0.1px solid #272727 !important;
    padding: 8px 12px;
}
.vam{
    vertical-align: middle !important;
}
.myy_table{
    border: 0.1px solid #ccc;
}
.myy_table td{
    padding: 2px 4px;
    color: #282727;
    font-weight: 600;
    font-size: 9px;
}
.myy_table th{
    background-color: #f2f2f2;
    padding: 2px 4px;
    color: #282727;
    
    font-size: 10px;
}
.myy_table1 td{
    border: 0.1px solid #ccc;
}
.myy_table1 th{
    border: 0.1px solid #ccc;
    line-height: 20px;
    font-weight: bold;
}
.myy_table2 td{
    border: 0.1px solid #ccc;
}
.myy_table2 th{
    border: 0.1px solid #ccc;
    font-weight: bold;
     line-height: 18px;
    background-color: #fff;
    color: #000;
}
.myy_table3 th{
    background-color: #19aec6;
    color: #fff;
    font-weight: 600;
    font-size: 10px;
    line-height: 24px;
    border: 0.1px solid #fff;
    padding: 2px 8px;
}
.myy_table3 td{
    padding: 2px 8px;
    color: #282727;
    font-weight: 600;
    font-size: 9px;
    border-bottom: 0.1px solid #ccc;
