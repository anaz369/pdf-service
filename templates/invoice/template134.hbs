<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>INVOICE - {{basicdetails.[0].inv_no}}</title>
  <style>
    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: "IBM Plex Sans Arabic", Arial, sans-serif;
      font-size: 9.5px;
      line-height: 1.4;
      color: #000;
      margin: 0 6mm;
    }

    .ar {
      direction: rtl;
    }

    table {
      border-collapse: collapse;
      width: 100%;
      table-layout: fixed;
    }

    /* ── TITLE + QR ───────────────────────────────── */
    .doc-title {
      text-align: center;
      font-size: 18px;
      font-weight: 800;
      margin-bottom: 4px;
    }
    .qr-top {
      text-align: center;
      margin-bottom: 8px;
    }
    .qr-top .qr-wrap {
      width: 100px;
      height: 100px;
      margin: 0 auto;
      overflow: hidden;
    }
    .qr-top .qr-wrap img {
      width: 100%;
      height: auto;
      max-width: 100px;
      max-height: 100px;
    }

    /* ── TOP 3-COLUMN ─────────────────────────────── */
    .top3 {
      border: 1px solid #000;
    }
    .top3 > tbody > tr > td {
      vertical-align: top;
      padding: 0;
    }
    .party-head {
      font-weight: 700;
      padding: 4px 8px;
      border-bottom: 1px solid #000;
    }

    .party-body {
      padding: 5px 8px;
      line-height: 1.6;
      min-height: 64px;
    }
    .party-body .ar {
      direction: rtl;
    }
    .inforight {
      width: 100%;
      border-collapse: collapse;
    }
    .inforight td {
      padding: 4px 6px;
      font-size: 9px;
      vertical-align: middle;
    }
    .inforight tr:last-child td {
      border-bottom: none;
    }
    .inforight td.ilbl {
      font-weight: 700;
      width: 60%;
    }
    .inforight td.ilbl .ar {
      direction: rtl;
    }
    .inforight td.icol {
      width: 2%;
      text-align: center;
    }

    /* ── ITEMS TABLE ──────────────────────────────── */
    .items-table {
      border: 1px solid #000;
      margin-top: 8px;
    }
    .items-table th,
    .items-table td {
      font-size: 9px;
      border: 1px solid #000;
      padding: 4px 6px;
      vertical-align: middle;
    }
    .items-table thead th {
      font-size: 11px;
      background: #6495ed;
      color: #fff;
      text-align: center;
      line-height: 1.3;
    }
    .items-table thead th .ar {
      display: block;
      direction: rtl;
      font-weight: 700;
    }
    .items-table thead th .en {
      display: block;
      font-weight: 700;
      font-size: 8.5px;
    }
    .items-table td.c {
      text-align: center;
    }
    .items-table td.r {
      text-align: right;
    }
    .items-table td.l {
      text-align: left;
    }
    .items-table tbody td {
      border-top: none;
      border-bottom: none;
    }
    .items-table tbody tr:last-child td {
      border-bottom: 1px solid #000;
    }

    /* ── PAYMENT TERMS + TOTALS ───────────────────── */
    .bottom-wrap {
      margin-top: 3px;
      border: 1px solid #000;
      border-top: none;
      table-layout: fixed;
    }
    .bottom-wrap td {
      border: 1px solid #000;
      padding: 5px 8px;
      vertical-align: top;
    }
    .pay-cell {
      width: 50%;
    }
    .bottom-wrap .tt-lbl {
      width: 32%;
      text-align: right;
      direction: rtl;
      font-weight: 700;
      vertical-align: middle;
    }
    .bottom-wrap .tt-lbl .en {
      display: block;
      direction: ltr;
      text-align: right;
    }
    .bottom-wrap .tt-val {
      width: 18%;
      text-align: right;
      font-weight: 700;
      vertical-align: middle;
      border-left: none;
    }
    .bottom-wrap tr.net .tt-lbl,
    .bottom-wrap tr.net .tt-val {
      font-weight: 800;
    }

    /* ── FOOTER : BANK | NOTE ─────────────────────── */
    .footer {
      margin-top: 12px;
    }
    .footer > tbody > tr > td {
      vertical-align: top;
      border: none;
      padding: 0 6px;
    }
    .bank-head {
      font-weight: 700;
      margin-bottom: 4px;
    }
    .bank-lines {
      border-collapse: collapse;
      width: 100%;
    }
    .bank-lines td {
      border: none;
      padding: 2px 2px;
      font-size: 9.5px;
    }
    .bank-lines td.bl {
      font-weight: 700;
      width: 36%;
    }
    .bank-lines td.bc {
      width: 5%;
    }
    .note-cell {
      text-align: center;
      font-weight: 700;
      color: #000;
      line-height: 1.6;
      vertical-align: middle;
    }
    .note-cell .note-ar {
      direction: rtl;
      margin-bottom: 8px;
    }
  </style>
</head>

<body>

  <!-- TITLE + QR -->
  <div class="doc-title"> Tax Invoice / <span class="ar">فاتورة ضريبية</span></div>
  <div class="qr-top">
    <div class="qr-wrap">{{{qrDataUri qrCodeBase64}}}</div>
  </div>

  <!-- TOP 3-COLUMN : CUSTOMER | DELIVERY | INFO -->
  <table class="top3">
    <tr>
      <td style="width:30%">
        <div class="party-head"><span>CUSTOMER / </span><span class="ar">العميل</span></div>
        <div class="party-body">
          {{billing_address.[0].name}}<br/>
          <span class="ar">{{billing_address_lang2.[0].name}}</span><br/>
          {{billing_address.[0].address_line1}} , {{billing_address.[0].address_line2}} , {{billing_address.[0].address_line3}} , {{billing_address.[0].address_line4}} , {{billing_address.[0].address_line5}} , {{billing_address.[0].address_code}} , VAT: {{billing_address.[0].vat}}
        </div>
      </td>
      <td style="width:30%">
        <div class="party-head"><span>DELIVERY ADDRESS / </span><span class="ar">عنوان التسليم</span></div>
        <div class="party-body">
          {{shipping_address.[0].name}}<br/>
          <span class="ar">{{shipping_address_lang2.[0].name}}</span><br/>
          {{shipping_address.[0].address_line1}} , {{shipping_address.[0].address_line2}} , {{shipping_address.[0].address_line3}} , {{shipping_address.[0].address_line4}} , {{shipping_address.[0].address_line5}} , {{shipping_address.[0].address_code}} , VAT: {{shipping_address.[0].vat}}
        </div>
      </td>
      <td style="width:40%">
        <table class="inforight">
          <tr>
            <td class="ilbl">INVOICE NO / <span class="ar">رقم الفاتورة</span></td>
            <td class="icol">:</td>
            <td>{{basicdetails.[0].inv_no}}</td>
          </tr>
          <tr>
            <td class="ilbl">INVOICE DATE / <span class="ar">تاريخ الفاتورة</span></td>
            <td class="icol">:</td>
            <td>{{basicdetails.[0].inv_date}}</td>
          </tr>
          <tr>
            <td class="ilbl">CUSTOMER PO / <span class="ar">رقم طلب شراء</span></td>
            <td class="icol">:</td>
            <td>{{basicdetails.[0].order_no}}</td>
          </tr>
          <tr>
            <td class="ilbl">CUSTOMER VAT NO / <span class="ar">رقم ضريبة للعميل</span></td>
            <td class="icol">:</td>
            <td>{{billing_address.[0].vat}}</td>
          </tr>
        </table>
      </td>
    </tr>
  </table>

  <!-- ITEMS TABLE (RTL) -->
  <table class="items-table">
    <thead>
      <tr>
        <th style="width:12%"><span class="ar">السعر الصافي</span><span class="en">NET PRICE</span></th>
        <th style="width:12%"><span class="ar">الحسم</span><span class="en">DISCOUNT</span></th>
        <th style="width:12%"><span class="ar">سعر الوحدة</span><span class="en">UNIT PRICE</span></th>
        <th style="width:12%"><span class="ar">الكمية</span><span class="en">QUANTITY</span></th>
        <th style="width:38%"><span class="ar">الوصف</span><span class="en">DESCRIPTION</span></th>
        <th style="width:14%"><span class="ar">رمز الصنف</span><span class="en">ITEM CODE</span></th>
      </tr>
    </thead>
    <tbody>
      {{#each itemdetails}}
      <tr>
        <td class="r">{{formatAmount amount ../bcdp}}</td>
        <td class="c">{{formatAmount disc_amt ../bcdp}}</td>
        <td class="r">{{formatAmount price ../bcdp}}</td>
        <td class="c">{{formatAmount quantity ../bcdp}}</td>
        <td class="blue">{{item_name}}{{name_lang2}}{{description}}</td>
        <td class="l blue">{{item_code}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>

  <!-- PAYMENT TERMS + TOTALS -->
  <table class="bottom-wrap">
    <tr>
      <td class="pay-cell" style="border-bottom:none;"><b>Payment Terms</b></td>
      <td class="tt-lbl"><span class="ar">الإجمالي قبل ضريبة</span><span class="en">TOTAL AMOUNT BEFORE VAT</span></td>
      <td class="tt-val"><b>{{formatAmount (divide basicdetails.[0].subtotal ccrate) bcdp}}</b></td>
    </tr>
    <tr>
      <td class="pay-cell" style="border-top: none;">{{basicdetails.[0].payment_terms}}</td>
      <td class="tt-lbl"><span class="ar">تخفيض</span><span class="en">DISCOUNT</span></td>
      <td class="tt-val"><b>{{formatAmount (divide basicdetails.[0].discount ccrate) bcdp}}</b></td>
    </tr>
    <tr>
      <td class="pay-cell" style="border-bottom:none;text-align:center;">{{basicdetails.[0].base_country_isocode}}({{bcamountinwords}})</td>
      <td class="tt-lbl"><span class="ar">مبلغ الضريبة</span><span class="en">{{datasettingstextvalue.d828}}</span></td>
      <td class="tt-val"><b>{{formatAmount (divide basicdetails.[0].vatamt ccrate) bcdp}}</b></td>
    </tr>
    <tr class="net">
      <td class="pay-cell" style="border-top: none;text-align:center;">{{bcamountinwordsar}}</td>
      <td class="tt-lbl"><span class="ar">الاجمالي</span><span class="en">NET TOTAL</span></td>
      <td class="tt-val"><b>{{formatAmount (divide basicdetails.[0].grand_total ccrate) bcdp}}</b></td>
    </tr>
  </table>

  <!-- FOOTER : BANK | NOTE -->
  <table class="footer">
    <tr>
      <td style="width:42%">
        <div class="bank-head"><u>Bank Details:-</u></div>
        <table class="bank-lines">
          <tr><td class="bl">Name</td><td class="bc">:</td><td>{{bankdetails.name}}</td></tr>
          <tr><td class="bl">Account No</td><td class="bc">:</td><td>{{bankdetails.acc_name}}</td></tr>
          <tr><td class="bl">IBAN</td><td class="bc">:</td><td>{{bankdetails.iban_no}}</td></tr>
          <tr><td class="bl">Bank</td><td class="bc">:</td><td>{{bankdetails.branch_name}}</td></tr>
          <tr><td class="bl">SWIFT CODE</td><td class="bc">:</td><td>{{bankdetails.swift_no}}</td></tr>
          <tr><td class="">ZATCA Clearance Status</td><td class=""></td><td></td></tr>
        </table>
      </td>
      <td class="note-cell" style="width:58%">
        <div class="note-ar">تنويه: هذا السند لا يحتاج إلى توقيع</div>
        Please note that this is a system generated receipt and does not require a signature Any cash payment must obtain official receipt voucher
      </td>
    </tr>
  </table>

</body>
</html>
