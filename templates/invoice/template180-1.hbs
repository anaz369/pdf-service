<html xmlns="http://www.w3.org/1999/xhtml">
<head>
<meta charset="utf-8">
<meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
<!-- Forcing initial-scale shouldn't be necessary -->
<meta http-equiv="X-UA-Compatible" content="IE=edge" />
<meta name="format-detection" content="telephone=yes" />
<title>180</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@200..1000&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css?family=Open+Sans:300,400,600,700" rel="stylesheet" />


</head>
<style>
    body{
    font-family: "Open Sans",sans-serif !important;
}
.h1,.h2,.h3,.h4,.h5,.h6,h1,h2,h3,h4,h5,h6{margin-top:0;margin-bottom:0;}
.table>:not(caption)>*>* {
    padding: 0.3rem 0.3rem;
}
@media (max-width: 720px)
.container, .container-sm {
    max-width: 680px;
}
table{
    width: 100%;
}
.bg-dark{
    background-color: #1a1a1a;
}
.bg-light{background-color:#ecf7f9;}
.bg-light1{background-color:#d9dbdb !important;}
.head{
background-color: #1a1a1a;
    padding: 15px 30px;
}
.head h1{
    color: #fff;
    font-size: 22px;
    font-weight: 600;
}
.arab{
    font-family: 'Cairo', sans-serif;
}
.text-gold{
    color: #db9600 !important;
}
.head-light{
    border-bottom: 1px solid #d7d7d7;
    background-color: #fbfbfb;
    padding: 8px 15px;
    font-weight: 600;
    font-size: 15px;
}
.detail-td{
    font-size: 12px;
    width: 100%;
}
.detail-td td{
    color: #7a7a7a;
    padding: 5px;
}
.detail-td th{
    color: #1a1a1a;
    padding: 5px;
    font-weight: 600;
}
.table_n th{
    background-color: #1a1a1a;
    color: #fff;
    font-size: 12px;
    line-height: 18px;
}
.table_n th span{
    font-family: 'Cairo', sans-serif;
    font-weight: 500;
    font-size: 11px;
    color: #ddd;
}
.table_n1{
    border: 1px solid #ededed;
    border-radius: 10px;
    font-size: 14px;
}
.table_n1 td:first-child{
    
}
.table_n1 td:last-child{
    text-align: right;
}
.tabn td:last-child{
    font-weight: 600;
}
.tabn td:first-child{
    font-weight: 400;
    color: #8b8b8b;
}
.tabn tr{
    border-bottom: 1px solid #dee2e6;
}
.amount{
    background-color: #fffbe6;
    border: 1px solid #f2e49d;
    padding: 8px;
    width: 100%;
    border-radius: 10px;
}
.amount h5{
    color: #d1b53f;
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 6px;
}
.amount h6{
    color: #1a1a1a;
    font-weight: 600;
}
.bank{
    background-color: #fff;
    border: 1px solid #d0d0d0;
    padding: 8px;
    width: 100%;
    margin-top: 4px;
    border-radius: 10px;
}
.bank h5{
    color: #1a1a1a;
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 6px;
    border-bottom: 1px solid #dee2e6;
    padding-bottom: 6px;
}
.bank h6{
    color: #1a1a1a;
    font-weight: 600;
}
.tabn1 td{
    font-weight: 600;
    color: #1a1a1a;
}
.tabn1 tr{
    border-bottom: 1px solid #dee2e6;
}


.invoice {
    width: 420px;
    margin: 20px auto;
    background: #f5f5f5;
    padding: 15px;
    color: #000;
    font-size: 14px;
    font-family: "Open Sans",sans-serif;
}

.center { text-align: center; }
.bold { font-weight: bold; }
.small { font-size: 12px; }

hr {
    border: none;
    border-top: 1px dashed #000;
    margin: 2px 0;
}
.hr {
    border: none;
    border-top: 2px solid #000;
    margin: 5px 0;
    opacity: 1;
}

.tabled {
    width: 100%;
    border-collapse: collapse;
    margin-top: 2px;
}
.tabled th {
    padding: 2px 4px;
    text-align: right;
    font-size: 13px;
}


.tabled td {
    padding: 6px 4px;
    text-align: right;
    font-size: 12px;
}

.tabled th {
    border-bottom: 1px solid #000;
}
.tabledtext {
    padding: 2px 4px;
    text-align: left;
    font-size: 12px;
}
.tabled td:last-child,
.tabled th:last-child {
    text-align: right;
}

.total-row {
    display: flex;
    justify-content: space-between;
    margin-top: 4px;
}
.footer {
    text-align: center;
    margin-top: 5px;       /* reduce space */
    padding: 0;
}

.footer img {
    display: block;        /* important */
    margin: 0 auto;        /* centers the QR */
}

.footer br {
    display: none;         /* remove extra gap */
}
</style>
<body>
    <div class="section">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <div class="invoice">
                        <div class="center invoice_head bold">{{branch.[0].name}}</div>

                        <div class="center small">
                            GST : {{branch.[0].vat}}<br/>
                            4521,King Abdu Aziz Road,Dammam,Al Khobar
                        </div>

                        <hr />
                        <div class="total-row small">
                            <div>Date : {{basicdetails.[0].inv_date}}</div>
                            <div>Time : {{basicdetails.[0].inv_time}}</div>
                        </div>
                        <div class="center small">
                            Invoice : {{basicdetails.[0].inv_no}}
                        </div>
                        <hr />

                        <div class="center bold">BILL TO</div>

                        <div class="center small">
                            {{billing_address.[0].name}}<br/>GST: {{customer_details.[0].VAT_number}}
                        </div>

                        <hr class="hr" />

                        <div class="center bold">TAX INVOICE</div>

                        <hr class="hr" />

                        <table class="tabled">
                            <tr>
                                <th class="bold" style="width:45%;text-align:start;">ITEM</th>
                                <th class="bold">QTY</th>
                                <th class="bold">RATE</th>
                                <th class="bold">AMOUNT</th>
                            </tr>
                            {{#each itemdetails}}
                            <tr>
                                <td style="width:45%;text-align:start;">{{item_name}}</td>
                                <td style="width:10%;">{{formatAmount quantity bcdp}}</td>
                                <td style="width:20%;">{{formatAmount price bcdp}}</td>
                                <td style="width:25%;">{{formatAmount amount bcdp}}</td>
                            </tr>
                            {{/each}}
                        </table>

                        <hr />
                        <table class="tabledtext">
                            <tr>
                                <td class="text-end" style="width:80%;">Total Taxable Amount</td>
                                <td class="text-end"><b>{{formatAmount (divide basicdetails.[0].subtotal ccrate) bcdp}}</b></td>
                            </tr>
                            <tr>
                                <td class="text-end">GST</td>
                                <td class="text-end"><b>{{formatAmount (divide basicdetails.[0].vatamt ccrate) bcdp}}</b></td>
                            </tr>
                            <tr>
                                <td class="text-end">Total</td>
                                <td class="text-end"><b>{{formatAmount (divide basicdetails.[0].grand_total ccrate) bcdp}}</b></td>
                            </tr>
                        </table>
                        <hr/>
                        <div class="footer small">{{bcamountinwords}}</div>
                        <hr/>

                        <div class="footer">
                             {{{qrDataUri qrCodeBase64}}}<br>
                            Thank you !
                        
                        </div>
                    </div>

                </div>
            </div>
            
        </div>
    </div>
</body>
</html>