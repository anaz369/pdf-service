<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>INVOICE - {{basicdetails.[0].inv_no}}</title>
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        font-family: "IBM Plex Sans Arabic", Arial, sans-serif;
        font-size: 9px;
        line-height: 1.3;
        color: #000;
        margin: 0 4mm;
      }

      .ar {
        direction: rtl;
      }

      table {
        border-collapse: collapse;
        width: 100%;
        table-layout: fixed;
      }

      /* ── TITLE ────────────────────────────────────── */
      .doc-title {
        text-align: center;
        font-size: 20px;
        font-weight: 800;
        color: #b72031;
        margin-bottom: 6px;
      }
      .doc-title .ar{
         color: #606261;
      }

      /* ── TOP : BUYER | INFO ───────────────────────── */
      .top-wrap > tbody > tr > td {
        vertical-align: top;
        border: none;
        padding: 0 4px;
      }
      .buyer,
      .info {
        
      }
      .buyer td,
      .info td {
        font-size: 9px;
        border: 1px solid #bfbfbf;
        padding: 4px 6px;
        vertical-align: middle;
      }
      .buyer td.lbl {
        font-weight: 700;
      }
      .info td.lbl {
        background-color:#ccc;
        font-weight: 700;
      }
      .info td.arl {
        background-color:#ccc;
        font-weight: 700;
      }
      .info td.val {
        text-align: center;
      }
      .buyer td.arl,
      .info td.arl {
        font-weight: 700;
        text-align: right;
        direction: rtl;
      }

      /* ── ITEMS TABLE ──────────────────────────────── */
      .items-table {
        margin-top: 8px;
      }
      .items-table th,
      .items-table td {
        font-size: 9px;
        border: 1px solid #bfbfbf;
        padding: 3px 5px;
        vertical-align: top;
      }
      .items-table thead th {
        font-size: 10px;
        text-align: center;
        line-height: 1.2;
      }
      .items-table thead th .ar {
        display: block;
        direction: rtl;
        font-weight: 700;
      }
      .items-table thead th .en {
        display: block;
        font-weight: 700;
      }
      .items-table td.num {
        text-align: center;
      }
      .items-table td.right {
        text-align: right;
      }
      .items-table tbody td {
        border-top: none;
        border-bottom: none;
      }
      .items-table tbody tr:last-child td {
        border-bottom: 1px solid #bfbfbf;
      }

      /* ── MID : QR | TOTALS ────────────────────────── */
      .mid {
        margin-top: 8px;
      }
      .mid > tbody > tr > td {
        vertical-align: top;
        padding: 0;
      }
      .mid .qrcell {
        text-align: center;
        vertical-align: middle;
        padding: 6px;
      }
      .mid .qrcell .qr-wrap {
        width: 120px;
        height: 120px;
        margin: 0 auto;
        overflow: hidden;
      }
      .mid .qrcell .qr-wrap img {
        width: 100%;
        height: auto;
        max-width: 120px;
        max-height: 120px;
      }
      .totals2 td {
        border: 1px solid #bfbfbf;
        padding: 5px 8px;
        font-size: 9.5px;
        vertical-align: middle;
      }
      .totals2 .tl {
        width: 60%;
        font-weight: 600;
        border-right: none;
      }
      .totals2 .tl .en {
        display: block;
      }
      .totals2 .tl .ar {
        display: block;
        direction: rtl;
      }
      .totals2 .tv {
        text-align: right;
        width: 40%;
        font-weight: 600;
        border-left: none;
      }
      .totals2 .b .tl,
      .totals2 .b .tv {
        font-weight: 800;
      }

      /* BANK BOX (left of totals) */
      .bankbox {
        border: 1px solid #bfbfbf;
      }
      .bankbox .bhd {
        background: #d9d9d9;
        font-weight: 700;
        padding: 5px 8px;
        border-bottom: 1px solid #bfbfbf;
      }
      .bankbox .blines {
        width: 100%;
        border-collapse: collapse;
      }
      .bankbox .blines td {
        border: none;
        padding: 4px 8px;
        font-size: 9.5px;
      }
      .bankbox .blines td.bl {
        width: 38%;
        font-weight: 600;
      }
      .bankbox .blines td.bc {
        width: 4%;
      }

      /* ── AMOUNT IN WORDS ──────────────────────────── */
      .words-bar td {
        font-size: 9.5px;
        border: 1px solid #bfbfbf;
        border-top: none;
        padding: 5px 8px;
      }
      .words-bar .words-en {
        width: 55%;
      }
      .words-bar .words-ar {
        width: 45%;
        text-align: right;
        direction: rtl;
      }

      /* ── FOOTER : BANK | SIGNATURES ───────────────── */
      .footer{
          width:100%;
          border-collapse:collapse;
          table-layout:fixed;
          margin-top:8px;
      }

      .footer td{
          padding:5px;
          font-size:10px;
          vertical-align:top;
      }

      .footer .fhd{
          padding:4px 8px;
      }

      .footer .shd{
          text-align:center;
          padding:4px 8px;
      }

      .footer .shd .ar{
          direction:rtl;
      }

      .footer .fhd table{
          width:100%;
          border-collapse:collapse;
      }

      .footer .fhd table td{
          border:none;
          padding:0;
      }

      .sig{
          height:110px;
          text-align:center;
          vertical-align:middle!important;
      }

      .sig img{
          max-width:120px;
          max-height:95px;
      }

      .bank-lines{
          width:100%;
          border-collapse:collapse;
      }

      .bank-lines td{
          border:none;
          padding:3px 2px;
      }

      .bank-lines .bl{
          width:38%;
      }

      .bank-lines .bc{
          width:6%;
          text-align:center;
      }

      .rb .ar{
        text-align: left;

      }
    </style>
  </head>
  <body>

    <!-- TITLE -->
    <div class="doc-title">INVOICE / <span class="ar">فاتورة</span></div>

    <!-- TOP : BUYER | INFO -->
    <table class="top-wrap">
      <tr>
        <!-- BUYER DETAILS -->
        <td style="width:58%">
          <table class="buyer">
            <colgroup>
                <col style="width:21%;">
                <col style="width:33%;">
                <col style="width:33%;">
                <col style="width:13%;">
            </colgroup>
            <tr>
              <td class="lbl">Customer Name</td>
              <td>{{billing_address.[0].name}}</td>
               <td style="text-align: right;">{{billing_address_lang2.[0].name}}</td>
              <td class="arl">الإسم</td>
            </tr>
            <tr>
              <td class="lbl">Address</td>
              <td>{{{joinAddress billing_address.[0] '<br>'}}}</td>
              <td style="text-align: right;">{{{joinAddress billing_address_lang2.[0] '<br>'}}}</td>
              <td class="arl">العنوان</td>
            </tr>
            <tr>
              <td class="lbl">Vendor Number</td>
              <td>{{billing_address.[0].subject}}</td>
              <td style="text-align: right;"></td>
              <td class="arl">الرقم البائع</td>
            </tr>
          </table>
        </td>

        <!-- INFO -->
        <td style="width:42%">
          <table class="info">
            <colgroup>
              <col style="width:27%;">
              <col style="width:46%;">
              <col style="width:27%;">
          </colgroup>
            <tr><td class="lbl">Invoice No</td><td class="val">{{basicdetails.[0].inv_no}}</td><td class="arl">رقم الفاتورة</td></tr>
            <tr><td class="lbl">Invoice Date</td><td class="val">{{basicdetails.[0].inv_date}}</td><td class="arl">تاريخ الفاتورة</td></tr>
            <tr><td class="lbl">Branch</td><td class="val">{{branch.[0].name}}</td><td class="arl">الفروع</td></tr>
            <tr><td class="lbl">PO No</td><td class="val">{{basicdetails.[0].order_no}}</td><td class="arl">رقم الطلب الشراء</td></tr>
          </table>
        </td>
      </tr>
    </table>

    <!-- ITEMS TABLE -->
    <table class="items-table">
      <thead>
        <tr>
          <th style="width:5%"><span class="ar">م</span><span class="en">S.N</span></th>
          <th style="width:38%"><span class="ar">الوصف</span><span class="en">Description</span></th>
          <th style="width:18%"><span class="ar">الباركود</span><span class="en">Barcode</span></th>
          <th style="width:10%"><span class="ar">الكمية</span><span class="en">QTY</span></th>
          <th style="width:10%"><span class="ar">الوحدة</span><span class="en">Unit</span></th>
          <th style="width:10%"><span class="ar">سعر الوحدة</span><span class="en">U.Rate</span></th>
          <th style="width:13%"><span class="ar">القيمة الاجمالي</span><span class="en">Total Amount</span></th>
        </tr>
      </thead>
      <tbody>
        {{#each itemdetails}}
        <tr>
          <td class="num">{{addOne @index}}</td>
          <td>{{item_name}}{{name_lang2}}{{description}}</td>
          <td class="num">{{barcode}}</td>
          <td class="num">{{formatAmount quantity ../bcdp}}</td>
          <td class="num">{{unit}}</td>
          <td class="right">{{formatAmount price ../bcdp}}</td>
          <td class="right">{{formatAmount amount ../bcdp}}</td>
        </tr>
        {{/each}}
        <tr>
            <td style="height: 50px;"></td>
            <td></td>
            <td></td>
            <td></td>
            <td></td>
            <td></td>
            <td></td>
            <td></td>
        </tr>
      </tbody>
    </table>


        <table style="font-family: ibmplexsansarabic;border:1px solid #bfbfbf;padding:5px;" border="0" cellspacing="0" cellpadding="1">

            <tr>

                <td width="65%" style="font-size: 10px;background-color:#ccc;border:1px solid #bfbfbf;line-height:200%;padding-left:5px;" colspan="3"> Bank Details</td>

                <td width="17.5%" style="font-size: 10px;border-left:1px solid #bfbfbf;line-height:150%;border-top:1px solid #bfbfbf;border-right:1px solid #bfbfbf;padding-left:5px;">&nbsp;&nbsp; Total Amount</td>

                <td width="17.5%" style="font-size: 10px;border:1px solid #bfbfbf;line-height:200%;text-align:right;padding-right:5px;" rowspan="2">{{formatAmount (divide basicdetails.[0].subtotal ccrate) bcdp}}</td>

            </tr>

            <tr>

                <td width="20%" style="font-size: 10px;border-left:1px solid #bfbfbf;line-height:200%;padding-left:5px;"> Bank Name</td>

                <td width="5%" style="font-size: 10px;line-height:200%;"> : </td>

                <td width="40%" style="font-size: 10px;border-right:1px solid #bfbfbf;line-height:200%;">{{bankdetails.name}} </td>

                <td width="17.5%" style="font-size: 10px;border-left:1px solid #bfbfbf;line-height:100%;border-bottom:1px solid #bfbfbf;border-right:1px solid #bfbfbf;padding-left:5px;"> المبلغ الإجمالي &nbsp;&nbsp;</td>

            </tr>

            <tr>

                <td width="20%" style="font-size: 10px;border-left:1px solid #bfbfbf;line-height:200%;padding-left:5px;"> Account Name</td>

                <td width="5%" style="font-size: 10px;line-height:200%;"> : </td>

                <td width="40%" style="font-size: 10px;border-right:1px solid #bfbfbf;line-height:200%;">{{bankdetails.acc_name}}</td>

                <td width="17.5%" style="font-size: 10px;border-left:1px solid #bfbfbf;line-height:150%;border-top:1px solid #bfbfbf;border-right:1px solid #bfbfbf;padding-left:5px;">&nbsp;&nbsp; Discount</td>

                <td width="17.5%" style="font-size: 10px;border:1px solid #bfbfbf;line-height:200%;text-align:right;padding-right:5px;" rowspan="2">{{formatAmount (divide basicdetails.[0].discount ccrate) bcdp}}</td>

            </tr>

            <tr>

                <td width="20%" style="font-size: 10px;border-left:1px solid #bfbfbf;line-height:200%;padding-left:5px;"> Account Number</td>

                <td width="5%" style="font-size: 10px;line-height:200%;"> : </td>

                <td width="40%" style="font-size: 10px;border-right:1px solid #bfbfbf;line-height:200%;">{{bankdetails.acc_no}}</td>

                <td width="17.5%" style="font-size: 10px;border-left:1px solid #bfbfbf;line-height:100%;border-bottom:1px solid #bfbfbf;border-right:1px solid #bfbfbf;padding-left:5px;">الخصم &nbsp;&nbsp;</td>

            </tr>

            <tr>

                <td width="20%" style="font-size: 10px;border-left:1px solid #bfbfbf;line-height:200%;padding-left:5px;"> IBAN Number</td>

                <td width="5%" style="font-size: 10px;line-height:200%;"> : </td>

                <td width="40%" style="font-size: 10px;border-right:1px solid #bfbfbf;line-height:200%;"> {{bankdetails.iban_no}}</td>

                <td width="17.5%" style="font-size: 10px;border-left:1px solid #bfbfbf;line-height:150%;border-top:1px solid #bfbfbf;border-right:1px solid #bfbfbf;font-weight:bold;padding-left:5px;">&nbsp;&nbsp; Grand Total</td>

                <td width="17.5%" style="font-size: 10px;border:1px solid #bfbfbf;line-height:200%;text-align:right;font-weight:bold;padding-right:5px;" rowspan="2">{{formatAmount (divide basicdetails.[0].grand_total ccrate) bcdp}}</td>

            </tr>

            <tr>

                <td width="20%" style="font-size: 10px;border-left:1px solid #bfbfbf;line-height:200%;border-bottom:1px solid #bfbfbf;padding-left:5px;"> SWIFT Number</td>

                <td width="5%" style="font-size: 10px;line-height:200%;border-bottom:1px solid #bfbfbf;"> : </td>

                <td width="40%" style="font-size: 10px;border-right:1px solid #bfbfbf;line-height:200%;border-bottom:1px solid #bfbfbf;"> {{bankdetails.swift_no}}</td>

                <td width="17.5%" style="font-size: 10px;border-left:1px solid #bfbfbf;line-height:100%;border-bottom:1px solid #bfbfbf;border-right:1px solid #bfbfbf;font-weight:bold;padding-left:5px;">المبلغ الإجمالي &nbsp;&nbsp;</td>

            </tr>

        </table>

    
    <!-- AMOUNT IN WORDS -->
    <table class="words-bar">
      <tr>
        <td class="words-en">{{bcamountinwords}}</td>
        <td class="words-ar">{{bcamountinwordsar}}</td>
      </tr>
    </table>

    <!-- FOOTER : SIGNATURES -->
    <table class="footer" cellpadding="0" cellspacing="0">
      <tr>
          <td class="shd" style="width:33.34%;">Authorized Signatury <span class="ar">/ التوقيع</span></td>
          <td class="shd" style="width:33.33%;">Authorized Stamp <span class="ar">/ الختم</span></td>
          <td class="shd" style="width:33.33%;">Received by <span class="ar">/ قبل من تلقى</span></td>
      </tr>
      <tr>
          <td class="sig">
              {{#if Signature}}
              <img src="{{Signature}}" alt="Signature" style="max-height:{{default datasettings.d458 '120'}}px; max-width:{{default datasettings.d458 '180'}}px;" onerror="this.style.display='none'"/>
              {{/if}}
          </td>
          <td class="sig">
              {{#if Seal}}
              <img class="seal-img" src="{{Seal}}" alt="Seal" style="max-height:{{default datasettings.d459 '120'}}px; max-width:{{default datasettings.d459 '180'}}px;" onerror="this.style.display='none'"/>
              {{/if}}
          </td>
          <td class="sig"></td>
      </tr>
  </table>

  </body>
</html>
