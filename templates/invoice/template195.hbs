}
</style>
<body>
    <div class="section">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <h1 class="text-center invoice_head"><span>INVOICE TAX</span> -  فاتورة ضريبية </h1>
                </div>
                <div class="col-lg-6 col-md-6 col-sm-6" style="width: 55%;">
                    <table class="myy_table myy_table2 lih-24">
    <tr>
        <th class="br" colspan="2">BUYER DETAILS</th>
        <th class="text-end bl">فاصيل المشتري</th>
    </tr>

    <tr>
        <th style="text-align: left;">Name</th>
        <td>{{billing_address.[0].name}}</td>
        <td style="text-align: right;">الإ سم</td>
    </tr>

    <tr>
        <th style="text-align: left;">VAT Number</th>
        <td>{{customer_details.[0].VAT_number}}</td>
        <td style="text-align: right;">الرقم ظريبه الشراء</td>
    </tr>

    <tr>
        <th style="text-align: left;">CR No</th>
        <td>{{customer_details.[0].cr_no}}</td>
        <td style="text-align: right;">رقم التجاري</td>
    </tr>

    <tr>
        <th style="text-align: left;">Address</th>
        <td>
            {{joinAddress billing_address.[0] '، '}}
        </td>
        <td style="text-align: right;">العنوان</td>
    </tr>
</table>
                </div>
                <div class="col-lg-6 col-md-6 col-sm-6" style="width: 45%;">
                    <table class="myy_table myy_table2 lih-24">

    <tr>
        <td class="bg-light1"><b>Invoice No</b></td>
        <td class="text-center"><b>{{basicdetails.[0].inv_no}}</b></td>
        <td class="bg-light1 text-end arab"><b>رقم الفاتورة</b></td>
    </tr>

    <tr>
        <td class="bg-light1"><b>Invoice Date</b></td>
        <td class="text-center"><b>{{basicdetails.[0].inv_date}}</b></td>
        <td class="bg-light1 text-end arab"><b>تاريخ الفاتورة</b></td>
    </tr>

    <tr>
        <td class="bg-light1"><b>Mode of pay</b></td>
        <td class="text-center">
            <b>
                
            </b>
        </td>
        <td class="bg-light1 text-end arab"><b>طريقة الدفع</b></td>
    </tr>

    <tr>
        <td class="bg-light1"><b>PO No</b></td>
        <td class="text-center"><b>{{basicdetails.[0].order_no}}</b></td>
        <td class="bg-light1 text-end arab"><b>رقم الطلب الشراء</b></td>
    </tr>

    <tr>
        <td class="bg-light1"><b>Payment Terms</b></td>
        <td class="text-center">
            <b>{{basicdetails.[0].payment_terms}}</b>
        </td>
        <td class="bg-light1 text-end arab"><b>شروط الدفع</b></td>
    </tr>

    <tr>
        <td class="bg-light1"><b>Project Name</b></td>
        <td class="text-center">
            <b>{{basicdetails.[0].project_name}}</b>
        </td>
        <td class="bg-light1 text-end arab"><b>اسم المشروع</b></td>
    </tr>

</table>
                    
                    
                </div>

                <div class="col-lg-12 mt-2">
                    <table class="myy_table myy_table2">
                        <thead>
                            <tr class="text-center">
                                <th><span class="arab">م</span><br>Sl </th>
                                <th><span class="arab">الوصف</span><br>Description</th>
                                <th><span class="arab">الكمية</span><br>QTY</th>
                                <th><span class="arab">الوحدة</span><br>Unit</th>
                                <th><span class="arab">سعر الوحدة</span><br>U.Rate</th>
                                <th><span class="arab">مبلغ</span><br>Amount</th>
                                <th><span class="arab">قيمة الضريبة</span><br>VAT Value</th>
                                <th><span class="arab">القيمه الاجمالي</span><br>Total Price</th>
                            </tr>
                        </thead>
                            <tbody>
{{#each itemdetails}}
<tr class="text-end">
    <td class="text-center">{{addOne @index}}</td>
    <td class="text-start">
      <div>{{item_name}}</div>
        {{#if name_lang2}}
            <div style="direction:rtl; font-size:9px; color:#555;">
                {{name_lang2}}
            </div>
        {{/if}}
        {{#if description}}
            <div style="font-size:9px; color:#777;">
                {{description}}
            </div>
        {{/if}}
    </td>
    <td>{{quantity}}</td>
    <td>{{unit}}</td>
    <td>{{formatAmount price ../bcdp}}</td>
    <td>{{formatAmount taxable ../bcdp}}</td>
    <td>{{formatAmount disc_amt ../bcdp}}</td>
    <td>{{formatAmount total ../bcdp}}</td>
    <td>{{formatAmount vat_amt ../bcdp}}</td>
    <td>{{formatAmount amount ../bcdp}}</td>
</tr>
{{/each}}
</tbody>

                            </tbody>
                    </table>
                </div>
                <div class="col-lg-5 col-md-5 col-sm-5 text-center">
                    {{{qrDataUri qrCodeBase64}}}
                </div>
                <div class="col-lg-7 col-md-7 col-sm-7 mt-1">
                    <table class="myy_table myy_table2">

    <tr>
        <td>Total Amount / الإجمالي المبلغ </td>
        <td class="text-end">
            {{basicdetails.[0].isocode}} 
            {{formatAmount basicdetails.[0].subtotal bcdp}}
        </td>
    </tr>

    <tr>
        <td>Discount / الخصم </td>
        <td class="text-end">
            {{basicdetails.[0].isocode}} 
            {{formatAmount basicdetails.[0].discount bcdp}}
        </td>
    </tr>

    <tr>
        <td><b>Net Amount / المجموع ص</b></td>
        <td class="text-end">
            <b>
                {{basicdetails.[0].isocode}} 
                {{formatAmount (subtract basicdetails.[0].subtotal basicdetails.[0].discount) bcdp}}
            </b>
        </td>
    </tr>

    <tr>
        <td>VAT (15%) / المضافة القيمة ضريبة </td>
        <td class="text-end">
            {{basicdetails.[0].isocode}} 
            {{formatAmount basicdetails.[0].vatamt bcdp}}
        </td>
    </tr>

    <tr>
        <td><b> Grand Total / الإجمالي ا</b></td>
        <td class="text-end">
            <b>
                {{basicdetails.[0].isocode}} 
                {{formatAmount basicdetails.[0].grand_total bcdp}}
            </b>
        </td>
    </tr>

</table>
                </div>
                
                <div class="col-lg-12">
                     <table class="myy_table myy_table2">
                        <tr>
                            <td class="w-50">{{bcamountinwords}}</td>
                            <td class="text-end"></td>
                        </tr>
                    </table>
                </div>
                <div class="col-lg-12 mt-1">
                    <table class="myy_table myy_table2 text-center lih-20">
                        <tr>
                            <td>Company Stamp<br> ختم الشركة</td>
                            <td>Prepared By<br>تمت الموافقة بواسطة</td>
                            <td>Authorized Signature<br> التوقيع المخول</td>
                            <td>Received By<br>تم الاستلام بواسطة</td>
                        </tr>
                        <tr>
                            <td>{{#if Seal}}
                                    <img src="{{Seal}}" alt="Seal" style="max-height:{{default datasettings.d458 '40'}}px; max-width:{{default datasettings.d458 '60'}}px;" onerror="this.style.display='none'"/>
                                {{/if}}</td>
                            <td></td>
                            <td>{{#if signature}}
                                    <img src="{{signature}}" alt="signature" style="max-height:{{default datasettings.d459 '40'}}px; max-width:{{default datasettings.d459 '60'}}px;" onerror="this.style.display='none'"/>
                                {{/if}}</td>
                            <td></td>
                        </tr>
                    </table>
                </div>
                
                
            </div> 
        </div>
    </div>
</body>
</html>