}
.tabn1 tr{
    border-bottom: 1px solid #dee2e6;
}


.invoice {
    width: 420px;
    margin: 20px auto;
    background: #f5f5f5;
    padding: 15px;
    color: #000;
    font-size: 10px;
    font-family: "Open Sans",sans-serif;
}

.center { text-align: center; }
.bold { font-weight: bold; }
.small { font-size: 10px; }

hr {
    border: none;
    border-top: 1px dashed #000;
    margin: 10px 0;
}
.hr {
    border: none;
    border-top: 2px solid #000;
    margin: 5px 0;
    opacity: 1;
}

.tabled {
    width: 100%;
    border-collapse: collapse;
    margin-top: 10px;
}

.tabled th, .tabled td {
    padding: 6px 4px;
    text-align: left;
    font-size: 10px;
}

.tabled th {
    border-bottom: 1px solid #000;
}

.tabled td:last-child,
.tabled th:last-child {
    text-align: right;
}

.total-row {
    display: flex;
    justify-content: space-between;
    margin-top: 8px;
}
.total-row1 {
    display: flex;
    justify-content: flex-start;
    margin-top: 8px;
}
.total-row1 div:last-child{
    padding-left: 0px;
    content: ":";
}
.total-row1 div:first-child{
    width: 30%;
}

.footer {
    text-align: center;
    margin-top: 10px;
}

.box_table{
        margin: 30px;
        display: block;
    }
    table th{
        font-weight: 600;
    }
    .table_sec td{
        font-weight: 400;
        line-height: 16px;
        border: 1px solid #76716a;
        padding: 2px 0;
        padding-left: 5px;
        padding-right: 5px;
        border-bottom: 0;
        border-right: 0;
        font-size: 10px;
        vertical-align: top;
    }
    .table_sec th{
        font-size: 10px;
        color: #26323e;
        padding: 2px 5px;
        border: 1px solid #76716a;
        border-bottom: 0;
        border-right: 0;
    }
    .table_sec tr:last-child td{
        border-bottom: 1px solid #b9bcbf;
    }
    .table_sec tr td:last-child{
        border-right: 1px solid #b9bcbf;
    }
    .table_sec tr:last-child th{
        border-bottom: 1px solid #76716a;
    }
    .table_sec tr th:last-child{
        border-right: 1px solid #76716a;
    }
.my_table table{
    font-size: 10px;
    line-height: 16px;
}
.my_table table th{
    font-weight: 700;
}
.invoice_head{
    font-weight: 700;
    font-size: 22px;
    margin-bottom: 15px;
}
.invoice_head span{
    color: #b72031;
}
.b{
    font-weight: 600;
}
.bd-code-snippet{
    border: 1px solid #acaeaf;
    border-radius: 6px;
    padding: 8px;
}
.bd-code-snippet2{
    border: 1px solid #272727;
    border-radius: 0px;
    padding: 8px;
}
.boxx_table{
    
}
.boxx_table td{
    padding: 8px;
}
.boxx_table th{
    border-bottom: 1px solid #acaeaf;
    padding: 8px;
}
.boxx_table th b{
    font-weight: 400;
}
.boxx_table th:first-child{
    border-right: 1px solid #acaeaf;
}
.boxx_table1 td{
    padding: 8px;
    border-bottom: 1px solid #acaeaf;
    border-right: 1px solid #acaeaf;
    text-align: center;
}
.boxx_table1 td:last-child{
    border-right: 0px solid #acaeaf;
}
.boxx_table1 th{
    border-bottom: 2px solid #707070;
    border-right: 1px solid #acaeaf;
    padding: 8px;
    text-align: center;
}
.boxx_table1 th b{
    font-weight: 400;
}
.boxx_table1 th:last-child{
    border-right: 0px solid #acaeaf;
}
.w-10{
    width: 10%;
}
.w-15{
    width: 15%;
}
.border-dark td{
    border: 1px solid #272727 !important;
}
.lih-20{
    line-height: 20px !important;
}
.lih-24{
    line-height: 24px !important;
}
.pl-0{
    padding-left: 0px !important;
}
.pr-0{
    padding-right: 0px !important;
}

.bb{
    border-bottom: 0px !important;
}
.br{
    border-right: 0px !important;
}
.bl{
    border-left: 0px !important;
}
.bt{
    border-top: 0px !important;
}
.br-1{
    border-right: 1px solid #acaeaf !important;
}
.bt-1{
    border-top: 1px solid #272727 !important;
}
.fw-400{
    font-weight: 400;
}
.box_d{
    border: 1px solid #272727 !important;
    padding: 8px 12px;
}
.vam{
    vertical-align: middle !important;
}
.myy_table{
    border: 1px solid #ccc;
}
.myy_table td{
    padding: 2px 8px;
    color: #282727;
    font-weight: 600;
    font-size: 9px;
}
.myy_table th{
    background-color: #f2f2f2;
    padding: 2px 8px;
    color: #282727;
    font-weight: 600;
    font-size: 10px;
}
.myy_table1 td{
    border: 1px solid #ccc;
}
.myy_table1 th{
    border: 1px solid #ccc;
    line-height: 26px;
}
.myy_table2 td{
    border: 1px solid #ccc;
}
.myy_table2 th{
    border: 1px solid #ccc;
    font-weight: bold;
    background-color: #fff;
    color: #000;
}
.myy_table3 th{
    background-color: #19aec6;
    color: #fff;
    font-weight: 600;
    font-size: 10px;
    line-height: 24px;
    border: 1px solid #fff;
    padding: 2px 8px;
}
.myy_table3 td{
    padding: 2px 8px;
    color: #282727;
    font-weight: 600;
    font-size: 9px;
    border-bottom: 1px solid #ccc;
    line-height: 24px;
}
.myy_table4{
    border: 1px solid #000;
}
.myy_table4 td{
    padding: 2px 8px;
    color: #282727;
    font-weight: 600;
    font-size: 9px;
}
.myy_table4 th{
    padding: 2px 8px;
    color: #000;
    font-weight: bold;
    font-size: 10px;
    border-bottom: 1px solid #000;
}
.myy_table5{
    border: 1px solid #000;
}
.myy_table5 td{
    padding: 10px 8px;
    color: #282727;
    font-weight: 600;
    font-size: 10px;
}
.myy_table5 th{
    padding: 8px 8px;
    color: #000;
    font-weight: bold;
    font-size: 10px;
    border-bottom: 1px solid #000;
}
.bt-1px{
    border-top: 1px solid #000;
}
.bl-1px{
    border-left: 1px solid #000;
}
.bg_red{
    background-color: #f54343;
    color: #fff !important;
}
.fs-11{
    font-size: 10px;
}
.fs-13{
    font-size: 15px;
}
