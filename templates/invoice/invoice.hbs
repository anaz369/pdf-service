    <style>
        @page {
            size: A4;
            margin: 0;
        }

        body {
            font-family: Arial, sans-serif;
            font-size: 12px;
            line-height: 1.2;
            margin: 0;
            padding: 10px;
            background: white;
        }

        .invoice-container {
            max-width: 210mm;
            margin: 0 auto;
            margin-top: 75px !important;
            background: white;
        }

        .header-title {
            text-align: center;
            font-size: 18px;
            font-weight: bold;
            margin-bottom: 0;
            padding: 4px 0;
        }

        .border-top-thick {
            border-top: 2px solid #000;
        }

        .border-bottom-thick {
            border-bottom: 2px solid #000;
        }

        .info-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 3px;
        }

        .info-table td {
            padding: 2px 4px;
            border: 1px solid #000;
            font-size: 11px;
        }

        .info-table td.label {
            font-weight: bold;
            background-color: #f8f9fa;
            text-align: left;
        }

        .section-header {
            background-color: #000;
            color: #fff;
            padding: 2px 6px;
            font-weight: bold;
            font-size: 11px;
            margin-top: 3px;
        }

        .items-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 3px;
        }

        .items-table th {
            background-color: #f8f9fa;
            border: 1px solid #000;
            padding: 3px 2px;
            font-size: 11px;
            font-weight: bold;
            text-align: center;
            line-height: 1.1;
        }

        .items-table td {
            border: 1px solid #000;
            padding: 3px 2px;
            font-size: 10px;
            vertical-align: top;
            line-height: 1.2;
        }

        .items-table td.center {
            text-align: center;
        }

        .items-table td.right {
            text-align: right;
        }

        .summary-table {
            width: 100%;
            margin-top: 3px;
        }

        .summary-table td {
            padding: 2px 4px;
            font-size: 10px;
        }

        .summary-table td.label {
            font-weight: bold;
            text-align: left;
            width: 50%;
            border: 1px solid #000;
            background-color: #f8f9fa;
        }

        .summary-table td.value {
            text-align: right;
            width: 20%;
            border: 1px solid #000;
        }

        .summary-table td.arabic {
            text-align: right;
            border: 1px solid #000;
            background-color: #f8f9fa;
            font-weight: bold;
        }

        .amount-words {
            text-align: center;
            padding: 3px;
            font-weight: bold;
            font-size: 10px;
            border: 1px solid #000;
            margin-top: 2px;
            line-height: 1.3;
        }

        .bank-section {
            margin-top: 5px;
        }

        .bank-table {
            width: 100%;
            border-collapse: collapse;
        }

        .bank-table th {
            background-color: #f8f9fa;
            border: 1px solid #000;
            padding: 3px 4px;
            font-weight: bold;
            font-size: 11px;
            text-align: center;
        }

        .bank-table td {
            border: 1px solid #000;
            padding: 3px 4px;
            font-size: 10px;
        }

        .signature-cell {
            height: 50px;
            text-align: center;
            vertical-align: bottom;
            font-weight: bold;
            font-size: 10px;
        }

        .qr-code {
            width: 140px;
            height: 140px;
            border: 1px solid #000;
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: #f8f9fa;
        }

        .arabic-text {
            direction: rtl;
            text-align: center;
        }

        .text-end {
            text-align: right;
        }
    </style>
</head>
