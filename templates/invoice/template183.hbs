    .qr-wrapper img {
      width: 85px;
      height: 85px;
      display: block;
    }

    .invoice-box {
        background: #fff;
    }
    table {
        width: 100%;
    }
    th, td {
        border: 1px solid #000 !important;
        padding: 6px;
        font-size: 13px;
    }
    .no-border td {
        border: none !important;
    }
    .title {
        font-weight: bold;
        text-align: center;
    }
