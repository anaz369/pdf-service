<body>

<div class="container mt-4">
<div class="invoice-box">

    {{!-- <!-- Top Header --> --}}
    <table class="mb-2">
        <tr>
            <td><b>CR No:</b> 316836186318</td>
            <td class="text-center"><b>VAT Reg No:</b> 30008687268326822</td>
            <td class="text-end arab"><b>رقم ضريبة</b></td>
        </tr>
    </table>

    {{!-- <!-- Customer + QR + Arabic --> --}}
    <div class="row mb-3">
        <div class="col-md-5 col-md-5 col-sm-5">
    <div class="box">

        <b class="px-3 pt-1 small-text">CUSTOMER NAME AND ADDRESS</b>

        <table class="mt-2">

            <tr>
                <td class="bl">Name</td>
                <td class="br">{{billing_address.[0].name}}</td>
            </tr>

            <tr>
                <td class="bl">Address</td>
                <td class="br">{{billing_address.[0].address_line1}}</td>
            </tr>

            <tr>
                <td class="bl">Place</td>
                <td class="br">{{billing_address.[0].address_line2}}</td>
            </tr>

            <tr>
                <td class="bl">City</td>
                <td class="br">{{billing_address.[0].address_line3}}</td>
            </tr>

            <tr>
                <td class="bl">Mobile No</td>
                <td class="br">{{customer_details.[0].contact_no1}}</td>
            </tr>

            <tr>
                <td class="bb bl">VAT</td>
                <td class="bb br">{{customer_details.[0].VAT_number}}</td>
            </tr>

        </table>

    </div>
</div>

        <div class="col-md-2 col-md-2 col-sm-2 text-center">
            <h5 class="arab title">فاتورة ضريبية</h5>
            <h5 class="title">TAX INVOICE</h5>
            {{{qrDataUri qrCodeBase64}}}
        </div>

        <div class="col-md-5 col-md-5 col-sm-5">
                <div class="box text-end">

                    <b class="arab px-3 small-text">اسم العميل والعنوان</b>

                    <table class="mt-2">

                        <tr>
                            <td class="bl">{{billing_address.[0].name}}</td>
                            <td class="br arab">اسم</td>
                        </tr>

                        <tr>
                            <td class="bl">
                                {{billing_address.[0].address_line1}}
                            </td>
                            <td class="br arab">عنوان</td>
                        </tr>

                        <tr>
                            <td class="bl">
                                {{billing_address.[0].address_line2}}
                            </td>
                            <td class="br arab">مكان</td>
                        </tr>

                        <tr>
                            <td class="bl">
                                {{billing_address.[0].address_line3}}
                            </td>
                            <td class="br arab">مدينة</td>
                        </tr>

                        <tr>
                            <td class="bl">
                                {{customer_details.[0].contact_no1}}
                            </td>
                            <td class="br arab">جوال</td>
                        </tr>

                        <tr>
                            <td class="bl bb">
                                {{customer_details.[0].VAT_number}}
                            </td>
                            <td class="br bb arab">ضريبة القيمة المضافة</td>
                        </tr>

                    </table>

                </div>
            </div>
    </div>

    {{!-- <!-- Invoice Details --> --}}
    <table class="mb-3 text-center">
    <tr>
        <th>Payment Mode <br> <span class="arab">وضع الدفع</span></th>
        <th>Invoice No <br> <span class="arab">رقم الفاتورة</span></th>
        <th>Invoice Date <br> <span class="arab">تاريخ الفاتورة</span></th>
        <th>Location <br> <span class="arab">موقع</span></th>
    </tr>

    <tr>
        <td>{{basicdetails.[0].payment_terms}}</td>
        <td>{{basicdetails.[0].inv_no}}</td>
        <td>{{basicdetails.[0].inv_date}}</td>
        <td>{{location.[0].city}}</td>
    </tr>
</table>

    {{!-- <!-- Items Table --> --}}
    <table class="text-center">
        <thead>
            <tr class="arab">
                <th>الرقم</th>
                <th> الجزء رقم</th>
                <th>وصف السلعة</th>
                <th>الكمية</th>
                <th>الوحدة</th>
                <th> سعر الوحدة</th>
                <th>المجموع</th>
                <th>% الضريبة </th>
                <th>الضريبة</th>
                <th>الإجمالي</th>
            </tr>
            <tr>
                <th>S.N</th>
                <th>Part No</th>
                <th>Description</th>
                <th>QTY</th>
                <th>Unit</th>
                <th>U.Rate</th>
                <th>Total (Excl VAT)</th>
                <th>VAT %</th>
                <th>VAT Amount</th>
                <th>Total Amount</th>
            </tr>
        </thead>

        <tbody>
             {{#each itemdetails}}
    <tr>
        <td>{{addOne @index}}</td>
        <td>{{item_code}}</td>
        <td>{{item_name}}</td>
        <td>{{quantity}}</td>
        <td>{{unit}}</td>
        <td>{{formatAmount price ../bcdp}}</td>
        <td>{{formatAmount taxable ../bcdp}}</td>
        <td>{{vat_perc}}%</td>
        <td>{{formatAmount vat_amt ../bcdp}}</td>
        <td>{{formatAmount amount ../bcdp}}</td>
    </tr>
    {{/each}}
        </tbody>
    </table>

    {{!-- <!-- Totals --> --}}
    <table class="mt-3">
  <tr>
    <td class="text-end"><b>Total Qty</b></td>
    <td></td>
    <td class="br"><b>Total Before VAT:</b></td>
    <td class="arab bl text-end"><b>ع الكولي قبل الضريب</b></td>
    <td class="text-end">{{formatAmount basicdetails.[0].subtotal bcdp}}</td>
  </tr>
  <tr>
    <td class="text-start bb" colspan="2">{{bcamountinwords}}</td>
    <td class="br"><b>Discount</b></td>
    <td class="arab bl text-end"><b>الخصم</b></td>
    <td class="text-end">{{formatAmount basicdetails.[0].discount bcdp}}</td>
  </tr>
  <tr>
    <td class="text-end bt" colspan="2" rowspan="2">{{bcamountinwordsar}}</td>
    <td class="br"><b>VAT</b></td>
    <td class="arab bl text-end"><b>القيمة ضريبة</b></td>
    <td class="text-end">{{formatAmount basicdetails.[0].vatamt bcdp}}</td>
  </tr>
  <tr>
    <td class="br"><b>Net Amount</b></td>
    <td class="arab bl text-end"><b>المبلغ الأجملي</b></td>
    <td class="text-end">{{formatAmount basicdetails.[0].grand_total bcdp}}</td>
  </tr>
  <tr>
    <td colspan="5" class="text-center">
      <b>RECEIVER <span class="arab">المستلم</span></b><br/><br/><br/>
      <span>----------------------------</span>
    </td>
  </tr>
</table>


</div>
</div>

</body>
</html>