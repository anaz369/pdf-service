<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Purchase Order - {{basicdetails.[0].inv_no}}</title>

<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: #ffffff;
    font-family: ibmplexsansarabic;
    font-size: 11px;
    color: #222;
    line-height: 1.45;
    margin: 0 8mm;
  }

  .page { width: 100%; margin: 0 auto; padding-top: 6px; }

  /* ── Title ─────────────────────────────────── */
  .main-title {
    text-align: center;
    padding: 4px 0 5px;
    color: #1f3a6b;
  }
  .main-title .ar {
    display: block;
    direction: rtl;
    font-size: 16px;
    font-weight: bold;
    margin-bottom: 2px;
  }
  .main-title .en {
    display: block;
    font-size: 16px;
    font-weight: bold;
  }

  /* ── Order info table ───────────────────────── */
  .order-info-table {
    width:50%;
    border-collapse:collapse;
    table-layout:fixed;
    margin-bottom:2px;
}

.order-info-table-full {
    width:100%;
    border-collapse:collapse;
    table-layout:fixed;
}

.order-info-table td,
.order-info-table-full td {
    border:1px solid #bfbfbf;
    padding:4px 8px;
    font-size:10px;
}

.oi-lbl {
    width:50%;
    background:#cccccc;
}

.oi-val {
    width:50%;
}
  /* ── Seller / Buyer table ──────────────────── */
  .sb-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
    margin-top: 3px;
  }
  .sb-table td {
    border: 1px solid #bfbfbf;
    padding: 4px 5px;
    font-size: 10px;
    vertical-align: middle;
  }
  .sb-table .sb-lbl {
    background: #cccccc;
  }
  .sb-table .sb-ar  {
    direction: rtl;
    text-align: right;
  }
  .sb-table .sb-spacer {border: none;  }
  .sb-table .sb-header td {
    font-weight: bold;
  }

  /* ── Items table ──────────────────────────── */
  .items-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
    border: 1px solid #bfbfbf;
    margin-top: 3px;
  }
  .items-table th,
  .items-table td {
    border: 1px solid #bfbfbf;
    font-size: 10px;
    vertical-align: middle;
  }
  .items-table thead th {
    background: #cccccc;
    text-align: center;
    padding: 4px 5px;
     font-size: 10px;
    font-weight: normal;
  }
  .items-table td {
    padding: 2px 4px;
  }
  .items-table .head-en { display: block; font-weight: bold; }
  .items-table .head-ar { display: block; direction: rtl; }
  .items-table .center { text-align: center; }
  .items-table .right  { text-align: right; }
  .items-table .left   { text-align: left; }
  .items-table .vat-cell { text-align: right; }
  .items-table .vat-perc { font-size: 10px; color: #444; }

  /* ── Totals + Thanks ──────────────────────── */
  .bottom-wrap {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
    margin-top: 3px;
  }
  .bottom-wrap > tbody > tr > td {
    padding: 0;
    vertical-align: top;
    font-size: 10px;
  }
  .thanks-cell {
    padding: 5px;
    font-size: 13px;
  }
  .totals-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
  }
  .totals-table td {
    border: 1px solid #bfbfbf;
    padding: 2px 5px;
    font-size: 11px;
  }
  .totals-table .t-en {
    width: 40%;
    text-align: left;
  }
  .totals-table .t-ar {
    width: 35%;
    direction: rtl;
    text-align: right;
  }
  .totals-table .t-val {
    width: 25%;
    text-align: right;
  }
</style>
</head>
<body>

<div class="page">

  <!-- Title -->
  <div class="main-title">
    <span class="ar"> أمر شراء</span>
    <span class="en">PURCHASE ORDER</span>
  </div>



<table style="width:100%; border-collapse:collapse;">
  <tr>
    <td style="width:49.5%; vertical-align:top;">
        <table class="order-info-table-full">
            <tr>
            <td class="oi-lbl">Order Number<br><span class="ar-lbl">رقم الطلب</span></td>
            <td class="oi-val">{{basicdetails.[0].inv_no}}</td>
            </tr>
        </table>
    </td>
    <td style="width:1%; border:none;"></td>

    <td style="width:49.5%; vertical-align:top;">

      <table class="order-info-table-full">
            <tr>
            <td class="oi-lbl">Order Issue Date<br><span class="ar-lbl">تاريخ إصدار الطلب</span></td>
            <td class="oi-val">{{basicdetails.[0].inv_date}}</td>
            </tr>
      </table>

    </td>
  </tr>
</table>




  <!-- Seller / Buyer -->
  <table class="sb-table">
    <colgroup>
      <col style="width:13%">
      <col style="width:28%">
      <col style="width:10%">
      <col style="width:1%">
      <col style="width:13%">
      <col style="width:28%">
      <col style="width:10%">
    </colgroup>
    <tr class="sb-header">
      <td style="background: #cccccc;">Seller</td>
      <td></td>
      <td class="sb-ar">البائع</td>
      <td class="sb-spacer"></td>
      <td style="background: #cccccc;">Buyer</td>
      <td></td>
      <td class="sb-ar">المشتري</td>
    </tr>
    <tr>
      <td class="sb-lbl">Name</td>
      <td class="sb-val">{{billing_address.[0].name}}</td>
      <td class="sb-ar">الاسم</td>
      <td class="sb-spacer"></td>
      <td class="sb-lbl">Name</td>
      <td class="sb-val">{{branch.[0].name}}</td>
      <td class="sb-ar">الاسم</td>
    </tr>
    <tr>
      <td class="sb-lbl">Building No</td>
      <td class="sb-val">{{billing_address.[0].address_line1}}</td>
      <td class="sb-ar">رقم المبنى</td>
      <td class="sb-spacer"></td>
      <td class="sb-lbl">Building No</td>
      <td class="sb-val">{{branch.[0].address_line1}}</td>
      <td class="sb-ar">رقم المبنى</td>
    </tr>
    <tr>
      <td class="sb-lbl">Street Name</td>
      <td class="sb-val">{{billing_address.[0].address_line2}}</td>
      <td class="sb-ar">اسم الشارع</td>
      <td class="sb-spacer"></td>
      <td class="sb-lbl">Street Name</td>
      <td class="sb-val">{{branch.[0].address_line2}}</td>
      <td class="sb-ar">اسم الشارع</td>
    </tr>
    <tr>
      <td class="sb-lbl">District</td>
      <td class="sb-val">{{billing_address.[0].address_line4}}</td>
      <td class="sb-ar">الحي</td>
      <td class="sb-spacer"></td>
      <td class="sb-lbl">District</td>
      <td class="sb-val">{{branch.[0].address_line4}}</td>
      <td class="sb-ar">الحي</td>
    </tr>
    <tr>
      <td class="sb-lbl">City</td>
      <td class="sb-val">{{billing_address.[0].address_line3}}</td>
      <td class="sb-ar">المدينة</td>
      <td class="sb-spacer"></td>
      <td class="sb-lbl">City</td>
      <td class="sb-val">{{branch.[0].address_line3}}</td>
      <td class="sb-ar">المدينة</td>
    </tr>
    <tr>
      <td class="sb-lbl">Country</td>
      <td class="sb-val">{{billing_address.[0].address_line5}}</td>
      <td class="sb-ar">الدولة</td>
      <td class="sb-spacer"></td>
      <td class="sb-lbl">Country</td>
      <td class="sb-val">{{branch.[0].address_line5}}</td>
      <td class="sb-ar">الدولة</td>
    </tr>
    <tr>
      <td class="sb-lbl">Postal Code</td>
      <td class="sb-val">{{billing_address.[0].address_code}}</td>
      <td class="sb-ar">الرمز البريدي</td>
      <td class="sb-spacer"></td>
      <td class="sb-lbl">Postal Code</td>
      <td class="sb-val">{{branch.[0].address_code}}</td>
      <td class="sb-ar">الرمز البريدي</td>
    </tr>
    <tr>
      <td class="sb-lbl">{{tax_label}}</td>
      <td class="sb-val">{{vendor_details.[0].VAT_number}}</td>
      <td class="sb-ar">{{tax_label_ar}}</td>
      <td class="sb-spacer"></td>
      <td class="sb-lbl">{{tax_label}}</td>
      <td class="sb-val">{{branch.[0].vat}}</td>
      <td class="sb-ar">{{tax_label_ar}}</td>
    </tr>
    <tr>
      <td class="sb-lbl">CR Number</td>
      <td class="sb-val">{{vendor_details.[0].cr_no}}</td>
      <td class="sb-ar">الرمز البريدي</td>
      <td class="sb-spacer"></td>
      <td class="sb-lbl">CR Number</td>
      <td class="sb-val">{{branch.[0].cr_no}}</td>
      <td class="sb-ar">الرمز البريدي</td>
    </tr>
  </table>

  <!-- Items Table -->
  <table class="items-table">
    <colgroup>
        <col style="width:4%">
        <col style="width:28%">
        <col style="width:10%">
        <col style="width:7%">
        <col style="width:7%">
        <col style="width:13%">
        <col style="width:9%">
        <col style="width:10%">
        <col style="width:12%">
    </colgroup>
    <thead>
      <tr>
        <th>#</th>
        <th>
          <span class="head-en">Description</span>
          <span class="head-ar">الوصف</span>
        </th>
        <th>
          <span class="head-en">Rate</span>
          <span class="head-ar">معدل</span>
        </th>
        <th>
          <span class="head-en">Qty</span>
          <span class="head-ar">الكمية</span>
        </th>
          <th>
            <span class="head-en">Discount</span>
            <span class="head-ar">الخصم</span>
          </th>
        <th>
          <span class="head-en">Taxable Amount</span>
          <span class="head-ar"> المبلغ</span>
        </th>
        <th>
          <span class="head-en">
            {{#if (eq basicdetails.[0].base_country_isocode "AED")}}
            Tax Rate
            {{else}}
            {{#if (eq basicdetails.[0].base_country_isocode "SAR")}}
              Vat Rate
            {{else}}
              Tax Rate
            {{/if}}
          {{/if}}</span>
          <span class="head-ar">مبلغ الضريبة</span>
        </th>
        <th>
          <span class="head-en">
            {{#if (eq basicdetails.[0].base_country_isocode "AED")}}
            Vat Amount
            {{else}}
            {{#if (eq basicdetails.[0].base_country_isocode "SAR")}}
              Vat Amount
            {{else}}
              Tax Amount
            {{/if}}
          {{/if}}</span>
          <span class="head-ar">مبلغ الضريبة</span>
        </th>
        <th>
          <span class="head-en">Item Subtotal</span>
          <span class="head-ar">المجموع</span>
        </th>
      </tr>
    </thead>
    <tbody>
      {{#each itemdetails}}
      <tr>
        <td class="center">{{addOne @index}}</td>
        <td class="left">
          {{#if name_lang2}}<div>{{name_lang2}}</div>{{/if}}
          {{#if description}}<div>{{description}}</div>{{/if}}
        </td>
        <td class="center"><span style="font-size:14px;">{{currencySymbol ../basicdetails.[0].base_country_isocode}}</span>{{formatAmount price ../bcdp}}</td>
        <td class="center">{{formatAmount quantity ../bcdp}}</td>
        <td class="right"><span style="font-size:14px;">{{currencySymbol ../basicdetails.[0].base_country_isocode}}</span>{{formatAmount disc_amt ../bcdp}}</td>
        <td class="right"><span style="font-size:14px;">{{currencySymbol ../basicdetails.[0].base_country_isocode}}</span>{{formatAmount taxable ../bcdp}}</td>
        <td class="center">{{vat_perc}}%</td>
        <td class="right"><span style="font-size:14px;">{{currencySymbol ../basicdetails.[0].base_country_isocode}}</span>{{formatAmount tax ../bcdp}}</td>
        <td class="right"><span style="font-size:14px;">{{currencySymbol ../basicdetails.[0].base_country_isocode}}</span>{{formatAmount amount ../bcdp}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>

  <!-- Totals + Thanks -->
  <table class="bottom-wrap">
    <tr>
      <td style="width:45%; vertical-align:top; padding-right:6px;">
        <table style="width:100%; border-collapse:collapse; table-layout:fixed;">
          <tr>
            <td style="border:1px solid #bfbfbf; border-right:none; padding:4px 6px; font-size:10px; font-weight:bold;">Terms And Conditions</td>
            <td style="border:1px solid #bfbfbf; border-left:none; padding:4px 6px; font-size:10px; font-weight:bold; direction:rtl; text-align:right;">الأحكام والشروط</td>
          </tr>
          <tr>
            <td colspan="2" style="border:1px solid #bfbfbf; border-top:none; padding:4px 6px; font-size:10px; height:60px; vertical-align:top;">{{#if basicdetails.[0].terms_and_condition}}{{{nl2br basicdetails.[0].terms_and_condition}}}{{/if}}</td>
          </tr>
        </table>
      </td>
      <td style="width:55%;">
        <table class="totals-table">
          <tr>
            <td class="t-en">Subtotal</td>
            <td class="t-ar">المجموع الفرعي</td>
            <td class="t-val"><span style="font-size:14px;">{{currencySymbol basicdetails.[0].base_country_isocode}}</span>{{formatAmount (divide basicdetails.[0].subtotal ccrate) bcdp}}</td>
          </tr>
          {{!-- {{#if (gt basicdetails.[0].discount 0)}} --}}
            <tr>
            <td class="t-en">Total Discount</td>
            <td class="t-ar">مجموع الخصومات</td>
            <td class="t-val"><span style="font-size:14px;">{{currencySymbol basicdetails.[0].base_country_isocode}}</span>{{formatAmount (divide basicdetails.[0].discount ccrate) bcdp}}</td>
          </tr>
          {{!-- {{/if}} --}}
          <tr>
            <td class="t-en">Total Taxable Amount</td>
            <td class="t-ar">إجمالي المبلغ الخاضع للضريبة</td>
            <td class="t-val"><span style="font-size:14px;">{{currencySymbol basicdetails.[0].base_country_isocode}}</span>{{formatAmount (divide (subtract basicdetails.[0].subtotal basicdetails.[0].discount) ccrate) bcdp}}</td>
          </tr>
          <tr>
            <td class="t-en">
              {{#if (eq basicdetails.[0].base_country_isocode "AED")}}Total VAT
              {{else}}{{#if (eq basicdetails.[0].base_country_isocode "SAR")}}Total VAT
              {{else}}Total TAX{{/if}}{{/if}}
            </td>
            <td class="t-ar">  
              {{#if (eq basicdetails.[0].base_country_isocode "AED")}}ضريبة القيمة المضافة
              {{else}}{{#if (eq basicdetails.[0].base_country_isocode "SAR")}}ضريبة القيمة المضافة
              {{else}}قيمة الضريبة{{/if}}{{/if}}
            </td>
            <td class="t-val"><span style="font-size:14px;">{{currencySymbol basicdetails.[0].base_country_isocode}}</span>{{formatAmount (divide basicdetails.[0].vatamt ccrate) bcdp}}</td>
          </tr>
          <tr>
            <td class="t-en">Total Amount</td>
            <td class="t-ar">إجمالي المبلغ</td>
            <td class="t-val"><span style="font-size:14px;">{{currencySymbol basicdetails.[0].base_country_isocode}}</span>{{formatAmount (divide basicdetails.[0].grand_total ccrate) bcdp}}</td>
          </tr>
          <tr>
            <td class="t-en">Paid</td>
            <td class="t-ar">مدفوع</td>
            <td class="t-val"><span style="font-size:14px;">{{currencySymbol basicdetails.[0].base_country_isocode}}</span>{{formatAmount (divide basicdetails.[0].received ccrate) bcdp}}</td>
          </tr>
          <tr>
            <td class="t-en">Balance</td>
            <td class="t-ar">الرصيد</td>
            <td class="t-val"><span style="font-size:14px;">{{currencySymbol basicdetails.[0].base_country_isocode}}</span>{{formatAmount (divide basicdetails.[0].balance ccrate) bcdp}}</td>
          </tr>
        </table>
      </td>
    </tr>
  </table>

</div>

</body>
</html>
