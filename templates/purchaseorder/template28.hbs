<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <title></title>
  <style>
    body {
      font-family: Arial, sans-serif;
      font-size: 11px;
      color: #000;
      background: #fff;
    }

    .page {
      margin: 0 auto;
      padding: 15px 25px;
    }

    /* ── Title ──────────────────────────────────── */
    .title {
      text-align: center;
      font-size: 18px;
      font-weight: bold;
      margin-bottom: 10px;
    }

    /* ── Top info bar ──────────────────────────── */
    .top-bar {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 8px;
    }
    .top-bar td {
      border: 1px solid #000;
      padding: 4px 6px;
      font-size: 11px;
    }
    .top-bar .lbl {
      font-weight: bold;
    }

    /* ── Section title ─────────────────────────── */
    .section-title {
      font-size: 11px;
      font-weight: bold;
      margin-bottom: 2px;
    }

    /* ── Vendor info ───────────────────────────── */
    .vendor-box {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 8px;
    }
    .vendor-box td {
      border: 1px solid #000;
      padding: 3px 6px;
      font-size: 11px;
    }
    .vendor-box .v-lbl {
      font-weight: bold;
      width: 80px;
    }

    /* ── Items table ───────────────────────────── */
    .items-table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 0;
    }
    .items-table th {
      background: #fff;
      font-size: 10px;
      font-weight: bold;
      padding: 4px 4px;
      text-align: center;
      border: 1px solid #000;
    }
    .items-table td {
      padding: 3px 4px;
      font-size: 10px;
      border: 1px solid #000;
      text-align: center;
      vertical-align: middle;
    }
    .items-table td.td-left { text-align: left; }
    .items-table td.td-right { text-align: right; }

    /* ── Tax breakup ───────────────────────────── */
    .tax-table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 0;
    }
    .tax-table th {
      font-size: 10px;
      font-weight: bold;
      padding: 4px 4px;
      text-align: center;
      border: 1px solid #000;
    }
    .tax-table td {
      padding: 3px 4px;
      font-size: 10px;
      border: 1px solid #000;
      text-align: center;
    }

    /* ── Totals ─────────────────────────────────── */
    .totals-table {
      width: 100%;
      border-collapse: collapse;
    }
    .totals-table td {
      padding: 3px 6px;
      font-size: 10px;
      border: 1px solid #000;
    }
    .totals-table .t-lbl {
      text-align: right;
      font-weight: bold;
    }
    .totals-table .t-val {
      text-align: right;
      width: 120px;
    }

    /* ── Amount in words ───────────────────────── */
    .amount-words {
      font-size: 11px;
      font-weight: bold;
      margin-top: 8px;
      margin-bottom: 8px;
    }

    /* ── Terms ──────────────────────────────────── */
    .terms-title {
      font-size: 11px;
      font-weight: bold;
      margin-bottom: 2px;
    }
    .terms-text {
      font-size: 10px;
      line-height: 1.6;
    }

    /* ── Footer ─────────────────────────────────── */
    .footer-wrap {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      margin-top: 15px;
    }
    .auth-sig {
      text-align: right;
      font-size: 11px;
    }
  </style>
</head>
<body>
<div class="page">

  {{!-- ══ TITLE ══ --}}
  <div class="title">PURCHASE ORDER</div>

  {{!-- ══ TOP INFO BAR ══ --}}
  <table class="top-bar">
    <tr>
      <td><span class="lbl">Reference No :</span> {{basicdetails.[0].inv_no}}</td>
      <td><span class="lbl">PO Date:</span> {{basicdetails.[0].inv_date}}</td>
      <td><span class="lbl">Due Date:</span> {{basicdetails.[0].due_date}}</td>
      <td><span class="lbl">Vendor Code:</span> {{vendor_details.[0].profile_code}}</td>
    </tr>
  </table>

  {{!-- ══ VENDOR INFORMATION ══ --}}
  <div class="section-title">Vendor Information</div>
  <table class="vendor-box">
    <tr>
      <td class="v-lbl">Vendor:</td>
      <td colspan="3">{{vendor_details.[0].name}}</td>
    </tr>
    <tr>
      <td class="v-lbl">Address:</td>
      <td colspan="3">{{#if billing_address.[0]}}{{joinAddress billing_address.[0]}}{{/if}}</td>
    </tr>
    <tr>
      <td class="v-lbl">Attention:</td>
      <td colspan="3">{{#if vendor_details.[0].contact_no1}}{{vendor_details.[0].contact_no1}}{{/if}}</td>
    </tr>
  </table>

  {{!-- ══ ORDER SUMMARY ══ --}}
  <div class="section-title">Order Summary</div>
  <table class="items-table">
    <thead>
      <tr>
        <th style="width:6%;">HSN</th>
        <th style="width:26%;">Product Title / Description</th>
        <th style="width:8%;">Quantity</th>
        <th style="width:7%;">Unit</th>
        <th style="width:11%;">Rate ({{{currencySymbol basicdetails.[0].isocode}}})</th>
        <th style="width:8%;">IGST %</th>
        <th style="width:8%;">CGST %</th>
        <th style="width:8%;">SGST %</th>
        <th style="width:8%;">CEST %</th>
        <th style="width:10%;">Total ({{{currencySymbol basicdetails.[0].isocode}}})</th>
      </tr>
    </thead>
    <tbody>
      {{#each itemdetails}}
      <tr>
        <td>{{#if hsn}}{{hsn}}{{/if}}</td>
        <td class="td-left">{{item_name}}{{#if description}}<br><span style="font-size:9px; color:#555;">{{description}}</span>{{/if}}</td>
        <td>{{formatAmount quantity ../bcdp}}</td>
        <td>{{unit}}</td>
        <td class="td-right">{{formatAmount price ../bcdp}}</td>
        <td>{{igst_perc}}</td>
        <td>{{cgst_perc}}</td>
        <td>{{sgst_perc}}</td>
        <td>{{cess_perc}}</td>
        <td class="td-right">{{formatAmount amount ../bcdp}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>

  {{!-- ══ TAX BREAKUP & TOTAL ══ --}}
  <div class="section-title" style="margin-top: 8px;">Tax Breakup & Total</div>
  <table class="tax-table">
    <thead>
      <tr>
        <th>Integrated GST (IGST) Amount</th>
        <th>Central GST (CGST) Amount</th>
        <th>State GST (SGST) Amount</th>
        <th>CESS Amount</th>
        <th>Total Tax Amount</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>{{formatAmount basicdetails.[0].igst bcdp}}</td>
        <td>{{formatAmount basicdetails.[0].cgst bcdp}}</td>
        <td>{{formatAmount basicdetails.[0].sgst bcdp}}</td>
        <td>{{formatAmount basicdetails.[0].cess bcdp}}</td>
        <td>{{formatAmount basicdetails.[0].vatamt bcdp}}</td>
      </tr>
    </tbody>
  </table>

  {{!-- ══ TOTAL PAYABLE ══ --}}
  <table class="totals-table" style="margin-top: 8px;">
    <tr>
      <td rowspan="3" style="text-align:center; font-weight:bold; vertical-align:middle; width:50%;">Total Payable</td>
      <td class="t-lbl">Total Taxable Value</td>
      <td class="t-val">{{formatAmount basicdetails.[0].subtotal bcdp}}</td>
    </tr>
    <tr>
      <td class="t-lbl">Total Tax Amount</td>
      <td class="t-val">{{formatAmount basicdetails.[0].vatamt bcdp}}</td>
    </tr>
    <tr>
      <td class="t-lbl" style="font-weight:bold;">GRAND TOTAL</td>
      <td class="t-val" style="font-weight:bold;">{{formatAmount basicdetails.[0].grand_total bcdp}}</td>
    </tr>
  </table>

  {{!-- ══ AMOUNT IN WORDS ══ --}}
  {{#if bcamountinwords}}
  <div class="amount-words">Amount in Words: {{bcamountinwords}}</div>
  {{/if}}

  {{!-- ══ TERMS & CONDITIONS ══ --}}
  <div class="terms-title">Terms & Conditions:</div>
  {{#if invterms}}
  <div class="terms-text">{{{nl2br invterms}}}</div>
  {{else}}
  <div class="terms-text">
    1. All goods must be accompanied by a delivery challan.<br>
    2. Price includes standard packing.<br>
    3. Warranty as per vendor standard.
  </div>
  {{/if}}

  {{!-- ══ FOOTER ══ --}}
  <div class="footer-wrap">
    <div></div>
    <div class="auth-sig">
      {{#if Signature}}
      <img src="{{Signature}}" alt="Signature" style="max-height:50px; max-width:100px; display:block; margin:0 0 5px auto;" onerror="this.style.display='none'"/>
      {{/if}}
      {{#if Seal}}
      <img src="{{Seal}}" alt="Seal" style="max-height:50px; max-width:100px; display:block; margin:0 0 5px auto;" onerror="this.style.display='none'"/>
      {{/if}}
      <div style="font-weight:bold;">Authorized Signatory</div>
      <div>[cite: Stamp]</div>
    </div>
  </div>

</div>
</body>
</html>
