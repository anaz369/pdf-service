<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Quotation - {{basicdetails.[0].inv_no}}</title>

<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: #ffffff;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 11px;
    color: #222;
    line-height: 1.4;
    margin: 0 6mm;
  }

  .page { width: 100%; margin: 0 auto; }

  /* ── Title ─────────────────────────────────── */
  .main-title {
    text-align: center;
    font-size: 20px;
    font-weight: normal;
    color: #c0392b;
    margin: 6px 0 12px;
    font-style: italic;
    font-weight: bold;
  }
  .main-title .ar {
    direction: rtl;
    unicode-bidi: embed;
    margin-right: 2px;
  }

  /* ── Header Info Table ─────────────────────── */
  .info-table {
    width: 60%;
    border-collapse: collapse;
    table-layout: fixed;
    border: 1px solid #bfbfbf;
  }
  .info-table td {
    border: 1px solid #bfbfbf;
    padding: 6px 8px;
    vertical-align: top;
    font-size: 11px;
  }
  .info-table .lbl {
    background: #c5c5c5;
    border-bottom:1px solid #c0c0c0;
    border-top:1px solid #c0c0c0;
    width: 23%;
  }

  /* ── Items table ───────────────────────────── */
  .items-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
    border: 1px solid #bfbfbf;
    margin-top: 8px;
  }
  .items-table th, .items-table td {
    border: 1px solid #bfbfbf;
    padding: 6px 6px;
    font-size: 11px;
    vertical-align: middle;
  }
  .items-table th {
    background: #c5c5c5;
    text-align: center;
    font-weight: normal;
  }
  .items-table th .ar {
    display: block;
    direction: rtl;
    font-weight: normal;
    margin-bottom: 2px;
  }
  .items-table th .en {
    display: block;
    font-weight: bold;
  }
  .items-table .center { text-align: center; }
  .items-table .right  { text-align: right; }
  .items-table .left   { text-align: left; }

  /* ── Totals rows (full row inside items-table) ── */
  .tot-row td {
    padding: 3px 3px;
    font-size: 11px;
    font-weight: bold;
  }
  .tot-row .t-lbl {
    text-align: right;
  }
  .tot-row .t-val {
    text-align: right;
  }
  .tot-row .ar { direction: rtl; unicode-bidi: embed; }

  /* ── Amount in Words box ───────────────────── */
  .aiw {
    border: 1px solid #bfbfbf;
    padding: 6px 8px;
    margin-top: 10px;
    font-size: 11px;
  }

  /* ── Terms + Bank section ──────────────────── */
  .tb-row {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
    margin-top: 10px;
  }
  .tb-row > tbody > tr > td {
    border: 1px solid #bfbfbf;
    padding: 6px 6px;
    vertical-align: top;
    font-size: 11px;
  }
  .tc-title {
    text-decoration: underline;
    font-weight: bold;
    margin-bottom: 6px;
  }
  .tc-body { white-space: pre-wrap; }

  .bank-title {
    font-weight: bold;
    margin-bottom: 6px;
  }
  .bank-list { width: 100%; border-collapse: collapse; }
  .bank-list td {
    padding: 2px 0;
    border: none;
    font-size: 11px;
    vertical-align: top;
  }
  .bank-list .k {
    width: 35%;
    white-space: nowrap;
  }

  /* ── Footer note ───────────────────────────── */
  .footer-note {
    border: 1px solid #bfbfbf;
    border-top: none;
    padding: 6px 6px;
    font-size: 11px;
  }
    .ryl { font-family: Arial, sans-serif;font-size: 16px;}

  /* ── Stamp ─────────────────────────────────── */
  .stamp-area {
    margin-top: 12px;
  }
  .stamp-area img {
    max-height: 140px;
    object-fit: contain;
  }

  /* ── Sig/Seal stack ────────────────────────── */
  .sig-stack { display: block; }
  .sig-stack img {
    display: block;
    object-fit: contain;
  }
  .sig-stack .sign-img {
    max-height: 80px;
    max-width: 180px;
    margin-bottom: 6px;
  }
  .sig-stack .seal-img {
    max-height: 100px;
    max-width: 180px;
    align-items: right;
  }
</style>
</head>
<body>

<div class="page">

  <!-- Title -->
  <div class="main-title">Quotation/<span class="ar">عرض السعر</span></div>

  <!-- Header Info -->
  <table class="info-table">
    <tr>
      <td class="lbl" style="border-bottom:1px solid #c0c0c0;">Date</td>
      <td style="border: 1px solid #bfbfbf;">{{basicdetails.[0].inv_date}}</td>
    </tr>
    <tr>
      <td class="lbl" style=" border-top:1px solid #c0c0c0; border-bottom:1px solid #c0c0c0;">To</td>
      <td style="border: 1px solid #bfbfbf;">
        <div>{{billing_address.[0].name}}</div>
        {{#if billing_address.[0].address_line1}}<div>{{billing_address.[0].address_line1}}</div>{{/if}}
        {{#if billing_address.[0].address_line2}}<div>{{billing_address.[0].address_line2}}</div>{{/if}}
        {{#if billing_address.[0].address_line3}}<div>{{billing_address.[0].address_line3}}</div>{{/if}}
        {{#if billing_address.[0].address_line4}}<div>{{billing_address.[0].address_line4}}</div>{{/if}}
      </td>
    </tr>
    <tr>
      <td class="lbl" style=" border-top:1px solid #c0c0c0; border-bottom:1px solid #c0c0c0;">VAT</td>
      <td style="border: 1px solid #bfbfbf;">{{billing_address.[0].vat}}</td>
    </tr>
    <tr>
      <td class="lbl" style=" border-top:1px solid #c0c0c0;">Quotation No</td>
      <td style="border: 1px solid #bfbfbf;">{{basicdetails.[0].inv_no}}</td>
    </tr>
    <tr>
      <td class="lbl" style=" border-top:1px solid #c0c0c0;">RFQ No</td>
      <td style="border: 1px solid #bfbfbf;">{{basicdetails.[0].rfq}}</td>
    </tr>
  </table>

  <!-- Items Table -->
  <table class="items-table">
    <colgroup>
      <col style="width:5%">
      <col style="width:14%">
      <col style="width:32%">
      <col style="width:10%">
      <col style="width:9%">
      <col style="width:15%">
      <col style="width:15%">
    </colgroup>
    <thead>
      <tr>
        <th><span class="ar">م</span><span class="en">S.N</span></th>
        <th><span class="ar">رمز الصنف</span><span class="en">Item Code</span></th>
        <th><span class="ar">الوصف</span><span class="en">Description</span></th>
        <th><span class="ar">نوع الوحدة</span><span class="en">UOM</span></th>
        <th><span class="ar">الكمية</span><span class="en">QTY</span></th>
        <th><span class="ar">سعر الصافي</span><span class="en">U.Price</span></th>
        <th><span class="ar">القيمة الاجمالي</span><span class="en">Total Price</span></th>
      </tr>
    </thead>
    <tbody>
      {{#each itemdetails}}
      <tr>
        <td class="center">{{addOne @index}}</td>
        <td class="left">{{item_code}}</td>
        <td class="left">
          {{item_name}}
          {{#if name_lang2}}<div style="direction:rtl;">{{name_lang2}}</div>{{/if}}
          {{#if description}}<div style="direction:rtl;">{{description}}</div>{{/if}}
        </td>
        <td class="center">{{unit}}</td>
        <td class="center">{{formatAmount quantity ../bcdp}}</td>
        <td class="right">{{formatAmount price ../bcdp}}</td>
        <td class="right">{{formatAmount vat_amt ../bcdp}}</td>
      </tr>
      {{/each}}
      <tr class="tot-row">
        <td colspan="6" class="t-lbl">Net Amount</td>
        <td class="t-val"><span class="ryl">{{currencySymbol basicdetails.[0].base_country_isocode}}</span>{{formatAmount (divide basicdetails.[0].subtotal ccrate) bcdp}}</td>
      </tr>
      <tr class="tot-row">
        <td colspan="6" class="t-lbl">Discount</td>
        <td class="t-val"><span class="ryl">{{currencySymbol basicdetails.[0].base_country_isocode}}</span>{{formatAmount (divide basicdetails.[0].discount ccrate) bcdp}}</td>
      </tr>
      <tr class="tot-row">
        <td colspan="6" class="t-lbl">After Discount</td>
        <td class="t-val"><span class="ryl">{{currencySymbol basicdetails.[0].base_country_isocode}}</span>{{formatAmount (divide (subtract basicdetails.[0].subtotal basicdetails.[0].discount) ccrate) bcdp}}</td>
      </tr>
      <tr class="tot-row">
        <td colspan="6" class="t-lbl">VAT</td>
        <td class="t-val"><span class="ryl">{{currencySymbol basicdetails.[0].base_country_isocode}}</span>{{formatAmount (divide basicdetails.[0].vatamt ccrate) bcdp}}{{formatAmount basicdetails.[0].vatamt 2}}</td>
      </tr>
      <tr class="tot-row">
        <td colspan="6" class="t-lbl">Total Amount in VAT {{basicdetails.[0].base_country_isocode}}</td>
        <td class="t-val"><span class="ryl">{{currencySymbol basicdetails.[0].base_country_isocode}}</span>{{formatAmount (divide basicdetails.[0].grand_total ccrate) bcdp}}</td>
      </tr>
      <tr class="tot-row">
        <td colspan="7" class="t-lbl" style="text-align: left;font-weight:normal;">{{nl2br basicdetails.[0].terms_and_condition}}</td>
      </tr>
    </tbody>
  </table>

  <!-- Terms + Bank Details -->
  <table class="tb-row">
    <colgroup>
      <col style="width:50%">
      <col style="width:50%">
    </colgroup>
    <tr>
      <td>
        <div class="sig-stack">
          {{#if Signature}}
          <img class="sign-img" src="{{Signature}}" alt="Signature" style="max-height:{{default datasettings.d458 '80'}}px; max-width:{{default datasettings.d458 '180'}}px;" onerror="this.style.display='none'"/>
          {{/if}}
          {{#if Seal}}
          <img class="seal-img" src="{{Seal}}" alt="Seal" style="max-height:{{default datasettings.d459 '100'}}px; max-width:{{default datasettings.d459 '180'}}px;" onerror="this.style.display='none'"/>
          {{/if}}
        </div>
      </td>
      <td>
        <div class="bank-title">Bank Details</div>
        <table class="bank-list">
          <tr>
            <td class="k">Bank Name</td>
            <td>: {{bankdetails.bank_name}}</td>
          </tr>
          <tr>
            <td class="k">A/c Name</td>
            <td>: {{bankdetails.acc_name}}</td>
          </tr>
          <tr>
            <td class="k">A/c No</td>
            <td>: {{bankdetails.account_no}}</td>
          </tr>
          <tr>
            <td class="k">IBAN</td>
            <td>: {{bankdetails.iban_no}}</td>
          </tr>
          <tr>
            <td class="k">SWIFT</td>
            <td>: {{bankdetails.swift_no}}</td>
          </tr>
        </table>
      </td>
    </tr>
  </table>


</div>

</body>
</html>
