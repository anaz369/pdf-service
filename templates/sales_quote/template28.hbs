<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sales Quotation - {{basicdetails.[0].inv_no}}</title>

<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: #ffffff;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 12px;
    color: #222;
    line-height: 1.5;
    margin: 0 8mm;
  }

  .page { width: 100%; margin: 0 auto; padding-top: 4px; }

  /* ── Title ─────────────────────────────────── */
  .main-title {
    text-align: center;
    font-size: 14px;
    font-weight: bold;
    color: #5fa1c4;
    padding: 8px 0 10px;
    border-bottom: 1px solid #ddd;
    margin-bottom: 14px;
  }

  /* ── Header (Quoted To + Refs) ─────────────── */
  .header-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 14px;
  }
  .header-table td {
    vertical-align: top;
    padding: 2px 0;
    font-size: 12px;
  }
  .header-table .left-col { width: 50%; padding-right: 14px; }
  .header-table .right-col { width: 50%; }

  .quoted-to-label { margin-bottom: 6px; }
  .quoted-to-addr { line-height: 1.55; }

  .refs-table { width: 100%; border-collapse: collapse; }
  .refs-table td {
    padding: 2px 0;
    font-size: 12px;
    vertical-align: top;
  }
  .refs-table .r-lbl { width: 42%; }
  .refs-table .r-sep { width: 4%; }
  .refs-table .r-val { width: 54%; }

  /* ── Items table ───────────────────────────── */
  .items-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
    border: 1px solid #000;
    margin-top: 6px;
  }
  .items-table th,
  .items-table td {
    border: 1px solid #000;
    padding: 6px 5px;
    font-size: 12px;
    vertical-align: top;
  }
  .items-table th {
    text-align: center;
    font-weight: normal;
    background: #ffffff;
  }
  .items-table .center { text-align: center; }
  .items-table .right  { text-align: right; }
  .items-table .left   { text-align: left; }

  .totals-lbl {
    text-align: right;
    color: #e02424;
  }
  .totals-val {
    text-align: right;
    color: #e02424;
  }

  /* ── Total budgetory line (red) ────────────── */
  .budgetory-line {
    color: #e02424;
    font-weight: bold;
    margin: 18px 0 12px;
    text-transform: uppercase;
  }

  /* ── Payment terms ─────────────────────────── */
  .terms-block { margin-top: 10px; }
  .terms-label {
    text-decoration: underline;
    display: inline;
  }
  .terms-value {
    display: inline;
    margin-left: 4px;
  }

  /* ── Terms & Conditions ────────────────────── */
  .tc-block { margin-top: 16px; }

  /* ── Bank Account Details ──────────────────── */
  .bank-wrap { margin-top: 16px; }
  .bank-title {
    text-decoration: underline;
    margin-bottom: 4px;
  }
  .bank-table { border-collapse: collapse; }
  .bank-table td {
    padding: 1px 0;
    font-size: 12px;
    vertical-align: top;
  }
  .bank-table .bk-lbl { width: 140px; }
  .bank-table .bk-sep { width: 14px; }

  /* ── Footer / Sign off ─────────────────────── */
  .footer-note {
    margin-top: 22px;
    font-size: 12px;
    line-height: 1.55;
  }
  .sign-off {
    margin-top: 22px;
    font-size: 12px;
  }
  .sign-off .company { font-weight: bold; }
</style>
</head>
<body>

<div class="page">

  <!-- Title -->
  <div class="main-title">SALES QUOTATION</div>

  <!-- Header: Quoted To + Refs -->
  <table class="header-table">
    <tr>
      <td class="left-col">
        <table style="width:100%;">
          <tr>
            <td style="width:30%;">QUOTED TO</td>
            <td style="width:4%;">:</td>
            <td style="width:66%;"></td>
          </tr>
        </table>
        <div class="quoted-to-addr" style="margin-top:6px;">
          <div>{{billing_address.[0].name}}</div>
          {{#if billing_address.[0].address_line1}}<div>{{billing_address.[0].address_line1}}{{#if billing_address.[0].address_line2}}{{billing_address.[0].address_line2}}{{/if}}</div>{{/if}}
          {{#if billing_address.[0].address_line3}}<div>{{billing_address.[0].address_line3}}{{#if billing_address.[0].address_line4}}{{billing_address.[0].address_line4}}{{/if}}{{#if billing_address.[0].address_line5}}{{billing_address.[0].address_line5}}{{/if}}</div>{{/if}}
          {{#if billing_address.[0].address_code}}<div>{{billing_address.[0].address_code}}</div>{{/if}}
        </div>
      </td>
      <td class="right-col">
        <table class="refs-table">
          <tr>
            <td class="r-lbl">OUR QUOTATION REF</td>
            <td class="r-sep">:</td>
            <td class="r-val">{{basicdetails.[0].inv_no}}</td>
          </tr>
          <tr>
            <td class="r-lbl">ENQUIRY REF</td>
            <td class="r-sep">:</td>
            <td class="r-val">{{basicdetails.[0].order_no}}</td>
          </tr>
          <tr>
            <td class="r-lbl">DATE</td>
            <td class="r-sep">:</td>
            <td class="r-val">{{basicdetails.[0].inv_date}}</td>
          </tr>
          <tr>
            <td class="r-lbl">PERSON</td>
            <td class="r-sep">:</td>
            <td class="r-val">{{basicdetails.[0].employeename}}</td>
          </tr>
          <tr>
            <td class="r-lbl">CONTACT</td>
            <td class="r-sep">:</td>
            <td class="r-val">{{basicdetails.[0].employeecontactno}}</td>
          </tr>
          <tr>
            <td class="r-lbl">EMAIL</td>
            <td class="r-sep">:</td>
            <td class="r-val">{{compprof.email}}</td>
          </tr>
        </table>
      </td>
    </tr>
  </table>

  <!-- Items Table -->
  <table class="items-table">
    <colgroup>
      <col style="width:6%">
      <col style="width:33%">
      <col style="width:10%">
      <col style="width:7%">
      <col style="width:7%">
      <col style="width:12%">
      <col style="width:12%">
      <col style="width:13%">
    </colgroup>
    <thead>
      <tr>
        <th>S.No</th>
        <th>DESCRIPTION</th>
        <th>CODE</th>
        <th>UNIT</th>
        <th>QTY</th>
        <th>UNIT PRICE</th>
        <th>DISCOUNT %</th>
        <th>TOTAL PRICE</th>
      </tr>
    </thead>
    <tbody>
      {{#each itemdetails}}
      <tr>
        <td class="center">{{addOne @index}}</td>
        <td class="left">
          {{item_name}}
          {{#if name_lang2}}<div style="direction:rtl;">{{name_lang2}}</div>{{/if}}
          {{#if description}}<div>{{description}}</div>{{/if}}
        </td>
        <td class="center">{{item_code}}</td>
        <td class="center">{{unit}}</td>
        <td class="center">{{formatAmount quantity ../bcdp}}</td>
        <td class="right">{{formatAmount price ../bcdp}}</td>
        <td class="right">{{formatAmount disc_amt ../bcdp}}</td>
        <td class="right">{{formatAmount amount ../bcdp}}</td>
      </tr>
      {{/each}}
      <tr>
        <td colspan="7" class="totals-lbl">TOTAL DISCOUNT</td>
        <td class="totals-val">{{formatAmount (divide basicdetails.[0].discount ccrate) bcdp}}</td>
      </tr>
      <tr>
        <td colspan="7" class="totals-lbl">TOTAL PRICE IN {{basicdetails.[0].base_country_isocode}}</td>
        <td class="totals-val">{{formatAmount (divide basicdetails.[0].grand_total ccrate) bcdp}}</td>
      </tr>
    </tbody>
  </table>

  <!-- Total Budgetory line -->
  {{#if bcamountinwords}}
  <div class="budgetory-line">TOTAL BUDGETORY QUOTATION: {{bcamountinwords}}</div>
  {{/if}}

  <!-- Payment terms -->
  {{#if basicdetails.[0].payment_terms}}
  <div class="terms-block">
    <span class="terms-label">PAYMENT TERMS:</span>
    <span class="terms-value">{{basicdetails.[0].payment_terms}}</span>
  </div>
  {{/if}}

  <!-- Terms and conditions -->
  <div class="tc-block">
    <div class="tc-title" style="text-decoration: underline;">TERMS AND CONDITIONS</div>
    <div class="tc-text">{{#if basicdetails.[0].terms_and_condition}}{{{nl2br basicdetails.[0].terms_and_condition}}}{{else}}{{#if invterms}}{{{nl2br invterms}}}{{/if}}{{/if}}</div>
  </div>

  <!-- Bank Account Details -->
  <div class="bank-wrap">
    <div class="bank-title">Bank Account Details:</div>
    <table class="bank-table">
      {{#if bankdetails.acc_name}}
      <tr>
        <td class="bk-lbl">A/C NAME</td>
        <td class="bk-sep">:</td>
        <td>{{bankdetails.acc_name}}</td>
      </tr>
      {{/if}}
      {{#if bankdetails.acc_no}}
      <tr>
        <td class="bk-lbl">EEFC USD A/C</td>
        <td class="bk-sep">:</td>
        <td>{{bankdetails.acc_no}}</td>
      </tr>
      {{/if}}
      {{#if bankdetails.swift_no}}
      <tr>
        <td class="bk-lbl">SWIFT CODE</td>
        <td class="bk-sep">:</td>
        <td>{{bankdetails.swift_no}}</td>
      </tr>
      {{/if}}
    </table>
  </div>

  <!-- Footer note -->
  <div class="footer-note">
    Should you require any additional information, please do not hesitate to contact our Operational Unit. We require a Purchase Order to start the following project, and mobilization time of 24 hours needs to be provided.
  </div>

  <!-- Sign off -->
  <div class="sign-off">
    Sincerely Yours,.<br>
    <span class="company">{{#if compprof.name}}{{compprof.name}}{{else}}{{basicdetails.[0].branchname}}{{/if}}</span>
  </div>

</div>

</body>
</html>
