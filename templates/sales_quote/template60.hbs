<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>QUOTATION - {{basicdetails.[0].inv_no}}</title>

<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: #ffffff;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 11px;
    color: #222;
    line-height: 1.45;
    margin: 0 8mm;
  }

  .page { width: 100%; margin: 0 auto; padding-top: 6px; }

  /* ── Title ─────────────────────────────────── */
  .main-title {
    text-align: center;
    font-family: 'Times New Roman', Times, serif;
    font-size: 26px;
    font-weight: bold;
    color: #1f3a6b;
    padding: 4px 0 16px;
    letter-spacing: 1px;
  }

  /* ── Outer doc table ───────────────────────── */
  .doc-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
    border: 1px solid #000;
  }
  .doc-table > tbody > tr > td {
    border: 1px solid #000;
    padding: 0;
    vertical-align: top;
    font-size: 11px;
  }

  /* ── Top header row ────────────────────────── */
  .top-head {
    text-align: center;
    padding: 10px;
    border-bottom: 1px solid #000;
    font-size: 12px;
  }

  .ref-head-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
  }
  .ref-head-table td {
    padding: 6px 8px;
    font-size: 11px;
    text-align: center;
  }
  .ref-head-table .v-sep { border-right: 1px solid #000; }
  .ref-head-table .ref-hdr { font-weight: normal; }
  .ref-head-table .ref-val { font-weight: bold; }

  /* ── Address / quotation block ─────────────── */
  .addr-cell {
    padding: 10px;
    vertical-align: top;
    min-height: 130px;
  }
  .addr-line { line-height: 1.55; }

  .qno-cell {
    padding: 14px 10px 8px;
    text-align: center;
    vertical-align: middle;
    font-size: 12px;
  }
  .qno-val { font-weight: bold; font-size: 13px; }

  /* Contact info under QUOTATION NO */
  .qno-contact { padding: 4px 10px 12px; }
  .qno-contact-table {
    width: 100%;
    border-collapse: collapse;
  }
  .qno-contact-table td {
    padding: 2px 0;
    font-size: 11px;
    vertical-align: top;
  }
  .qno-contact-table .qc-lbl { width: 35%; font-weight: bold; }
  .qno-contact-table .qc-sep { width: 4%; text-align: center; }
  .qno-contact-table .qc-val { width: 61%; }

  /* ── Items table ───────────────────────────── */
  .items-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
  }
  .items-table th,
  .items-table td {
    font-size: 11px;
    vertical-align: middle;
    padding: 8px 6px;
    border: 1px solid #ccc;
  }
  .items-table thead th {
    text-align: center;
    font-weight: bold;
    background: #0d1676;
    color: #ffffff;
    border: 1px solid #1f3a6b;
  }
  .items-table .center { text-align: center; }
  .items-table .right  { text-align: right; }
  .items-table .left   { text-align: left; }

  /* ── Remark row ────────────────────────────── */
  .remark-cell { padding: 6px 10px; font-size: 11px; }

  /* ── Bottom combined section ───────────────── */
  .bottom-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
  }
  .bottom-table > tbody > tr > td {
    padding: 0;
    vertical-align: top;
    font-size: 11px;
  }

  .words-block { padding: 8px 10px; }
  .words-label { }
  .words-value { font-weight: bold; margin-top: 2px; }
  .banking-title {
    margin-top: 10px;
    font-weight: bold;
    text-decoration: underline;
  }

  .bank-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 6px;
  }
  .bank-table td {
    border: 1px solid #ccc;
    padding: 6px 8px;
    font-size: 11px;
  }
  .bank-table .bank-lbl { width: 40%; }

  .totals-table {
    width: 100%;
    border-collapse: collapse;
  }
  .totals-table td {
    padding: 8px 10px;
    font-size: 11px;
     border-bottom: 1px solid #ccc;
  }
  .totals-table tr:last-child td { border-bottom: none; }
  .totals-table .t-lbl { text-align: right; border-right: 1px solid #ccc; }
  .totals-table .t-val { text-align: right; width: 35%; }
  .totals-table .total-row td { font-weight: bold; }

  .signoff-cell {
    padding: 8px 10px;
    text-align: right;
  }
  .signoff-cell .sign-imgs {
    margin-top: 14px;
    text-align: center;
    line-height: 1.4;
  }
  .sig-img  { display: inline-block; vertical-align: middle; }
  .seal-img { display: inline-block; vertical-align: middle; margin-left: 60px; }

  /* ── Terms & Condition + Signature area ────── */
  .tc-block {
    padding: 8px 10px 6px;
  }
  .tc-title { font-size: 13px; }
  .tc-text {
    margin-top: 4px;
    padding-bottom: 6px;
    border-bottom: 1px solid #bfbfbf;
  }
  .tc-sign-area {
    position: relative;
    padding: 2px;
  }
  .tc-sign-imgs {
    text-align: right;
    margin-top: 6px;
  }
  .tc-for {
    position: absolute;
    left: 10px;
    bottom: 8px;
    font-size: 12px;
  }
</style>
</head>
<body>

<div class="page">

  <!-- Title -->
  <div class="main-title">QUOTATION</div>

  <!-- Document -->
  <table class="doc-table">
    <!-- Top row: To+address | Our Reference | Customer Reference | Date -->
    <tr>
      <td style="width:45%; padding:0;" rowspan="1">
        <div class="addr-cell">
          <div class="addr-line"><strong>To,</strong> {{billing_address.[0].name}}</div>
          <div style="height:10px;"></div>
          {{#if billing_address.[0].address_line1}}<div class="addr-line">{{billing_address.[0].address_line1}}</div>{{/if}}
          {{#if billing_address.[0].address_line2}}<div class="addr-line">{{billing_address.[0].address_line2}}</div>{{/if}}
          {{#if billing_address.[0].address_line3}}<div class="addr-line">{{billing_address.[0].address_line3}}</div>{{/if}}
          {{#if billing_address.[0].address_line4}}<div class="addr-line">{{billing_address.[0].address_line4}}</div>{{/if}}
          {{#if billing_address.[0].address_line5}}<div class="addr-line">{{billing_address.[0].address_line5}}</div>{{/if}}
          {{#if billing_address.[0].address_code}}<div class="addr-line">{{billing_address.[0].address_code}}</div>{{/if}}
          {{#if billing_address.[0].vat}}<div class="addr-line">VAT: {{billing_address.[0].vat}}</div>{{/if}}
          <div class="addr-line">Contact Number:{{#if basicdetails.[0].contactno}} {{basicdetails.[0].contactno}}{{/if}}</div>
        </div>
      </td>
      <td style="width:20%; padding:10px; text-align:center; vertical-align:top;">
        <div style="font-weight:bold;">Our Reference</div>
        <div style="margin-top:42px;">{{basicdetails.[0].reference_no}}</div>
      </td>
      <td style="width:20%; padding:10px; text-align:center; vertical-align:top;">
        <div style="font-weight:bold;">Quotation No</div>
        <div style="margin-top:42px;">{{basicdetails.[0].inv_no}}</div>
      </td>
      <td style="width:15%; padding:10px; text-align:center; vertical-align:top;">
        <div style="font-weight:bold;">Date</div>
        <div style="margin-top:42px;">{{basicdetails.[0].inv_date}}</div>
      </td>
    </tr>

    <!-- Attention row -->
    <tr>
      <td colspan="4" style="padding:6px 10px;">Attention :{{#if basicdetails.[0].attention}} {{basicdetails.[0].attention}}{{/if}}</td>
    </tr>

    <!-- Dear Sir / Intro -->
    <tr>
      <td colspan="4" style="padding:6px 10px; line-height:1.6;">
        <div>Dear Sir,</div>
        <div>Thank you for your inquiry. In response to your request, we are pleased to offer our best prices for the following works.</div>
      </td>
    </tr>

    {{!-- Old Quotation No + contact block (kept hidden so the rest of the template still references qno-contact-table without errors) --}}
    {{#if false}}
    <tr>
      <td style="padding:0;">
        <div class="qno-cell">
          QUOTATION NO :<span class="qno-val">{{basicdetails.[0].inv_no}}</span>
        </div>
        <div class="qno-contact">
          <table class="qno-contact-table">
            {{#if basicdetails.[0].contactname}}
            <tr>
              <td class="qc-lbl">Contact Name</td>
              <td class="qc-sep">:</td>
              <td class="qc-val">{{basicdetails.[0].contactname}}</td>
            </tr>
            {{/if}}
            {{#if basicdetails.[0].contactno}}
            <tr>
              <td class="qc-lbl">Contact No</td>
              <td class="qc-sep">:</td>
              <td class="qc-val">{{basicdetails.[0].contactno}}</td>
            </tr>
            {{/if}}
            {{#if basicdetails.[0].contactemail}}
            <tr>
              <td class="qc-lbl">Email</td>
              <td class="qc-sep">:</td>
              <td class="qc-val">{{basicdetails.[0].contactemail}}</td>
            </tr>
            {{/if}}
            {{#if basicdetails.[0].employeedesignation}}
            <tr>
              <td class="qc-lbl">Position</td>
              <td class="qc-sep">:</td>
              <td class="qc-val">{{basicdetails.[0].employeedesignation}}</td>
            </tr>
            {{/if}}
            {{#if billing_address.[0].vat}}
            <tr>
              <td class="qc-lbl">VAT</td>
              <td class="qc-sep">:</td>
              <td class="qc-val">{{billing_address.[0].vat}}</td>
            </tr>
            {{/if}}
          </table>
        </div>
      </td>
    </tr>
    {{/if}}

    <!-- Items -->
    <tr>
      <td colspan="4" style="padding:0; border-top:1px solid #000;">
        <table class="items-table">
          <colgroup>
            <col style="width:5%">
            <col style="width:43%">
            <col style="width:8%">
            <col style="width:8%">
            <col style="width:13%">
            <col style="width:11%">
            <col style="width:12%">
          </colgroup>
          <thead>
            <tr>
              <th>#</th>
              <th>DESCRIPTION</th>
              <th>QTY</th>
              <th>UNIT</th>
              <th>UNIT PRICE</th>
              <th>TAX</th>
              <th>TOTAL</th>
            </tr>
          </thead>
          <tbody>
            {{#each itemdetails}}
            <tr>
              <td class="center">{{addOne @index}}</td>
              <td class="left">
                {{item_name}}
                {{#if name_lang2}}<div>{{name_lang2}}</div>{{/if}}
                {{#if description}}<div>{{description}}</div>{{/if}}
              </td>
              <td class="center">{{formatAmount quantity ../bcdp}}</td>
              <td class="center">{{unit}}</td>
              <td class="right"><span style="font-size:14px;">{{currencySymbol ../basicdetails.[0].base_country_isocode}}</span>{{formatAmount price ../bcdp}}</td>
              <td class="right"><span style="font-size:14px;">{{currencySymbol ../basicdetails.[0].base_country_isocode}}</span>{{formatAmount vat_amt ../bcdp}}</td>
              <td class="right"><span style="font-size:14px;">{{currencySymbol ../basicdetails.[0].base_country_isocode}}</span>{{formatAmount amount ../bcdp}}</td>
            </tr>
            {{/each}}
          </tbody>
        </table>
      </td>
    </tr>

    <!-- Remark row -->

    <!-- Words + Bank + Totals -->
    <tr>
      <td colspan="4" style="padding:0;">
        <table class="bottom-table">
          <tr>
            <td style="width:50%; padding:0; vertical-align:top; border:none;">
              <div class="words-block">
                <div class="words-label">Amount chargable in words:</div>
                <div class="words-value">{{bcamountinwords}}</div>
                <div class="banking-title"></div>
                
              </div>
            </td>
            <td style="width:50%; padding:0; vertical-align:top;">
              <table class="totals-table">
                <tr>
                  <td class="t-lbl">SubTotal (Excluding VAT)</td>
                  <td class="t-val"><span style="font-size:14px;">{{currencySymbol basicdetails.[0].base_country_isocode}}</span>{{formatAmount (divide basicdetails.[0].subtotal ccrate) bcdp}}</td>
                </tr>
                <tr>
                  <td class="t-lbl">VAT {{#if itemdetails.[0].vat_perc}}{{itemdetails.[0].vat_perc}}%{{/if}}</td>
                  <td class="t-val"><span style="font-size:14px;">{{currencySymbol basicdetails.[0].base_country_isocode}}</span>{{formatAmount (divide basicdetails.[0].vatamt ccrate) bcdp}}</td>
                </tr>
                <tr>
                  <td class="t-lbl">Discount</td>
                  <td class="t-val"><span style="font-size:14px;">{{currencySymbol basicdetails.[0].base_country_isocode}}</span>{{formatAmount (divide basicdetails.[0].discount ccrate) bcdp}}</td>
                </tr>
                <tr class="total-row" style="border-bottom: 1px dashed #ccc;">
                  <td class="t-lbl">Total Amount in{{basicdetails.[0].base_country_isocode}}</td>
                  <td class="t-val">{{formatAmount (divide basicdetails.[0].grand_total ccrate) bcdp}}</td>
                </tr>
              </table>
            </td>
          </tr>
        </table>
      </td>
    </tr>

    <!-- Terms & Conditions + Signature block -->
    <tr style="border-top:1px solid #bfbfbf;border-bottom:#bfbfbf;">
      <td colspan="4" style="padding:0; ">
        <div class="tc-block">
          <div class="tc-title">Terms &amp; Condition</div>
          <div class="tc-text">{{#if basicdetails.[0].terms_and_condition}}{{{nl2br basicdetails.[0].terms_and_condition}}}{{else}}{{#if invterms}}{{{nl2br invterms}}}{{/if}}{{/if}}</div>
        </div>
        <div class="tc-sign-area">
          <div class="tc-sign-imgs">
            {{#if Signature}}<img src="{{Signature}}" alt="Signature" style="max-height:{{default datasettings.d458 '120'}}px; max-width:{{default datasettings.d458 '180'}}px;" onerror="this.style.display='none'"/>{{/if}}
          </div>
          <div class="tc-for">For {{#if compprof.name}}{{compprof.name}}{{else}}{{basicdetails.[0].branchname}}{{/if}}</div>
        </div>
      </td>
    </tr>

  </table>

</div>

</body>
</html>
