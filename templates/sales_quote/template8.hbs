<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>QUOTATION - {{basicdetails.[0].inv_no}}</title>

<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: #ffffff;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 11px;
    color: #222;
    line-height: 1.45;
    margin: 0 8mm;
  }

  .page { width: 100%; margin: 0 auto; padding-top: 6px; }

  /* ── Title ─────────────────────────────────── */
  .main-title {
    text-align: center;
    font-family: 'Times New Roman', Times, serif;
    font-size: 22px;
    font-weight: bold;
    color: #1f3a6b;
    padding: 4px 0 12px;
  }

  /* ── Outer doc table ───────────────────────── */
  .doc-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
    border: 1px solid #000;
  }
  .doc-table > tbody > tr > td {
    border: 1px solid #000;
    padding: 0;
    vertical-align: top;
    font-size: 11px;
  }

  /* ── Top heading row ───────────────────────── */
  .top-head {
    text-align: center;
    font-weight: bold;
    padding: 8px 10px;
    border-bottom: 1px solid #000;
    font-size: 12px;
  }
  .ref-head-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
  }
  .ref-head-table th,
  .ref-head-table td {
    padding: 6px 8px;
    text-align: center;
    font-size: 11px;
  }
  .ref-head-table .ref-hdr { font-weight: normal; }
  .ref-head-table .ref-val { font-weight: bold; }
  .ref-head-table .v-sep { border-right: 1px solid #000; }
  .ref-head-row { border-bottom: 1px solid #000; }

  /* ── Address cells ─────────────────────────── */
  .addr-cell {
    padding: 8px 10px;
    vertical-align: top;
    min-height: 150px;
  }
  .addr-line { line-height: 1.55; }

  /* ── Subject ───────────────────────────────── */
  .subject-cell {
    padding: 4px 10px;
    font-size: 11px;
    border-top: 1px solid #000;
  }

  /* ── Items table ───────────────────────────── */
  .items-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
  }
  .items-table th,
  .items-table td {
    font-size: 11px;
    vertical-align: middle;
    padding: 6px 8px;
    border: 1px solid #ccc;
  }
  .items-table th {
    text-align: center;
    font-weight: bold;
    background: #ffffff;
  }
  .items-table .center { text-align: center; }
  .items-table .right  { text-align: right; }
  .items-table .left   { text-align: left; }

  /* ── Terms row ─────────────────────────────── */
  .terms-cell { padding: 6px 10px; }
  .terms-title { font-weight: bold; }

  /* ── Bank + Totals ─────────────────────────── */
  .bank-totals-wrap {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
  }
  .bank-totals-wrap > tbody > tr > td {
    padding: 0;
    vertical-align: top;
    border: 1px solid #000;
    font-size: 11px;
  }

  .words-cell { padding: 6px 10px; }
  .words-label { font-weight: bold; }

  .bank-table {
    width: 100%;
    border-collapse: collapse;
  }
  .bank-table th,
  .bank-table td {
    border: 1px solid #000;
    padding: 6px 8px;
    font-size: 11px;
    text-align: center;
  }
  .bank-table .bank-header td {
    font-weight: bold;
    text-align: center;
  }
  .bank-table .bank-lbl { font-weight: bold; }

  .totals-table {
    width: 100%;
    border-collapse: collapse;
  }
  .totals-table td {
    padding: 6px 10px;
    font-size: 11px;
    border-bottom: 1px solid #000;
  }
  .totals-table tr:last-child td { border-bottom: none; }
  .totals-table .t-lbl { text-align: right; border-right: 1px solid #000; }
  .totals-table .t-val { text-align: right; width: 35%; }
  .totals-table .total-row td { font-weight: bold; }

  /* ── Combined bank + totals table ──────────── */
  .combined-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
  }
  .combined-table > tbody > tr > td {
    border: 1px solid #000;
    padding: 6px 8px;
    font-size: 11px;
    vertical-align: middle;
  }
  .combined-table .words-cell {
    text-align: left;
    vertical-align: top;
    padding: 8px 10px;
  }
  .combined-table .words-label { font-weight: bold; }
  .combined-table .bank-header-cell {
    text-align: center;
    font-weight: bold;
  }
  .combined-table .bank-lbl { text-align: left; }
  .combined-table .bank-val { text-align: left; }
  .combined-table .t-lbl { text-align: right; }
  .combined-table .t-val { text-align: right; }
  .combined-table .total-row { font-weight: bold; }

  /* ── Sign-off ──────────────────────────────── */
  .signoff-cell {
    padding: 8px 10px 18px;
    text-align: right;
    line-height: 1.6;
    min-height: 130px;
    position: relative;
  }
  .signoff-cell .sign-imgs {
    margin-top: 10px;
    text-align: center;
  }
  .sig-img { max-height: 80px; max-width: 160px; display: inline-block; vertical-align: middle; }
  .seal-img { max-height: 90px; max-width: 110px; display: inline-block; vertical-align: middle; margin-left: 30px; }
</style>
</head>
<body>

<div class="page">

  <!-- Title -->
  <div class="main-title">QUOTATION</div>

  <!-- Document -->
  <table class="doc-table">
    <!-- Header bar: company name | reference + date -->
    <tr class="ref-head-row">
      <td style="width:35%; padding:10px;">{{billing_address.[0].name}}
      </td>
      <td style="width:65%; padding:0;">
        <table class="ref-head-table">
          <tr>
            <th class="v-sep ref-hdr">Reference No<br><span class="ref-val">{{basicdetails.[0].inv_no}}</span></th>
            <th class="ref-hdr">Date<br><span class="ref-val">{{basicdetails.[0].inv_date}}</span></th>
          </tr>
        </table>
      </td>
    </tr>

    <!-- Addresses row -->
    <tr>
      <td style="width:35%; padding:0;">
        <div class="addr-cell">
   
        </div>
      </td>
      <td style="width:65%; padding:0;">
        <div class="addr-cell">
          {{#if billing_address.[0].name}}<div class="addr-line">{{billing_address.[0].name}}</div>{{/if}}
          {{#if billing_address.[0].address_line1}}<div class="addr-line">{{billing_address.[0].address_line1}}</div>{{/if}}
          {{#if billing_address.[0].address_line2}}<div class="addr-line">{{billing_address.[0].address_line2}}</div>{{/if}}
          {{#if billing_address.[0].address_line4}}<div class="addr-line">{{billing_address.[0].address_line4}}</div>{{/if}}
          {{#if billing_address.[0].address_line3}}<div class="addr-line">{{billing_address.[0].address_line3}}</div>{{/if}}
          {{#if billing_address.[0].address_line5}}<div class="addr-line">{{billing_address.[0].address_line5}}</div>{{/if}}
          {{#if billing_address.[0].address_code}}<div class="addr-line">{{billing_address.[0].address_code}}</div>{{/if}}
          {{#if shipping_address.[0].vat}}<div class="addr-line">VAT: {{shipping_address.[0].vat}}</div>{{/if}}
          {{#if basicdetails.[0].contactname}}<div class="addr-line">Contact : {{basicdetails.[0].contactname}}</div>{{/if}}
          {{#if basicdetails.[0].contactno}}<div class="addr-line">{{basicdetails.[0].contactno}}</div>{{/if}}
          {{#if basicdetails.[0].contactemail}}<div class="addr-line">Email: {{basicdetails.[0].contactemail}}</div>{{/if}}
        </div>
      </td>
    </tr>

    <!-- Subject -->
    <tr>
      <td colspan="2" style="padding:0;">
        <div class="subject-cell">Subject{{#if basicdetails.[0].subj}} : {{basicdetails.[0].subj}}{{/if}}</div>
      </td>
    </tr>

    <!-- Items -->
    <tr>
      <td colspan="2" style="padding:0;">
        <table class="items-table">
          <colgroup>
            <col style="width:5%">
            <col style="width:26%">
            <col style="width:10%">
            <col style="width:8%">
            <col style="width:13%">
            <col style="width:12%">
            <col style="width:12%">
            <col style="width:14%">
          </colgroup>
          <thead>
            <tr>
              <th>#</th>
              <th>Description</th>
              <th>Quantity</th>
              <th>Unit</th>
              <th>Unit Price</th>
              <th>Tax</th>
              <th>Delivery Time</th>
              <th>Total</th>
            </tr>
          </thead>
          <tbody>
            {{#each itemdetails}}
            <tr>
              <td class="center">{{addOne @index}}</td>
              <td class="left">
                {{item_name}}
                {{#if name_lang2}}<div>{{name_lang2}}</div>{{/if}}
                {{#if description}}<div>{{description}}</div>{{/if}}
              </td>
              <td class="center">{{formatAmount quantity ../bcdp}}</td>
              <td class="center">{{unit}}</td>
              <td class="right"><span style="font-size:16px;">{{currencySymbol ../basicdetails.[0].base_country_isocode}}</span>{{formatAmount price ../bcdp}}</td>
              <td class="right"><span style="font-size:16px;">{{currencySymbol ../basicdetails.[0].base_country_isocode}}</span>{{formatAmount vat_amt ../bcdp}}</td>
              <td class="center"></td>
              <td class="right"><span style="font-size:16px;">{{currencySymbol ../basicdetails.[0].base_country_isocode}}</span>{{formatAmount amount ../bcdp}}</td>
            </tr>
            {{/each}}
          </tbody>
        </table>
      </td>
    </tr>

    <!-- Terms -->
    <tr>
      <td colspan="2">
        <div class="terms-cell">
          <div class="terms-title">Terms and Conditions:</div>
          <div>{{#if basicdetails.[0].terms_and_condition}}{{{nl2br basicdetails.[0].terms_and_condition}}}{{else}}{{#if invterms}}{{{nl2br invterms}}}{{/if}}{{/if}}</div>
        </div>
      </td>
    </tr>

    <!-- Words + Bank Details (left 4 cols) | Totals (right 2 cols) — unified rows -->
    <tr>
      <td colspan="2" style="padding:0;">
        <table class="combined-table">
          <colgroup>
            <col style="width:17%">
            <col style="width:16%">
            <col style="width:16%">
            <col style="width:17%">
            <col style="width:19%">
            <col style="width:15%">
          </colgroup>

          <!-- Row 1: Amount in Words (cols 1-4) | Total Taxable Amount -->
          <tr>
            <td colspan="4" class="words-cell">
              <div><span class="words-label">Amount In Words :</span> {{bcamountinwords}}</div>
              <div style="margin-top:6px;">Cheque should be crossed and made payable to : {{#if compprof.name}}{{compprof.name}}{{else}}{{basicdetails.[0].branchname}}{{/if}}</div>
            </td>
            <td class="t-lbl">Total Taxable Amount (Excluding VAT)</td>
            <td class="t-val"><span style="font-size:16px;">{{currencySymbol basicdetails.[0].base_country_isocode}}</span>{{formatAmount (divide basicdetails.[0].subtotal ccrate) bcdp}}</td>
          </tr>

          <!-- Row 2: BANK DETAILS header (cols 1-4) | Discount -->
          <tr>
            <td colspan="4" class="bank-header-cell">BANK DETAILS</td>
            <td class="t-lbl">Discount</td>
            <td class="t-val"><span style="font-size:16px;">{{currencySymbol basicdetails.[0].base_country_isocode}}</span>{{formatAmount (divide basicdetails.[0].discount ccrate) bcdp}}</td>
          </tr>

          <!-- Row 3 -->
          <tr>
            <td class="bank-lbl">Beneficiary A/C Name</td>
            <td class="bank-val">{{bankdetails.acc_name}}</td>
            <td class="bank-lbl">Beneficiary Bank</td>
            <td class="bank-val">{{bankdetails.name}}</td>
            <td class="t-lbl">After Discount</td>
            <td class="t-val"><span style="font-size:16px;">{{currencySymbol basicdetails.[0].base_country_isocode}}</span>{{formatAmount (subtract (divide basicdetails.[0].subtotal ccrate) (divide basicdetails.[0].discount ccrate)) bcdp}}</td>
          </tr>

          <!-- Row 4 -->
          <tr>
            <td class="bank-lbl">Beneficiary Bank Branch</td>
            <td class="bank-val">{{bankdetails.branch_name}}</td>
            <td class="bank-lbl">{{bankdetails.branch_name}}</td>
            <td class="bank-val">{{bankdetails.acc_no}}</td>
            <td class="t-lbl">VAT</td>
            <td class="t-val"><span style="font-size:16px;">{{currencySymbol basicdetails.[0].base_country_isocode}}</span>{{formatAmount (divide basicdetails.[0].vatamt ccrate) bcdp}}</td>
          </tr>

          <!-- Row 5 -->
          <tr>
            <td class="bank-lbl">Swift Code</td>
            <td class="bank-val">{{bankdetails.swift_no}}</td>
            <td class="bank-lbl">IBAN No</td>
            <td class="bank-val">{{bankdetails.iban_no}}</td>
            <td class="t-lbl total-row">Total Amount</td>
            <td class="t-val total-row"><span style="font-size:16px;">{{currencySymbol basicdetails.[0].base_country_isocode}}</span>{{formatAmount (divide basicdetails.[0].grand_total ccrate) bcdp}}</td>
          </tr>
        </table>
      </td>
    </tr>

    <!-- Sign-off -->
    <tr>
      <td colspan="2" style="border-top:none;">
        <div class="signoff-cell">
          <div>For {{#if compprof.name}}{{compprof.name}}{{else}}{{basicdetails.[0].branchname}}{{/if}}</div>
          <div class="sign-imgs">
            {{#if Signature}}<img class="sig-img" src="{{Signature}}" alt="signature"/>{{/if}}
            {{#if Seal}}<img class="seal-img" src="{{Seal}}" alt="Seal" style="max-height:{{default datasettings.d459 '100'}}px; max-width:{{default datasettings.d459 '180'}}px;" onerror="this.style.display='none'"/>{{/if}}
          </div>
        </div>
      </td>
    </tr>
  </table>

</div>

</body>
</html>
