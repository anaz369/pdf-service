<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>QUOTATION - {{basicdetails.[0].inv_no}}</title>

<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: #ffffff;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 11px;
    color: #222;
    line-height: 1.45;
    margin: 0 8mm;
  }

  .page { width: 100%; margin: 0 auto; padding-top: 6px; }

  /* ── Title ─────────────────────────────────── */
  .main-title {
    text-align: center;
    font-family: 'Times New Roman', Times, serif;
    font-size: 24px;
    font-weight: bold;
    color: #1f3a6b;
    padding: 4px 0 14px;
  }

  /* ── Outer doc table ───────────────────────── */
  .doc-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
    border: 1px solid #000;
  }
  .doc-table > tbody > tr > td {
    border: 1px solid #000;
    padding: 0;
    vertical-align: top;
    font-size: 11px;
  }

  /* ── Top customer info ─────────────────────── */
  .cust-block { padding: 8px 10px; }
  .cust-name { font-weight: bold; }
  .cust-line { line-height: 1.55; }

  /* ── Ref / Date sub-table ──────────────────── */
  .ref-head-table {
    width: 100%;
    height: 100%;
    border-collapse: collapse;
    table-layout: fixed;
  }
  .ref-head-table td {
    padding: 8px 10px;
    font-size: 11px;
    text-align: center;
    vertical-align: middle;
  }
  .ref-head-table .v-sep { border-right: 1px solid #000; }
  .ref-head-table .ref-hdr { font-weight: normal; }
  .ref-head-table .ref-val { font-weight: bold; }

  /* ── Items table ───────────────────────────── */
  .items-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
  }
  .items-table th,
  .items-table td {
    font-size: 11px;
    vertical-align: top;
    padding: 6px 8px;
    border: 1px solid #ccc;
  }
  .items-table thead th {
    text-align: center;
    font-weight: bold;
    background: #ffffff;
    border-top: none;
  }
  .items-table .desc-h { text-align: center; }
  .items-table .center { text-align: center; }
  .items-table .right  { text-align: right; }
  .items-table .left   { text-align: left; }

  /* ── Remark row ────────────────────────────── */
  .remark-cell { padding: 4px 10px; min-height: 24px; }

  /* ── Totals (right aligned full-width rows) ── */
  .totals-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
  }
  .totals-table td {
    padding: 6px 10px;
    font-size: 11px;
    border-top: 1px solid #ccc;
    vertical-align: middle;
  }
  .totals-table .t-lbl {
    text-align: right;
    border-right: 1px solid #ccc;
    width: 70%;
  }
  .totals-table .t-val {
    text-align: right;
    width: 18%;
  }
  .totals-table .total-row td {
    font-weight: bold;
  }

  /* ── Amount in words ───────────────────────── */
  .words-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
  }
  .words-table td {
    padding: 6px 10px;
    font-size: 11px;
    vertical-align: top;
  }
  .words-table .w-lbl {
    font-weight: bold;
    width: 22%;
  }
  .words-table .w-sep {
    width: 2%;
  }
  .words-table .w-val { width: 80%; }

  /* ── Signature block ───────────────────────── */
  .signoff-cell {
    padding: 10px 10px 14px;
    text-align: right;
    line-height: 1.8;
  }
  .sig-img {  display: inline-block; margin: 5px 0; }
  .signoff-cell .auth-sig { margin-top: 20px; }
</style>
</head>
<body>

<div class="page">

  <!-- Title -->
  <div class="main-title">QUOTATION</div>

  <!-- Document -->
  <table class="doc-table">
    <!-- Top header: Customer info | Reference / Doc No | Date -->
    <tr>
      <td style="width:30%; padding:0;">
        <div class="cust-block">
          <div class="cust-name">{{billing_address.[0].name}}</div>
          {{#if billing_address.[0].address_line1}}<div class="cust-line">{{billing_address.[0].address_line1}}</div>{{/if}}
          {{#if billing_address.[0].address_line2}}<div class="cust-line">{{billing_address.[0].address_line2}}</div>{{/if}}
          {{#if billing_address.[0].address_line3}}<div class="cust-line">{{billing_address.[0].address_line3}}</div>{{/if}}
          {{#if billing_address.[0].address_line4}}<div class="cust-line">{{billing_address.[0].address_line4}}</div>{{/if}}
          {{#if billing_address.[0].address_line5}}<div class="cust-line">{{billing_address.[0].address_line5}}</div>{{/if}}
          {{#if billing_address.[0].address_code}}<div class="cust-line">{{billing_address.[0].address_code}}</div>{{/if}}
          {{#if billing_address.[0].vat}}<div class="cust-line">VAT : {{billing_address.[0].vat}}</div>{{/if}}
        </div>
      </td>
      <td style="width:35%; padding:8px 10px; text-align:center; vertical-align:middle;">
        Reference No :{{#if basicdetails.[0].reference_no}} {{basicdetails.[0].reference_no}}{{/if}}<br>
        Doc. No: <span style="font-weight:bold;">{{basicdetails.[0].inv_no}}</span>
      </td>
      <td style="width:35%; padding:8px 10px; text-align:center; vertical-align:middle;">
        Date : <span style="font-weight:bold;">{{basicdetails.[0].inv_date}}</span>
      </td>
    </tr>

    <!-- Items -->
    <tr>
      <td colspan="3" style="padding:0; border-top:1px solid #000;">
        <table class="items-table">
          <colgroup>
            <col style="width:5%">
            <col style="width:34%">
            <col style="width:12%">
            <col style="width:11%">
            <col style="width:12%">
            <col style="width:12%">
            <col style="width:14%">
          </colgroup>
          <thead>
            <tr>
              <th style="border-left:1px solid #000;">#</th>
              <th class="desc-h">Description</th>
              <th>Quantity</th>
              <th>Unit Price</th>
              <th>Amount</th>
              <th>VAT</th>
              <th style="border-right:1px solid #000;">Total Price</th>
            </tr>
          </thead>
          <tbody>
            {{#each itemdetails}}
            <tr>
              <td class="center" style="border-left:1px solid #000;">{{addOne @index}}</td>
              <td class="left">
                {{item_name}}
                {{#if name_lang2}}<div>{{name_lang2}}</div>{{/if}}
                {{#if description}}<div>{{description}}</div>{{/if}}
              </td>
              <td class="center">{{formatAmount quantity ../bcdp}} {{unit}}</td>
              <td class="right">{{formatAmount price ../bcdp}}</td>
              <td class="right">{{formatAmount taxable ../bcdp}}</td>
              <td class="right">{{formatAmount vat_amt ../bcdp}}</td>
              <td class="right" style="border-right:1px solid #000;">{{formatAmount amount ../bcdp}}</td>
            </tr>
            {{/each}}
          </tbody>
        </table>
      </td>
    </tr>

    <!-- Remark row -->
    <tr>
      <td colspan="3">
        <div class="remark-cell">
          {{#if basicdetails.[0].terms_and_condition}}{{{nl2br basicdetails.[0].terms_and_condition}}}{{else}}{{#if invterms}}{{{nl2br invterms}}}{{/if}}{{/if}}
        </div>
      </td>
    </tr>

    <!-- Totals -->
    <tr>
      <td colspan="3" style="padding:0;">
        <table class="totals-table">
          <tr>
            <td class="t-lbl">Gross Total</td>
            <td class="t-val">{{formatAmount (divide basicdetails.[0].subtotal ccrate) bcdp}}</td>
          </tr>
          <tr>
            <td class="t-lbl">Discount</td>
            <td class="t-val">{{formatAmount (divide basicdetails.[0].discount ccrate) bcdp}}</td>
          </tr>
          <tr>
            <td class="t-lbl">Taxable Amount</td>
            <td class="t-val">{{formatAmount (divide (subtract basicdetails.[0].subtotal basicdetails.[0].discount) ccrate) bcdp}}
                
            </td>
          </tr>
          <tr>
            <td class="t-lbl">VAT</td>
            <td class="t-val">{{formatAmount (divide basicdetails.[0].vatamt ccrate) bcdp}}</td>
          </tr>
          <tr class="total-row">
            <td class="t-lbl">Total Amount</td>
            <td class="t-val">{{formatAmount (divide basicdetails.[0].grand_total ccrate) bcdp}}</td>
          </tr>
        </table>
      </td>
    </tr>

    <!-- Amount in words -->
    <tr>
      <td colspan="3" style="padding:0;">
        <table class="words-table">
          <tr>
            <td class="w-lbl">Amount in Words</td>
            <td class="w-sep">:</td>
            <td class="w-val">{{bcamountinwords}}</td>
          </tr>
          <tr>
            <td class="w-lbl">VAT Amount in Words</td>
            <td class="w-sep">:</td>
            <td class="w-val"></td>
          </tr>
        </table>
      </td>
    </tr>

    <!-- Signature block -->
    <tr>
      <td colspan="3">
        <div class="signoff-cell">
          <div>For {{#if compprof.name}}{{compprof.name}}{{else}}{{basicdetails.[0].branchname}}{{/if}}</div>
          {{#if Signature}}<div><img class="sign-img" src="{{Signature}}" alt="Signature" style="max-height:{{default datasettings.d458 '80'}}px; max-width:{{default datasettings.d458 '180'}}px;" onerror="this.style.display='none'"/></div>{{/if}}
          <div class="auth-sig">Authorized Signatory</div>
        </div>
      </td>
    </tr>
  </table>

</div>

</body>
</html>
