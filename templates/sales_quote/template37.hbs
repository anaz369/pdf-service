<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Quotation - {{basicdetails.[0].inv_no}}</title>

<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: #ffffff;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 11px;
    color: #222;
    line-height: 1.4;
    margin: 0 6mm;
  }

  .page { width: 100%; margin: 0 auto; }

  /* ── Title ─────────────────────────────────── */
  .main-title {
    text-align: center;
    font-size: 22px;
    font-weight: bold;
    margin: 10px 0 16px;
  }

  /* ── Header (To/Place + Date/Refs) ─────────── */
  .header-row {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
  }
  .header-row > tbody > tr > td {
    vertical-align: top;
    padding: 0 8px;
    font-size: 11px;
    border: none;
  }

  .to-list {
    width: 100%;
    border-collapse: collapse;
  }
  .to-list td {
    padding: 3px 0;
    vertical-align: top;
    font-size: 11px;
    border: none;
  }
  .to-list .k {
    width: 60px;
    font-weight: bold;
    white-space: nowrap;
    padding-right: 8px;
  }
  .to-list .v { font-weight: bold; }

  .ref-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
  }
  .ref-table td {
    border: none;
    border-bottom: 1px solid #000;
    padding: 4px 4px;
    font-size: 11px;
    vertical-align: middle;
  }
  .ref-table .k {
    width: 35%;
    font-weight: bold;
    white-space: nowrap;
  }

  /* ── Items table ───────────────────────────── */
  .items-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
    border: 1px solid #000;
    margin-top: 14px;
  }
  .items-table th, .items-table td {
    border: 1px solid #000;
    padding: 6px 6px;
    font-size: 11px;
    vertical-align: top;
  }
  .items-table th {
    background: #d9e2f3;
    text-align: left;
    font-weight: bold;
  }
  .items-table .center { text-align: center; }
  .items-table .right  { text-align: right; }
  .items-table .left   { text-align: left; }
  .items-table th.center { text-align: center; }

  /* ── Totals (right-aligned bordered table) ─── */
  .ta-wrap {
    width: 100%;
    display: flex;
    justify-content: flex-end;
    margin-top: 16px;
  }
  .ta-table {
    border-collapse: collapse;
    table-layout: fixed;
    width: 50%;
  }
  .ta-table td {
    border: 1px solid #000;
    padding: 6px 10px;
    font-size: 11px;
    vertical-align: middle;
  }
  .ta-table .t-lbl {
    text-align: right;
    font-weight: bold;
  }
  .ta-table .t-val {
    text-align: right;
    font-weight: bold;
    width: 30%;
  }

  /* ── Terms + closing ───────────────────────── */
  .terms-body {
    margin-top: 14px;
    font-size: 11px;
    white-space: pre-wrap;
  }
  .closing-bold {
    margin-top: 16px;
    font-weight: bold;
    font-size: 11px;
  }
  .for-line {
    margin-top: 12px;
    font-size: 11px;
  }
  .for-line .nm { font-weight: bold; }

  /* ── Bank Details box ──────────────────────── */
  .bank-box {
    margin-top: 18px;
    border: 1px solid #2a8fbd;
    border-radius: 12px;
    padding: 10px 14px;
    width:400px;
    font-size: 11px;
  }
  .bank-title {
    font-weight: bold;
    color: #002060;
    text-decoration: underline;
    margin-bottom: 6px;
  }
  .bank-list {
    width: 100%;
    border-collapse: collapse;
  }
  .bank-list td {
    border: none;
    padding: 2px 0;
    vertical-align: top;
    font-size: 11px;
    color: #002060;
  }
  .bank-list .k {
    width: 90px;
    white-space: normal;
    padding-right: 8px;
  }
  .bank-list .v { color: #002060; }
</style>
</head>
<body>

<div class="page">

  <!-- Title -->
  <div class="main-title">Quotation</div>

  <!-- Header -->
  <table class="header-row">
    <colgroup>
      <col style="width:55%">
      <col style="width:45%">
    </colgroup>
    <tr>
      <td>
        <table class="to-list">
          <tr>
            <td class="k">To:</td>
            <td class="v">{{billing_address.[0].name}}</td>
          </tr>
          <tr>
            <td class="k">Place:</td>
            <td>
              {{billing_address.[0].address_line1}}{{#if billing_address.[0].address_line2}} {{billing_address.[0].address_line2}}{{/if}}
              {{#if billing_address.[0].address_line3}}<div>{{billing_address.[0].address_line3}}{{#if billing_address.[0].address_line4}} {{billing_address.[0].address_line4}}{{/if}}</div>{{/if}}
            </td>
          </tr>
          <tr>
            <td class="k">Tel:</td>
            <td>{{customer_details.[0].contact_no1}}</td>
          </tr>
          <tr>
            <td class="k">Attn:</td>
            <td>{{basicdetails.[0].attention}}</td>
          </tr>
        </table>
      </td>
      <td>
        <table class="ref-table">
          <tr>
            <td class="k">Date:</td>
            <td>{{basicdetails.[0].inv_date}}</td>
          </tr>
          <tr>
            <td class="k">Client Ref:</td>
            <td>{{basicdetails.[0].reference_no}}</td>
          </tr>
          <tr>
            <td class="k">Our Ref:</td>
            <td>{{basicdetails.[0].inv_no}}</td>
          </tr>
        </table>
      </td>
    </tr>
  </table>

  <!-- Items Table -->
  <table class="items-table">
    <colgroup>
      <col style="width:7%">
      <col style="width:11%">
      <col style="width:38%">
      <col style="width:8%">
      <col style="width:18%">
      <col style="width:18%">
    </colgroup>
    <thead>
      <tr>
        <th>Sl.No</th>
        <th>Part Code</th>
        <th class="center">Description</th>
        <th class="center">Qty</th>
        <th class="center">Unit Price</th>
        <th class="center">Total Price</th>
      </tr>
    </thead>
    <tbody>
      {{#each itemdetails}}
      <tr>
        <td class="center">{{addOne @index}}</td>
        <td>{{item_code}}</td>
        <td>
          {{item_name}}
          {{#if name_lang2}}<div style="direction:rtl;">{{name_lang2}}</div>{{/if}}
           {{#if description}}<div style="">{{description}}</div>{{/if}}
        </td>
        <td class="center">{{formatAmount quantity ../bcdp}}</td>
        <td class="right">{{formatAmount price ../bcdp}}</td>
        <td class="right">{{formatAmount amount ../bcdp}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>

  <!-- Totals -->
  <div class="ta-wrap">
    <table class="ta-table">
      <tr>
        <td class="t-lbl">Total Price in {{basicdetails.[0].base_country_isocode}}=========&gt;</td>
        <td class="t-val">{{formatAmount (divide basicdetails.[0].subtotal ccrate) bcdp}}</td>
      </tr>
      <tr>
        <td class="t-lbl">VAT @15%</td>
        <td class="t-val">{{formatAmount (divide basicdetails.[0].vatamt ccrate) bcdp}}</td>
      </tr>
      <tr>
        <td class="t-lbl">Order Amount ({{basicdetails.[0].base_country_isocode}} )</td>
        <td class="t-val">{{formatAmount (divide basicdetails.[0].grand_total ccrate) bcdp}}</td>
      </tr>
    </table>
  </div>

  <!-- Terms -->
  {{#if basicdetails.[0].terms_and_condition}}
  <div class="terms-body">{{nl2br basicdetails.[0].terms_and_condition}}</div>
  {{/if}}

  <!-- Closing -->
  <div class="closing-bold">Trust our offer meets your approval, and we are looking forward to receiving your valued order.</div>
  <div class="for-line">For <span class="nm">{{compprof.name}}</span></div>

  <!-- Bank Details -->
  <div class="bank-box">
    <div class="bank-title">Bank Details</div>
    <table class="bank-list">
      <tr>
        <td class="k">VAT:</td>
        <td class="v">{{compprof.vat}}</td>
      </tr>
      <tr>
        <td class="k">Bank Name:</td>
        <td class="v">{{bankdetails.bank_name}}</td>
      </tr>
      <tr>
        <td class="k">IBAN:</td>
        <td class="v">{{bankdetails.iban_no}}</td>
      </tr>
      <tr>
        <td class="k">Account No:</td>
        <td class="v">{{bankdetails.account_no}}</td>
      </tr>
    </table>
  </div>

</div>

</body>
</html>
