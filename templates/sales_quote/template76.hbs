<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>QUOTATION - {{basicdetails.[0].inv_no}}</title>

<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: #ffffff;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 11px;
    color: #222;
    line-height: 1.45;
    margin: 0 8mm;
  }

  .page { width: 100%; margin: 0 auto; padding-top: 6px; }

  /* ── Title ─────────────────────────────────── */
  .main-title {
    text-align: center;
    font-family: 'Times New Roman', Times, serif;
    font-size: 26px;
    font-weight: bold;
    color: #1f3a6b;
    padding: 4px 0 16px;
    letter-spacing: 1px;
  }

  /* ── Outer doc table ───────────────────────── */
  .doc-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
    border: 1px solid #000;
  }
  .doc-table > tbody > tr > td {
    border: 1px solid #000;
    padding: 0;
    vertical-align: top;
    font-size: 11px;
  }

  /* ── Top header row ────────────────────────── */
  .top-head {
    text-align: center;
    padding: 10px;
    border-bottom: 1px solid #000;
    font-size: 12px;
  }

  .ref-head-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
  }
  .ref-head-table td {
    padding: 6px 8px;
    font-size: 11px;
    text-align: center;
  }
  .ref-head-table .v-sep { border-right: 1px solid #000; }
  .ref-head-table .ref-hdr { font-weight: normal; }
  .ref-head-table .ref-val { font-weight: bold; }

  /* ── Address / quotation block ─────────────── */
  .addr-cell {
    padding: 10px;
    vertical-align: top;
    min-height: 130px;
  }
  .addr-line { line-height: 1.55; }

  .qno-cell {
    padding: 30px 10px;
    text-align: center;
    vertical-align: middle;
    font-size: 12px;
  }
  .qno-val { font-weight: bold; font-size: 13px; }

  /* ── Party header (Customer / Company) ────── */
  .party-cell {
    padding: 0;
    vertical-align: top;
  }
  .party-name {
    text-align: center;
    font-weight: bold;
    padding: 6px 10px;
    border-bottom: 1px solid #ccc;
  }
  .party-doc {
    text-align: center;
    padding: 6px 10px;
  }
  .party-doc .doc-lbl { font-weight: normal; display: block; }
  .party-doc .doc-val { font-weight: bold; display: block; }
  .party-details {
    padding: 8px 12px;
    line-height: 1.65;
  }

  /* ── Items table ───────────────────────────── */
  .items-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
  }
  .items-table th,
  .items-table td {
    font-size: 11px;
    vertical-align: middle;
    padding: 8px 6px;
    border: 1px solid #ccc;
  }
  .items-table thead th {
    text-align: center;
    font-weight: bold;
    background: #0d1676;
    color: #ffffff;
    border: 1px solid #1f3a6b;
  }
  .items-table .center { text-align: center; }
  .items-table .right  { text-align: right; }
  .items-table .left   { text-align: left; }

  /* ── Remark row ────────────────────────────── */
  .remark-cell { padding: 6px 10px; font-size: 11px; }

  /* ── Bottom combined section ───────────────── */
  .bottom-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
  }
  .bottom-table > tbody > tr > td {
    padding: 0;
    vertical-align: top;
    font-size: 11px;
  }

  .words-block { padding: 8px 10px; }
  .words-label { }
  .words-value { font-weight: bold; margin-top: 2px; }
  .banking-title {
    margin-top: 10px;
    font-weight: bold;
    text-decoration: underline;
  }

  .bank-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 6px;
  }
  .bank-table td {
    border: 1px solid #ccc;
    padding: 6px 8px;
    font-size: 11px;
  }
  .bank-table .bank-lbl { width: 40%; }

  .totals-table {
    width: 100%;
    border-collapse: collapse;
  }
  .totals-table td {
    padding: 8px 10px;
    font-size: 11px;
     border-bottom: 1px solid #ccc;
  }
  .totals-table tr:last-child td { border-bottom: none; }
  .totals-table .t-lbl { text-align: right; border-right: 1px solid #ccc; }
  .totals-table .t-val { text-align: right; width: 35%; }
  .totals-table .total-row td { font-weight: bold; }

  .signoff-cell {
    padding: 8px 10px;
    text-align: right;
  }
  .signoff-cell .sign-imgs {
    margin-top: 14px;
    text-align: center;
    line-height: 1.4;
  }
  .sig-img  { max-height: 80px; max-width: 160px; display: inline-block; vertical-align: middle; }
  .seal-img { max-height: 90px; max-width: 110px; display: inline-block; vertical-align: middle; margin-left: 60px; }
</style>
</head>
<body>

<div class="page">

  <!-- Title -->
  <div class="main-title">QUOTATION</div>

  <!-- Document -->
  <table class="doc-table">
    <!-- Top: Customer (left) | Company (right) -->
    <tr>
      <td class="party-cell" style="width:50%;">
        <div class="party-name">{{billing_address.[0].name}}</div>
        <div class="party-doc">
          <span class="doc-lbl">Date</span>
          <span class="doc-val">{{basicdetails.[0].inv_date}}</span>
        </div>
        <div class="party-details">
          <div>Contact Name :{{#if basicdetails.[0].contactname}} {{basicdetails.[0].contactname}}{{/if}}</div>
          <div>Contact Number :{{#if basicdetails.[0].contactno}} {{basicdetails.[0].contactno}}{{/if}}</div>
          <div>Email :{{#if basicdetails.[0].contactemail}} {{basicdetails.[0].contactemail}}{{/if}}</div>
          {{#if billing_address.[0].address_line1}}<div>Place : {{billing_address.[0].address_line1}}</div>{{/if}}
          {{#if billing_address.[0].address_line2}}<div>{{billing_address.[0].address_line2}}</div>{{/if}}
          {{#if billing_address.[0].address_line3}}<div>{{billing_address.[0].address_line3}}</div>{{/if}}
          {{#if billing_address.[0].address_line4}}<div>{{billing_address.[0].address_line4}}</div>{{/if}}
          {{#if billing_address.[0].address_line5}}<div>{{billing_address.[0].address_line5}}</div>{{/if}}
        </div>
      </td>
      <td class="party-cell" style="width:50%;">
        <div class="party-name">{{#if compprof.name}}{{compprof.name}}{{else}}{{basicdetails.[0].branchname}}{{/if}}</div>
        <div class="party-doc">
          <span class="doc-lbl">Quotation No</span>
          <span class="doc-val">{{basicdetails.[0].inv_no}}</span>
        </div>
        <div class="party-details">
          <div>Contact Name :{{#if basicdetails.[0].salesman_name}}{{basicdetails.[0].salesman_name}}{{else}}{{basicdetails.[0].employeename}}{{/if}}</div>
          <div>Contact Number :{{#if basicdetails.[0].salesman_no}} {{basicdetails.[0].salesman_no}}{{else}}{{#if basicdetails.[0].employeecontactno}} {{basicdetails.[0].employeecontactno}}{{/if}}{{/if}}</div>
          <div>Email :{{#if basicdetails.[0].salesman_email}} {{basicdetails.[0].salesman_email}}{{else}}{{#if basicdetails.[0].employeeemail}} {{basicdetails.[0].employeeemail}}{{/if}}{{/if}}</div>
          <div>Position :{{#if basicdetails.[0].employeedesignation}} {{basicdetails.[0].employeedesignation}}{{/if}}</div>
        </div>
      </td>
    </tr>

    {{!-- Old contact block kept hidden so any later partial references stay valid --}}
    {{#if false}}
    <tr>
      <td style="padding:0;">
        <div class="qno-cell">
          QUOTATION NO :<span class="qno-val">{{basicdetails.[0].inv_no}}</span>
        </div>
      </td>
    </tr>
    {{/if}}

    <!-- Items -->
    <tr>
      <td colspan="2" style="padding:0; border-top:1px solid #000;">
        <table class="items-table">
          <colgroup>
            <col style="width:5%">
            <col style="width:12%">
            <col style="width:27%">
            <col style="width:8%">
            <col style="width:13%">
            <col style="width:12%">
            <col style="width:11%">
            <col style="width:12%">
          </colgroup>
          <thead>
            <tr>
              <th>#</th>
              <th>ITEM CODE</th>
              <th>DESCRIPTION</th>
              <th>QTY</th>
              <th>UNIT PRICE</th>
              <th>TAXABLE</th>
              <th>TAX</th>
              <th>TOTAL</th>
            </tr>
          </thead>
          <tbody>
            {{#each itemdetails}}
            <tr>
              <td class="center">{{addOne @index}}</td>
              <td class="left">{{item_code}}</td>
              <td class="left">
                {{item_name}}
                {{#if name_lang2}}<div>{{name_lang2}}</div>{{/if}}
                {{#if description}}<div>{{description}}</div>{{/if}}
              </td>
              <td class="center">{{formatAmount quantity ../bcdp}}</td>
              <td class="right"><span style="font-size:14px;">{{currencySymbol ../basicdetails.[0].base_country_isocode}}</span>{{formatAmount price ../bcdp}}</td>
              <td class="right"><span style="font-size:14px;">{{currencySymbol ../basicdetails.[0].base_country_isocode}}</span>{{formatAmount taxable ../bcdp}}</td>
              <td class="right"><span style="font-size:14px;">{{currencySymbol ../basicdetails.[0].base_country_isocode}}</span>{{formatAmount vat_amt ../bcdp}}</td>
              <td class="right"><span style="font-size:14px;">{{currencySymbol ../basicdetails.[0].base_country_isocode}}</span>{{formatAmount amount ../bcdp}}</td>
            </tr>
            {{/each}}
          </tbody>
        </table>
      </td>
    </tr>

    <!-- Remark row -->
    <tr>
      <td colspan="2">
        <div class="remark-cell">
          {{#if basicdetails.[0].terms_and_condition}}{{{nl2br basicdetails.[0].terms_and_condition}}}{{else}}{{#if invterms}}{{{nl2br invterms}}}{{/if}}{{/if}}
        </div>
      </td>
    </tr>
  </table>

</div>

</body>
</html>
