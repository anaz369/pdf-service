<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Quotation - {{basicdetails.[0].inv_no}}</title>

<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }


  body {
    margin:  0mm 10mm;
    background: #ffffff;
      font-family: "Arial", sans-serif;
    font-size: 11px;
    color: #000;
    line-height: 1.4;
    margin: 0 6mm;
  }

  .page { width: 100%; margin: 0 auto; }

  /* ── Title ─────────────────────────────────── */
  .main-title {
    text-align: center;
    font-size: 20px;
    font-weight: bold;
    margin: 4px 0 12px;
  }
  .main-title .ar {
    font-family: "Arial", sans-serif;
    direction: rtl;
    unicode-bidi: embed;
    margin-left: 4px;
  }

  /* ── Header Info Table ─────────────────────── */
  .info-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
    border: 1px solid #bfbfbf;
  }
  .info-table td {
    border: 1px solid #bfbfbf;
    padding: 6px 8px;
    vertical-align: middle;
    font-size: 11px;
  }
  .info-table .lbl {
    background: #f2f2f2;
    font-weight: bold;
    width: 15%;
  }
  .info-table .val { width: 35%; }

  /* ── Items table ───────────────────────────── */
  .items-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
    border: 1px solid #bfbfbf;
    margin-top: 14px;
  }
  .items-table th, .items-table td {
    border: 1px solid #000;
    padding: 6px 6px;
    font-size: 11px;
    vertical-align: middle;
  }
  .items-table th {
    text-align: center;
    font-weight: bold;
    background: #ffffff;
  }
  .items-table .center { text-align: center; }
  .items-table .right  { text-align: right; }
  .items-table .left   { text-align: left; }

  /* ── Total row ─────────────────────────────── */
  .total-row td {
    border: 1px solid #000;
    padding: 6px 8px;
    font-size: 11px;
    font-weight: bold;
  }
  .total-row .t-label { text-align: right; }
  .total-row .t-value { text-align: right; }

  /* ── Amount in words ───────────────────────── */
  .aiw {
    margin-top: 14px;
    font-size: 11px;
    font-weight: bold;
  }

  /* ── Terms ─────────────────────────────────── */
  .terms-wrap { margin-top: 16px; }
  .terms-title {
    font-weight: bold;
    text-decoration: underline;
    margin-bottom: 4px;
  }
  .terms-body { white-space: pre-wrap; }

  /* ── Footer note ───────────────────────────── */
  .foot-note {
    margin-top: 16px;
    font-size: 11px;
  }
  .foot-note .line { margin-bottom: 10px; }
  .foot-note .bold { font-weight: bold; }
</style>
</head>
<body>

<div class="page">

  <!-- Title -->
  <div class="main-title">QUOTATION / <span class="ar">عرض سعر</span></div>

  <!-- Header Info Table -->
  <table class="info-table">
    <tr>
      <td class="lbl">Company</td>
      <td class="val">{{billing_address.[0].name}}</td>
      <td class="lbl">Date</td>
      <td class="val">{{basicdetails.[0].inv_date}}</td>
    </tr>
    <tr>
      <td class="lbl">Your Ref</td>
      <td class="val">{{basicdetails.[0].order_no}}</td>
      <td class="lbl">Quotation No.</td>
      <td class="val">{{basicdetails.[0].inv_no}}</td>
    </tr>
    <tr>
      <td class="lbl">Attention</td>
      <td colspan="3">{{basicdetails.[0].attention}}</td>
    </tr>
  </table>

  <!-- Items Table -->
  <table class="items-table">
    <colgroup>
      <col style="width:6%">
      <col style="width:46%">
      <col style="width:12%">
      <col style="width:9%">
      <col style="width:14%">
      <col style="width:13%">
    </colgroup>
    <thead>
      <tr>
        <th>Item</th>
        <th>Description</th>
        <th>UOM</th>
        <th>QTY</th>
        <th>Unit Rate</th>
        <th>Total Price</th>
      </tr>
    </thead>
    <tbody>
      {{#each itemdetails}}
      <tr>
        <td class="center">{{addOne @index}}</td>
        <td class="left">
          {{item_name}}
          {{#if name_lang2}}<div style="direction:rtl;">{{name_lang2}}</div>{{/if}}
            {{#if description}}<div style="direction:rtl;">{{description}}</div>{{/if}}
        </td>
        <td class="center">{{unit}}</td>
        <td class="center">{{formatAmount quantity ../bcdp}}</td>
        <td class="right">{{formatAmount price ../bcdp}}</td>
        <td class="right">{{formatAmount amount ../bcdp}}</td>
      </tr>
      {{/each}}
      <tr class="total-row">
        <td colspan="5" class="t-label">Total Amount in {{basicdetails.[0].base_country_isocode}} (Excluding VAT)</td>
        <td class="t-value">{{formatAmount (divide basicdetails.[0].grand_total ccrate) bcdp}}</td>
      </tr>
    </tbody>
  </table>

  <!-- Amount in Words -->
  <div class="aiw">{{bcamountinwords}}</div>

  <!-- Terms & Conditions -->
  <div class="terms-wrap">
    <div class="terms-title">TERMS &amp; CONDITIONS:</div>
    <div class="terms-body">{{nl2br basicdetails.[0].terms_and_condition}}</div>
  </div>

  <!-- Footer note -->
  <div class="foot-note">
    <div class="line">Hope our offer Meets your Requirements.For any further information,Please feel free to contact us</div>
    <div class="line">Best Regards</div>
    <div class="line bold">{{basicdetails.[0].employeename}}</div>
    <div class="line">Mob:{{basicdetails.[0].employeecontactno}}</div>
  </div>

</div>

</body>
</html>
