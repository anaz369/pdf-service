<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Quotation - {{basicdetails.[0].inv_no}}</title>

<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: #ffffff;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 11px;
    color: #222;
    line-height: 1.4;
    margin: 0 6mm;
  }

  .page { width: 100%; margin: 0 auto; }

  /* ── Title ─────────────────────────────────── */
  .main-title {
    text-align: center;
    font-size: 22px;
    font-weight: bold;
    color: #000;
    margin: 8px 0 16px;
  }
  .main-title .ar {
    direction: rtl;
    unicode-bidi: embed;
    margin-right: 4px;
  }

  /* ── Header Info (two boxes) ────────────────── */
  .header-row {
    width: 100%;
    border-collapse: separate;
    border-spacing: 10px 0;
    table-layout: fixed;
  }
  .header-row > tbody > tr > td {
    vertical-align: top;
    background: #d9d9d9;
    padding: 12px 14px;
    font-size: 11px;
    width: 50%;
  }
  .info-list { width: 100%; border-collapse: collapse; }
  .info-list td {
    padding: 2px 0;
    vertical-align: top;
    font-size: 11px;
    border: none;
  }
  .info-list .k {
    width: 42%;
    white-space: nowrap;
    padding-right: 8px;
  }
  .info-list .k .ar {
    direction: rtl;
    unicode-bidi: embed;
  }
  .info-list .sep { width: 10px; }

  /* ── Items table ───────────────────────────── */
  .items-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
    border: 1px solid #bfbfbf;
    margin-top: 16px;
  }
  .items-table th, .items-table td {
    border: 1px solid #bfbfbf;
    padding: 6px 6px;
    font-size: 11px;
    vertical-align: middle;
  }
  .items-table th {
    text-align: center;
    font-weight: normal;
      background: #d9d9d9;
  }
  .items-table th .ar {
    display: block;
    direction: rtl;
    font-weight: normal;
    margin-bottom: 2px;
  }
  .items-table th .en {
    display: block;
    font-weight: bold;
  }
  .items-table .center { text-align: center; }
  .items-table .right  { text-align: right; }
  .items-table .left   { text-align: left; }
  .ryl { font-family: Arial, sans-serif;font-size: 14px;}

  /* ── Totals (right-aligned, no borders) ─────── */
  .totals-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
    margin-top: 10px;
  }
  .totals-table td {
    padding: 4px 8px;
    font-size: 11px;
    vertical-align: middle;
    border: none;
  }
  .totals-table .t-lbl {
    text-align: right;
    width: 25%;
  }
  .totals-table .t-sep {
    text-align: center;
    width: 4%;
  }
  .totals-table .t-val {
    text-align: right;
    width: 18%;
  }
  .totals-table .ar {
    direction: rtl;
    unicode-bidi: embed;
  }
  .totals-table .grand .t-lbl,
  .totals-table .grand .t-val {
    font-weight: bold;
  }

  /* ── Amount in Words ───────────────────────── */
  .aiw-bar {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
    margin-top: 14px;
    background: #d9d9d9;
  }
  .aiw-bar td {
    padding: 8px 12px;
    font-size: 11px;
    vertical-align: middle;
  }
  .aiw-bar .en { text-align: left; }
  .aiw-bar .ar {
    text-align: right;
    direction: rtl;
    unicode-bidi: embed;
  }

  /* ── Terms & Conditions ────────────────────── */
  .tc-wrap { margin-top: 10px; }
  .tc-title {
    background: #d9d9d9;
    font-weight: bold;
    padding: 6px 12px;
    font-size: 11px;
  }
  .tc-body {
    background: #f2f2f2;
    padding: 8px 12px;
    font-size: 11px;
    white-space: pre-wrap;
  }

  /* ── Bank Details + Seal ───────────────────── */
  .bank-row {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
    margin-top: 18px;
  }
  .bank-row > tbody > tr > td {
    vertical-align: top;
    padding: 0 8px;
    font-size: 11px;
  }
  .bank-title {
    font-weight: bold;
    margin-bottom: 8px;
    font-size: 12px;
  }
  .bank-list {
    width: 100%;
    border-collapse: collapse;
  }
  .bank-list td {
    padding: 3px 0;
    font-size: 11px;
    vertical-align: top;
    border: none;
  }
  .bank-list .k {
    width: 130px;
    white-space: nowrap;
  }
  .bank-list .sep { width: 14px; }
  .seal-cell {
    text-align: right;
    vertical-align: middle;
  }
  .seal-cell img {
    max-height: 130px;
    object-fit: contain;
  }
</style>
</head>
<body>

<div class="page">

  <!-- Title -->
  <div class="main-title"> QUOTATION /<span class="ar">عرض أسعار</span></div>

  <!-- Header Info -->
  <table class="header-row">
    <colgroup>
      <col style="width:50%">
      <col style="width:50%">
    </colgroup>
    <tr>
      <td>
        <table class="info-list">
          <tr>
            <td class="k">Customer Name / <span class="ar">اسم</span></td>
            <td class="sep">:</td>
            <td>{{billing_address.[0].name}}</td>
          </tr>
          <tr>
            <td class="k">Address / <span class="ar">عنوان</span></td>
            <td class="sep">:</td>
            <td>
              {{#if billing_address.[0].address_line1}}<div>{{billing_address.[0].address_line1}}</div>{{/if}}
              {{#if billing_address.[0].address_line2}}<div>{{billing_address.[0].address_line2}}</div>{{/if}}
              {{#if billing_address.[0].address_line3}}<div>{{billing_address.[0].address_line3}}</div>{{/if}}
              {{#if billing_address.[0].address_line4}}<div>{{billing_address.[0].address_line4}}</div>{{/if}}
              {{#if billing_address.[0].address_line5}}<div>{{billing_address.[0].address_line5}}</div>{{/if}}
              {{#if billing_address.[0].address_code}}<div>{{billing_address.[0].address_code}}</div>{{/if}}
            </td>
          </tr>
          <tr>
            <td class="k">VAT / <span class="ar">الضريبة</span></td>
            <td class="sep">:</td>
            <td>{{billing_address.[0].vat}}</td>
          </tr>
        </table>
      </td>
      <td>
        <table class="info-list">
          <tr>
            <td class="k">Quotation No/<span class="ar">رقم عرض الأسعار</span></td>
            <td class="sep">:</td>
            <td>{{basicdetails.[0].inv_no}}</td>
          </tr>
          <tr>
            <td class="k">Date / <span class="ar">تاريخ</span></td>
            <td class="sep">:</td>
            <td>{{basicdetails.[0].inv_date}}</td>
          </tr>
          <tr>
            <td class="k">Created By / <span class="ar">تم إنشاؤه بواسطة</span></td>
            <td class="sep">:</td>
            <td>{{basicdetails.[0].employeename}}</td>
          </tr>
          <tr>
            <td class="k">Contact Email</td>
            <td class="sep">:</td>
            <td>{{basicdetails.[0].employeeemail}}</td>
          </tr>
          <tr>
            <td class="k">Contact Number</td>
            <td class="sep">:</td>
            <td>{{basicdetails.[0].employeecontactno}}</td>
          </tr>
          {{#if basicdetails.[0].attention}}
          <tr>
            <td class="k">Attn.</td>
            <td class="sep">:</td>
            <td>{{basicdetails.[0].attention}}</td>
          </tr>
          {{/if}}
          {{#if basicdetails.[0].reference_no}}
          <tr>
            <td class="k">Ref No.</td>
            <td class="sep">:</td>
            <td>{{basicdetails.[0].reference_no}}</td>
          </tr>
          {{/if}}
        </table>
      </td>
    </tr>
  </table>

  <!-- Items Table -->
  <table class="items-table">
    <colgroup>
      <col style="width:6%">
      <col style="width:12%">
      <col style="width:23%">
      <col style="width:7%">
      <col style="width:7%">
      <col style="width:11%">
      <col style="width:11%">
      <col style="width:11%">
      <col style="width:12%">
    </colgroup>
    <thead>
      <tr>
        <th><span class="ar">رقم</span><span class="en">Sl No</span></th>
        <th><span class="ar">رمز المنتج</span><span class="en">Product Code</span></th>
        <th><span class="ar">وصف</span><span class="en">Description</span></th>
        <th><span class="ar">الكمية</span><span class="en">Qty</span></th>
        <th><span class="ar">وحدة</span><span class="en">Unit</span></th>
        <th><span class="ar">سعر الوحدة</span><span class="en">Unit Rate</span></th>
        <th><span class="ar">المبلغ</span><span class="en">Amount</span></th>
        <th><span class="ar">مبلغ الضريبة</span><span class="en">VAT Amount</span></th>
        <th><span class="ar">المجموع</span><span class="en">Total</span></th>
      </tr>
    </thead>
    <tbody>
      {{#each itemdetails}}
      <tr>
        <td class="center">{{addOne @index}}</td>
        <td class="left">{{item_code}}</td>
        <td class="left">
          {{item_name}}
          {{#if name_lang2}}<div style="direction:rtl;">{{name_lang2}}</div>{{/if}}
          {{#if description}}<div style="direction:rtl;">{{description}}</div>{{/if}}
        </td>
        <td class="center">{{formatAmount quantity ../bcdp}}</td>
        <td class="center">{{unit}}</td>
        <td class="right"><span class="ryl">{{currencySymbol basicdetails.[0].base_country_isocode}}</span>{{formatAmount price ../bcdp}}</td>
        <td class="right"><span class="ryl">{{currencySymbol basicdetails.[0].base_country_isocode}}</span>{{formatAmount taxable ../bcdp}}</td>
        <td class="right"><span class="ryl">{{currencySymbol basicdetails.[0].base_country_isocode}}</span>{{formatAmount vat_amt ../bcdp}}</td>
        <td class="right"><span class="ryl">{{currencySymbol basicdetails.[0].base_country_isocode}}</span>{{formatAmount amount ../bcdp}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>

  <!-- Totals -->
  <table class="totals-table">
    <colgroup>
      <col style="width:60%">
      <col style="width:22%">
      <col style="width:4%">
      <col style="width:14%">
    </colgroup>
    <tr>
      <td></td>
      <td class="t-lbl"> Total Amount / <span class="ar">المبلغ الإجمالي</span></td>
      <td class="t-sep">:</td>
      <td class="t-val"><span class="ryl">{{currencySymbol basicdetails.[0].base_country_isocode}}</span>{{formatAmount (divide basicdetails.[0].subtotal ccrate) bcdp}}</td>
    </tr>
    <tr>
      <td></td>
      <td class="t-lbl"> Discount / <span class="ar">الخصم</span></td>
      <td class="t-sep">:</td>
      <td class="t-val"><span class="ryl">{{currencySymbol basicdetails.[0].base_country_isocode}}</span>{{formatAmount (divide basicdetails.[0].discount ccrate) bcdp}}</td>
    </tr>
    <tr>
      <td></td>
      <td class="t-lbl"> After Discount / <span class="ar"> بعد الخصم</span></td>
      <td class="t-sep">:</td>
      <td class="t-val"><span class="ryl">{{currencySymbol basicdetails.[0].base_country_isocode}}</span>{{formatAmount (divide (subtract basicdetails.[0].subtotal basicdetails.[0].discount) ccrate) bcdp}}</td>
    </tr>
    <tr>
      <td></td>
      <td class="t-lbl"> VAT (15%) / <span class="ar">ضريبة القيمة المضافة </span></td>
      <td class="t-sep">:</td>
      <td class="t-val"><span class="ryl">{{currencySymbol basicdetails.[0].base_country_isocode}}</span>{{formatAmount (divide basicdetails.[0].vatamt ccrate) bcdp}}</td>
    </tr>
    <tr class="grand">
      <td></td>
      <td class="t-lbl" style="background-color:#d9d9d9;"> Grand Total / <span class="ar"> المجموع الإجمالي</span></td>
      <td class="t-sep" style="background-color:#d9d9d9;">:</td>
      <td class="t-val" style="background-color:#d9d9d9;"><span class="ryl">{{currencySymbol basicdetails.[0].base_country_isocode}}</span>{{formatAmount (divide basicdetails.[0].grand_total ccrate) bcdp}}</td>
    </tr>
  </table>

  <!-- Amount in Words -->
  <table class="aiw-bar">
    <colgroup>
      <col style="width:50%">
      <col style="width:50%">
    </colgroup>
    <tr>
      <td class="en">{{bcamountinwords}}</td>
      <td class="ar">{{bcamountinwordsar}}</td>
    </tr>
  </table>

  <!-- Terms & Conditions -->
  <div class="tc-wrap">
    <div class="tc-title">Terms &amp; Conditions</div>
    <div class="tc-body">{{nl2br basicdetails.[0].terms_and_condition}}</div>
  </div>

  <!-- Bank Details + Seal -->
  <table class="bank-row">
    <colgroup>
      <col style="width:70%">
      <col style="width:30%">
    </colgroup>
    <tr>
      <td>
        <div class="bank-title">Bank Account Details</div>
        <table class="bank-list">
          <tr>
            <td class="k">Bank Name</td>
            <td class="sep">:</td>
            <td>{{bankdetails.bank_name}}</td>
          </tr>
          <tr>
            <td class="k">Account Name</td>
            <td class="sep">:</td>
            <td>{{bankdetails.acc_name}}</td>
          </tr>
          <tr>
            <td class="k">Account Number</td>
            <td class="sep">:</td>
            <td>{{bankdetails.account_no}}</td>
          </tr>
          <tr>
            <td class="k">IBAN No</td>
            <td class="sep">:</td>
            <td>{{bankdetails.iban_no}}</td>
          </tr>
          <tr>
            <td class="k">SWIFT No</td>
            <td class="sep">:</td>
            <td>{{bankdetails.swift_no}}</td>
          </tr>
          <tr>
            <td class="k">Branch Name</td>
            <td class="sep">:</td>
            <td>{{bankdetails.branch_name}}</td>
          </tr>
        </table>
      </td>
      <td class="seal-cell">
        {{#if seal}}
          <img src="{{Seal}}" alt="Seal" style="max-height:{{default datasettings.d459 '40'}}px; max-width:{{default datasettings.d459 '60'}}px;" onerror="this.style.display='none'"/> 
        {{/if}}
      </td>
    </tr>
  </table>

</div>

</body>
</html>
