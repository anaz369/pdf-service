<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Quotation - {{basicdetails.[0].inv_no}}</title>

<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: #ffffff;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 11px;
    color: #222;
    line-height: 1.45;
    margin: 0 6mm;
  }

  .page { width: 100%; margin: 0 auto; padding-top: 4px; }

  /* ── Title ─────────────────────────────────── */
  .main-title {
    text-align: center;
    font-size: 16px;
    font-weight: bold;
    color: #2a7bb8;
    padding: 6px 0 10px;
    border-bottom: 1px solid #ddd;
    margin-bottom: 12px;
  }

  /* ── Header (Quoted To + Refs) ─────────────── */
  .header-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 14px;
  }
  .header-table td {
    vertical-align: top;
    padding: 2px 0;
    font-size: 11px;
  }
  .header-table .left-col { width: 50%; padding-right: 14px; }
  .header-table .right-col { width: 50%; }

  .quoted-to-label {
    font-weight: bold;
    margin-bottom: 8px;
  }
  .quoted-to-name {
    font-weight: normal;
    margin-bottom: 2px;
  }
  .quoted-to-addr {
    line-height: 1.5;
  }

  .refs-table { width: 100%; border-collapse: collapse; }
  .refs-table td {
    padding: 2px 0;
    font-size: 11px;
    vertical-align: top;
  }
  .refs-table .r-lbl { width: 42%; font-weight: bold; }
  .refs-table .r-sep { width: 4%; }
  .refs-table .r-val { width: 54%; }

  /* ── Items table ───────────────────────────── */
  .items-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
    border: 1px solid #000;
    margin-top: 8px;
  }
  .items-table th,
  .items-table td {
    border: 1px solid #000;
    padding: 6px 5px;
    font-size: 11px;
    vertical-align: middle;
  }
  .items-table th {
    text-align: center;
    font-weight: bold;
    background: #ffffff;
  }
  .items-table .center { text-align: center; }
  .items-table .right  { text-align: right; }
  .items-table .left   { text-align: left; }

  .totals-lbl {
    text-align: right;
    font-weight: bold;
    color: #e02424;
  }
  .totals-val {
    text-align: right;
    font-weight: bold;
    color: #e02424;
  }

  /* ── Words / Notes ────────────────────────── */
  .amount-words {
    color: #e02424;
    font-weight: bold;
    margin: 14px 0 18px;
    text-transform: uppercase;
  }

  .terms-block { margin-top: 10px; }
  .terms-label {
    font-weight: bold;
    text-decoration: underline;
    display: inline;
  }
  .terms-value {
    display: inline;
    margin-left: 4px;
  }

  .remark-block {
    margin-top: 18px;
    font-size: 11px;
  }

  /* ── Bank section ─────────────────────────── */
  .bank-wrap { margin-top: 18px; }
  .bank-title {
    text-decoration: underline;
    font-weight: bold;
    margin-bottom: 6px;
  }
  .bank-table { border-collapse: collapse; }
  .bank-table td {
    padding: 2px 0;
    font-size: 11px;
    vertical-align: top;
  }
  .bank-table .bk-lbl {
    font-weight: bold;
    width: 130px;
  }
  .bank-table .bk-sep { width: 12px; }

  /* ── Footer ────────────────────────────────── */
  .footer-note {
    margin-top: 22px;
    font-size: 11px;
    line-height: 1.55;
  }

  .sign-off {
    margin-top: 22px;
    font-size: 11px;
  }
  .sign-off .company { font-weight: bold; }
</style>
</head>
<body>

<div class="page">

  <!-- Title -->
  <div class="main-title">QUOTATION</div>

  <!-- Header: Quoted To + Refs -->
  <table class="header-table">
    <tr>
      <td class="left-col">
        <div class="quoted-to-label">QUOTED TO&nbsp;&nbsp;&nbsp;&nbsp;:</div>
        <div class="quoted-to-name">{{billing_address.[0].name}}</div>
        <div class="quoted-to-addr">
          {{#if billing_address.[0].address_line1}}{{billing_address.[0].address_line1}}{{/if}}{{#if billing_address.[0].address_line2}} {{billing_address.[0].address_line2}}{{/if}}{{#if billing_address.[0].address_line3}}<br>{{billing_address.[0].address_line3}}{{/if}}{{#if billing_address.[0].address_line4}}{{billing_address.[0].address_line4}}{{/if}}{{#if billing_address.[0].address_line5}}{{billing_address.[0].address_line5}}{{/if}}{{#if billing_address.[0].address_code}}{{billing_address.[0].address_code}}{{/if}}
        </div>
      </td>
      <td class="right-col">
        <table class="refs-table">
          <tr>
            <td class="r-lbl">OUR QUOTATION REF</td>
            <td class="r-sep">:</td>
            <td class="r-val">{{basicdetails.[0].inv_no}}</td>
          </tr>
          <tr>
            <td class="r-lbl">ENQUIRY REF</td>
            <td class="r-sep">:</td>
            <td class="r-val">{{basicdetails.[0].order_no}}</td>
          </tr>
          <tr>
            <td class="r-lbl">VESSEL NAME</td>
            <td class="r-sep">:</td>
            <td class="r-val"></td>
          </tr>
          <tr>
            <td class="r-lbl">DATE</td>
            <td class="r-sep">:</td>
            <td class="r-val">{{basicdetails.[0].inv_date}}</td>
          </tr>
          <tr>
            <td class="r-lbl">PERSON</td>
            <td class="r-sep">:</td>
            <td class="r-val">{{basicdetails.[0].employeename}}</td>
          </tr>
          <tr>
            <td class="r-lbl">CONTACT</td>
            <td class="r-sep">:</td>
            <td class="r-val">{{basicdetails.[0].employeecontactno}}</td>
          </tr>
          <tr>
            <td class="r-lbl">EMAIL</td>
            <td class="r-sep">:</td>
            <td class="r-val">{{compprof.[0].email}}</td>
          </tr>
          <tr>
            <td class="r-lbl">DELIVERY PORT</td>
            <td class="r-sep">:</td>
            <td class="r-val">{{basicdetails.[0].port_of_delivery}}</td>
          </tr>
        </table>
      </td>
    </tr>
  </table>

  <!-- Items Table -->
  <table class="items-table">
    <colgroup>
      <col style="width:7%">
      <col style="width:35%">
      <col style="width:9%">
      <col style="width:9%">
      <col style="width:13%">
      <col style="width:13%">
      <col style="width:14%">
    </colgroup>
    <thead>
      <tr>
        <th>S.No</th>
        <th>DESCRIPTION</th>
        <th>UNIT</th>
        <th>QTY</th>
        <th>UNIT PRICE</th>
        <th>DISCOUNT %</th>
        <th>TOTAL PRICE</th>
      </tr>
    </thead>
    <tbody>
      {{#each itemdetails}}
      <tr>
        <td class="center">{{addOne @index}}</td>
        <td class="left">
          {{item_name}}
          {{#if name_lang2}}<div style="direction:rtl;">{{name_lang2}}</div>{{/if}}
          {{#if description}}<div>{{description}}</div>{{/if}}
        </td>
        <td class="center">{{unit}}</td>
        <td class="center">{{formatAmount quantity 0}}</td>
        <td class="right">{{formatAmount price ../bcdp}}</td>
        <td class="right">{{formatAmount disc_amt ../bcdp}}</td>
        <td class="right">{{formatAmount amount ../bcdp}}</td>
      </tr>
      {{/each}}
      <tr>
        <td colspan="6" class="totals-lbl">TOTAL DISCOUNT</td>
        <td class="totals-val">{{formatAmount (divide basicdetails.[0].discount ccrate) bcdp}}</td>
      </tr>
      <tr>
        <td colspan="6" class="totals-lbl">TOTAL PRICE IN {{basicdetails.[0].base_country_isocode}}</td>
        <td class="totals-val">{{formatAmount (divide basicdetails.[0].grand_total ccrate) bcdp}}</td>
      </tr>
    </tbody>
  </table>

  <!-- Amount in words -->
  {{#if bcamountinwords}}
  <div class="amount-words">TOTAL BUDGETORY QUOTATION: {{bcamountinwords}}</div>
  {{/if}}

  <!-- Payment Terms -->
  {{#if basicdetails.[0].payment_terms}}
  <div class="terms-block">
    <span class="terms-label">PAYMENT TERMS:</span>
    <span class="terms-value">{{basicdetails.[0].payment_terms}}</span>
  </div>
  {{/if}}

  <!-- Remark / Notes -->
  {{#if basicdetails.[0].remark}}
  <div class="remark-block">{{nl2br basicdetails.[0].remark}}</div>
  {{/if}}

  <!-- Bank Account Details -->
  <div class="bank-wrap">
    <div class="bank-title">Bank Account Details:</div>
    <table class="bank-table">
      {{#if bankdetails.acc_name}}
      <tr>
        <td class="bk-lbl">A/C NAME</td>
        <td class="bk-sep">:</td>
        <td>{{bankdetails.acc_name}}</td>
      </tr>
      {{/if}}
      {{#if bankdetails.acc_no}}
      <tr>
        <td class="bk-lbl">EEFC USD A/C</td>
        <td class="bk-sep">:</td>
        <td>{{bankdetails.acc_no}}</td>
      </tr>
      {{/if}}
      {{#if bankdetails.swift_no}}
      <tr>
        <td class="bk-lbl">SWIFT CODE</td>
        <td class="bk-sep">:</td>
        <td>{{bankdetails.swift_no}}</td>
      </tr>
      {{/if}}
    </table>
  </div>

  <!-- Footer note -->
  <div class="footer-note">
    Should you require any additional information, please do not hesitate to contact our Operational Unit. We require a Purchase Order to start the following project, and mobilization time of 24 hours needs to be provided.
  </div>

  <!-- Sign off -->
  <div class="sign-off">
    Sincerely Yours,.<br>
    <span class="company">{{#if compprof.name}}{{compprof.name}}{{else}}{{branch.[0].name}}{{/if}}</span>
  </div>

</div>

</body>
</html>
