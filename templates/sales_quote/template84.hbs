<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Quotation - {{basicdetails.[0].inv_no}}</title>

<style>

    * {
        box-sizing: border-box;
    }

    body {
        margin: 0 8mm;
        padding: 0;
        background: #ffffff;
        font-family: Arial, Helvetica, sans-serif;
        font-size: 10px;
        color: #222;
        line-height: 1.35;
    }

    .page {
        width: 100%;
        margin: 0 auto;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        table-layout: fixed;
    }

    td, th {
        border: 1px solid #bfbfbf;
        padding: 3px 2px;
        vertical-align: top;
        word-wrap: break-word;
    }

    .center { text-align: center; }
    .right  { text-align: right; }
    .bold   { font-weight: bold; }

    /* Header */
    .title {
        text-align: center;
        font-size: 18px;
        font-weight: bold;
        color: #0070ff;
        margin-bottom: 10px;
    }

    /* Top Summary Table */
    .summary-table td {
        height: 38px;
        vertical-align: middle;
    }

    .summary-label {
        text-align: center;
        font-size: 9px;
        background: #e9ecef;
    }


    .summary-value {
        text-align: center;
        font-size: 10px;
        white-space: nowrap;
        background: #e9ecef;
    }

    .arabic {
        direction: rtl;
        text-align: center;
        font-size: 10px;
    }

    /* Two Column Section */
    .section-row {
        width: 100%;
        margin-top: 10px;
        overflow: hidden;
    }

    .column {
        width: 49%;
        float: left;
    }
    .column td {
        width: 100%;
    }


    .column.right-column {
        float: right;
    }

    .section-header {
        background: #e9ecef;
        font-weight: bold;
        padding: 4px;
        vertical-align: middle;
        width: 100%;
    }

    .section-header td {
        vertical-align: middle;
    }

    .label-en {
        width: 21%;
        padding-left:5px;
        white-space: nowrap;
        background: #e9ecef;
    }

    .value-cell {
        width: 58%;
        padding-left:5px;
    }

    .label-ar {
        width: 21%;
        direction: rtl;
        text-align: right;
        padding-right:5px;
    }

    /* Item Table */
    .items-table {
        margin-top: 10px;
    }

    .items-table th {
        background: #e9ecef;
        font-weight: normal;
        text-align: center;
        vertical-align: middle;
        padding: 3px 2px;
    }

    .items-table .en {
        display: block;
        font-size: 9px;
    }

    .items-table .ar {
        display: block;
        direction: rtl;
        font-size: 9px;
        margin-top: 1px;
    }

    /* Bottom Section */
    .bottom-section {
        margin-top: 10px;
        width: 100%;
        display: flex;
        align-items: stretch;
        gap: 1%;
    }

    .terms-box {
        width: 45%;
        flex-shrink: 0;
        border: 1px solid #b6b6b6;
        display: flex;
        flex-direction: column;
    }

    .terms-header {
        font-weight: bold;
        padding: 3px 2px;
        border-bottom: 1px solid #b6b6b6;
    }

    .terms-content {
        padding: 6px;
        flex: 1;
    }

    .totals-box {
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .totals-box .totals-table {
        height: 100%;
    }

    .totals-table td {
        vertical-align: middle;
        font-size: 9px;
    }

    .totals-label-en {
        width: 40%;
    }

    .totals-label-ar {
        width: 40%;
        direction: rtl;
        text-align: right;
    }

    .totals-value {
        width: 20%;
        text-align: right;
        white-space: nowrap;
        font-weight: bold;
        padding-right: 5px;
    }

    .currency {
        font-weight: bold;
        font-size:13px ;
    }

    .clearfix {
        clear: both;
    }
</style>
</head>
<body>

<div class="page">

    <!-- Title -->
    <div class="title">SALES QUOTE / تسعير المبيعات</div>

    <!-- Summary -->
    <table class="summary-table">
        <colgroup>
            <col style="width:20%">
            <col style="width:10%">
            <col style="width:25%">
            <col style="width:12%">
            <col style="width:18%">
            <col style="width:15%">
        </colgroup>
        <tr>
            <td class="summary-label">
                Sales Quote Number<br>
                <div class="arabic">رقم عرض أسعار المبيعات</div>
            </td>
            <td class="summary-value">{{basicdetails.[0].inv_no}}</td>

            <td class="summary-label">
                Sales Quote issue date<br>
                <div class="arabic">تاريخ إصدار عرض أسعار المبيعات</div>
            </td>
            <td class="summary-value">{{basicdetails.[0].inv_date}}</td>

            <td class="summary-label">
                Sales Quote due date<br>
                <div class="arabic">تاريخ استحقاق قياس المبيعات</div>
            </td>
            <td class="summary-value">{{basicdetails.[0].due_date}}</td>
        </tr>
    </table>

    <!-- Seller & Buyer -->
    <div class="section-row">

        <!-- Seller -->
        <div class="column">
            <table>
                <tr class="section-header">
                    <td style="width: 21%;border-right:none;">Seller</td>
                    <td style="width: 58%;border-left:none;border-right:none;"></td>
                    <td  style="width: 21%;border-left:none;"class="label-ar">المورد</td>
                </tr>
                <tr>
                    <td class="label-en">Name</td>
                    <td class="value-cell">{{compprof.name}}</td>
                    <td class="label-ar">الاسم</td>
                </tr>
                <tr><td class="label-en">Building No.</td><td class="value-cell"></td><td class="label-ar">رقم المبنى</td></tr>
                <tr><td class="label-en">Street Name</td><td class="value-cell"></td><td class="label-ar">اسم الشارع</td></tr>
                <tr><td class="label-en">District</td><td class="value-cell"></td><td class="label-ar">الحي</td></tr>
                <tr><td class="label-en">City</td><td class="value-cell"></td><td class="label-ar">المدينة</td></tr>
                <tr><td class="label-en">Country</td><td class="value-cell"></td><td class="label-ar">البلد</td></tr>
                <tr><td class="label-en">Postal Code</td><td class="value-cell"></td><td class="label-ar">رمز بريدي</td></tr>
                <tr><td class="label-en">VAT Number</td><td class="value-cell"></td><td class="label-ar">رقم ضريبة القيمة</td></tr>
            </table>
        </div>

        <!-- Buyer -->
        <div class="column right-column">
            <table>
                <tr class="section-header">
                    <td style="width: 21%;border-right:none;">Buyer</td>
                    <td style="width: 58%;border-left:none;border-right:none;"></td>
                    <td  style="width: 21%;border-left:none;"class="label-ar">العميل</td>
                </tr>
                <tr>
                    <td class="label-en">Name</td>
                    <td class="value-cell">{{billing_address.[0].name}}</td>
                    <td class="label-ar">الاسم</td>
                </tr>
                <tr><td class="label-en">Building No.</td><td class="value-cell">{{billing_address.[0].address_line1}}</td><td class="label-ar">رقم المبنى</td></tr>
                <tr><td class="label-en">Street Name</td><td class="value-cell">{{billing_address.[0].address_line2}}</td><td class="label-ar">اسم الشارع</td></tr>
                <tr><td class="label-en">District</td><td class="value-cell">{{billing_address.[0].address_line4}}</td><td class="label-ar">الحي</td></tr>
                <tr><td class="label-en">City</td><td class="value-cell">{{billing_address.[0].address_line3}}</td><td class="label-ar">المدينة</td></tr>
                <tr><td class="label-en">Country</td><td class="value-cell">{{billing_address.[0].address_line5}}</td><td class="label-ar">البلد</td></tr>
                <tr><td class="label-en">Postal Code</td><td class="value-cell">{{billing_address.[0].address_code}}</td><td class="label-ar">رمز بريدي</td></tr>
                <tr><td class="label-en">VAT Number</td><td class="value-cell">{{billing_address.[0].vat}}</td><td class="label-ar">رقم ضريبة القيمة</td></tr>
            </table>
        </div>

        <div class="clearfix"></div>
    </div>

    <!-- Items -->
    <table class="items-table">
        <colgroup>
            <col style="width:3%">
            <col style="width:31%">
            <col style="width:9%">
            <col style="width:10%">
            <col style="width:10%">
            <col style="width:15%">
            <col style="width:11%">
            <col style="width:11%">
        </colgroup>
        <tr>
            <th><span class="en">#</span></th>
            <th><span class="en">Description</span><span class="ar">وصف</span></th>
            <th><span class="en">Quantity</span><span class="ar">كمية</span></th>
            <th><span class="en">UOM</span><span class="ar">وحدة القياس</span></th>
            <th><span class="en">Make/Origin</span><span class="ar">صنعه/أصل</span></th>
            <th><span class="en">Delivery</span><span class="ar">توصيل</span></th>
            <th><span class="en">Unit Price</span><span class="ar">سعر الوحدة</span></th>
            <th><span class="en">Total Price</span><span class="ar">السعر الإجمالي</span></th>
        </tr>
        {{#each itemdetails}}
        <tr>
            <td class="center">{{addOne @index}}</td>
            <td>
                {{item_name}}
            </td>
            <td class="center">{{formatAmount quantity ../bcdp}}</td>
            <td class="center">{{unit}}</td>
            <td class="center"></td>
            <td class="center">{{remark}}</td>
            <td class="right"><span class="currency">{{currencySymbol ../basicdetails.[0].isocode}}</span>{{formatAmount price ../bcdp}}</td>
            <td class="right"><span class="currency">{{currencySymbol ../basicdetails.[0].isocode}}</span>{{formatAmount amount ../bcdp}}</td>
        </tr>
        {{/each}}
    </table>

    <!-- Bottom Section -->
    <div class="bottom-section">

        <!-- Terms -->
        <div class="terms-box">
            <div class="terms-header">
                Terms And Conditions / والأحكام والشروط
            </div>
            <div class="terms-content">
                {{nl2br basicdetails.[0].terms_and_condition}}
            </div>
        </div>

        <!-- Totals -->
        <div class="totals-box">
            <table class="totals-table">
                <tr>
                    <td class="totals-label-en">SubTotal </td>
                    <td class="totals-label-ar">المجموع الفرعي</td>
                    <td class="totals-value"><span class="currency">{{currencySymbol ../basicdetails.[0].isocode}}</span>{{formatAmount (divide basicdetails.[0].subtotal ccrate) bcdp}}</td>
                </tr>
                <tr>
                    <td class="totals-label-en">Discount</td>
                    <td class="totals-label-ar">تخفيض</td>
                    <td class="totals-value"><span class="currency">{{currencySymbol basicdetails.[0].isocode}}</span>{{formatAmount (divide basicdetails.[0].discount ccrate) bcdp}}</td>
                </tr>
                <tr>
                    <td class="totals-label-en">
                        Total Taxable Amount<br>(Excluding VAT)
                    </td>
                    <td class="totals-label-ar">
                        إجمالي المبلغ الخاضع للضريبة (باستثناء ضريبة القيمة المضافة)
                    </td>
                    <td class="totals-value"><span class="currency">{{currencySymbol basicdetails.[0].isocode}}</span>{{formatAmount (divide (subtract basicdetails.[0].subtotal basicdetails.[0].discount) ccrate) bcdp}}</td>
                </tr>
                <tr>
                    <td class="totals-label-en">Total VAT</td>
                    <td class="totals-label-ar">مجموع ضريبة القيمة المضافة</td>
                    <td class="totals-value"><span class="currency">{{currencySymbol basicdetails.[0].isocode}}</span>{{formatAmount (divide basicdetails.[0].vatamt ccrate) bcdp}}</td>
                </tr>
                <tr>
                    <td class="totals-label-en">Total Amount</td>
                    <td class="totals-label-ar">المبلغ الإجمالي</td>
                    <td class="totals-value"><span class="currency">{{currencySymbol basicdetails.[0].isocode}}</span>{{formatAmount (divide basicdetails.[0].grand_total ccrate) bcdp}}</td>
                </tr>
            </table>
        </div>

        <div class="clearfix"></div>
    </div>

</div>
</body>
</html>