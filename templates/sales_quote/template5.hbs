<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Quotation - {{basicdetails.[0].inv_no}}</title>

<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: #ffffff;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 11px;
    color: #222;
    line-height: 1.45;
    margin: 0 10mm;
  }

  .page { width: 100%; margin: 0 auto; padding-top: 6px; }

  /* ── Title ─────────────────────────────────── */
  .main-title {
    text-align: center;
    font-size: 20px;
    font-weight: bold;
    color: #2a4d7b;
    text-decoration: underline;
    padding: 8px 0 14px;
    margin-bottom: 14px;
  }

  /* ── Header info table ────────────────────── */
  .info-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
    margin-bottom: 10px;
  }
  .info-table td {
    border: 1px solid #000;
    padding: 6px 8px;
    font-size: 11px;
    vertical-align: middle;
  }
  .info-table .lbl {
    font-weight: bold;
    width: 12%;
  }
  .info-table .val {
    width: 38%;
  }

  /* ── Items table ──────────────────────────── */
  .items-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
    border: 1px solid #000;
    margin-top: 6px;
  }
  .items-table th,
  .items-table td {
    border: 1px solid #000;
    padding: 6px 8px;
    font-size: 11px;
    vertical-align: middle;
  }
  .items-table th {
    text-align: left;
    font-weight: bold;
    background: #ffffff;
  }
  .items-table .center { text-align: center; }
  .items-table .right  { text-align: right; }
  .items-table .left   { text-align: left; }

  .grand-total-lbl {
    font-weight: bold;
  }
  .grand-total-val {
    font-weight: bold;
    text-align: right;
  }
</style>
</head>
<body>

<div class="page">

  <!-- Title -->
  <div class="main-title">QUOTATION</div>

  <!-- Info Table -->
  <table class="info-table">
    <tr>
      <td class="lbl">Date</td>
      <td class="val">{{basicdetails.[0].inv_date}}</td>
      <td class="lbl">From</td>
      <td class="val">{{#if compprof.name}}{{compprof.name}}{{else}}{{basicdetails.[0].employeename}}{{/if}}</td>
    </tr>
    <tr>
      <td class="lbl">To</td>
      <td class="val">{{basicdetails.[0].customer_name}}</td>
      <td class="lbl">Tel</td>
      <td class="val">{{compprof.phone}}</td>
    </tr>
    <tr>
      <td class="lbl">Attn</td>
      <td class="val">{{basicdetails.[0].attention}}</td>
      <td class="lbl">Email</td>
      <td class="val">{{compprof.email}}</td>
    </tr>
    <tr>
      <td class="lbl">Tel</td>
      <td class="val">{{basicdetails.[0].contactno}}</td>
      <td class="lbl">Ref#</td>
      <td class="val">{{basicdetails.[0].reference_no}}</td>
    </tr>
    <tr>
      <td class="lbl">Email</td>
      <td class="val">{{basicdetails.[0].contactemail}}</td>
      <td class="lbl">Pages</td>
      <td class="val"></td>
    </tr>
  </table>

  <!-- Items Table -->
  <table class="items-table">
    <colgroup>
      <col style="width:8%">
      <col style="width:32%">
      <col style="width:25%">
      <col style="width:13%">
      <col style="width:22%">
    </colgroup>
    <thead>
      <tr>
        <th class="left">NO</th>
        <th class="left">DESCRIPTION</th>
        <th class="left">MATERIAL</th>
        <th class="left">UNIT</th>
        <th class="right">UNIT PRICE</th>
      </tr>
    </thead>
    <tbody>
      {{#each itemdetails}}
      <tr>
        <td class="left">{{addOne @index}}</td>
        <td class="left">{{description}}</td>
        <td class="left">{{item_name}}</td>
        <td class="left">{{unit}}</td>
        <td class="right">{{formatAmount price ../bcdp}}</td>
      </tr>
      {{/each}}
      <tr>
        <td colspan="4" class="grand-total-lbl">GRAND TOTAL</td>
        <td class="grand-total-val">{{formatAmount (divide basicdetails.[0].grand_total ccrate) bcdp}}</td>
      </tr>
    </tbody>
  </table>
   {{!-- ══ TERMS &amp; CONDITIONS ══ --}}
    {{#if invterms}}
    <div class="terms-block">
        <div class="terms-title">Terms &amp; Conditions :</div>
        <div class="terms-text">{{{nl2br terms_and_condition}}}</div>
    </div>
    {{/if}}


</div>

</body>
</html>
