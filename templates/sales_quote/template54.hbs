<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Quotation - {{basicdetails.[0].inv_no}}</title>

<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    background: #ffffff;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 11px;
    color: #222;
    line-height: 1.4;
    margin: 0 6mm;
  }

  .page { width: 100%; margin: 0 auto; }



  /* ── Top header (To / Title / Ref-Date) ─────── */
  .top-header {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
  }
  .top-header > tbody > tr > td {
    vertical-align: top;
    padding: 0 6px;
    font-size: 11px;
  }
  .to-block { font-size: 11px; line-height: 1.5; }
  .to-block .nm { font-weight: bold; }

  .qtn-badge {
    background: #6c63a8;
    color: #ffffff;
    text-align: center;
    font-weight: bold;
    font-size: 14px;
    padding: 5px 4px;
  }

  .ref-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
  }
  .ref-table td {
    border: 1px solid #000;
    padding: 5px 4px;
    font-size: 11px;
    vertical-align: middle;
  }
  .ref-table .lbl { font-weight: normal; width: 40%; }
  .ref-table .val { text-align: right; }

  /* ── Three-column info table ───────────────── */
  .info-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
    margin-top: 14px;
    border: 1px solid #000;
  }
  .info-table th, .info-table td {
    border: 1px solid #000;
    padding: 4px 4px;
    font-size: 11px;
    vertical-align: middle;
  }
  .info-table th {
    background: #6c63a8;
    color: #ffffff;
    text-align: center;
    font-weight: bold;
  }

  /* ── Items table ───────────────────────────── */
  .items-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
    border: 1px solid #000;
    margin-top: 5px;
  }
  .items-table th, .items-table td {
    border: 1px solid #000;
    padding: 5px 4px;
    font-size: 11px;
    vertical-align: middle;
  }
  .items-table th {
        background: #6c63a8;
    color: #ffffff;
    text-align: center;
    font-weight: bold;
  }
  .items-table .center { text-align: center; }
  .items-table .right  { text-align: right; }
  .items-table .left   { text-align: left; }

  /* ── Grand total row ───────────────────────── */
  .gt-row td {
    padding: 4px 4px;
     background: #6c63a8;
    color: #ffffff;
    font-size: 11px;
    font-weight: bold;
  }
  .gt-row .t-label { text-align: left; }
  .gt-row .t-value { text-align: right; }

  /* ── Single-row bordered boxes ─────────────── */
  .box-row {
    border: 1px solid #000;
    padding: 4px 5px;
    font-size: 11px;
  }
  .box-row1 {
    border: 1px solid #000;
    border-top: none;
    padding: 4px 5px;
    font-size: 11px;
        margin-bottom:6px;
  }
  .box-row .lbl { font-weight: bold; }

  .terms-body { white-space: pre-wrap; }

  /* ── Closing note ──────────────────────────── */
  .closing {
    margin-top: 8px;
    font-size: 11px;
  }
  .thanks { margin-top: 22px; font-size: 11px; }
  .signer { margin-top: 14px; font-size: 11px; font-weight: bold; }

  /* ── Stamp ─────────────────────────────────── */
  .stamp-area {
    margin-top: 10px;
    text-align: center;
  }
  .stamp-area img {
    max-height: 130px;
    object-fit: contain;
  }
</style>
</head>
<body>

<div class="page">

  <!-- Top header: To / Title / Ref-Date -->
  <table class="top-header">
    <colgroup>
      <col style="width:38%">
      <col style="width:32%">
      <col style="width:30%">
    </colgroup>
    <tr>
      <td>
        <div class="to-block">
          <div>To,</div>
          <div class="nm">{{billing_address.[0].name}}</div>
          <div>
            {{billing_address.[0].address_line1}}
            {{#if billing_address.[0].address_line2}}, {{billing_address.[0].address_line2}}{{/if}}
            {{#if billing_address.[0].address_line3}}, {{billing_address.[0].address_line3}}{{/if}}
            {{#if billing_address.[0].address_line4}}, {{billing_address.[0].address_line4}}{{/if}}
            {{#if billing_address.[0].address_line5}}, {{billing_address.[0].address_line5}}{{/if}}
          </div>
      </td>
      <td>
        <div class="qtn-badge">QUOTATION</div>
      </td>
      <td>
        <table class="ref-table">
          <tr>
            <td class="lbl">Ref#</td>
            <td class="val">{{basicdetails.[0].inv_no}}</td>
          </tr>
          <tr>
            <td class="lbl">Date</td>
            <td class="val">{{basicdetails.[0].inv_date}}</td>
          </tr>
        </table>
      </td>
    </tr>
  </table>

  <!-- Three-column info table -->
  <table class="info-table">
    <colgroup>
      <col style="width:33.33%">
      <col style="width:33.33%">
      <col style="width:33.34%">
    </colgroup>
    <thead>
      <tr>
        <th>{{compprof.name}} Sales</th>
        <th>Requested by</th>
        <th>Payment Terms</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>{{basicdetails.[0].employeename}}</td>
        <td>{{basicdetails.[0].contactname}}</td>
        <td rowspan="4">{{{nl2br basicdetails.[0].payment_terms}}}</td>
      </tr>
      <tr>
        <td>{{basicdetails.[0].employeecontactno}}</td>
        <td>{{customer_details.[0].contact_no1}}</td>
      </tr>
      <tr>
        <td>{{basicdetails.[0].employeeemail}}</td>
        <td>{{customer_details.[0].email}}</td>
      </tr>
      <tr>
        <td></td>
        <td>{{billing_address.[0].address_line4}}{{#if billing_address.[0].address_line5}},{{billing_address.[0].address_line5}}{{/if}}</td>
      </tr>
    </tbody>
  </table>

  <!-- Items Table -->
  <table class="items-table">
    <colgroup>
      <col style="width:6%">
      <col style="width:16%">
      <col style="width:40%">
      <col style="width:8%">
      <col style="width:15%">
      <col style="width:15%">
    </colgroup>
    <thead>
      <tr>
        <th>Sl No</th>
        <th>Part No</th>
        <th>Part Description</th>
        <th>Qty</th>
        <th>Unit Rate({{basicdetails.[0].base_country_isocode}})</th>
        <th>Sub({{basicdetails.[0].base_country_isocode}})</th>
      </tr>
    </thead>
    <tbody>
      {{#each itemdetails}}
      <tr>
        <td class="center">{{addOne @index}}</td>
        <td class="left">{{item_code}}</td>
        <td class="left">
          {{item_name}}
          {{#if name_lang2}}<div style="direction:rtl;">{{name_lang2}}</div>{{/if}}
          {{#if description}}<div style="direction:rtl;">{{description}}</div>{{/if}}
        </td>
        <td class="center">{{formatAmount quantity ../bcdp}}</td>
        <td class="right">{{formatAmount price ../bcdp}}</td>
        <td class="right">{{formatAmount amount ../bcdp}}</td>
      </tr>
      {{/each}}
      <tr class="gt-row">
        <td colspan="3" style="border:none;border-left:none !important; background:#ffffff;"></td>
        <td colspan="2" class="t-label" style="border: 1px solid #000;">Grand Total ({{basicdetails.[0].base_country_isocode}})</td>
        <td class="t-value" style="border: 1px solid #000;">{{formatAmount (divide basicdetails.[0].grand_total ccrate) bcdp}}</td>
      </tr>
    </tbody>
  </table>

  <!-- Amount in Words box -->
  <div class="box-row1"><span class="lbl" style="font-weight: bold;">Total Amount in Words</span> {{bcamountinwords}}</div>

  <!-- Terms box -->
  <div class="box-row">
    <div class="lbl">TERMS &amp; CONDITIONS:</div>
    <div class="terms-body">{{nl2br basicdetails.[0].terms_and_condition}}</div>
  </div>

  <!-- Closing note -->
  <div class="closing">We hope our offer is in line with your requirements and awaiting your favorable reply in this regard.</div>

  <div class="thanks">Thank You</div>
  <div class="signer">{{basicdetails.[0].employeename}}</div>

  <!-- Stamp --> exacl
  {{#if seal}}
  <div class="stamp-area">
    <img src="{{Seal}}" alt="Seal" style="max-height:{{default datasettings.d459 '40'}}px; max-width:{{default datasettings.d459 '60'}}px;" onerror="this.style.display='none'"/> 
  </div>
  {{/if}}

</div>

</body>
</html>
