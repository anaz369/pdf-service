<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Quotation - {{basicdetails.[0].inv_no}}</title>

<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: #ffffff;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 11px;
    color: #222;
    line-height: 1.4;
    margin: 0 6mm;
  }

  .page { width: 100%; margin: 0 auto; }

  /* ── Title ─────────────────────────────────── */
  .main-title {
    text-align: center;
    font-size: 22px;
    font-weight: bold;
    color: #d92121;
    margin: 8px 0;
    padding-bottom: 8px;
    border-bottom: 1px solid #d9d9d9;
  }
  .main-title .ar {
    direction: rtl;
    unicode-bidi: embed;
    margin-right: 4px;
  }

  /* ── Header (two columns) ──────────────────── */
  .header-row {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
    margin-top: 10px;
  }
  .header-row > tbody > tr > td {
    vertical-align: top;
    padding: 0;
    border: none;
  }
  .header-row > tbody > tr > td:first-child { padding-right: 5px; }
  .header-row > tbody > tr > td:last-child  { padding-left: 5px; }

  .info-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
    border: 1px solid #000;
  }
  .info-table td {
    border: 1px solid #000;
    padding: 6px 8px;
    vertical-align: middle;
    font-size: 11px;
  }
  .info-table .lbl {
    background: #ededed;
    font-weight: bold;
    text-align: center;
    width: 25%;
  }

  /* ── Items table ───────────────────────────── */
  .items-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
    border: 1px solid #000;
    margin-top: 10px;
  }
  .items-table th, .items-table td {
    border: 1px solid #000;
    padding: 6px 6px;
    font-size: 11px;
    vertical-align: middle;
  }
  .items-table th {
    text-align: center;
    font-weight: bold;
    background: #ffffff;
  }
  .items-table .center { text-align: center; }
  .items-table .right  { text-align: right; }
  .items-table .left   { text-align: left; }

  /* ── Grand Total row ───────────────────────── */
  .gt-row td {
    border: 1px solid #000;
    padding: 6px 8px;
    font-size: 11px;
    font-weight: bold;
  }
  .gt-row .t-lbl { text-align: right; }
  .gt-row .t-val { text-align: right; }
  .gt-row .blank { border: none; }

  /* ── Terms ─────────────────────────────────── */
  .terms-body {
    margin-top: 14px;
    font-size: 11px;
    white-space: pre-wrap;
  }
</style>
</head>
<body>

<div class="page">

  <!-- Title -->
  <div class="main-title">QUOTATION / <span class="ar" style="color: #000;">اقتباس</span></div>

  <!-- Header -->
  <table class="header-row">
    <colgroup>
      <col style="width:50%">
      <col style="width:50%">
    </colgroup>
    <tr>
      <td>
        <table class="info-table">
          <tr>
            <td class="lbl">Date</td>
            <td>{{basicdetails.[0].inv_date}}</td>
          </tr>
          <tr>
            <td class="lbl">To</td>
            <td>{{billing_address.[0].name}}</td>
          </tr>
          <tr>
            <td class="lbl">Attn</td>
            <td>{{basicdetails.[0].attention}}</td>
          </tr>
          <tr>
            <td class="lbl">Address</td>
            <td>
              {{billing_address.[0].address_line1}}{{#if billing_address.[0].address_line2}}{{billing_address.[0].address_line2}}{{/if}}{{#if billing_address.[0].address_line3}}{{billing_address.[0].address_line3}}{{/if}}{{#if billing_address.[0].address_line4}}{{billing_address.[0].address_line4}}{{/if}}{{#if billing_address.[0].address_code}}{{billing_address.[0].address_code}}{{/if}}
            </td>
          </tr>
          <tr>
            <td class="lbl">Email</td>
            <td>{{customer_details.[0].email}}</td>
          </tr>
        </table>
      </td>
      <td>
        <table class="info-table">
          <tr>
            <td class="lbl">From</td>
            <td>{{compprof.name}}</td>
          </tr>
          <tr>
            <td class="lbl">Email</td>
            <td>{{compprof.email}}</td>
          </tr>
          <tr>
            <td class="lbl">Ref</td>
            <td>{{basicdetails.[0].inv_no}}</td>
          </tr>
        </table>
      </td>
    </tr>
  </table>

  <!-- Items Table -->
  <table class="items-table">
    <colgroup>
      <col style="width:8%">
      <col style="width:38%">
      <col style="width:10%">
      <col style="width:9%">
      <col style="width:17%">
      <col style="width:18%">
    </colgroup>
    <thead>
      <tr>
        <th>Sl No</th>
        <th>Material</th>
        <th>Unit</th>
        <th>Qty</th>
        <th>Unit Price</th>
        <th>Amount</th>
      </tr>
    </thead>
    <tbody>
      {{#each itemdetails}}
      <tr>
        <td class="center">{{addOne @index}}</td>
        <td class="left">
          {{item_name}}
          {{#if name_lang2}}<div style="direction:rtl;">{{name_lang2}}</div>{{/if}}
          {{#if description}}<div>{{description}}</div>{{/if}}
        </td>
        <td class="center">{{unit}}</td>
        <td class="center">{{formatAmount quantity ../bcdp}}</td>
        <td class="right">{{formatAmount price ../bcdp}}</td>
        <td class="right">{{formatAmount amount ../bcdp}}</td>
      </tr>
      {{/each}}
      <tr class="gt-row">
        <td colspan="4" class="blank"></td>
        <td class="t-lbl">Grand Total</td>
        <td class="t-val">{{formatAmount (divide basicdetails.[0].grand_total ccrate) bcdp}}</td>
      </tr>
    </tbody>
  </table>

  <!-- Terms -->
  {{#if basicdetails.[0].terms_and_condition}}
  <div class="terms-body">{{nl2br basicdetails.[0].terms_and_condition}}</div>
  {{/if}}

</div>

</body>
</html>
