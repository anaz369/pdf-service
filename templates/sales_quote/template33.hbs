<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Quotation - {{basicdetails.[0].inv_no}}</title>

<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }


  body {
    background: #ffffff;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 11px;
    color: #222;
    line-height: 1.4;
    margin: 0 6mm;
  }

  .page { width: 100%; margin: 0 auto; }

  /* ── Title ─────────────────────────────────── */
  .main-title {
    text-align: center;
    font-family: "Times New Roman", Times, serif;
    font-size: 20px;
    font-weight: bold;
    margin: 4px 0 14px;
  }

  /* ── Header Info Table ─────────────────────── */
  .info-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
    border: 1px solid #bfbfbf;
  }
  .info-table td {
    border: 1px solid #bfbfbf;
    padding: 4px 4px;
    vertical-align: top;
    font-size: 11px;
  }
  .info-table .lbl {
    background: #f2f2f2;
    font-weight: bold;
    width: 18%;
  }
  .info-table .val { width: 32%; }

  /* ── Items table ───────────────────────────── */
  .items-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
    border: 1px solid #000;
    margin-top: 16px;
  }
  .items-table th, .items-table td {
    border: 1px solid #000;
    padding: 5px 4px;
    font-size: 11px;
    vertical-align: middle;
  }
  .items-table th {
    text-align: center;
    font-weight: bold;
    background: #ffffff;
  }
  .items-table .center { text-align: center; }
  .items-table .right  { text-align: right; }
  .items-table .left   { text-align: left; }

  /* ── Totals (right-aligned mini table) ──────── */
  .totals-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
  }
  .totals-table td {
    padding: 5px 5px;
    font-size: 11px;
    vertical-align: middle;
  }
  .totals-table .t-lbl {
    border: 1px solid #000;
    font-weight: bold;
    text-align: right;
  }
  .totals-table .t-lbl1,
  .totals-table .t-val1 {
    border: 1px solid #000;
    border-top: none;
    font-weight: bold;
    text-align: right;
  }
  .totals-table .t-val {
    border: 1px solid #000;
    font-weight: bold;
    text-align: right;
  }
  .totals-table .t-blank { border: none; }
  .totals-table .t-foot {
    border: 1px solid #000;
    border-top: none;
    font-weight: bold;
    text-align: right;
  }

  /* ── Terms ─────────────────────────────────── */
  .terms-wrap { margin-top: 18px; }
  .terms-title {
    font-weight: bold;
    text-decoration: underline;
    margin-bottom: 4px;
  }
  .terms-body { white-space: pre-wrap; }

  /* ── Footer admin ──────────────────────────── */
  .signer {
    margin-top: 18px;
    font-weight: bold;
    font-size: 11px;
  }
  .mob {
    margin-top: 10px;
    font-size: 11px;
  }
  .mob-email { font-size: 11px; }

  /* ── Stamp / Signature ─────────────────────── */
  .stamp-sig {
    margin-top: 12px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 8px;
  }
  .stamp-sig img {
    display: block;
    max-height: 100px;
    object-fit: contain;
  }
  .stamp-sig .sign-img { max-height: 80px; }
  .pageNumber::before {
  content: counter(page);
}

.totalPages::before {
  content: counter(pages);
}
</style>
</head>
<body>

<div class="page">

  <!-- Title -->
  <div class="main-title">QUOTATION</div>

  <!-- Header Info Table -->
  <table class="info-table">
    <tr>
      <td class="lbl">Company</td>
      <td class="val">{{billing_address.[0].name}}</td>
      <td class="lbl">Date</td>
      <td class="val">{{basicdetails.[0].inv_date}}</td>
    </tr>
    <tr>
      <td class="lbl">Customer Address</td>
      <td class="val">
        {{#if billing_address.[0].address_line1}}<div>{{billing_address.[0].address_line1}}</div>{{/if}}
        {{#if billing_address.[0].address_line2}}<div>{{billing_address.[0].address_line2}}</div>{{/if}}
        {{#if billing_address.[0].address_line3}}<div>{{billing_address.[0].address_line3}}</div>{{/if}}
        {{#if billing_address.[0].address_line4}}<div>{{billing_address.[0].address_line4}}</div>{{/if}}
        {{#if billing_address.[0].address_line5}}<div>{{billing_address.[0].address_line5}}</div>{{/if}}
        {{#if billing_address.[0].address_code}}<div>{{billing_address.[0].address_code}}</div>{{/if}}
      </td>
      <td class="lbl">Contact Person Name</td>
      <td class="val">{{basicdetails.[0].contactname}}</td>
    </tr>
    <tr>
      <td class="lbl">VAT No</td>
      <td class="val">{{billing_address.[0].vat}}</td>
      <td class="lbl">Tel No</td>
      <td class="val">{{customer_details.[0].contact_no1}}</td>
    </tr>
    <tr>
      <td class="lbl">Attention</td>
      <td class="val">{{basicdetails.[0].attention}}</td>
      <td class="lbl">Mob</td>
      <td class="val">{{customer_details.[0].contact_no2}}</td>
    </tr>
    <tr>
      <td class="lbl">Your Ref</td>
      <td class="val">{{basicdetails.[0].reference_no}}</td>
      <td class="lbl">Our Ref</td>
      <td class="val">{{basicdetails.[0].inv_no}}</td>
    </tr>
    <tr>
      <td class="lbl">Subject</td>
      <td class="val">{{basicdetails.[0].subj}}</td>
      <td class="lbl">Pages</td>
      <td class="val"><span class="pageNumber"></span>/<span class="totalPages"></span></td>
    </tr>
  </table>

  <!-- Items Table -->
  <table class="items-table">
    <colgroup>
      <col style="width:5%">
      <col style="width:31%">
      <col style="width:7%">
      <col style="width:6%">
      <col style="width:11%">
      <col style="width:7%">
      <col style="width:9%">
      <col style="width:11%">
      <col style="width:13%">
    </colgroup>
    <thead>
      <tr>
        <th>SL</th>
        <th>Description</th>
        <th>UOM</th>
        <th>QTY</th>
        <th>Unit Rate</th>
        <th>VAT %</th>
        <th>VAT Amount</th>
        <th>Total Price Without VAT</th>
        <th>Total Price With VAT</th>
      </tr>
    </thead>
    <tbody>
      {{#each itemdetails}}
      <tr>
        <td class="center">{{addOne @index}}</td>
        <td class="left">
          {{item_name}}
          {{#if name_lang2}}<div style="direction:rtl;">{{name_lang2}}</div>{{/if}}
          {{#if description}}<div>{{description}}</div>{{/if}}
        </td>
        <td class="center">{{unit}}</td>
        <td class="center">{{formatAmount quantity ../bcdp}}</td>
        <td class="right">{{formatAmount price ../bcdp}}</td>
        <td class="center">{{vat_perc}}%</td>
        <td class="right">{{formatAmount vat_amt ../bcdp}}</td>
        <td class="right">{{formatAmount taxable ../bcdp}}</td>
        <td class="right">{{formatAmount amount ../bcdp}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>

  <!-- Totals (right side) -->
  <table class="totals-table">
    <colgroup>
      <col style="width:87%">
      <col style="width:13%">
    </colgroup>
    <tr style="border-top: none;">
      <td class="t-lbl1">Total Cost</td>
      <td class="t-val1">{{formatAmount (divide basicdetails.[0].subtotal ccrate) bcdp}}</td>
    </tr>
    <tr>

      <td class="t-lbl">Total Amount Without VAT</td>
      <td class="t-val">{{formatAmount (divide (subtract basicdetails.[0].subtotal basicdetails.[0].discount) ccrate) bcdp}}</td>
    </tr>
    <tr>

      <td class="t-lbl">VAT Total</td>
      <td class="t-val">{{formatAmount (divide basicdetails.[0].vatamt ccrate) bcdp}}</td>
    </tr>
    <tr>

      <td class="t-lbl">Grand Total</td>
      <td class="t-val">{{formatAmount (divide basicdetails.[0].grand_total ccrate) bcdp}}</td>
    </tr>
  </table>

  <!-- Terms -->
  <div class="terms-wrap">
    <div class="terms-title">TERMS &amp; CONDITIONS:</div>
    <div class="terms-body">{{nl2br basicdetails.[0].terms_and_condition}}</div>
  </div>

  <!-- Footer admin -->
  <div class="signer">{{basicdetails.[0].employeename}}</div>
  <div class="mob">Mob:{{basicdetails.[0].employeecontactno}}</div>
  <div class="mob-email">Email: {{basicdetails.[0].employeeemail}}</div>

  <!-- Stamp & Signature (signature directly under seal) -->
  <div class="stamp-sig">
    {{#if seal}}
    <img class="seal-img" src="{{Seal}}" alt="Seal" style="max-height:{{default datasettings.d459 '120'}}px; max-width:{{default datasettings.d459 '180'}}px;" onerror="this.style.display='none'"/>
    {{/if}}
    {{#if signature}}
    <img class="sign-img" src="{{Signature}}" alt="Signature" style="max-height:{{default datasettings.d458 '120'}}px; max-width:{{default datasettings.d458 '180'}}px;" onerror="this.style.display='none'"/>
    {{/if}}
  </div>

</div>

</body>
</html>
