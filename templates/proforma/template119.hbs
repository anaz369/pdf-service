<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>INVOICE - {{basicdetails.[0].inv_no}}</title>
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        font-family: "IBM Plex Sans Arabic", Arial, sans-serif;
        font-size: 9px;
        line-height: 1.3;
        color: #000;
        margin: 0 4mm;
      }

      .ar {
        direction: rtl;
      }

      table {
        border-collapse: collapse;
        width: 100%;
        table-layout: fixed;
      }

      /* ── TITLE ────────────────────────────────────── */
      .doc-title {
        text-align: center;
        font-size: 20px;
        font-weight: 800;
        color: #b72031;
        margin-bottom: 6px;
      }
      .doc-title .ar{
         color: #606261;
      }

      /* ── TOP : BUYER | INFO ───────────────────────── */
      .top-wrap > tbody > tr > td {
        vertical-align: top;
        border: none;
        padding: 0 4px;
      }
      .buyer,
      .info {
        
      }
      .buyer td,
      .info td {
        font-size: 9.5px;
        border: 1px solid #bfbfbf;
        padding: 4px 6px;
        vertical-align: middle;
      }
      .buyer td.lbl {
        font-weight: 700;
      }
      .info td.lbl {
        background-color:#ccc;
        font-weight: 700;
        width: 30%;
      }
      .info td.arl {
        background-color:#ccc;
        font-weight: 700;
      }
      .buyer td.arl,
      .info td.arl {
        font-weight: 700;
        text-align: right;
        direction: rtl;
        width: 24%;
      }

      /* ── ITEMS TABLE ──────────────────────────────── */
      .items-table {
        margin-top: 8px;
      }
      .items-table th,
      .items-table td {
        font-size: 9px;
        border: 1px solid #bfbfbf;
        padding: 3px 5px;
        vertical-align: top;
      }
      .items-table thead th {
        font-size: 10px;
        text-align: center;
        line-height: 1.2;
      }
      .items-table thead th .ar {
        display: block;
        direction: rtl;
        font-weight: 700;
      }
      .items-table thead th .en {
        display: block;
        font-weight: 700;
      }
      .items-table td.num {
        text-align: center;
      }
      .items-table td.right {
        text-align: right;
      }

      /* ── MID : QR | TOTALS ────────────────────────── */
      .mid {
        margin-top: 8px;
      }
      .mid > tbody > tr > td {
        vertical-align: top;
        padding: 0;
      }
      .mid .qrcell {
        text-align: center;
        vertical-align: middle;
        padding: 6px;
      }
      .mid .qrcell .qr-wrap {
        width: 120px;
        height: 120px;
        margin: 0 auto;
        overflow: hidden;
      }
      .mid .qrcell .qr-wrap img {
        width: 100%;
        height: auto;
        max-width: 120px;
        max-height: 120px;
      }
      .totals2 td {
        border: 1px solid #bfbfbf;
        padding: 5px 8px;
        font-size: 9.5px;
        vertical-align: middle;
      }
      .totals2 .tl {
        width: 72%;
      }
      .totals2 .tl .ar {
        float: right;
        direction: rtl;
      }
      .totals2 .tv {
        text-align: right;
        width: 28%;
      }
      .totals2 .b .tl,
      .totals2 .b .tv {
        font-weight: 700;
      }

      /* ── AMOUNT IN WORDS ──────────────────────────── */
      .words-bar {
        margin-top: 6px;
      }
      .words-bar td {
        font-size: 9.5px;
        border: 1px solid #bfbfbf;
        padding: 5px 8px;
      }
      .words-bar .words-en {
        width: 55%;
      }
      .words-bar .words-ar {
        width: 45%;
        text-align: right;
        direction: rtl;
      }

      /* ── FOOTER : BANK | SIGNATURES ───────────────── */
      .footer{
          width:100%;
          border-collapse:collapse;
          table-layout:fixed;
          margin-top:8px;
      }

      .footer td{
          border:1px solid #000;
          padding:5px;
          font-size:10px;
          vertical-align:top;
      }

      .footer .fhd{
          background:#d9d9d9;
          padding:4px 8px;
      }

      .footer .fhd table{
          width:100%;
          border-collapse:collapse;
      }

      .footer .fhd table td{
          border:none;
          padding:0;
      }

      .sig{
          height:110px;
          text-align:center;
          vertical-align:middle!important;
      }

      .sig img{
          max-width:120px;
          max-height:95px;
      }

      .bank-lines{
          font-size:9.5px;
          width:100%;
          border-collapse:collapse;
      }

      .bank-lines td{
        font-size:9.5px;
          border:none;
          padding:3px 2px;
      }

      .bank-lines .bc{
          text-align:center;
      }

      .rb .ar{
        text-align: left;

      }

      /* ── FOOTER BLOCK : keep together, else move to next page ── */

      .footer-block{
          page-break-inside: avoid;
          break-inside: avoid;
      }

      /* ── FOOTER NOTE ──────────────────────────────── */
      .note-text {
        text-align: center;
        font-weight: 700;
        font-size: 11px;
        color: #b72031;
        margin-top: 8px;
      }
    </style>
  </head>
  <body>

    <!-- TITLE -->
    <div class="doc-title">PROFORMA INVOICE / <span class="ar">فاتورة أولية</span></div>

    <!-- TOP : BUYER | INFO -->
    <table class="top-wrap">
      <tr>
        <!-- BUYER DETAILS -->
        <td style="width:58%">
          <table class="buyer">
            <colgroup>
                <col style="width:20%;">
                <col style="width:60%;">
                <col style="width:20%;">
            </colgroup>
            <tr>
              <td style="border: 1px solid #bfbfbf;border-right:none;font-weight:700;">BUYER DETAILS</td>
              <td style="border: 1px solid #bfbfbf;border-right:none;border-left:none;"></td>
              <td style="border: 1px solid #bfbfbf;border-left:none;font-weight:700;" class="ar">تفاصيل العميل</td>
            </tr>
            <tr>
              <td class="lbl">Name</td>
              <td>{{billing_address.[0].name}}</td>
              <td class="arl">الاسم</td>
            </tr>
            <tr>
              <td class="lbl">VAT Number</td>
              <td>{{billing_address.[0].vat}}</td>
              <td class="arl">الرقم الضريبي</td>
            </tr>
            <tr>
              <td class="lbl">Contact No</td>
              <td>{{customer_details.[0].contact_no1}}</td>
              <td class="arl">رقم الاتصال</td>
            </tr>
            <tr>
              <td class="lbl">Address</td>
              <td>{{joinAddress billing_address.[0] ', '}}</td>
              <td class="arl">العنوان</td>
            </tr>
          </table>
        </td>

        <!-- INFO -->
        <td style="width:42%">
          <table class="info">
            <tr><td class="lbl">Invoice No</td><td style="text-align: center;">{{basicdetails.[0].inv_no}}</td><td class="arl">رقم الفاتورة</td></tr>
            <tr><td class="lbl">Invoice Date</td><td style="text-align: center;">{{basicdetails.[0].inv_date}}</td><td class="arl">تاريخ الفاتورة</td></tr>
            <tr><td class="lbl">PO No</td><td style="text-align: center;">{{basicdetails.[0].order_no}}</td><td class="arl">رقم أمر الشراء</td></tr>
            <tr><td class="lbl">PO Date</td><td style="text-align: center;">{{basicdetails.[0].po_date}}</td><td class="arl">تاريخ أمر الشراء</td></tr>
            <tr><td class="lbl">Delivery Terms</td style="text-align: center;"><td></td><td class="arl">شروط التسليم</td></tr>
            <tr><td class="lbl">Payment Terms</td><td style="text-align: center;">{{basicdetails.[0].payment_terms}}</td><td class="arl">شروط الدفع</td></tr>
          </table>
        </td>
      </tr>
    </table>

    <!-- ITEMS TABLE -->
    <table class="items-table">
      <thead>
        <tr>
          <th style="width:4%"><span class="ar">م</span><span class="en">S.N</span></th>
          <th style="width:10%"><span class="ar">رمز العنصر</span><span class="en">Itemcode</span></th>
          <th style="width:27%"><span class="ar">الوصف</span><span class="en">Description</span></th>
          <th style="width:8%"><span class="ar">الكمية</span><span class="en">QTY</span></th>
          <th style="width:8%"><span class="ar">الوحدة</span><span class="en">Unit</span></th>
          <th style="width:10%"><span class="ar">سعر الوحدة</span><span class="en">U.Rate</span></th>
          <th style="width:10%"><span class="ar">مبلغ</span><span class="en">Amount</span></th>
          <th style="width:11%"><span class="ar">قيمة الضريبة</span><span class="en">VAT Value</span></th>
          <th style="width:12%"><span class="ar">القيمة الاجمالي</span><span class="en">Total Price</span></th>
        </tr>
      </thead>
      <tbody>
        {{#each itemdetails}}
        <tr>
          <td class="num">{{addOne @index}}</td>
          <td class="num">{{item_code}}</td>
          <td>{{item_name}}{{name_lang2}}{{description}}</td>
          <td class="num">{{formatAmount quantity ../bcdp}}</td>
          <td class="num">{{unit}}</td>
          <td class="right">{{formatAmount price ../bcdp}}</td>
          <td class="right">{{formatAmount taxable ../bcdp}}</td>
          <td class="right">{{formatAmount vat_amt ../bcdp}}</td>
          <td class="right">{{formatAmount amount ../bcdp}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>

    <!-- MID : BANK DETAILS | TOTALS -->
    <table class="mid">
      <tr>
        <td style="width:50%;padding:0;vertical-align:top;">
          <table style="border-collapse:collapse;width:100%;table-layout:fixed;border:1px solid #bfbfbf;">
            <tr>
              <td style="border-bottom:1px solid #bfbfbf;padding:5px 8px;font-weight:700;font-size:9.5px;">
                Bank Details <span class="ar" style="float:right;">تفاصيل البنك</span>
              </td>
            </tr>
            <tr>
                <td style="padding:5px 8px;">
                    <table class="bank-lines" style="font-size:9.5px;">
                        <colgroup>
                            <col style="width:29%;">
                            <col style="width:2%;">
                            <col style="width:69%;">
                        </colgroup>
                    <tr><td class="bl" style="padding:5px 2px;">Bank Name</td><td class="bc" style="padding:5px 2px;">:</td><td style="padding:5px 2px;">{{bankdetails.name}}</td></tr>
                    <tr><td class="bl" style="padding:5px 2px;">A/C Name</td><td class="bc" style="padding:5px 2px;">:</td><td style="padding:5px 2px;">{{bankdetails.acc_name}}</td></tr>
                    <tr><td class="bl" style="padding:5px 2px;">A/C No</td><td class="bc" style="padding:5px 2px;">:</td><td style="padding:5px 2px;">{{bankdetails.acc_no}}</td></tr>
                    <tr><td class="bl" style="padding:5px 2px;">IBAN</td><td class="bc" style="padding:5px 2px;">:</td><td style="padding:5px 2px;">{{bankdetails.iban_no}}</td></tr>
                    <tr><td class="bl" style="padding:5px 2px;">SWIFT</td><td class="bc" style="padding:5px 2px;">:</td><td style="padding:5px 2px;">{{bankdetails.swift_no}}</td></tr>
                    </table>
                </td>
            </tr>
          </table>
        </td>
        <td style="width:50%;padding:0;vertical-align:top">
          <table class="totals2">
            <tr>
              <td class="tl">Total Amount Excl. VAT / <span>المجموع الفرعي</span></td>
              <td class="tv">{{formatAmount (divide basicdetails.[0].subtotal ccrate) bcdp}}</td>
            </tr>
            {{#if zatcadiscount.[0]}}
              {{#each zatcadiscount}}
                <tr>
                  <td class="tl">{{reason_name}} / <span>{{reason_name_lang2}}</span></td>
                  <td class="tv">{{formatAmount (divide dld ../ccrate) ../bcdp}}</td>
                </tr>
                {{/each}}
                <tr class="b">
                  <td class="tl">Total Amount Excl. VAT / <span>صافي المجموع</span></td>
                  <td class="tv">{{formatAmount (divide (subtract basicdetails.[0].subtotal zatcadiscount.[0].dld) ccrate) bcdp}}</td>
                </tr>
            {{else}}

              {{#if (or basicdetails.[0].discount basicdetails.[0].dld)}}
              <tr>
                <td class="tl">Discount / <span>الخصم</span></td>
                <td class="tv">{{formatAmount (divide (add basicdetails.[0].discount basicdetails.[0].dld) ccrate) bcdp}}</td>
              </tr>
              <tr class="b">
                <td class="tl">Total Amount Excl. VAT / <span>المبلغ الإجمالي بدون ضريبة القيمة</span></td>
                <td class="tv">{{formatAmount (divide (subtract basicdetails.[0].subtotal (add basicdetails.[0].discount basicdetails.[0].dld)) ccrate) bcdp}}</td>
              </tr>
              {{/if}}

          {{/if}}
            <tr>
              <td class="tl">VAT / <span>ضريبة القيمة المضافة</span></td>
              <td class="tv">{{formatAmount (divide basicdetails.[0].vatamt ccrate) bcdp}}</td>
            </tr>
            <tr class="b">
              <td class="tl">Total Amount Incl. VAT / <span>المبلغ الإجمالي شامل ضريبة القيمة</span></td>
              <td class="tv">{{formatAmount (divide basicdetails.[0].grand_total ccrate) bcdp}}</td>
            </tr>
          </table>
        </td>
      </tr>
    </table>

    <!-- AMOUNT IN WORDS -->
    <table class="words-bar">
        <tr>
            <td class="words-en">{{bcamountinwords}}</td>
            <td class="words-ar">{{bcamountinwordsar}}</td>
        </tr>
        <tr>
            <td class="words-en" style="font-weight: bold;" colspan="2">Terms and Conditions :-</td>
        </tr>
        <tr>
            <td class="words-ar" colspan="2">{{basicdetails.[0].terms_and_condition}}</td>
        </tr>
    </table>
  </body>
</html>
