<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>PROFORMA INVOICE - {{basicdetails.[0].inv_no}}</title>
    <style>
      *,
      *::before,
      *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: "IBM Plex Sans Arabic", Arial, sans-serif;
        font-size: 9px;
        line-height: 1.3;
        color: #000;
        margin: 0 4mm;
      }

      .ar { direction: rtl; }

      table { border-collapse: collapse; width: 100%; table-layout: fixed; }

      /* ── TITLE ─────────────────────────────── */
      .doc-title {
        text-align: center;
        font-size: 18px;
        font-weight: 800;
        color: red;
        margin-bottom: 6px;
      }

      /* ── GENERIC BORDERED CELLS ────────────── */
      .bx { border-collapse: collapse; width: 100%; table-layout: fixed; }
      .bx td { border: 1px solid #ccc; padding: 3px 5px; font-size: 9px; vertical-align: top; }
      .lbl { font-weight: 700; }
      .c { text-align: center; }
      .r { text-align: right; }

      .mt { margin-top: 6px; }

      .naked { border: none; }
      .naked > tbody > tr > td { border: none; padding: 0; vertical-align: top; }
      .gap { width: 1%; }

      /* ── ITEMS ─────────────────────────────── */
      .items td, .items th { border: 1px solid #ccc; padding: 3px 5px; font-size: 9px; vertical-align: top; }
      .items thead th { text-align: center; line-height: 1.2; color:#202940;}
      .items thead th .en { display: block; font-weight: 700; }
      .items thead th .ar { display: block; direction: rtl; font-weight: 700; }
      .items td.num { text-align: center; }
      .items td.r { text-align: right; }

      /* ── BANK + TOTALS ─────────────────────── */
      .inb { border-collapse: collapse; width: 100%; table-layout: fixed; }
      .inb td { padding: 3px 5px; font-size: 9px; vertical-align: top; }
      .inb .hdc { text-align: center; font-weight: 700; }

      .tot td {  padding: 3px 5px; font-size: 9px; vertical-align: top; }
      .tot .t-ar { direction: rtl; text-align: right; }
      .tot .t-val { text-align: right;}

      .words-ar-full { direction: rtl; text-align: center; font-size: 9px; }

      /* ── SIGNATURE ─────────────────────────── */
      .sign td { border: 1px solid #ccc; font-size: 9px; vertical-align: top; }
      .sign .sh { text-align: center; padding: 4px 5px; }
      .sign .sh .en { display: block; font-weight: 700; }
      .sign .sh .ar { display: block; direction: rtl; }
      .sign .sbody { height: 120px; text-align: center; vertical-align: middle; padding: 5px; }
      .sign .sbody img { max-width: 130px; max-height: 105px; }

      .footer-block { page-break-inside: avoid; break-inside: avoid; }
    </style>
  </head>
  <body>

    <!-- TITLE -->
    <div class="doc-title">PROFORMA INVOICE / <span class="ar">فاتورة تجريبية</span></div>

    <!-- TOP : CUSTOMER | DOCUMENT -->
    <table class="naked">
      <colgroup>
        <col style="width:47%">
        <col class="gap">
        <col style="width:52%">
      </colgroup>
      <tr>
        <td>
          <table class="bx">
            <colgroup>
              <col style="width:50%">
              <col style="width:50%">
            </colgroup>
            <tr>
              <td class="lbl">Customer</td>
              <td class="r ar" style="font-weight: bold;">عميل</td>
            </tr>
            <tr>
              <td style="height:96px;">
                {{billing_address.[0].name}}<br>
                {{billing_address.[0].address_line1}}{{#if billing_address.[0].address_line1}}{{#if billing_address.[0].address_line2}}, {{/if}}{{/if}}{{billing_address.[0].address_line2}}<br>
                {{billing_address.[0].address_line3}}{{#if billing_address.[0].address_line3}}{{#if billing_address.[0].address_line4}}, {{/if}}{{/if}}{{billing_address.[0].address_line4}}<br>
                {{billing_address.[0].address_line5}}
                {{#if billing_address.[0].vat}}<br>VAT: {{billing_address.[0].vat}}{{/if}}
              </td>
              <td style="height:96px;text-align:right;">
                {{billing_address_lang2.[0].name}}<br>
                {{billing_address_lang2.[0].address_line1}}{{#if billing_address_lang2.[0].address_line1}}{{#if billing_address_lang2.[0].address_line2}}, {{/if}}{{/if}}{{billing_address_lang2.[0].address_line2}}<br>
                {{billing_address_lang2.[0].address_line3}}{{#if billing_address_lang2.[0].address_line3}}{{#if billing_address_lang2.[0].address_line4}}, {{/if}}{{/if}}{{billing_address_lang2.[0].address_line4}}<br>
                {{billing_address_lang2.[0].address_line5}}
                {{#if billing_address_lang2.[0].vat}}{{billing_address_lang2.[0].vat}} : رقم ضريبة {{/if}}
              </td>
            </tr>
          </table>
        </td>
        <td></td>
        <td>
          <table class="bx">
            <colgroup>
              <col style="width:25%">
              <col style="width:25%">
              <col style="width:25%">
              <col style="width:25%">
            </colgroup>
            <tr>
              <td class="lbl" colspan="2">Document No.</td>
              <td colspan="2">{{basicdetails.[0].inv_no}}</td>
            </tr>
            <tr>
              <td class="lbl" colspan="2">Document Date.</td>
              <td colspan="2">{{basicdetails.[0].inv_date}}</td>
            </tr>
            <tr>
              <td class="lbl" colspan="2">Reference No.</td>
              <td colspan="2">{{basicdetails.[0].reference_no}}</td>
            </tr>
            <tr>
              <td class="lbl" colspan="2">Purchase Order No.</td>
              <td colspan="2">{{basicdetails.[0].order_no}}</td>
            </tr>
            <tr>
              <td class="lbl">Partial <br><span class="ar">جزئي</span></td>
              <td></td>
              <td class="lbl">Complete <br><span class="ar">كمال</span></td>
              <td></td>
            </tr>
          </table>
        </td>
      </tr>
    </table>

    <!-- ITEMS -->
    <table class="items mt">
      <colgroup>
        <col style="width:5%">
        <col style="width:42%">
        <col style="width:9%">
        <col style="width:9%">
        <col style="width:12%">
        <col style="width:11%">
        <col style="width:12%">
      </colgroup>
      <thead>
        <tr>
          <th><span class="en">Item</span><span class="ar">عرض</span></th>
          <th><span class="en">Description</span><span class="ar">وصف</span></th>
          <th><span class="en">Quantity</span><span class="ar">كمية</span></th>
          <th><span class="en">UOM</span><span class="ar">وحدة القياس</span></th>
          <th><span class="en">Unit Price</span><span class="ar">سعر الوحدة</span></th>
          <th><span class="en">VAT Amount</span><span class="ar">مبلغ الضريبة</span></th>
          <th><span class="en">Total Amount</span><span class="ar">المبلغ الاجمالي</span></th>
        </tr>
      </thead>
      <tbody>
        {{#each itemdetails}}
        <tr>
          <td class="num">{{addOne @index}}</td>
          <td>{{item_name}}{{name_lang2}}{{#if description}} {{description}}{{/if}}</td>
          <td class="num">{{formatAmount quantity ../bcdp}}</td>
          <td class="num">{{unit}}</td>
          <td class="r">{{formatAmount price ../bcdp}}</td>
          <td class="r">{{formatAmount vat_amt ../bcdp}}</td>
          <td class="r">{{formatAmount taxable ../bcdp}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>

    <div class="footer-block">
    <!-- BANK DETAILS | TOTALS -->
    <table class="bx mt">
      <colgroup>
        <col style="width:48%">
        <col style="width:52%">
      </colgroup>
      <tr>
        <td style="padding:0;vertical-align:top;">
          <table class="inb">
            <colgroup>
              <col style="width:24%">
              <col style="width:76%">
            </colgroup>
            <tr><td class="hdc" colspan="2">BANK DETAILS</td></tr>
            <tr><td class="lbl">Bank Name</td><td>{{bankdetails.name}}</td></tr>
            <tr><td class="lbl">Account Name</td><td>{{bankdetails.acc_name}}</td></tr>
            <tr><td class="lbl">Branch</td><td>{{bankdetails.branch_name}}</td></tr>
            <tr><td class="lbl">A/C Number</td><td>{{bankdetails.acc_no}}</td></tr>
            <tr><td class="lbl">Swift Code</td><td>{{bankdetails.swift_no}}</td></tr>
            <tr><td class="lbl">IBAN No</td><td>{{bankdetails.iban_no}}</td></tr>
          </table>
        </td>
        <td style="padding:0;vertical-align:top;">
          <table class="tot">
            <colgroup>
              <col style="width:35%">
              <col style="width:47%">
              <col style="width:18%">
            </colgroup>
            <tr>
              <td class="t-en lbl">Sub Total</td>
              <td class="t-ar">المجموع الفرعي</td>
              <td class="t-val">{{formatAmount (divide basicdetails.[0].subtotal ccrate) bcdp}}</td>
            </tr>
            {{#if zatcadiscount.[0]}}
                {{#each zatcadiscount}}
                  <tr>
                    <td class="t-en lbl">{{reason_name}}</td>
                    <td class="t-ar">{{reason_name_lang2}}</td>
                    <td class="t-val">{{formatAmount (divide dld ../ccrate) bcdp}}</td>
                  </tr>
                {{/each}}
                  <tr>
                    <td class="t-en lbl">Total Amount Excluding VAT</td>
                    <td class="t-ar">المبلغ الإجمالي باستثناء ضريبة القيمة المضافة</td>
                    <td class="t-val">{{formatAmount (divide (subtract basicdetails.[0].subtotal zatcadiscount.[0].dld) ccrate) bcdp}}</td>
                  </tr>
                {{else}}

                  {{#if (or basicdetails.[0].discount basicdetails.[0].dld)}}
                  <tr>
                    <td class="t-en lbl">Discount</td>
                    <td class="t-ar">تخفيض</td>
                    <td class="t-val">{{formatAmount (divide (add basicdetails.[0].discount basicdetails.[0].dld) ccrate) bcdp}}</td>
                  </tr>
                  <tr>
                    <td class="t-en lbl">Total Amount Excluding VAT</td>
                    <td class="t-ar">المبلغ الإجمالي باستثناء ضريبة القيمة المضافة</td>
                    <td class="t-val">{{formatAmount (divide (subtract basicdetails.[0].subtotal (add basicdetails.[0].discount basicdetails.[0].dld)) ccrate) bcdp}}</td>
                  </tr>
                  {{/if}}
              {{/if}}
            <tr>
              <td class="t-en lbl">VAT</td>
              <td class="t-ar">ضريبة القيمة المضافة</td>
              <td class="t-val">{{formatAmount (divide basicdetails.[0].vatamt ccrate) bcdp}}</td>
            </tr>
            <tr>
              <td class="t-en lbl">Total Amount Including VAT</td>
              <td class="t-ar">المبلغ الإجمالي شامل ضريبة القيمة المضافة</td>
              <td class="t-val">{{formatAmount (divide basicdetails.[0].grand_total ccrate) bcdp}}</td>
            </tr>
            <tr>
              <td class="t-en lbl">Total Amount In Words</td>
              <td colspan="2" class="t-val" style="text-align:left;">{{bcamountinwords}}</td>
            </tr>
            <tr>
              <td class="t-en lbl">المبلغ الإجمالي بالكلمات</td>
              <td colspan="2" class="t-val" style="text-align:left;">{{bcamountinwordsar}}</td>
            </tr>
          </table>
        </td>
      </tr>
    </table>

    <!-- TERMS AND CONDITIONS -->
    <table class="bx mt">
      <tr>
        <td class="lbl">Terms And Conditions / <span class="ar">الأحكام والشروط</span></td>
      </tr>
      <tr>
        <td style="min-height:20px;">{{basicdetails.[0].terms_and_condition}}</td>
      </tr>
    </table>

    <!-- SIGNATURES -->
    <table class="sign mt">
      <colgroup>
        <col style="width:25%">
        <col style="width:25%">
        <col style="width:25%">
        <col style="width:25%">
      </colgroup>
      <tr>
        <td class="sh"><span class="en">Company Stamp</span><span class="ar">ختم الشركة</span></td>
        <td class="sh"><span class="en">Prepared By</span><span class="ar">إعداد</span></td>
        <td class="sh"><span class="en">Authorized Signature</span><span class="ar">توقيع معتمد</span></td>
        <td class="sh"><span class="en">Received By</span><span class="ar">تم الاستلام بواسطة</span></td>
      </tr>
      <tr>
        <td class="sbody">
          {{#if Seal}}
              <img src="{{Seal}}" alt="Seal" style="max-height:{{default datasettings.d458 '40'}}px; max-width:{{default datasettings.d458 '60'}}px;" onerror="this.style.display='none'"/>
          {{/if}}
        </td>
        <td class="sbody">{{basicdetails.[0].salesman_name}}</td>
        <td class="sbody">
          {{#if Signature}}
              <img src="{{Signature}}" alt="Seal" style="max-height:{{default datasettings.d459 '40'}}px; max-width:{{default datasettings.d459 '60'}}px;" onerror="this.style.display='none'"/>
          {{/if}}
        </td>
        <td class="sbody"></td>
      </tr>
    </table>
    </div><!-- /footer-block -->

  </body>
</html>
