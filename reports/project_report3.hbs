<html xmlns="http://www.w3.org/1999/xhtml">
<head>
<meta charset="utf-8">
<meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
<meta http-equiv="X-UA-Compatible" content="IE=edge" />
<meta name="format-detection" content="telephone=yes" />
<title>viewmps</title>
   <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<style>
    .invoice_head{
    font-weight: 600;
    font-size: 20px;
    margin-bottom: 15px;
}
.invoice_head span{
    color: #b72031;
}
    table{
        width: 100%;
        font-family: Arial, sans-serif;
        font-size: 12px;
        vertical-align: top;
    }
    p{font-size: 12px;}
    .table_sample{
        font-size: 12px;
    }
    .table_sample td{
        padding: 4px 8px;
        color: #000;
        font-size: 12px;
        line-height: 18px;
        vertical-align: top;
    }
    .tablee1{
        border: 1px solid #000;
    }
    .tablee1 td{
        padding: 6px 8px;
        color: #000;
        border: 1px solid #000;
        text-align: center;
    }
    .tablee2{
        border: 2px solid #344767;
    }
    .tablee2 th{
        padding: 6px 8px;
        color: #fff;
        background-color: #344767;
        font-size: 14px;
    }
    .tablee2 td{
        padding: 6px 8px;
        color: #000;
    }
    .table_black{
        border: 2px solid #000;
    }
    .table_black td{
        padding: 6px 8px;
        color: #000;
        vertical-align: top;
        border: 2px solid #000;
    }
</style>
</head>
<body>
    <div class="section">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <table class="table_sample">
                        <tr>
                            <td>To : {{default manpowers.[0].to_name "-"}}</td>
                            <td class="text-end">Date : {{formatDate manpowers.[0].date}}</td>
                        </tr>
                        <tr>
                            <td>Project: {{default manpowers.[0].project "-"}}</td>
                            <td></td>
                        </tr>
                        <tr>
                            <td>Attn: {{default manpowers.[0].attention "-"}}</td>
                            <td></td>
                        </tr>
                        <tr>
                            <td>SUBJECT: {{default manpowers.[0].subject "-"}}</td>
                            <td></td>
                        </tr>
                        <tr>
                            <td>{{default manpowers.[0].header_note ""}}</td>
                            <td></td>
                        </tr>
                    </table>
                    
                </div>
                <div class="col-lg-12 mt-4">
                    <table class="tablee1">
                        <tr>
                            <td>SL NO </td>
                            <td>NAME</td>
                            <td>IQAMA</td>
                            <td>POSITION</td>
                            <td>NATIONALITY</td>
                            <td>JOINING DATE</td>
                        </tr>
                        {{#each manpowers}}
                        <tr>
                            <td>{{add @index 1}}</td>
                            <td>{{default this.employee "-"}}</td>
                            <td>{{default this.idnumber "-"}}</td>
                            <td>{{default this.designation "-"}}</td>
                            <td>{{default this.country "-"}}</td>
                            <td>{{formatDate this.joining_date}}</td>
                        </tr>
                        {{/each}}
                    </table>
                </div>
                <p class="mt-4">{{default manpowers.[0].footer_note ""}}</p>
                <div class="col-lg-4 col-md-4 col-sm-4 pe-0 mt-4">
                    <table class="tablee1">
                        <tr>
                            <td>
                                {{#if Seal}}
                                <img src="{{Seal}}" alt="Seal" style="max-height:80px;" />
                                {{else}}
                                <br><br><br><br><br><br>
                                {{/if}}
                            </td>
                        </tr>
                    </table>
                </div>
                <div class="col-lg-4 col-md-4 col-sm-4 pe-0 mt-4">
                    <table class="tablee1">
                        <tr>
                            <th class="text-center">Prepared By / اعدت بواسطة</th>
                        </tr>
                        <tr>
                            <td>
                                {{#if Signature}}
                                <img src="{{Signature}}" alt="Signature" style="max-height:60px;" />
                                {{else}}
                                <br><br><br><br><br>
                                {{/if}}
                            </td>
                        </tr>
                    </table>
                </div>
                <div class="col-lg-4 col-md-4 col-sm-4 mt-4">
                    <table class="tablee1">
                        <tr>
                            <th class="text-center">Received By / استلمت من قبل</th>
                        </tr>
                        <tr>
                            <td>
                                <br><br><br><br><br>
                            </td>
                        </tr>
                    </table>
                </div>
            </div> 
        </div>
    </div>
</body>
</html>
