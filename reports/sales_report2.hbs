<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
<meta charset="utf-8">
<meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
<meta http-equiv="X-UA-Compatible" content="IE=edge" />
<meta name="format-detection" content="telephone=yes" />
<title>Invoice Listing</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<style>
    .invoice_head {
        font-weight: 600;
        font-size: 20px;
        margin-bottom: 15px;
    }
    .invoice_head span {
        color: #b72031;
    }
    table {
        width: 100%;
        font-family: Arial, sans-serif;
        font-size: 12px;
        vertical-align: top;
    }
    p { font-size: 12px; }
    .table_sample { font-size: 12px; }
    .table_sample td {
        padding: 4px 8px;
        color: #000;
        font-size: 12px;
        line-height: 18px;
        vertical-align: top;
    }
    .tablee1 {
        border: 1px solid #000;
        font-size: 11px;
    }
    .tablee1 th {
        padding: 6px 8px;
        color: #000;
        border: 1px solid #000;
        text-align: center;
        background-color: #f2f2f2;
    }
    .tablee1 td {
        padding: 6px 8px;
        color: #000;
        border: 1px solid #bfbfbf;
    }
    .total-row td {
        background-color: #f9f9f9;
    }
</style>
</head>
<body>
    <div class="section">
        <div class="container">
            <div class="row">

                {{!-- ── Header Row ── --}}
                <div class="col-lg-12">
                    <table class="table_sample">
                        <tr>
                            <td><strong>Invoice List</strong></td>
                            <td class="text-center">
                                {{#if filters.from}}{{filters.from}}{{/if}}
                                {{#if filters.to}} - {{filters.to}}{{/if}}
                            </td>
                            <td class="text-end">Date : {{summary.generated_at}}</td>
                        </tr>

                        {{!-- optional active filters --}}
                        {{#if filters.branch}}
                        <tr>
                            <td><small>Branch: <b>{{filters.branch}}</b></small></td>
                            <td></td>
                            <td></td>
                        </tr>
                        {{/if}}
                        {{#if filters.customer}}
                        <tr>
                            <td><small>Customer: <b>{{filters.customer}}</b></small></td>
                            <td></td>
                            <td></td>
                        </tr>
                        {{/if}}
                        {{#if filters.sales_person}}
                        <tr>
                            <td><small>Sales Person: <b>{{filters.sales_person}}</b></small></td>
                            <td></td>
                            <td></td>
                        </tr>
                        {{/if}}
                        {{#if filters.search}}
                        <tr>
                            <td><small>Search: <b>{{filters.search}}</b></small></td>
                            <td></td>
                            <td></td>
                        </tr>
                        {{/if}}
                    </table>
                </div>

                {{!-- ── Invoice Table ── --}}
                <div class="col-lg-12 mt-2">
                    <table class="tablee1">
                        <thead>
                            <tr>
                                <th>No</th>
                                <th>Invoice Date</th>
                                <th>Due Date</th>
                                <th>Invoice No</th>
                                <th>Customer</th>
                                <th>Branch</th>
                                <th>Total</th>
                                <th>Vat</th>
                                <th>Grand Total</th>
                                <th>Paid</th>
                                <th>Balance</th>
                                <th>Payment Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#each invoices}}
                            <tr>
                                <td class="text-center">{{sl_no}}</td>
                                <td class="text-center">{{inv_date_fmt}}</td>
                                <td class="text-center">{{due_date_fmt}}</td>
                                <td class="text-start">{{#if inv_no}}{{inv_no}}{{else}}—{{/if}}</td>
                                <td class="text-start">{{#if customer_name}}{{customer_name}}{{else}}—{{/if}}</td>
                                <td class="text-start">{{#if branch_name}}{{branch_name}}{{else}}—{{/if}}</td>
                                <td class="text-end">{{total_fmt}}</td>
                                <td class="text-end">{{vat_fmt}}</td>
                                <td class="text-end">{{grand_fmt}}</td>
                                <td class="text-end">{{paid_fmt}}</td>
                                <td class="text-end">{{balance_fmt}}</td>
                                <td class="text-end">{{payment_status_label}}</td>
                            </tr>
                            {{/each}}
                        </tbody>
                        <tfoot>
                            {{!-- ── Totals Row ── --}}
                            <tr class="total-row">
                                <td class="text-center" colspan="6"><b>Total</b></td>
                                <td class="text-end"><b>{{summary.total_total}}</b></td>
                                <td class="text-end"><b>{{summary.total_vat}}</b></td>
                                <td class="text-end"><b>{{summary.total_grand}}</b></td>
                                <td class="text-end"><b>{{summary.total_paid}}</b></td>
                                <td class="text-end"><b>{{summary.total_balance}}</b></td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>

            </div>
        </div>
    </div>
</body>
</html>