<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Salary Slip</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
  <style>
    body {
      font-family: Arial, sans-serif;
      font-size: 12px;
      color: #222;
      margin: 0;
      padding: 0;
    }

    .wrapper { padding: 28px 22px; }

    /* ── Company Header ─────────────────────────── */
    .co-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      padding-bottom: 14px;
      border-bottom: 3px solid #344767;
      margin-bottom: 16px;
    }
    .co-header-left {
      display: flex;
      align-items: flex-start;
      gap: 14px;
    }
    .co-logo img {
      height: 54px;
      width: auto;
      object-fit: contain;
    }
    .co-details { display: flex; flex-direction: column; justify-content: center; }
    .co-name {
      font-size: 16px;
      font-weight: 700;
      color: #344767;
      margin: 0 0 2px;
      letter-spacing: 0.4px;
      text-transform: uppercase;
    }
    .co-reg {
      font-size: 11px;
      color: #555;
      margin: 0 0 2px;
    }
    .co-address {
      font-size: 10px;
      color: #777;
      margin: 0 0 2px;
      max-width: 420px;
      line-height: 1.4;
    }
    .co-meta {
      font-size: 10px;
      color: #777;
      margin: 0;
    }
    .co-header-right {
      text-align: right;
      flex-shrink: 0;
    }
    .slip-badge {
      display: inline-block;
      background: #344767;
      color: #fff;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 1.2px;
      text-transform: uppercase;
      padding: 4px 14px;
      border-radius: 3px;
      margin-bottom: 5px;
    }
    .slip-period {
      font-size: 12px;
      font-weight: 600;
      color: #344767;
      margin: 0;
    }

    /* ── Info Grid ──────────────────────────────── */
    .info-table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 16px;
      font-size: 11px;
    }
    .info-table td {
      padding: 5px 10px;
      border: 1px solid #dee2e6;
    }
    .info-table td.lbl {
      background: #f0f2f5;
      font-weight: 600;
      color: #555;
      width: 18%;
      white-space: nowrap;
    }
    .info-table td.val {
      color: #222;
      width: 32%;
    }

    /* ── Section Header ─────────────────────────── */
    .section-title {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: #344767;
      background: #e9ecef;
      padding: 5px 8px;
      border: 1px solid #dee2e6;
      border-bottom: none;
      margin-top: 16px;
    }

    /* ── Slip Tables ────────────────────────────── */
    .slip-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 11px;
    }
    .slip-table thead tr th {
      background: #f8f9fa;
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      color: #666;
      padding: 5px 8px;
      border: 1px solid #dee2e6;
    }
    .slip-table tbody tr td {
      padding: 5px 8px;
      border: 1px solid #dee2e6;
      vertical-align: middle;
    }
    .slip-table tbody tr:nth-child(even) td { background: #fafafa; }
    .slip-table tfoot tr td {
      padding: 5px 8px;
      border: 1px solid #dee2e6;
      font-weight: 700;
      background: #f0f2f5;
    }
    .text-end { text-align: right; }
    .text-center { text-align: center; }

    /* ── Statutory Side-by-Side ─────────────────── */
    .statutory-wrap {
      display: flex;
      gap: 12px;
      margin-top: 16px;
    }
    .statutory-wrap > div { flex: 1; }

    /* ── Net Pay Summary ────────────────────────── */
    .summary-wrap {
      display: flex;
      justify-content: flex-end;
      margin-top: 16px;
    }
    .summary-table {
      border-collapse: collapse;
      font-size: 11px;
      min-width: 320px;
    }
    .summary-table td {
      padding: 5px 14px;
      border: 1px solid #dee2e6;
    }
    .summary-table td.s-lbl {
      background: #f0f2f5;
      font-weight: 600;
      color: #555;
    }
    .summary-table td.s-val { text-align: right; min-width: 110px; }
    .summary-table tr.net td {
      background: #344767;
      color: #fff;
      font-weight: 700;
      font-size: 13px;
    }

    /* ── Amount in Words ────────────────────────── */
    .amount-words {
      margin-top: 12px;
      padding: 8px 12px;
      background: #f8f9fa;
      border: 1px solid #dee2e6;
      border-left: 4px solid #344767;
      font-size: 11px;
      color: #333;
    }
    .amount-words span { font-weight: 600; color: #344767; }

    /* ── Employer Note ──────────────────────────── */
    .er-note {
      font-size: 9px;
      color: #888;
      font-style: italic;
      margin-left: 4px;
    }

    /* ── Footer ─────────────────────────────────── */
    .slip-footer {
      margin-top: 28px;
      padding-top: 10px;
      border-top: 1px solid #dee2e6;
      font-size: 9px;
      color: #999;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
  </style>
</head>
<body>
<div class="wrapper">

  <!-- ── Company Header ──────────────────────────── -->
  <div class="co-header">
    <div class="co-header-left">

      {{#if Companylogo}}
      <div class="co-logo">
        <img src="{{Companylogo}}" alt="Logo" />
      </div>
      {{/if}}

      <div class="co-details">
        {{#if company_profile.name}}
        <p class="co-name">{{company_profile.name}}</p>
        {{/if}}
        {{#if company_profile.id_no}}
        <p class="co-reg">Reg. No: {{company_profile.id_no}}</p>
        {{/if}}
        {{#if company_profile.address}}
        <p class="co-address">{{company_profile.address}}</p>
        {{/if}}
        <p class="co-meta">
          {{#if company_profile.contact_no1}}Tel: {{company_profile.contact_no1}}{{/if}}
          {{#if company_profile.email}}&nbsp;&nbsp;|&nbsp;&nbsp;{{company_profile.email}}{{/if}}
          {{#if company_profile.tin}}&nbsp;&nbsp;|&nbsp;&nbsp;TIN: {{company_profile.tin}}{{/if}}
        </p>
      </div>
    </div>

    <div class="co-header-right">
      <div class="slip-badge">Salary Slip</div>
      <p class="slip-period">{{formatMonthYear slip.period_from}}</p>
    </div>
  </div>

  <!-- ── Employee Details ─────────────────────────── -->
  <table class="info-table">
    <tbody>
      <tr>
        <td class="lbl">Employee Name</td>
        <td class="val">
          {{slip.employee_name}}
          {{#if slip.profile_code}}<span style="color:#888;font-size:10px;">&nbsp;({{slip.profile_code}})</span>{{/if}}
        </td>
        <td class="lbl">Pay Period</td>
        <td class="val">{{formatDate slip.period_from}} &mdash; {{formatDate slip.period_to}}</td>
      </tr>
      <tr>
        <td class="lbl">IC / Passport No</td>
        <td class="val">{{default slip.ic_no '-'}}</td>
        <td class="lbl">Pay Date</td>
        <td class="val">{{formatDate slip.date}}</td>
      </tr>
      <tr>
        <td class="lbl">EPF (KWSP) No</td>
        <td class="val">{{default slip.epf_no '-'}}</td>
        <td class="lbl">SOCSO (PERKESO) No</td>
        <td class="val">{{default slip.socso_no '-'}}</td>
      </tr>
      <tr>
        <td class="lbl">Income Tax No</td>
        <td class="val">{{default slip.income_tax_no '-'}}</td>
        <td class="lbl">Reference No</td>
        <td class="val">{{default slip.reference_no '-'}}</td>
      </tr>
    </tbody>
  </table>

  <!-- ── Earnings ─────────────────────────────────── -->
  <div class="section-title">Earnings</div>
  <table class="slip-table">
    <thead>
      <tr>
        <th style="width:38%;">Category</th>
        <th style="width:28%;">Description</th>
        <th class="text-end" style="width:11%;">Unit</th>
        <th class="text-end" style="width:12%;">Rate (RM)</th>
        <th class="text-end" style="width:11%;">Amount (RM)</th>
      </tr>
    </thead>
    <tbody>
      {{#each earnings}}
      <tr>
        <td>{{category_name}}</td>
        <td>{{description}}</td>
        <td class="text-end">{{formatAmount unit}}</td>
        <td class="text-end">{{formatAmount rate}}</td>
        <td class="text-end">{{formatAmount total}}</td>
      </tr>
      {{else}}
      <tr><td colspan="5" class="text-center" style="color:#aaa;">No earnings recorded.</td></tr>
      {{/each}}
    </tbody>
    <tfoot>
      <tr>
        <td colspan="4" class="text-end">Total Earnings</td>
        <td class="text-end">RM {{formatAmount slip.total_earnings}}</td>
      </tr>
    </tfoot>
  </table>

  <!-- ── Deductions ───────────────────────────────── -->
  <div class="section-title">Deductions (Employee)</div>
  <table class="slip-table">
    <thead>
      <tr>
        <th style="width:38%;">Category</th>
        <th style="width:28%;">Description</th>
        <th class="text-end" style="width:11%;">Unit</th>
        <th class="text-end" style="width:12%;">Rate (RM)</th>
        <th class="text-end" style="width:11%;">Amount (RM)</th>
      </tr>
    </thead>
    <tbody>
      {{#each deductions}}
      <tr>
        <td>{{category_name}}</td>
        <td>{{description}}</td>
        <td class="text-end">{{formatAmount unit}}</td>
        <td class="text-end">{{formatAmount rate}}</td>
        <td class="text-end">{{formatAmount total}}</td>
      </tr>
      {{else}}
      <tr><td colspan="5" class="text-center" style="color:#aaa;">No deductions recorded.</td></tr>
      {{/each}}
    </tbody>
    <tfoot>
      <tr>
        <td colspan="4" class="text-end">Total Deductions</td>
        <td class="text-end">RM {{formatAmount slip.total_deductions}}</td>
      </tr>
    </tfoot>
  </table>

  <!-- ── Employer Contributions ───────────────────── -->
  {{#if employer_contributions.length}}
  {{#if_gt employer_contributions.length 0}}
  <div class="section-title">
    Employer Contributions
    <span class="er-note">(not deducted from employee salary)</span>
  </div>
  <table class="slip-table">
    <thead>
      <tr>
        <th style="width:70%;">Component</th>
        <th class="text-end" style="width:30%;">Amount (RM)</th>
      </tr>
    </thead>
    <tbody>
      {{#each employer_contributions}}
      <tr>
        <td>{{category_name}}</td>
        <td class="text-end">{{formatAmount total}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>
  {{/if_gt}}
  {{/if}}

  <!-- ── Net Pay Summary ──────────────────────────── -->
  <div class="summary-wrap">
    <table class="summary-table">
      <tbody>
        <tr>
          <td class="s-lbl">Total Earnings</td>
          <td class="s-val">RM {{formatAmount slip.total_earnings}}</td>
        </tr>
        <tr>
          <td class="s-lbl">Total Deductions</td>
          <td class="s-val">RM {{formatAmount slip.total_deductions}}</td>
        </tr>
        <tr class="net">
          <td class="s-lbl">Net Pay (Gaji Bersih)</td>
          <td class="s-val">RM {{formatAmount slip.total}}</td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- ── Amount in Words ──────────────────────────── -->
  <div class="amount-words">
    Amount in Words: <span>{{amountInWords slip.total}}</span>
  </div>

  <!-- ── Footer ───────────────────────────────────── -->
  <div class="slip-footer">
    <span>This is a computer-generated salary slip and does not require a signature.</span>
    <span style="color:#bbb;">CONFIDENTIAL</span>
  </div>

</div>
</body>
</html>
