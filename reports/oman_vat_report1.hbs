<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>{{report_title}}</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
  <style>
    body {
      font-family: Arial, sans-serif;
      font-size: 12px;
      color: #333;
      margin: 0;
      padding: 0;
    }

    {{#if WatermarkCss}}
    {{{WatermarkCss}}}
    {{/if}}

    .report-wrapper { padding: 20px 28px; }

    /* ── Company Header ─────────────────────────────── */
    .rpt-top-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-bottom: 2px solid #1a1a2e;
      padding-bottom: 12px;
      margin-bottom: 0;
    }
    .rpt-top-header .logo-box img {
      max-height: 55px;
      max-width: 150px;
      object-fit: contain;
    }
    .rpt-top-header .company-box { text-align: right; }
    .rpt-top-header .company-box h3 {
      font-size: 15px;
      font-weight: 700;
      margin: 0 0 2px;
      color: #1a1a2e;
    }
    .rpt-top-header .company-box p { margin: 0; font-size: 10px; color: #666; }

    /* ── Info bar ───────────────────────────────────── */
    .info-bar {
      background: #f8f9fa;
      border-bottom: 1px solid #e9ecef;
      padding: 10px 0;
      margin-bottom: 14px;
      display: flex;
      gap: 40px;
    }
    .info-bar .info-item .label {
      font-size: 9px;
      color: #6c757d;
      text-transform: uppercase;
      letter-spacing: 0.4px;
    }
    .info-bar .info-item .value {
      font-size: 12px;
      font-weight: 600;
      color: #1a1a2e;
    }

    /* ── Section divider + title ────────────────────── */
    .vat-section-divider {
      height: 3px;
      background: linear-gradient(90deg, #1a73e8 0%, #e3f0ff 100%);
      border-radius: 2px;
      margin-bottom: 0;
    }
    .section-title {
      font-size: 11px;
      font-weight: 700;
      color: #344767;
      letter-spacing: 0.3px;
      text-transform: uppercase;
      margin: 10px 0 8px;
    }

    /* ── VAT Table ──────────────────────────────────── */
    .vat-table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 6px;
    }
    .vat-table thead tr { background: #f0f2f5; }
    .vat-table thead th {
      font-size: 9px;
      font-weight: 700;
      color: #7b809a;
      letter-spacing: 0.5px;
      text-transform: uppercase;
      padding: 7px 10px;
      border-top: 1px solid #dee2e6;
      border-bottom: 1px solid #dee2e6;
      white-space: nowrap;
    }
    .vat-table thead th.text-end { text-align: right; }
    .vat-table tbody tr { border-bottom: 1px solid #f0f0f0; }
    .vat-table tbody td {
      padding: 7px 10px;
      vertical-align: middle;
      font-size: 11px;
      color: #344767;
    }

    .box-col    { width: 60px; text-align: center; }
    .desc-col   { width: 52%; }
    .amount-col { width: 18%; }
    .vat-col    { width: 18%; }

    /* Box badge */
    .box-badge {
      display: inline-block;
      min-width: 32px;
      padding: 2px 6px;
      border-radius: 4px;
      font-size: 10px;
      font-weight: 700;
      text-align: center;
      background: #e8f4fd;
      color: #1a73e8;
      letter-spacing: 0.2px;
    }

    /* Row types */
    .row-na td { color: #b0b7c3 !important; font-style: italic; }
    .row-na .box-badge { background: #f0f2f5; color: #b0b7c3; }

    .row-adj td { background: #fff8e7; font-weight: 600; color: #b7791f; }
    .row-adj .box-badge { background: #fef3c7; color: #b7791f; }

    .row-subtotal td { background: #f0f7ff; font-weight: 700; color: #344767; }
    .row-subtotal .box-badge { background: #dbeafe; color: #1a56db; }

    .row-total td {
      background: #f8f9fa;
      font-weight: 700;
      border-top: 2px solid #dee2e6 !important;
    }

    .row-net-positive td { color: #d9534f; font-weight: 700; }
    .row-net-zero td     { color: #5cb85c; font-weight: 700; }
    .row-net-base td     { font-weight: 600; color: #344767; }

    /* Net VAT table — 3 columns (no amount col) */
    .net-table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 16px;
    }
    .net-table thead tr { background: #f0f2f5; }
    .net-table thead th {
      font-size: 9px;
      font-weight: 700;
      color: #7b809a;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      padding: 7px 10px;
      border-top: 1px solid #dee2e6;
      border-bottom: 1px solid #dee2e6;
    }
    .net-table thead th.text-end { text-align: right; }
    .net-table tbody tr { border-bottom: 1px solid #f0f0f0; }
    .net-table tbody td { padding: 7px 10px; vertical-align: middle; font-size: 11px; color: #344767; }

    .small-desc {
      display: block;
      font-size: 9px;
      color: #7b809a;
      line-height: 1.5;
      margin-top: 2px;
      font-weight: 400;
    }

    .text-end   { text-align: right; }
    .text-muted { color: #7b809a !important; }

    /* Footer */
    .report-footer {
      margin-top: 20px;
      font-size: 9px;
      color: #aaa;
      text-align: right;
      border-top: 1px solid #ddd;
      padding-top: 6px;
    }
  </style>
</head>
<body>
<div class="report-wrapper">

  {{!-- ── Company Header ────────────────────────────────── --}}
  <div class="rpt-top-header">
    <div class="logo-box">
      {{#if Companylogo}}
        <img src="{{Companylogo}}" alt="Logo" />
      {{else}}
        <span style="font-size:16px;font-weight:700;color:#1a1a2e;">{{company_name}}</span>
      {{/if}}
    </div>
    <div class="company-box">
      {{#if Companylogo}}<h3>{{company_name}}</h3>{{/if}}
      <p style="font-size:13px;font-weight:600;color:#1a73e8;margin-bottom:2px;">{{report_title}}</p>
      <p>{{date_from}} &mdash; {{date_to}}</p>
      <p>Value Added Tax &mdash; Sultanate of Oman &nbsp;|&nbsp; Standard Rate: <strong>5%</strong></p>
    </div>
  </div>

  {{!-- ── Info Bar ───────────────────────────────────────── --}}
  <div class="info-bar">
    <div class="info-item">
      <div class="label">Tax Period</div>
      <div class="value">{{date_from}} to {{date_to}}</div>
    </div>
    <div class="info-item">
      <div class="label">Branch</div>
      <div class="value">{{orgname}}</div>
    </div>
    <div class="info-item">
      <div class="label">VAT Rate</div>
      <div class="value">5%</div>
    </div>
    <div class="info-item">
      <div class="label">Generated</div>
      <div class="value">{{generated_at}}</div>
    </div>
  </div>

  {{!-- ══════════════════════════════════════════════════════
       SECTION 1 — VAT on Sales and all other Outputs
  ══════════════════════════════════════════════════════ --}}
  <div class="vat-section-divider"></div>
  <p class="section-title">VAT on Sales and all other Outputs</p>

  <table class="vat-table">
    <thead>
      <tr>
        <th class="box-col">BOX</th>
        <th class="desc-col">DESCRIPTION</th>
        <th class="text-end amount-col">AMOUNT (OMR)</th>
        <th class="text-end vat-col">VAT AMOUNT (OMR)</th>
      </tr>
    </thead>
    <tbody>

      {{!-- 1a: Standard rated 5% --}}
      <tr>
        <td class="box-col"><span class="box-badge">1a</span></td>
        <td>
          Supplies of goods / services taxed at standard rate
          <span class="small-desc">5% standard rate supplies</span>
        </td>
        <td class="text-end">{{formatAmount box_1a_amount 3}}</td>
        <td class="text-end">{{formatAmount box_1a_vat 3}}</td>
      </tr>

      {{!-- 1b: Zero rated --}}
      <tr>
        <td class="box-col"><span class="box-badge">1b</span></td>
        <td>
          Supplies of goods / services taxed at zero rate (0%)
          <span class="small-desc">Zero-rated domestic supplies</span>
        </td>
        <td class="text-end">{{formatAmount box_1b_amount 3}}</td>
        <td class="text-end text-muted">&mdash;</td>
      </tr>

      {{!-- 1c: Exempt --}}
      <tr>
        <td class="box-col"><span class="box-badge">1c</span></td>
        <td>
          Supplies of goods / services that are tax exempt
          <span class="small-desc">Exempt supplies</span>
        </td>
        <td class="text-end">{{formatAmount box_1c_amount 3}}</td>
        <td class="text-end text-muted">&mdash;</td>
      </tr>

      {{!-- 1d: GCC RCM goods — Not Activated --}}
      <tr class="row-na">
        <td class="box-col"><span class="box-badge">1d</span></td>
        <td>
          Supplies of goods, tax levy shifted to recipient inside GCC (RCM)
          <span class="small-desc">Not Activated</span>
        </td>
        <td class="text-end">N/A</td>
        <td class="text-end">N/A</td>
      </tr>

      {{!-- 1e: GCC RCM services — Not Activated --}}
      <tr class="row-na">
        <td class="box-col"><span class="box-badge">1e</span></td>
        <td>
          Supplies of services, tax levy shifted to recipient inside GCC (RCM)
          <span class="small-desc">Not Activated</span>
        </td>
        <td class="text-end">N/A</td>
        <td class="text-end">N/A</td>
      </tr>

      {{!-- 1f: Profit margin scheme --}}
      <tr>
        <td class="box-col"><span class="box-badge">1f</span></td>
        <td>
          Supply of goods as per profit margin scheme
          <span class="small-desc">Profit margin scheme supplies</span>
        </td>
        <td class="text-end">0.000</td>
        <td class="text-end">0.000</td>
      </tr>

      {{!-- 2a: GCC purchases RCM — Not Activated --}}
      <tr class="row-na">
        <td class="box-col"><span class="box-badge">2a</span></td>
        <td>
          Purchases from the GCC subject to Reverse Charge Mechanism
          <span class="small-desc">Not Activated</span>
        </td>
        <td class="text-end">N/A</td>
        <td class="text-end">N/A</td>
      </tr>

      {{!-- 2b: Outside GCC RCM --}}
      <tr>
        <td class="box-col"><span class="box-badge">2b</span></td>
        <td>
          Purchases from outside of GCC subject to Reverse Charge Mechanism
          <span class="small-desc">Outside-GCC RCM</span>
        </td>
        <td class="text-end">0.000</td>
        <td class="text-end">0.000</td>
      </tr>

      {{!-- 3a: Exports --}}
      <tr>
        <td class="box-col"><span class="box-badge">3a</span></td>
        <td>
          Exports
          <span class="small-desc">Zero-rated export supplies</span>
        </td>
        <td class="text-end">{{formatAmount box_3a_amount 3}}</td>
        <td class="text-end text-muted">&mdash;</td>
      </tr>

      {{!-- 4a: Imports postponed --}}
      <tr>
        <td class="box-col"><span class="box-badge">4a</span></td>
        <td>
          Import of Goods (Postponed payment)
          <span class="small-desc">Deferred import VAT</span>
        </td>
        <td class="text-end">0.000</td>
        <td class="text-end">0.000</td>
      </tr>

      {{!-- 4b: Total goods imported --}}
      <tr>
        <td class="box-col"><span class="box-badge">4b</span></td>
        <td>
          Total goods imported
          <span class="small-desc">Total import value</span>
        </td>
        <td class="text-end">0.000</td>
        <td class="text-end text-muted">&mdash;</td>
      </tr>

      {{!-- 5a: Sub-total output VAT --}}
      <tr class="row-subtotal">
        <td class="box-col"><span class="box-badge">5a</span></td>
        <td>
          Total VAT due
          <span class="small-desc">Box 1(a) + 1(f) + 2(a) + 2(b) + 4(a)</span>
        </td>
        <td class="text-end text-muted">&mdash;</td>
        <td class="text-end">{{formatAmount box_5a_vat 3}}</td>
      </tr>

      {{!-- 5b: Adjustment of output VAT — Separate row --}}
      <tr class="row-adj">
        <td class="box-col"><span class="box-badge">5b</span></td>
        <td>
          Adjustment of VAT due
          <span class="small-desc" style="color:#92600a;">Credit notes &amp; sales returns (deduction from output VAT)</span>
        </td>
        <td class="text-end">({{formatAmount box_5b_amount 3}})</td>
        <td class="text-end">({{formatAmount box_5b_vat 3}})</td>
      </tr>

    </tbody>
  </table>

  {{!-- ══════════════════════════════════════════════════════
       SECTION 2 — VAT on Purchases and all other Inputs
  ══════════════════════════════════════════════════════ --}}
  <div class="vat-section-divider" style="margin-top:16px;"></div>
  <p class="section-title">VAT on Purchases and all other Inputs</p>

  <table class="vat-table">
    <thead>
      <tr>
        <th class="box-col">BOX</th>
        <th class="desc-col">DESCRIPTION</th>
        <th class="text-end amount-col">AMOUNT (OMR)</th>
        <th class="text-end vat-col">VAT AMOUNT (OMR)</th>
      </tr>
    </thead>
    <tbody>

      {{!-- 6a: Standard-rated purchases --}}
      <tr>
        <td class="box-col"><span class="box-badge">6a</span></td>
        <td>
          Purchases (except import of goods)
          <span class="small-desc">Standard-rated domestic purchases at 5%</span>
        </td>
        <td class="text-end">{{formatAmount box_6a_amount 3}}</td>
        <td class="text-end">{{formatAmount box_6a_vat 3}}</td>
      </tr>

      {{!-- 6b: Import of goods / zero-rated purchases --}}
      <tr>
        <td class="box-col"><span class="box-badge">6b</span></td>
        <td>
          Import of goods
          <span class="small-desc">Zero-rated and imported purchases</span>
        </td>
        <td class="text-end">{{formatAmount box_6b_amount 3}}</td>
        <td class="text-end">0.000</td>
      </tr>

      {{!-- 6c: Fixed assets --}}
      <tr>
        <td class="box-col"><span class="box-badge">6c</span></td>
        <td>
          VAT on acquisition of fixed assets
          <span class="small-desc">Capital goods input VAT</span>
        </td>
        <td class="text-end text-muted">&mdash;</td>
        <td class="text-end">0.000</td>
      </tr>

      {{!-- 6d: Adjustment of input VAT — Separate row --}}
      <tr class="row-adj">
        <td class="box-col"><span class="box-badge">6d</span></td>
        <td>
          Adjustment of input VAT credit
          <span class="small-desc" style="color:#92600a;">Purchase returns (deduction from input VAT credit)</span>
        </td>
        <td class="text-end">({{formatAmount box_6d_amount 3}})</td>
        <td class="text-end">({{formatAmount box_6d_vat 3}})</td>
      </tr>

    </tbody>
  </table>

  {{!-- ══════════════════════════════════════════════════════
       SECTION 3 — Net VAT Due
  ══════════════════════════════════════════════════════ --}}
  <div class="vat-section-divider" style="margin-top:16px;"></div>
  <p class="section-title">Net VAT Due</p>

  <table class="net-table">
    <thead>
      <tr>
        <th class="box-col">BOX</th>
        <th style="width:70%">DESCRIPTION</th>
        <th class="text-end vat-col">VAT AMOUNT (OMR)</th>
      </tr>
    </thead>
    <tbody>

      {{!-- 7a: Total output VAT --}}
      <tr class="row-net-base">
        <td class="box-col"><span class="box-badge">7a</span></td>
        <td>
          Total VAT due
          <span class="small-desc">Box 5(a) &minus; 5(b) &mdash; Net output VAT after adjustments</span>
        </td>
        <td class="text-end">{{formatAmount box_7a_vat 3}}</td>
      </tr>

      {{!-- 7b: Total input VAT credit --}}
      <tr class="row-net-base">
        <td class="box-col"><span class="box-badge">7b</span></td>
        <td>
          Total input VAT credit
          <span class="small-desc">Box 6(a) + 6(b) + 6(c) &minus; 6(d) &mdash; Net recoverable input VAT</span>
        </td>
        <td class="text-end">{{formatAmount box_7b_vat 3}}</td>
      </tr>

      {{!-- 7c: Net VAT due — Payable or Refundable --}}
      {{#if is_vat_payable}}
      <tr class="row-net-positive row-total">
        <td class="box-col"><span class="box-badge" style="background:#fde8e8;color:#c53030;">7c</span></td>
        <td>
          Net VAT Payable
          <span class="small-desc" style="color:#c53030;font-weight:500;">Total (7a &minus; 7b) &mdash; Amount payable to Oman Tax Authority</span>
        </td>
        <td class="text-end" style="font-size:14px;">{{formatAmount box_7c_vat 3}}</td>
      </tr>
      {{else}}
      <tr class="row-net-zero row-total">
        <td class="box-col"><span class="box-badge" style="background:#fde8e8;color:#c53030;">7c</span></td>
        <td>
          Net VAT Refundable
          <span class="small-desc" style="color:#276749;font-weight:500;">Total (7a &minus; 7b) &mdash; Amount reclaimable from Oman Tax Authority</span>
        </td>
        <td class="text-end" style="font-size:14px;color:#276749;">({{formatAmount box_7c_abs_vat 3}})</td>
      </tr>
      {{/if}}

    </tbody>
  </table>

  {{!-- ── Footer ───────────────────────────────────────────── --}}
  <div class="report-footer">
    Generated: {{generated_at}} &nbsp;|&nbsp; Period: {{date_from}} to {{date_to}} &nbsp;&mdash;&nbsp; Ethicfin - Smart Accounting Solutions
  </div>

</div>
</body>
</html>
