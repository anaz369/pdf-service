<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{report_title}}</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
  <style>
    body {
      font-family: Arial, sans-serif;
      font-size: 12px;
      color: #333;
      margin: 0;
      padding: 0;
    }

    /* ── Watermark ─────────────────────────────────── */
    {{#if WatermarkCss}}
    {{{WatermarkCss}}}
    {{/if}}

    .report-wrapper {
      padding: 20px 25px;
    }

    /* ── Report header ─────────────────────────────── */
    .report-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-bottom: 2px solid #333;
      padding-bottom: 12px;
      margin-bottom: 16px;
    }

    .report-header .company-logo img {
      max-height: 60px;
      max-width: 160px;
      object-fit: contain;
    }

    .report-header .report-info {
      text-align: right;
    }

    .report-header .report-info h2 {
      font-size: 16px;
      font-weight: 700;
      margin: 0 0 4px;
    }

    .report-header .report-info p {
      margin: 0;
      font-size: 11px;
      color: #555;
    }

    /* ── Filter summary bar ────────────────────────── */
    .filter-bar {
      background: #f5f5f5;
      border: 1px solid #ddd;
      border-radius: 4px;
      padding: 6px 12px;
      margin-bottom: 14px;
      font-size: 11px;
      color: #444;
    }

    /* ── Table ─────────────────────────────────────── */
    .report-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 11px;
    }

    .report-table thead tr {
      background: #2c3e50;
      color: #fff;
    }

    .report-table thead th {
      padding: 7px 8px;
      text-align: left;
      font-weight: 600;
      white-space: nowrap;
    }

    .report-table thead th.text-right {
      text-align: right;
    }

    .report-table tbody tr:nth-child(even) {
      background: #f9f9f9;
    }

    .report-table tbody tr:hover {
      background: #eef3fb;
    }

    .report-table tbody td {
      padding: 6px 8px;
      border-bottom: 1px solid #e5e5e5;
    }

    .report-table tbody td.text-right {
      text-align: right;
    }

    /* ── Totals row ────────────────────────────────── */
    .report-table tfoot tr {
      background: #ecf0f1;
      font-weight: 700;
    }

    .report-table tfoot td {
      padding: 7px 8px;
      border-top: 2px solid #bdc3c7;
    }

    .report-table tfoot td.text-right {
      text-align: right;
    }

    /* ── Footer ────────────────────────────────────── */
    .report-footer {
      margin-top: 18px;
      font-size: 10px;
      color: #888;
      text-align: right;
      border-top: 1px solid #ddd;
      padding-top: 6px;
    }
  </style>
</head>
<body>
  <div class="report-wrapper">

    {{!-- ── Report Header ── --}}
    <div class="report-header">
      <div class="company-logo">
        {{#if Companylogo}}
          <img src="{{Companylogo}}" alt="Company Logo" />
        {{else}}
          <span style="font-size:14px;font-weight:700;">{{company_name}}</span>
        {{/if}}
      </div>

      <div class="report-info">
        <h2>{{report_title}}</h2>
        {{#if date_from}}
          <p>Period: {{date_from}} — {{date_to}}</p>
        {{/if}}
        <p>Generated: {{generated_at}}</p>
      </div>
    </div>

    {{!-- ── Filter Summary ── --}}
    {{#if filter_summary}}
    <div class="filter-bar">
      <strong>Filters:</strong> {{{filter_summary}}}
    </div>
    {{/if}}

    {{!-- ── Data Table ── --}}
    <table class="report-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Item / Description</th>
          <th>Category</th>
          <th class="text-right">Qty</th>
          <th class="text-right">Unit Price</th>
          <th class="text-right">Amount</th>
        </tr>
      </thead>
      <tbody>
        {{!-- rows will be dynamic once post data is wired -- replace with {{#each rows}} --}}
        <tr>
          <td>1</td>
          <td>Sample Product A</td>
          <td>Category 1</td>
          <td class="text-right">10</td>
          <td class="text-right">100.00</td>
          <td class="text-right">1,000.00</td>
        </tr>
        <tr>
          <td>2</td>
          <td>Sample Product B</td>
          <td>Category 2</td>
          <td class="text-right">5</td>
          <td class="text-right">200.00</td>
          <td class="text-right">1,000.00</td>
        </tr>
        <tr>
          <td>3</td>
          <td>Sample Product C</td>
          <td>Category 1</td>
          <td class="text-right">8</td>
          <td class="text-right">150.00</td>
          <td class="text-right">1,200.00</td>
        </tr>
      </tbody>
      <tfoot>
        <tr>
          <td colspan="5" class="text-right"><strong>Total</strong></td>
          <td class="text-right">3,200.00</td>
        </tr>
      </tfoot>
    </table>

    {{!-- ── Report Footer ── --}}
    <div class="report-footer">
      Printed by {{printed_by}} &nbsp;|&nbsp; {{generated_at}}
    </div>

  </div>
</body>
</html>
