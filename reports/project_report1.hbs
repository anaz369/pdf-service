<html xmlns="http://www.w3.org/1999/xhtml">

<head>
    <meta charset="utf-8">
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="format-detection" content="telephone=yes" />
    <title>{{report_title}}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100..900;1,100..900&display=swap"
        rel="stylesheet">
    <style>
        .head {
            font-weight: 900;
            font-size: 30px;
            margin-bottom: 15px;
            border-bottom: 3px solid #1a2b3c;
            padding-bottom: 24px;
            color: #1a2b3c;
            font-family: "Roboto", sans-serif;
        }

        table {
            width: 100%;
            font-family: "Roboto", sans-serif;
            font-size: 12px;
            vertical-align: top;
        }

        .table_sample {
            font-size: 12px;
            border: 2px solid #e7e7e7;
            font-family: "Roboto", sans-serif;
        }

        .table_sample td {
            padding: 20px;
            color: #000;
            font-size: 12px;
            line-height: 18px;
            vertical-align: top;
            border: 2px solid #e7e7e7;
        }

        .table_sample p {
            color: #666668;
            margin-bottom: 4px;
            font-weight: 700;
            font-size: 14px;
        }

        .table_sample h6 {
            color: #0f172a;
            margin-bottom: 0px;
            font-weight: 700;
            font-size: 16px;
        }

        .table_sample th {
            padding: 20px;
            color: #000;
            font-size: 12px;
            line-height: 18px;
            vertical-align: top;
            border: 2px solid #e7e7e7;
            background-color: #f8f9fa;
        }

        .table_sample th p {
            color: #666668;
            margin-bottom: 4px;
            font-weight: 700;
            font-size: 14px;
        }

        .table_sample th h3 {
            color: #0f172a;
            margin-bottom: 0px;
            font-weight: 900;
            font-size: 26px;
        }

        .tablee {
            font-size: 16px;
            color: #0f172a;
        }

        .tablee th {
            padding: 16px 15px;
            color: #fff;
            background-color: #1a2b3c;

                {
                    {
                    !-- background-color: #1a2b3c;
                    --
                }
            }

                {
                    {
                    !-- background-color: #1a2b3c;
                    --
                }
            }

            font-size: 12px;
        }

        .tablee td {
            padding: 16px 15px;
            color: #1a2b3c;
            border-bottom: 2px solid #dddddd;
        }

        .bg_g {
            background-color: #dbe5f1;
        }

        .ps-40 {
            padding-left: 40px !important;
        }
    </style>
</head>

<body>
    <div class="section">
        <div class="container">
            <div class="row">
                <div class="col-lg-12 mt-4">
                    <h1 class="head">{{upper report_title}}</h1>
                </div>
                <div class="col-lg-12 mt-4">
                    <table class="table_sample">
                        <tr>
                            <td class="col-sm-3">
                                <p class="bold">PROJECT CODE</p>
                                <h6>{{project.project_code}}</h6>
                            </td>
                            <td class="col-sm-3">
                                <p class="bold">PROJECT</p>
                                <h6>{{project.name}}</h6>
                            </td>
                            <td class="col-sm-3">
                                <p class="bold">CLIENT</p>
                                <h6>{{project.client_name}}</h6>
                            </td>
                            <td class="col-sm-3">
                                <p class="bold">LOCATION</p>
                                <h6>{{default project.location "-"}}</h6>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <p class="bold">CONTACT</p>
                                <h6>{{default project.contact_name "-"}}</h6>
                            </td>
                            <td>
                                <p class="bold">PERIOD</p>
                                <h6>{{default project.start "-"}} - {{default project.end "-"}}</h6>
                            </td>
                            <td>
                                <p class="bold">ESTIMATED</p>
                                <h6>{{default project.estimated_start "-"}} - {{default project.estimated_end "-"}}</h6>
                            </td>
                            <td>
                                <p class="bold">PHONE</p>
                                <h6>{{default project.contact_no1 "-"}}</h6>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <p class="bold">PROJECT VALUE</p>
                                <h6>{{formatAmount project.project_cost}}</h6>
                            </td>
                            <td>
                                <p class="bold">SALES QUOTE</p>
                                <h6>{{formatAmount data.sales_quote_amount}}</h6>
                            </td>
                            <td>
                                <p class="bold">PROFORMA INVOICE</p>
                                <h6>{{formatAmount data.proforma_invoice}}</h6>
                            </td>
                            <td>
                                <p class="bold">EST. AMOUNT</p>
                                <h6>{{formatAmount project.estimated_amount}}</h6>
                            </td>
                        </tr>
                    </table>

                </div>
                <div class="col-lg-12 mt-4">
                    <table class="tablee">
                        <tr>
                            <th>Description</th>
                            <th>Amount</th>
                        </tr>

                        {{#if data.income_accounts}}
                        <tr>
                            <td colspan="2" class="bg_g"><b>Income</b></td>
                        </tr>
                        {{#each data.income_accounts}}
                        <tr>
                            <td class="ps-40">{{this.account_name}}</td>
                            <td class="text-end">{{formatAmount this.amount}}</td>
                        </tr>
                        {{/each}}
                        {{/if}}

                        <tr>
                            <td><b>Total Income</b></td>
                            <td class="text-end"><b>{{formatAmount data.total_income}}</b></td>
                        </tr>

                        {{#if data.expense_accounts}}
                        <tr>
                            <td colspan="2" class="bg_g"><b>Expense</b></td>
                        </tr>
                        {{#each data.expense_accounts}}
                        <tr>
                            <td class="ps-40">{{this.account_name}}</td>
                            <td class="text-end">{{formatAmount this.amount}}</td>
                        </tr>
                        {{/each}}
                        {{/if}}

                        <tr>
                            <td><b>Total Expense</b></td>
                            <td class="text-end"><b>{{formatAmount data.total_expense}}</b></td>
                        </tr>
                    </table>
                </div>

                <div class="col-lg-12 mt-4 mb-4">
                    <table class="table_sample">
                        <tr>
                            <th class="text-center col-sm-4">
                                <p>TOTAL INCOME</p>
                                <h3>{{formatAmount data.total_income}}</h3>
                            </th>
                            <th class="text-center col-sm-4">
                                <p>TOTAL EXPENSE</p>
                                <h3>{{formatAmount data.total_expense}}</h3>
                            </th>
                            <th class="text-center col-sm-4">
                                <p>PROFIT / LOSS</p>
                                <h3 class="{{#if (gt data.profit 0)}}text-success{{else}}text-danger{{/if}}">
                                    {{formatAmount data.profit}} ({{data.profitPct}}%)
                                </h3>
                            </th>
                        </tr>
                    </table>
                </div>
            </div>
        </div>
    </div>
</body>

</html>